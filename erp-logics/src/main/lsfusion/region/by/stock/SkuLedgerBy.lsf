MODULE SkuLedgerBy;

REQUIRE SkuLedger, ItemBy;

NAMESPACE Stock;

EXTEND FORM currentBalanceSkuStock
    PROPERTIES (s) READONLY socialDiscount
    FILTERGROUP socialDiscount FILTER 'Социальная скидка' socialDiscount(s)
;

EXTEND FORM balanceSkuStock
    PROPERTIES (s) READONLY socialDiscount
    FILTERGROUP socialDiscount FILTER 'Социальная скидка' socialDiscount(s)
;
