MODULE SaleInternetOrderInvoiceStoreBy;

REQUIRE SaleInternetOrderInvoiceBy, SaleInternetOrderInvoiceStore;

NAMESPACE Sale;

overCreateRetailInvoiceStore(DeliveryReport r, UserInvoice i) + {
    dataPayer(i) <- OVERRIDE legalEntity(legalEntityStock(carrier(r))), legalEntity(internetStock());
    arrivalTime(i) <- dateTimeToDateTime(currentDate(), 16:00);
    downtime(i) <- 60;
}