MODULE EZJewerlyParametersItem;

REQUIRE Item, EZDirectoriesImport;

NAMESPACE EZ;

showJewelryParameters = ABSTRACT BOOLEAN (Item);

DESIGN item {
    itemDetail {
        NEW itemEZ {
            caption = 'Данные ЭЗ';
            NEW  jewelryParameters  {
                showIf = showJewelryParameters(i);
                fill = 1;
                NEW  jewelryAddParameters {
                    caption = 'Дополнительные параметры';
                    lines = 3;
                }

                NEW  jewelryParameterDetail LAST {
                    fill = 1;
                    tabbed = TRUE;
                }
            }
        }
    }
}

// Основной металл сплава
CLASS JewelryAlloy 'Основной металл сплава';

metalName 'Металл' = DATA STRING (JewelryAlloy);
finenessCode 'Код пробы' = DATA STRING (JewelryAlloy);
finenessName 'Проба' = DATA STRING (JewelryAlloy);

weight 'Масса в чистоте, г' = DATA NUMERIC[14,5] (JewelryAlloy);

item = DATA Item (JewelryAlloy);

onChange (JewelryAlloy a) {
    selectJewelryMetalFinenessEZ();
    DIALOG dialogMetalList OBJECTS fineness INPUT NULL DO {
        metalName(a) <- metalNameByFineness(fineness);
        finenessCode(a) <- metalFinenessCode(fineness);
        finenessName(a) <- metalFinenessName(fineness);
    }
}

EXTEND FORM item
    OBJECTS alloy = JewelryAlloy
    PROPERTIES (alloy) metalName ON CHANGE onChange(alloy), finenessCode ON CHANGE onChange(alloy), finenessName ON CHANGE onChange(alloy), weight
    PROPERTIES (alloy) NEW, DELETE GRID
    FILTERS item(alloy) == i
;

DESIGN item {
    jewelryParameterDetail {
        MOVE BOX(alloy) {
            fill = 1;
            caption = 'Основной металл сплава';
        }
    }
}

// Номер партии ГИПН
jewelryGipnBatch 'Номер партии ГИПН' = DATA STRING(Item);
EXTEND FORM item
    PROPERTIES (i) jewelryGipnBatch
;

DESIGN item {
    jewelryAddParameters {
        MOVE PROPERTY (jewelryGipnBatch(i));
    }
}

