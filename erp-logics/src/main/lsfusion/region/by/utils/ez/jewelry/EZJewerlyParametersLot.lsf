MODULE EZJewerlyParametersLot;

REQUIRE Lot, EZDirectoriesImport;

NAMESPACE EZ;

DESIGN lot {
    tabbedPane {
        NEW lotEZ {
            caption = 'Данные ЭЗ';
            NEW  jewelryParameters {
                fill = 1;
                NEW  jewelryAddParameters {
                    caption = 'Дополнительные параметры';
                    lines = 3;
                }

                NEW  jewelryParameterDetail LAST {
                    fill = 1;
                    tabbed = TRUE;
                }
            }
        }
    }
}


// Основной металл сплава
CLASS JewelryAlloyLot 'Основной металл сплава';

metalName 'Металл' = DATA STRING (JewelryAlloyLot);
finenessAlloyCode 'Код пробы' = DATA STRING (JewelryAlloyLot);
finenessName 'Проба' = DATA STRING (JewelryAlloyLot);

weight 'Масса в чистоте, г' = DATA NUMERIC[14,5] (JewelryAlloyLot);

lot = DATA Lot (JewelryAlloyLot);

onChange (JewelryAlloyLot a) {
    selectJewelryMetalFinenessEZ();
    DIALOG dialogMetalList OBJECTS fineness INPUT NULL DO {
        metalName(a) <- metalNameByFineness(fineness);
        finenessAlloyCode(a) <- metalFinenessCode(fineness);
        finenessName(a) <- metalFinenessName(fineness);
    }
}

EXTEND FORM lot
    OBJECTS alloy = JewelryAlloyLot
    PROPERTIES (alloy) metalName ON CHANGE onChange(alloy), finenessAlloyCode ON CHANGE onChange(alloy), finenessName ON CHANGE onChange(alloy), weight
    PROPERTIES (alloy) NEW, DELETE GRID
    FILTERS lot(alloy) == l
;

DESIGN lot {
    jewelryParameterDetail {
        MOVE BOX(alloy) {
            fill = 1;
            caption = 'Основной металл сплава';
        }
    }
}

// Номер партии ГИПН
jewelryGipnBatch 'Номер партии ГИПН' = DATA STRING(Lot);
EXTEND FORM lot
    PROPERTIES (l) jewelryGipnBatch
;

DESIGN lot {
    jewelryAddParameters {
        MOVE PROPERTY (jewelryGipnBatch(l));
    }
}

