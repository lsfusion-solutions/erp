MODULE EZAuthentication;

REQUIRE Utils, LotBy, LegalEntity;

NAMESPACE EZ;

TABLE authentication() NODEFAULT;

urlEZ 'Url к Web-сервису ГИС "Электронный знак"' = DATA STRING () TABLE authentication;
testWebService 'Тестовый Web-сервис' = DATA BOOLEAN () TABLE authentication;
usernameEZ 'Пользователь для API ЭЗ' = DATA STRING() TABLE authentication;
passwordEZ 'Пароль для API ЭЗ' = DATA STRING() ECHO TABLE authentication;
hostEZ 'Host' = DATA STRING () TABLE authentication;
token 'Токен' = DATA STRING () ECHO TABLE authentication;

ezToken() = DATA LOCAL STRING () TABLE authentication;

// при всех использованиях сначала заполнять ezToken
ezHeadersLotOrder (TEXT name) = CASE
    WHEN name = 'Content-Type' THEN 'application/json; charset=utf-8'
    WHEN name = 'Host' THEN hostEZ()
    WHEN name = 'Token' THEN ezToken();

EXTEND FORM integrationData
    PROPERTIES() urlEZ, hostEZ, testWebService, usernameEZ, passwordEZ
    PROPERTIES() READONLY EZtoken = token
;

DESIGN integrationData {
    lotBy {
        NEW EZ {
            caption = 'ЭЗ';
            MOVE PROPERTY(urlEZ());
            MOVE PROPERTY(hostEZ());
            MOVE PROPERTY(testWebService());
            MOVE PROPERTY(usernameEZ());
            MOVE PROPERTY(passwordEZ());
            MOVE PROPERTY(EZtoken);
        }
    }
}

//авторизация
authorization 'Авторизация в ЭЗ' () {
    NEWSESSION {
        LOCAL result = FILE();
        TRY {
            headers('Host') <- hostEZ();
            headers('Content-Type') <- 'multipart/form-data; boundary=...';
            insecureSSL() <- TRUE;
            EXTERNAL HTTP POST urlEZ()  + '/auth'  BODYPARAMNAMES 'username', 'password' HEADERS headers PARAMS usernameEZ(), passwordEZ() TO result;
        } CATCH {
            MESSAGE messageCaughtException() NOWAIT;
            fileToString(result());
            MESSAGE resultString() NOWAIT;
        }
        fileToString(result());
        IMPORT JSON FROM result() TO() token;
        APPLY;
    }
}

EXTEND FORM integrationData
    PROPERTIES() authorization;

DESIGN integrationData {
    EZ {
        MOVE PROPERTY(authorization());
    }
}

dataUsernameEZ 'Пользователь для API ЭЗ' = DATA STRING(LegalEntity);
dataPasswordEZ 'Пароль для API ЭЗ' = DATA STRING(LegalEntity) ECHO;

dataToken 'Токен' = DATA STRING (LegalEntity) ECHO;

useEZLegalEntity 'Использовать организации' = DATA BOOLEAN ();
defaultEZLegalEntity 'По умолчанию' = DATA BOOLEAN (LegalEntity);
defaultEZLegalEntity() = GROUP MIN LegalEntity le IF defaultEZLegalEntity(le);

changeDefaultEZLegalEntity(LegalEntity lez) {    
    IF defaultEZLegalEntity() == lez THEN {
        defaultEZLegalEntity(lez) <- NOT defaultEZLegalEntity(lez);
    } ELSE {
        defaultEZLegalEntity(LegalEntity le) <- NULL;
        defaultEZLegalEntity(lez) <- TRUE;
    }
}

EXTEND FORM integrationData
    PROPERTIES useEZLegalEntity() 

    OBJECTS lez = LegalEntity
    PROPERTIES(lez) READONLY id, name
    PROPERTIES(lez) dataUsernameEZ, dataPasswordEZ, dataToken READONLY, defaultEZLegalEntity ON CHANGE changeDefaultEZLegalEntity(lez)
    FILTERS isCompany(lez)
;

DESIGN integrationData {
    EZ {
        MOVE PROPERTY(useEZLegalEntity());
        MOVE BOX(lez) { showIf = useEZLegalEntity(); }
    }
}

EZActive(LegalEntity l) = useEZLegalEntity() AND dataToken(l) MATERIALIZED;

authorization 'Авторизация в ЭЗ' (LegalEntity l) {
    NEWSESSION {
        LOCAL result = FILE();
        LOCAL token = STRING();

        TRY {
            headers('Host') <- hostEZ();
            headers('Content-Type') <- 'multipart/form-data; boundary=...';
            insecureSSL() <- TRUE;
            EXTERNAL HTTP POST urlEZ()  + '/auth'  BODYPARAMNAMES 'username', 'password' HEADERS headers PARAMS dataUsernameEZ(l), dataPasswordEZ(l) TO result;
        } CATCH {
            MESSAGE messageCaughtException() NOWAIT;
        }
        fileToString(result());
        IMPORT JSON FROM result() TO() token;
        dataToken(l) <- token();

        APPLY;
    }
}

EXTEND FORM integrationData
    PROPERTIES(lez) authorization GRID
;

// Пользователь
userNameEZ 'Пользователь для API ЭЗ' = DATA STRING(CustomUser);
passwordEZ 'Пароль для API ЭЗ' = DATA STRING(CustomUser) ECHO;
token 'Токен' = DATA STRING (CustomUser) ECHO;

useEZCustomUser 'Использовать пользователей' = DATA BOOLEAN ();

EXTEND FORM integrationData
    PROPERTIES useEZCustomUser()

    OBJECTS cez = CustomUser
    PROPERTIES(cez) READONLY shortName, login
    PROPERTIES(cez) userNameEZ, passwordEZ, token READONLY
;

DESIGN integrationData {
    EZ {
        MOVE PROPERTY(useEZCustomUser());
        MOVE BOX(cez) { showIf = useEZCustomUser(); }
    }
}

authorization 'Авторизация в ЭЗ' (CustomUser c) {
    NEWSESSION {
        LOCAL result = FILE();
        LOCAL token = STRING();

        TRY {
            headers('Host') <- hostEZ();
            headers('Content-Type') <- 'multipart/form-data; boundary=...';
            insecureSSL() <- TRUE;
            EXTERNAL HTTP POST urlEZ()  + '/auth'  BODYPARAMNAMES 'username', 'password' HEADERS headers PARAMS userNameEZ(c), passwordEZ(c) TO result;
        } CATCH {
            MESSAGE messageCaughtException() NOWAIT;
        }
        fileToString(result());
        IMPORT JSON FROM result() TO() token;
        token(c) <- token();

        APPLY;
    }
}

EXTEND FORM integrationData
    PROPERTIES(cez) authorization GRID
;

getToken() {  
    IF usernameEZ() THEN authorization();
}

getToken(CustomUser u) {
    IF userNameEZ(u) THEN authorization(u);
}

getToken(LegalEntity l) {
    IF dataUsernameEZ(l) THEN authorization(l);
}

commonGetToken(LegalEntity l) {
    IF useEZCustomUser() THEN {
        getToken(currentUser());
        ezToken() <- token(currentUser());
        IF ezToken() THEN RETURN;
    }
    
    IF useEZLegalEntity() THEN {
        getToken(l);
        ezToken() <- dataToken(l);
        IF ezToken() THEN RETURN;
    }

    getToken();
    ezToken() <- token();
}

commonGetToken() {
    commonGetToken(defaultEZLegalEntity());
}

useContourV3EZ 'Использовать Контур V3 (Представление Б)' = DATA BOOLEAN () TABLE authentication;

EXTEND FORM integrationData
    PROPERTIES() useContourV3EZ
;


// Вспомогательные функции форматирования цены для Представления Б
trunc = FORMULA INTEGER 'trunc($1)';
rub 'Рубли (цена за базовую единицу до)' (NUMERIC n) = trunc(n);
kop 'Копейки (цена за базовую единицу до)' (NUMERIC n) = lpad((OVERRIDE STRING[2](round0(abs(rub(n) (-) n) * 100.0)), '' IF n), 2, '0');

// Индивидуальные настройки V3 по методам (для поэтапного тестирования)
dataUseV3ShipsAddEZ 'V3: ships/add (отправка отгрузки)' = DATA BOOLEAN () TABLE authentication;
dataUseV3ShipsTakeEZ 'V3: ships/list + ships/take (приёмка)' = DATA BOOLEAN () TABLE authentication;
dataUseV3ReportsAddMarkEZ 'V3: reports/addMark (отчёт о маркировке)' = DATA BOOLEAN () TABLE authentication;
dataUseV3OrdersAddGroupEZ 'V3: orders/addGroupOrder (групповой заказ КМ)' = DATA BOOLEAN () TABLE authentication;
dataUseV3OrdersListEZ 'V3: orders/list + скачивание КМ' = DATA BOOLEAN () TABLE authentication;
dataUseV3OrdersAddEZ 'V3: orders/add (заказ SSCC)' = DATA BOOLEAN () TABLE authentication;
dataUseV3LabelsAddAggregateEZ 'V3: labels/addAggregate (агрегирование кит)' = DATA BOOLEAN () TABLE authentication;
dataUseV3ReportsAddAggregateEZ 'V3: reports/addAggregate (агрегирование лотов)' = DATA BOOLEAN () TABLE authentication;
dataUseV3ReportsAggregateDeleteEZ 'V3: reports/aggregateDelete (разагрегирование)' = DATA BOOLEAN () TABLE authentication;
// dataUseV3LabelsStatusEZ удалён: /v3/labels/ снят с 1 июня 2026, всегда используется /v2/labels/
dataUseV3ReportsListEZ 'V3: reports/list (статус отчёта)' = DATA BOOLEAN () TABLE authentication;

useV3ShipsAddEZ 'V3: ships/add (отправка отгрузки)' () = OVERRIDE dataUseV3ShipsAddEZ(), useContourV3EZ();
useV3ShipsTakeEZ 'V3: ships/list + ships/take (приёмка)' () = OVERRIDE dataUseV3ShipsTakeEZ(), useContourV3EZ();
useV3ReportsAddMarkEZ 'V3: reports/addMark (отчёт о маркировке)' () = OVERRIDE dataUseV3ReportsAddMarkEZ(), useContourV3EZ();
useV3OrdersAddGroupEZ 'V3: orders/addGroupOrder (групповой заказ КМ)' () = OVERRIDE dataUseV3OrdersAddGroupEZ(), useContourV3EZ();
useV3OrdersListEZ 'V3: orders/list + скачивание КМ' () = OVERRIDE dataUseV3OrdersListEZ(), useContourV3EZ();
useV3OrdersAddEZ 'V3: orders/add (заказ SSCC)' () = OVERRIDE dataUseV3OrdersAddEZ(), useContourV3EZ();
useV3LabelsAddAggregateEZ 'V3: labels/addAggregate (агрегирование кит)' () = OVERRIDE dataUseV3LabelsAddAggregateEZ(), useContourV3EZ();
useV3ReportsAddAggregateEZ 'V3: reports/addAggregate (агрегирование лотов)' () = OVERRIDE dataUseV3ReportsAddAggregateEZ(), useContourV3EZ();
useV3ReportsAggregateDeleteEZ 'V3: reports/aggregateDelete (разагрегирование)' () = OVERRIDE dataUseV3ReportsAggregateDeleteEZ(), useContourV3EZ();
// useV3LabelsStatusEZ удалён: /v3/labels/ снят с 1 июня 2026
useV3ReportsListEZ 'V3: reports/list (статус отчёта)' () = OVERRIDE dataUseV3ReportsListEZ(), useContourV3EZ();

EXTEND FORM integrationData
    PROPERTIES()
        useV3ShipsAddEZ, useV3ShipsTakeEZ,
        useV3ReportsAddMarkEZ,
        useV3OrdersAddGroupEZ, useV3OrdersListEZ, useV3OrdersAddEZ,
        useV3LabelsAddAggregateEZ, useV3ReportsAddAggregateEZ, useV3ReportsAggregateDeleteEZ,
        useV3ReportsListEZ
;

DESIGN integrationData {
    EZ {
        NEW v3settings {
            caption = 'V3 (Представление Б)';
            MOVE PROPERTY(useContourV3EZ());
            NEW v3methods {
                caption = 'Методы V3 (поэтапный переход)';
                MOVE PROPERTY(useV3ShipsAddEZ());
                MOVE PROPERTY(useV3ShipsTakeEZ());
                MOVE PROPERTY(useV3ReportsAddMarkEZ());
                MOVE PROPERTY(useV3OrdersAddGroupEZ());
                MOVE PROPERTY(useV3OrdersListEZ());
                MOVE PROPERTY(useV3OrdersAddEZ());
                MOVE PROPERTY(useV3LabelsAddAggregateEZ());
                MOVE PROPERTY(useV3ReportsAddAggregateEZ());
                MOVE PROPERTY(useV3ReportsAggregateDeleteEZ());
                MOVE PROPERTY(useV3ReportsListEZ());
            }
        }
    }
}