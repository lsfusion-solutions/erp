fillLotParams (LotInit i, Sku sku) {
    jewerlySku() <- sku;
    lotInit() <- i;
    
    overFillLotParams(i, sku);

    IF returnMessage() THEN {
        MESSAGE returnMessage();
        RETURN;
    }    
}

addMarkReportId = DATA LOCAL LONG();
addMarkReportUid = DATA LOCAL STRING();

FORM importAddMarkReport
    PROPERTIES() addMarkReportId EXTID 'report_id',  addMarkReportUid EXTID 'report_uid';

addMark 'Отправить отчет'(LotInit i, Sku sku) {
    // обновление статусов перед отправкой
    in(Lot l) <- filterLot(l);

    IF EZActive(legalEntityStock(i)) THEN
        getStatus(legalEntityStock(i));
    ELSE
        getStatus();

    findJewelryItemsEZ(i, sku);
    
    fillLotParams(i, sku);
    
    IF (NOT GROUP SUM 1 IF filterJewerlyLot(Lot l)) THEN {
        RETURN;
    }

    IF returnMessage() THEN 
        RETURN;
    
    EXPORT exportJewelryMark JSON;   
    LOCAL result = FILE();

    exception(i) <- NULL;
    getToken(legalEntityStock(i));
    ezToken() <- token(legalEntityStock(i));
    
    TRY {
        insecureSSL() <- TRUE;
        fileToString(exportFile());
        processAddMarkJson();
//        MESSAGE resultString();
        
        EXTERNAL HTTP POST urlEZ() + '/v3/reports/jewelryAddMark' HEADERS ezHeadersLotOrder PARAMS exportFile() TO result;        
    } CATCH {
        handleException(i, result());
        RETURN;
    }
    fileToString(result());

    in(Lot l) <- lotInit(l) == i AND NOT isSend(l) WHERE lotInit(l) == i;
    status(Lot l) <- LotStatus.MARKED WHERE sku(l) AND NOT isSend(l) AND lotInit(l) == i; // getStatus() для ЮИ не используется
    APPLY;

    IMPORT importAddMarkReport JSON FROM result();
// MESSAGE resultString();
    
// Получение id отчета    
     IF addMarkReportId() THEN  NEW r = ReportEZ {
            lotInit(r) <- i;
            id(r) <- STRING(addMarkReportId());
            getStatusReport(r);
     }

    APPLY;
}

skipDefaultAddMark(LotInit i) += type(i) == LotType.jewelry;
addMark (LotInit i) + {
    IF type(i) == LotType.jewelry THEN {
        IF (GROUP MIN (Sku sku) AND ((GROUP SUM 1 IF sku == sku(LotInitDetail d) AND i == lotInit(d)) > 0)) THEN {
            FOR (Sku sku) AND ((GROUP SUM 1 IF sku == sku(LotInitDetail d) AND i == lotInit(d)) > 0) DO {
                addMark(i, sku);
            }

            in(Lot l) <- lotInit(l) == i AND NOT isSend(l) WHERE lotInit(l) == i;
            APPLY;
        }
    }    
}

// Получить статус документа маркировки для ЮИ
GROUP statusReportEZ EXTID 'status';

nextReportEZ = DATA LOCAL STRING();
previousReportEZ = DATA LOCAL STRING();

gtinReportEZ = DATA LOCAL STRING(INTEGER);
createdAtReportEZ = DATA LOCAL STRING(INTEGER);
typeReportEZ = DATA LOCAL LONG(INTEGER);
aggregateInReportEZ = DATA LOCAL NUMERIC(INTEGER);
uidReportEZ = DATA LOCAL STRING(INTEGER);
updatedAtReportEZ = DATA LOCAL STRING(INTEGER);
idReportEZ = DATA LOCAL LONG(INTEGER);
//status
reasonStatusReportEZ = DATA LOCAL STRING(INTEGER);
codeStatusReportEZ = DATA LOCAL LONG(INTEGER);
messageStatusReportEZ = DATA LOCAL STRING(INTEGER);

FORM importReportEZ
    PROPERTIES() nextReportEZ, previousReportEZ

    OBJECTS results = INTEGER

    PROPERTIES(results) gtinReportEZ EXTID 'gtin', createdAtReportEZ EXTID 'created_at', typeReportEZ EXTID 'type', aggregateInReportEZ EXTID 'aggregate_in', uidReportEZ EXTID 'uid', updatedAtReportEZ EXTID 'updated_at', idReportEZ EXTID 'id'
    
    PROPERTIES(results) IN statusReportEZ reasonStatusReportEZ EXTID 'reason', codeStatusReportEZ EXTID 'code', messageStatusReportEZ EXTID 'message';

skipDefaultGetStatusReport(ReportEZ r) += type(lotInit(r)) == LotType.jewelry;
getStatusReport (ReportEZ r) +{
    IF type(lotInit(r)) == LotType.jewelry THEN {
        EXPORT JSON FROM search = id(r);
        fileToString(exportFile());

        LOCAL result = FILE();

        TRY {
            insecureSSL() <- TRUE;
            EXTERNAL HTTP GET urlEZ() + '/v3/reports/list' HEADERS ezHeadersLotOrder PARAMS exportFile() TO result;
        } CATCH {
            MESSAGE CONCAT ' ', 'Ошибка при обращении к ЭЗ', messageCaughtException() NOWAIT;
            CANCEL;
            RETURN;
        }
        
        fileToString(result());
        //MESSAGE resultString();
        LOCAL statusCode = INTEGER ();
        IMPORT importReportEZ JSON FROM result();
        statusCode() <- GROUP MAX codeStatusReportEZ(INTEGER i) IF LONG(id(r)) == idReportEZ(i);
        status(r) <- statusReport(statusCode());
        APPLY;        
    }    
}