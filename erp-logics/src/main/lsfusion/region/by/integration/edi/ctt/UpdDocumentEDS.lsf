MODULE UpdDocumentEDS;

REQUIRE UpdDocument, EDS;

NAMESPACE EDI;

EDSServiceReceiver = ABSTRACT CASE EDSService (STRING[100], UpdDocument);
EDSServiceSender = ABSTRACT CASE EDSService (STRING[100], UpdDocument);

getSignedDocumentReceiver ABSTRACT LIST FIRST (STRING[100], UpdDocument, STRING, BOOLEAN);
getSignedDocumentSender ABSTRACT LIST FIRST (STRING[100], UpdDocument, STRING, BOOLEAN);