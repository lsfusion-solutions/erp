                    stringToFile(s);
                    logToFile('edi', provider + ' (' + loginProfile(le) + '): ' + 'ROSEU/UOU/1.03/' + cancellationId(d) + '?base64=true');
                    EXTERNAL HTTP POST url(profile(le)) + 'ROSEU/UOU/1.03/' + cancellationId(d) + '?base64=true' HEADERS headers PARAMS resultFile() TO result;
                    IMPORT importSignDoc JSON FROM result();
                    IF errorDescription() != 'OK' THEN {
                        MESSAGE errorDescription();
                    } ELSE {
                        getSignedDocumentReceiver(provider, d, xmlBase64(), TRUE);
                        IF signError() THEN {
                            logToFile('edi', provider + ' (' + loginProfile(le) + ') SendDenyCancellationCustomer error: ROSEU ' + (OVERRIDE innerId(d), number(d), STRING[35](resultMilliseconds())) + ' не подписан. Ошибка: ' + signError());
                            MESSAGE provider + ' (' + loginProfile(le) + ') Документ не выгружен: ROSEU ' + (OVERRIDE innerId(d), number(d), STRING[35](resultMilliseconds())) + ' не подписан. Ошибка: ' + signError() NOWAIT;
                        } ELSE IF base64Signature() THEN {
                            EXPORT JSON FROM id(), signatureBase64 = base64Signature(), xmlBody = xmlBase64();
                            logToFile('edi', provider + ' (' + loginProfile(le) + '): ' + 'ROSEU/document/saveSignedAndSend');
                            EXTERNAL HTTP POST url(profile(le)) + 'ROSEU/document/saveSignedAndSend' HEADERS headers PARAMS exportFile() TO result;
                            logToFile('edi', provider + ' (' + loginProfile(le) + '): ' + result());
                            IF statusHttp() = 200 THEN {
                                cancellationConfirmed(d) <- TRUE;
                            }
                        } ELSE {
                            MESSAGE 'Документ не подписан';
                        }
                    }
                    IF statusHttp() = 200 THEN {
                        cancellationDenied(d) <- TRUE;
                    }
                    APPLY;
                } ELSE {
                    logToFile('edi', provider + ' (' + loginProfile(le) + ') SendDenyCancellationCustomer: ошибка при аутентификации');
                    MESSAGE provider + ' (' + loginProfile(le) + ') Документ не выгружен: ошибка при аутентификации' NOWAIT;
                }
            } ELSE {
                logToFile('edi', provider + ' (' + loginProfile(le) + ') SendDenyCancellationCustomer: не заданы параметры EDSService');
                MESSAGE provider + ' (' + loginProfile(le) + ') Запрос на аннулирование не отправлен: не заданы параметры EDSService' NOWAIT;
            }
        } ELSE {
            logToFile('edi', provider + ' SendDenyCancellationCustomer: не задан профиль организации отправителя');
            MESSAGE provider + ' Документ не выгружен: не задан профиль организации отправителя' NOWAIT;
        }
    } CATCH {
        logToFile('edi', CONCAT '\n', provider + ' (' + loginProfile(le) + ') error:', messageCaughtException(), javaStackTraceCaughtException() IF logStackForException(), lsfStackTraceCaughtException());
        MESSAGE 'Запрос на аннулирование не отправлен. Обратитесь к администратору' NOWAIT;
    }
}

denyCancellationCustomerEDI (UpdDocument d, STRING[1000] s) + {
    IF EDIProviderUpd(supplier(d), customer(d)) == EDIProvider.topBy THEN {
        IF (cancellationDenied(d)) THEN
            MESSAGE 'Уже было отказано в аннулировании';
        ELSE
            denyCancellationCustomerUpdDocument(d, customer(d), s, outputDirTopBy(), 'CTT');
    }
}
