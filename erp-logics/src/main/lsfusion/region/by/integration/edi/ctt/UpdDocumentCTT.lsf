//denySign
idDeny = DATA LOCAL STRING();
bundleId6 = DATA LOCAL NUMERIC();
dateCreate6 = DATA LOCAL STRING();
documentNumber6 = DATA LOCAL STRING();
receiverSignRequired6 = DATA LOCAL BOOLEAN();
id23 = DATA LOCAL NUMERIC();
gln23 = DATA LOCAL STRING();
name23 = DATA LOCAL STRING();
unp23 = DATA LOCAL STRING();
