idProcessingStatusPrimary = DATA LOCAL STRING();
nameProcessingStatusPrimary = DATA LOCAL STRING();
idProcessingStatusBPrimary = DATA LOCAL STRING();
nameProcessingStatusBPrimary = DATA LOCAL STRING();
