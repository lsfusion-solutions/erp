certificateUserName4 = DATA LOCAL STRING(INTEGER);
signatureDate4 = DATA LOCAL STRING(INTEGER);
signatureTime4 = DATA LOCAL TIME(INTEGER);
//response
idResponse = DATA LOCAL STRING();
bundleId3 = DATA LOCAL INTEGER();
dateCreate3 = DATA LOCAL STRING();
documentNumber3 = DATA LOCAL STRING();
