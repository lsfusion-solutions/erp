name8 = DATA LOCAL STRING();
id9 = DATA LOCAL STRING();
name9 = DATA LOCAL STRING();
id10 = DATA LOCAL INTEGER(INTEGER);
certificateUserName10 = DATA LOCAL STRING(INTEGER);
signatureDate10 = DATA LOCAL STRING(INTEGER);
signatureTime10 = DATA LOCAL TIME(INTEGER);
//cancel
idCancel = DATA LOCAL STRING();
bundleId4 = DATA LOCAL INTEGER();
dateCreateCancel4 = DATA LOCAL STRING();
documentNumberCancel4 = DATA LOCAL STRING();
receiverSignRequiredCancel4 = DATA LOCAL BOOLEAN();
id11 = DATA LOCAL INTEGER();
gln11 = DATA LOCAL STRING();
name11 = DATA LOCAL STRING();
unp11 = DATA LOCAL STRING();
idReceiverCancel = DATA LOCAL STRING();
gln12 = DATA LOCAL STRING();
name12 = DATA LOCAL STRING();
