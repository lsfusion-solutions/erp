idPrimary = DATA LOCAL STRING();
bundleIdPrimary = DATA LOCAL STRING();
dateCreate2 = DATA LOCAL STRING();
documentNumber2 = DATA LOCAL STRING();
receiverSignRequired2 = DATA LOCAL BOOLEAN();
id2 = DATA LOCAL INTEGER();
gln2 = DATA LOCAL STRING();
name2 = DATA LOCAL STRING();
unp2 = DATA LOCAL STRING();
