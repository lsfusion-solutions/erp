name18 = DATA LOCAL STRING();
unp18 = DATA LOCAL STRING();
id19 = DATA LOCAL STRING();
name19 = DATA LOCAL STRING();
id20 = DATA LOCAL STRING();
name20 = DATA LOCAL STRING();
id21 = DATA LOCAL STRING();
name21 = DATA LOCAL STRING();
id22 = DATA LOCAL INTEGER(INTEGER);
certificateUserName22 = DATA LOCAL STRING(INTEGER);
signatureDate22 = DATA LOCAL STRING(INTEGER);
