id16 = DATA LOCAL STRING(INTEGER);
certificateUserName16 = DATA LOCAL STRING(INTEGER);
signatureDate16 = DATA LOCAL STRING(INTEGER);
signatureTime16 = DATA LOCAL TIME(INTEGER);
