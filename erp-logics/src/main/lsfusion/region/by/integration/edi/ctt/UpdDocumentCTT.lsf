MODULE UpdDocumentCTT;

REQUIRE UpdDocumentApi;

NAMESPACE EDI;

GROUP info;
GROUP senderInfo : info;
GROUP receiverInfo : info;
GROUP processingStatusInfo : info;
GROUP documentType;
GROUP primary;
GROUP senderPrimary EXTID 'sender' : primary;
GROUP receiverPrimary EXTID 'receiver' : primary;
GROUP documentTypePrimary EXTID 'documentType' : primary;
GROUP processingStatusPrimary EXTID 'processingStatus' : primary;
GROUP processingStatusBundlePrimary EXTID 'processingStatusBundle' : primary;
GROUP response;
GROUP senderResponse EXTID 'sender' : response;
GROUP receiverResponse EXTID 'receiver' : response;
GROUP documentTypeResponse EXTID 'documentType' : response;
GROUP processingStatusResponse EXTID 'processingStatus' : response;
GROUP processingStatusBundleResponse EXTID 'processingStatusBundle' : response;
GROUP cancel;
GROUP senderCancel EXTID 'sender' : cancel;
GROUP receiverCancel EXTID 'receiver' : cancel;
GROUP documentTypeCancel EXTID 'documentType' : cancel;
GROUP processingStatusCancel EXTID 'processingStatus' : cancel;
GROUP processingStatusBundleCancel EXTID 'processingStatusBundle' : cancel;
GROUP cancelDeny;
GROUP senderDeny EXTID 'sender' : cancelDeny;
GROUP receiverDeny EXTID 'receiver' : cancelDeny;
GROUP documentTypeDeny EXTID 'documentType' : cancelDeny;
GROUP processingStatusDeny EXTID 'processingStatus' : cancelDeny;
GROUP processingStatusBundleDeny EXTID 'processingStatusBundle' : cancelDeny;
GROUP denySign;
GROUP receiverDenySign EXTID 'receiver' : denySign;
GROUP senderDenySign EXTID 'sender' : denySign;
GROUP documentTypeDenySign EXTID 'documentType' : denySign;
GROUP processingStatusDenySign EXTID 'processingStatus' : denySign;
GROUP processingStatusBundleDenySign EXTID 'processingStatusBundle' : denySign;
GROUP senderDocuments EXTID 'sender';
GROUP receiverDocuments EXTID 'receiver';
GROUP documentTypeDocuments EXTID 'documentType';
GROUP processingStatusDocuments EXTID 'processingStatus';
GROUP processingStatusBundleDocuments EXTID 'processingStatusBundle';

//info
dateCreate = DATA LOCAL STRING ();
deliveryStatus = DATA LOCAL INTEGER ();
read = DATA LOCAL BOOLEAN ();
receiverSignRequired = DATA LOCAL BOOLEAN ();
idSender = DATA LOCAL INTEGER ();
glnSender = DATA LOCAL STRING ();
nameSender = DATA LOCAL STRING ();
unpSender = DATA LOCAL STRING ();
idReceiver = DATA LOCAL INTEGER ();
glnReceiver = DATA LOCAL STRING ();
nameReceiver = DATA LOCAL STRING ();
unpReceiver = DATA LOCAL STRING ();
idStatusInfo = DATA LOCAL STRING ();
nameStatusInfo = DATA LOCAL STRING ();
idDocumentTypeInfo = DATA LOCAL STRING ();
