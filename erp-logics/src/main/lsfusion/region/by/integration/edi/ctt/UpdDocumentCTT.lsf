name33 = DATA LOCAL STRING(INTEGER);
id34 = DATA LOCAL INTEGER(INTEGER);
certificateUserName34 = DATA LOCAL STRING(INTEGER);
signatureDate34 = DATA LOCAL STRING(INTEGER);
signatureTime34 = DATA LOCAL TIME(INTEGER);

FORM importDocumentRoseu
//info
    PROPERTIES() IN info id, dateCreate, documentDate, documentNumber, deliveryStatus, read, receiverSignRequired
    PROPERTIES() IN senderInfo idSender EXTID 'id', glnSender EXTID 'gln', nameSender EXTID 'name', unpSender EXTID 'unp'
    PROPERTIES() IN receiverInfo idReceiver EXTID 'id', glnReceiver EXTID 'gln', nameReceiver EXTID 'name', unpReceiver EXTID 'unp'
    PROPERTIES() IN processingStatusInfo idStatusInfo EXTID 'id', nameStatusInfo EXTID 'name'
    PROPERTIES() IN documentType idDocumentTypeInfo EXTID 'id'

    //primary
    PROPERTIES() IN primary idPrimary EXTID 'id', bundleIdPrimary EXTID 'bundleId', dateCreate2 EXTID 'dateCreate', documentNumber2 EXTID 'documentNumber', receiverSignRequired2 EXTID 'receiverSignRequired'
    PROPERTIES() IN senderPrimary id2 EXTID 'id', gln2 EXTID 'gln', name2 EXTID 'name', unp2 EXTID 'unp'
    PROPERTIES() IN receiverPrimary id3 EXTID 'id', gln3 EXTID 'gln', name3 EXTID 'name', unp3 EXTID 'unp'
    PROPERTIES() IN documentTypePrimary documentTypePrimary EXTID 'id'
    PROPERTIES() IN processingStatusPrimary idProcessingStatusPrimary EXTID 'id', nameProcessingStatusPrimary EXTID 'name'
    PROPERTIES() IN processingStatusBundlePrimary idProcessingStatusBPrimary EXTID 'id', nameProcessingStatusBPrimary EXTID 'name'

    OBJECTS signaturesPrimary = INTEGER EXTID 'signatures' IN primary
    PROPERTIES(signaturesPrimary) id4 EXTID 'id', certificateUserName4 EXTID 'certificateUserName', signatureDate4 EXTID 'signatureDate', signatureTime4 EXTID 'signatureTime'
    FILTERS imported(signaturesPrimary)

    //response
    PROPERTIES() IN response idResponse EXTID 'id', bundleId3 EXTID 'bundleId', dateCreate3 EXTID 'dateCreate', documentNumber3 EXTID 'documentNumber', receiverSignRequired3 EXTID 'receiverSignRequired'
    PROPERTIES() IN senderResponse id5 EXTID 'id', gln5 EXTID 'gln', name5 EXTID 'name', unp5 EXTID 'unp'
    PROPERTIES() IN receiverResponse id6 EXTID 'id', gln6 EXTID 'gln', name6 EXTID 'name', unp6 EXTID 'unp'
    PROPERTIES() IN documentTypeResponse id7 EXTID 'id', name7 EXTID 'name'
    PROPERTIES() IN processingStatusResponse id8 EXTID 'id', name8 EXTID 'name'
    PROPERTIES() IN processingStatusBundleResponse id9 EXTID 'id', name9 EXTID 'name'

    OBJECTS signaturesResponse = INTEGER EXTID 'signatures' IN response
    PROPERTIES(signaturesResponse) id10 EXTID 'id', certificateUserName10 EXTID 'certificateUserName', signatureDate10 EXTID 'signatureDate', signatureTime10 EXTID 'signatureTime'
    FILTERS imported(signaturesResponse)

    //cancel
    PROPERTIES() IN cancel idCancel EXTID 'id', bundleId4 EXTID 'bundleId', dateCreateCancel4 EXTID 'dateCreate', documentNumberCancel4 EXTID 'documentNumber', receiverSignRequiredCancel4 EXTID 'receiverSignRequired'
    PROPERTIES() IN senderCancel id11 EXTID 'id', gln11 EXTID 'gln', name11 EXTID 'name', unp11 EXTID 'unp'
    PROPERTIES() IN receiverCancel idReceiverCancel EXTID 'id', gln12 EXTID 'gln', name12 EXTID 'name', unp12 EXTID 'unp'
    PROPERTIES() IN documentTypeCancel id13 EXTID 'id', name13 EXTID 'name'
    PROPERTIES() IN processingStatusCancel id14 EXTID 'id', name14 EXTID 'name'
    PROPERTIES() IN processingStatusBundleCancel id15 EXTID 'id', name15 EXTID 'name'

    OBJECTS signaturesCancel = INTEGER EXTID 'signatures' IN cancel
    PROPERTIES(signaturesCancel) id16 EXTID 'id', certificateUserName16 EXTID 'certificateUserName', signatureDate16 EXTID 'signatureDate', signatureTime16 EXTID 'signatureTime'
    FILTERS imported(signaturesCancel)

    //cancelDeny
    PROPERTIES() IN cancelDeny idCancelDeny EXTID 'id', bundleId5 EXTID 'bundleId', dateCreate5 EXTID 'dateCreate', documentNumber5 EXTID 'documentNumber', receiverSignRequired5 EXTID 'receiverSignRequired'
    PROPERTIES() IN senderDeny id17 EXTID 'id', gln17 EXTID 'gln', name17 EXTID 'name', unp17 EXTID 'unp'
    PROPERTIES() IN receiverDeny id18 EXTID 'id', gln18 EXTID 'gln', name18 EXTID 'name', unp18 EXTID 'unp'
    PROPERTIES() IN documentTypeDeny id19 EXTID 'id', name19 EXTID 'name'
    PROPERTIES() IN processingStatusDeny id20 EXTID 'id', name20 EXTID 'name'
    PROPERTIES() IN processingStatusBundleDeny id21 EXTID 'id', name21 EXTID 'name'

    OBJECTS signaturesCancelDeny = INTEGER EXTID 'signatures' IN cancelDeny
    PROPERTIES(signaturesCancelDeny) id22 EXTID 'id', certificateUserName22 EXTID 'certificateUserName', signatureDate22 EXTID 'signatureDate', signatureTime22 EXTID 'signatureTime'
    FILTERS imported(signaturesCancelDeny)

    //denySign
    PROPERTIES() IN denySign idDeny EXTID 'id', bundleId6 EXTID 'bundleId', dateCreate6 EXTID 'dateCreate', documentNumber6 EXTID 'documentNumber', receiverSignRequired6 EXTID 'receiverSignRequired'
    PROPERTIES() IN senderDenySign id23 EXTID 'id', gln23 EXTID 'gln', name23 EXTID 'name', unp23 EXTID 'unp'
    PROPERTIES() IN receiverDenySign id24 EXTID 'id', gln24 EXTID 'gln', name24 EXTID 'name', unp24 EXTID 'unp'
    PROPERTIES() IN documentTypeDenySign id25 EXTID 'id', name25 EXTID 'name'
    PROPERTIES() IN processingStatusDenySign id26 EXTID 'id', name26 EXTID 'name'
    PROPERTIES() IN processingStatusBundleDenySign id27 EXTID 'id', name27 EXTID 'name'

    OBJECTS signaturesDeny = INTEGER EXTID 'signatures' IN denySign
    PROPERTIES(signaturesDeny) id28 EXTID 'id', certificateUserName28 EXTID 'certificateUserName', signatureDate28 EXTID 'signatureDate', signatureTime28 EXTID 'signatureTime'
    FILTERS imported(signaturesDeny)

    //documents
    OBJECTS documents = INTEGER
    PROPERTIES(documents) idDocuments EXTID 'id', bundleId7 EXTID 'bundleId', dateCreate7 EXTID 'dateCreate', documentNumber7 EXTID 'documentNumber', receiverSignRequired7 EXTID 'receiverSignRequired'
    PROPERTIES(documents) IN senderDocuments id29 EXTID 'id', gln29 EXTID 'gln', name29 EXTID 'name', unp29 EXTID 'unp'
    PROPERTIES(documents) IN receiverDocuments id30 EXTID 'id', gln30 EXTID 'gln', name30 EXTID 'name', unp30 EXTID 'unp'
    PROPERTIES(documents) IN documentTypeDocuments id31 EXTID 'id', name31 EXTID 'name'
    PROPERTIES(documents) IN processingStatusDocuments id32 EXTID 'id', name32 EXTID 'name'
    PROPERTIES(documents) IN processingStatusBundleDocuments id33 EXTID 'id', name33 EXTID 'name'

    OBJECTS signaturesDocuments = INTEGER EXTID 'signatures'
    PROPERTIES(signaturesDocuments) id34 EXTID 'id', certificateUserName34 EXTID 'certificateUserName', signatureDate34 EXTID 'signatureDate', signatureTime34 EXTID 'signatureTime'
    FILTERS imported(signaturesDocuments)
;

FORM importRoseuDocs
    PROPERTIES() last, totalPages

    OBJECTS content = INTEGER
    PROPERTIES(content) id
    FILTERS imported(content)

    PROPERTIES(content) IN documentType idContent EXTID 'id'
;

checkStatuses() {
    IF NOT processingStatusUpd(idProcessingStatusPrimary()) THEN {
        NEW psu = ProcessingStatusUpd {
            id(psu) <- idProcessingStatusPrimary();
            name(psu) <- nameProcessingStatusPrimary();
        }
    }
    IF NOT processingStatusBundleUpd(idProcessingStatusBPrimary()) THEN {
        NEW psu = ProcessingStatusBundleUpd {
            id(psu) <- idProcessingStatusBPrimary();
            name(psu) <- nameProcessingStatusBPrimary();
        }
    }
    APPLY NESTED LOCAL;
}

identifier 'Индентификатор' = DATA STRING (UpdDocumentInfoDetail);
EXTEND FORM updDocument PROPERTIES (v) identifier BEFORE nameInfoType(v);

overCreateUpdDocument(UpdDocument u) + {
    innerId(u) <- bundleIdPrimary();
    innerIdDoc(u) <- idPrimary();
    read(u) <- read();

    customer(u) <- legalEntityGLN(vinyeSved2()) WHERE NOT customer(u);
    nameCustomer(u) <- OVERRIDE fullName(customer(u)), STRING[1000](vvnaim()), STRING[1000](vvnaim2()) WHERE NOT nameCustomer(u);
    countryNameAddressCustomer(u) <- STRING[255](OVERRIDE vnaimStran4(), vvnaimStr2());
    nameConsignorCompany(u) <- nameOriginatorSupplier(u) WHERE isConsignerSupplier(u) AND NOT nameConsignorCompany(u);
    innConsignorCompany(u) <- innSupplier(u) WHERE isConsignerSupplier(u) AND NOT innConsignorCompany(u);
    countryCodeAddressConsignorCompany(u) <- countryCodeAddressSupplier(u) WHERE isConsignerSupplier(u) AND NOT countryCodeAddressConsignorCompany(u);
    countryNameAddressConsignorCompany(u) <- countryNameAddressSupplier(u) WHERE isConsignerSupplier(u) AND NOT countryNameAddressConsignorCompany(u);
    addressConsignorCompany(u) <- addressSupplier(u) WHERE isConsignerSupplier(u) AND NOT addressConsignorCompany(u);
    nameReceiverCompany(u) <- STRING[1000](vvnaim2()) WHERE NOT nameReceiverCompany(u);
    descriptionContract(u) <- STRING[255](vrekvNaimDok1()) WHERE NOT descriptionContract(u);
    numberContract(u) <- STRING[255](vrekvNomerDok1()) WHERE NOT numberContract(u);
    dateContract(u) <- DATE(toDateFormat(vrekvDataDok1(), 'DD.MM.YYYY')) WHERE NOT dateContract(u);
    nameCurrency(u) <- STRING[50](vnaimOKV());
    quantityDetail(u) <- NUMERIC[15,11](vkolNiettoVs());
    supplierSignerCredentials(u) <- GROUP MAX Credential c IF staticCaption(c) == vsposPodtPolnom() AND NOT supplierSignerCredentials(u);
}

getRoseuFilteredPage (LegalEntity le, STRING login, STRING[100] archiveDir, BOOLEAN disableConfirmation, STRING[100] provider) {
    LOCAL NESTED page = INTEGER ();

    TRY {
        authenticate(profile(le));
        IF token() THEN {
            LOCAL headers = STRING(STRING);
            headers('Authorization') <- token();
            EXPORT JSON FROM documentDateStart = ZDATETIME(documentDateStart()), documentDateEnd = ZDATETIME(documentDateEnd());

            WHILE TRUE DO {
                timeoutHttp() <- 300000;
                page() <- page() (+) 1;

                logToFile('edi', provider + ' (' + login + ') ReceiveMessages request sent. POST /api/v1/ROSEU/filteredPage?page=' + page());
                EXTERNAL HTTP POST url(profile(le)) + 'ROSEU/filteredPage?page=' + page() HEADERS headers PARAMS exportFile() TO sendRequestEDIResponse;

                IMPORT importRoseuDocs JSON FROM sendRequestEDIResponse();
                FOR idContent(INTEGER i) = 'REUDS' OR idContent(i) = 'REUSDS' DO {
                    logToFile('edi', provider + ' (' + login + ') ReceiveMessages request sent. GET /api/v1/ROSEU/' + id(i));
                    EXTERNAL HTTP GET url(profile(le)) + 'ROSEU/' + id(i) HEADERS headers TO sendRequestEDIResponse;

                    IMPORT importDocumentRoseu JSON FROM sendRequestEDIResponse();

                    checkStatuses();

                    IF bundleIdPrimary() THEN {
                        logToFile('edi', provider + ' (' + login + ') ReceiveMessages request sent. GET /api/v1/ROSEU/document/' + idPrimary() + '/file');
                        EXTERNAL HTTP GET url(profile(le)) + 'ROSEU/document/' + idPrimary() + '/file' HEADERS headers TO sendRequestEDIResponse;

                        IMPORT importUPD XML FROM sendRequestEDIResponse();
                        IF (documentTypePrimary() = 'REUDS' OR documentTypePrimary() = 'REUSDS') AND NOT updDocument(id(i)) THEN {
                            createUpdDocument(sendRequestEDIResponse());

                            IF idCancel() AND NOT idCancelDeny() THEN {
                                onCancellation(createdUpdDoc()) <- TRUE;
                            }
                            cancellationId(createdUpdDoc()) <- idCancel();
                            denySignId(createdUpdDoc()) <- idDeny();
                            cancelledBySender(createdUpdDoc()) <- unp11() = unp2();
                            responseId(createdUpdDoc()) <- idResponse() WHERE id8() = 'CREATED_CONFIRMED';
                            processingStatusUpd(createdUpdDoc()) <- processingStatusUpd(idProcessingStatusPrimary());
                            processingStatusBundleUpd(createdUpdDoc()) <- processingStatusBundleUpd(idProcessingStatusBPrimary());

                            IF archiveDir THEN {
                                TRY { mkdir(archiveDir + '/received/roseu/' + toChar(currentDate(), 'yyyyMMdd')); }
                                WRITE sendRequestEDIResponse() TO archiveDir + '/received/roseu/' + toChar(currentDate(), 'yyyyMMdd') + '/' + id(i);
                            }
                        } ELSE IF updDocument(id(i)) THEN {
                            IF idCancel() AND NOT idCancelDeny() THEN {
                                onCancellation(updDocument(id(i))) <- TRUE;
                            }
                            cancellationId(updDocument(id(i))) <- idCancel();
                            denySignId(createdUpdDoc()) <- idDeny();
                            cancelledBySender(updDocument(id(i))) <- unp11() = unp2();
                            responseId(updDocument(id(i))) <- idResponse() WHERE id8() = 'CREATED_CONFIRMED';
                            processingStatusUpd(updDocument(id(i))) <- processingStatusUpd(idProcessingStatusPrimary());
                            processingStatusBundleUpd(updDocument(id(i))) <- processingStatusBundleUpd(idProcessingStatusBPrimary());
                        }
                    }
                }

                IF totalPages() == page() OR last() THEN BREAK;
            }
            APPLY;
        } ELSE {
            logToFile('edi', provider + ' (' + login + ') ReceiveMessages: ошибка при аутентификации');
            MESSAGE provider + ' (' + login + ') Сообщения не получены: ошибка при аутентификации' NOWAIT;
        }
    } CATCH {
        importRequestResult(sendRequestEDIResponse(), statusHttp());
        IF requestError() THEN {
            logToFile('edi', CONCAT '\n', provider + ' (' + login + ') error:' + requestError());
            MESSAGE provider + '(' + login + ') Сообщения не получены. Ошибка: ' + requestError() NOWAIT;
        } ELSE MESSAGE CONCAT '\n', provider + ' (' + login + ') error:', messageCaughtException(), javaStackTraceCaughtException() IF logStackForException(), lsfStackTraceCaughtException();
        page() <- NULL;
    }
}

getRoseuLegalEntity (LegalEntity l) + {
    IF EDIProvider(l) = EDIProvider.topBy THEN {
        NEWSESSION {
            lockTopBy(loginProfile(l));
            IF lockResultTopBy() THEN {
                TRY {
                    getRoseuFilteredPage(l, loginProfile(l), archiveDirTopBy(), disableConfirmationTopBy(), 'CTT');
                    APPLY;
                } FINALLY {
                    unlockTopBy(loginProfile(l));
                }
            } ELSE {
                MESSAGE 'Уже выполняется получение сообщений CTT для ' + loginProfile(l) + '. Подождите...' NOWAIT;
            }
        }
    }
}

overShowEdit (UpdDocument upd) += TRUE;
overShowDelete (UpdDocument upd) += TRUE;