MODULE DiadocLogisticsT3;

REQUIRE DiadocLogistics, DiadocLogisticsT3Form;

NAMESPACE Diadoc;

// ------------------------- Т3 через Диадок: генерация + подпись + отправка ------------------------- //
// Т3+Т4 - отдельный двухтитульный документ (delivery). Т3 создаёт этот delivery-документ
// (PostMessage), связь с reception-документом (Т1/Т2) - через letterId/documentId в GenerateTitleXml.
// Т4 затем отправляется как patch к созданному delivery-документу.

diadocSendT3 (ETRN.ETRN e) {
    IF NOT diadocReceptionDocument(e) THEN {
        MESSAGE 'Нет reception-документа перевозки (Т1) в Диадоке';
        RETURN;
    }
    IF NOT diadocBox(ETRN.consignee(e)) THEN {
        MESSAGE 'Не найден ящик Диадока грузополучателя';
        RETURN;
    }

    FOR User u == userDiadocETRN() DO NEWSESSION {
        fromBox() <- diadocBox(ETRN.consignee(e));
        toBox() <- diadocBox(ETRN.carrier(e));   // Т3 отправляется перевозчику (далее Т4)

        getToken(u);
        EXPORT diadocT3UserData OBJECTS e = e XML;

        LOCAL result = FILE ();
        TRY {
            EXTERNAL HTTP POST url() + '/GenerateTitleXml?boxId=' + fromBoxId() +
                '&documentTypeNamedId=' + logisticsTypeNamedId() +
                '&documentFunction=delivery&documentVersion=' + logisticsVersion() +
                '&titleIndex=2&letterId=' + receptionMessageId(e) + '&documentId=' + receptionEntityId(e)
                HEADERS httpHeadersToken PARAMS exportFile() TO result;

            typeNamedIdDocument(0) <- logisticsTypeNamedId();
            functionDocument(0) <- 'delivery';
            versionDocument(0) <- logisticsVersion();
            contentDocument(0) <- encode(RAWFILE(result()), 'base64');

            IF useTestSignature() THEN signWithTestSignature(0) <- TRUE;
            ELSE {
                sign(FILE(result()), TRUE, ETRN.consignee(e));
                signatureDocument(0) <- encodedSignature();
            }

            postMessage(u);
            // postMessage глотает HTTP-ошибки (MESSAGE внутри) - успех определяем по созданному документу
            IF createdDocument() THEN {
                // Т3 создаёт delivery-документ перевозки (Т4 - patch к нему)
                diadocDeliveryDocument(e) <- createdDocument();
                ETRN.exchangeStatus(e) <- ETRN.ETRNExchangeStatus.signed;
                ETRN.exchangeMessage(e) <- NULL;
            } ELSE
                ETRN.exchangeMessage(e) <- 'Т3 не отправлен (Диадок): ошибка PostMessage';
        } CATCH {
            fileToString(result(), 'UTF-8');
            ETRN.exchangeMessage(e) <- 'Ошибка отправки Т3 (Диадок): ' + (OVERRIDE statusHttp() + ' ' + resultString(), messageCaughtException());
            MESSAGE ETRN.exchangeMessage(e);
        }
        APPLY;
    }
}

ETRN.sendConsigneeSigned (ETRN.ETRN e) + WHEN ETRN.provider(e) == ETRN.ETRNProvider.diadoc THEN {
    diadocSendT3(e);
}
