MODULE ETRNConsignee;

REQUIRE ETRNExchange;

NAMESPACE ETRN;

// ------------------------- Титул грузополучателя (Т3) ------------------------- //
// Приказ ФНС N ЕД-7-26/1065@, раздел VI: файл обмена информации грузополучателя.

CLASS ETRNAcceptResult 'Итог приемки груза' {
    accepted 'Груз принят',       // СодОпПр
    rejected 'Отказано в приеме'  // СодОпОтк
}

name 'Наименование' (ETRNAcceptResult r) = staticCaption(r) IF r IS ETRNAcceptResult CHARWIDTH 15;

FORM etrnAcceptResults 'Итог приемки груза'
    OBJECTS r = ETRNAcceptResult
    PROPERTIES(r) READONLY name

    LIST ETRNAcceptResult OBJECT r
;

// -- Шапка: итог приемки

acceptResult 'Итог приемки' = DATA ETRNAcceptResult (ETRN);
nameAcceptResult 'Итог приемки' (ETRN e) = name(acceptResult(e));

// по умолчанию - груз принят (типовой случай)
WHEN LOCAL SET(ETRN e IS ETRN) AND NOT CHANGED(acceptResult(e)) INLINE DO
    acceptResult(e) <- ETRNAcceptResult.accepted;

rejectReason 'Причина отказа в приеме груза' = DATA ISTRING[2000](ETRN) CHARWIDTH 40;

CONSTRAINT acceptResult(ETRN e) = ETRNAcceptResult.rejected AND NOT rejectReason(e)
    MESSAGE 'При отказе в приеме груза должна быть указана причина отказа';

// -- Сведения о приеме груза грузополучателем от перевозчика (ПриемГрузГП)

unloadingDeclaredDateTime 'Заявленные дата и время прибытия под выгрузку' = DATA DATETIME (ETRN);
unloadingArrivalDateTime 'Фактические дата и время прибытия под выгрузку' = DATA DATETIME (ETRN);
unloadingDepartureDateTime 'Фактические дата и время убытия' = DATA DATETIME (ETRN);

unloadingWeightMethod 'Метод определения массы груза' = DATA ETRNWeightMethod (ETRN);
nameUnloadingWeightMethod 'Метод определения массы груза' (ETRN e) = name(unloadingWeightMethod(e));

acceptedQuantityPlaces 'Общее количество принятых грузовых мест' = DATA INTEGER (ETRN);
quantityPlacesETRNDetail = GROUP SUM quantityPlaces(ETRNDetail d) BY etrn(d);
acceptedQuantityPlaces(ETRN e) <- quantityPlacesETRNDetail(e) WHEN CHANGED(quantityPlacesETRNDetail(e));
acceptedCondition 'Общие сведения о фактическом состоянии груза, тары, упаковки, маркировки и опломбирования' = DATA STRING (ETRN) CHARWIDTH 40;
acceptedCondition(ETRN e) <- 'Новое' WHEN SET(e IS ETRN);
grossWeightETRNDetail = GROUP SUM grossWeight(ETRNDetail d) BY etrn(d);
acceptedGrossWeight 'Масса брутто принятого груза, кг' = DATA NUMERIC[17,3](ETRN);
acceptedGrossWeight(ETRN e) <- grossWeightETRNDetail(e) WHEN CHANGED(grossWeightETRNDetail(e));
acceptedNetWeight 'Масса нетто принятого груза, кг' = DATA NUMERIC[17,3](ETRN);
acceptedVolume 'Объем грузовых мест, м3' = DATA NUMERIC[17,3](ETRN);

unloadingAddress 'Адрес места выгрузки' = DATA ISTRING[350](ETRN) CHARWIDTH 40;

WHEN LOCAL CHANGED(deliveryAddress(ETRN e)) AND NOT CHANGED(unloadingAddress(e)) DO
    unloadingAddress(e) <- deliveryAddress(e);

// -- Строки: сведения о принятом грузе по отгрузочным наименованиям (СвПринПоНаим)

acceptedCondition 'Состояние груза, тары, упаковки, маркировки и опломбирования' = DATA STRING (ETRNDetail) CHARWIDTH 25;
acceptedQuantityPlaces 'Принято грузовых мест' = DATA INTEGER (ETRNDetail);
acceptedVolume 'Принятый объем, м3' = DATA NUMERIC[17,3](ETRNDetail);
acceptedNetWeight 'Принятая масса нетто, кг' = DATA NUMERIC[17,3](ETRNDetail);
acceptedGrossWeight 'Принятая масса брутто, кг' = DATA NUMERIC[17,3](ETRNDetail);
acceptedQuantityPallets 'Принято паллет' = DATA INTEGER (ETRNDetail);

// -- Проверка обязательных полей титула Т3 (приказ ФНС, раздел VI)
// Проверяется при отправке: черновик можно сохранять частично заполненным.

missingT3 (ETRN e) = CONCAT ', ',
    'итог приемки' IF NOT acceptResult(e),
    'причина отказа в приеме груза' IF acceptResult(e) = ETRNAcceptResult.rejected AND NOT rejectReason(e),
    'заявленные дата и время прибытия под выгрузку' IF acceptResult(e) = ETRNAcceptResult.accepted AND NOT unloadingDeclaredDateTime(e),
    'фактические дата и время прибытия под выгрузку' IF acceptResult(e) = ETRNAcceptResult.accepted AND NOT unloadingArrivalDateTime(e),
    'фактические дата и время убытия' IF acceptResult(e) = ETRNAcceptResult.accepted AND NOT unloadingDepartureDateTime(e),
    'общее количество принятых грузовых мест' IF acceptResult(e) = ETRNAcceptResult.accepted AND NOT acceptedQuantityPlaces(e),
    'общие сведения о фактическом состоянии груза' IF acceptResult(e) = ETRNAcceptResult.accepted AND NOT acceptedCondition(e),
    'масса брутто принятого груза' IF acceptResult(e) = ETRNAcceptResult.accepted AND NOT acceptedGrossWeight(e),
    'адрес места выгрузки' IF acceptResult(e) = ETRNAcceptResult.accepted AND NOT unloadingAddress(e);

checkT3 (ETRN e) {
    IF missingT3(e) THEN {
        MESSAGE CONCAT '\n', 'Не заполнены обязательные поля титула Т3:', missingT3(e);
        RETURN;
    }
}

// -- Отправка титула (реализации - в модулях провайдеров;
//    черновик / на подпись Т3 - специфика Контур.Логистики, модуль KonturLogistics)

sendConsigneeSignedETRN 'Подписать и отправить Т3' (ETRN e) {
    checkProvider(e);
    IF NOT provider(e) THEN RETURN;
    IF NOT skipFieldCheckETRN() THEN {
        checkT3(e);
        IF missingT3(e) THEN RETURN;
    }
    sendConsigneeSigned(e);
} IMAGE 'apply.png';

// ------------------------- Формы ------------------------- //

accepted (ETRN e) = acceptResult(e) = ETRNAcceptResult.accepted;

EXTEND FORM etrn
    PROPERTIES(e) READONLYIF readonlyT3(e)
                  nameAcceptResult BACKGROUND (backgroundMandatory(e) IF NOT acceptResult(e)),
                  rejectReason BACKGROUND (backgroundMandatory(e) IF acceptResult(e) = ETRNAcceptResult.rejected AND NOT rejectReason(e)),
                  unloadingDeclaredDateTime BACKGROUND (backgroundMandatory(e) IF accepted(e) AND NOT unloadingDeclaredDateTime(e)),
                  unloadingArrivalDateTime BACKGROUND (backgroundMandatory(e) IF accepted(e) AND NOT unloadingArrivalDateTime(e)),
                  unloadingDepartureDateTime BACKGROUND (backgroundMandatory(e) IF accepted(e) AND NOT unloadingDepartureDateTime(e)),
                  nameUnloadingWeightMethod,
                  acceptedQuantityPlaces BACKGROUND (backgroundMandatory(e) IF accepted(e) AND NOT acceptedQuantityPlaces(e)),
                  acceptedCondition BACKGROUND (backgroundMandatory(e) IF accepted(e) AND NOT acceptedCondition(e)),
                  acceptedGrossWeight BACKGROUND (backgroundMandatory(e) IF accepted(e) AND NOT acceptedGrossWeight(e)),
                  acceptedNetWeight, acceptedVolume,
                  unloadingAddress BACKGROUND (backgroundMandatory(e) IF accepted(e) AND NOT unloadingAddress(e))
    OBJECTS d3 = ETRNDetail
    PROPERTIES(d3) READONLY index, nameCargo
    PROPERTIES(d3) READONLYIF readonlyT3(e)
                   acceptedCondition, acceptedQuantityPlaces, acceptedVolume,
                   acceptedNetWeight, acceptedGrossWeight, acceptedQuantityPallets
    ORDERS index(d3)
    FILTERS etrn(d3) = e
;

DESIGN etrn {
    pane {
        NEW consigneeTab BEFORE exchangeTab {
            caption = 'Т3: Приемка (грузополучатель)';
            NEW acceptResultBox {
                caption = 'Итог приемки';
                horizontal = TRUE;
                MOVE PROPERTY(nameAcceptResult(e));
                MOVE PROPERTY(rejectReason(e));
            }
            NEW unloadingDates {
                caption = 'Подача под выгрузку';
                horizontal = TRUE;
                MOVE PROPERTY(unloadingDeclaredDateTime(e));
                MOVE PROPERTY(unloadingArrivalDateTime(e));
                MOVE PROPERTY(unloadingDepartureDateTime(e));
            }
            NEW acceptParamsT3 {
                lines = 3;
                MOVE PROPERTY(nameUnloadingWeightMethod(e));
                MOVE PROPERTY(acceptedQuantityPlaces(e));
                MOVE PROPERTY(acceptedGrossWeight(e));
                MOVE PROPERTY(acceptedNetWeight(e));
                MOVE PROPERTY(acceptedVolume(e));
                MOVE PROPERTY(unloadingAddress(e));
            }
            MOVE PROPERTY(acceptedCondition(e));
            MOVE BOX(d3) {
                caption = 'Принятый груз по отгрузочным наименованиям';
                fill = 1;
            }
        }
    }
}

EXTEND FORM etrns
    PROPERTIES(e) sendConsigneeSignedETRN SHOWIF (roleConsignee(e) AND NOT readonlyT3(e))
;

DESIGN etrns {
    actionsTab {
        NEW actionsT3 BEFORE actionsCommon {
            caption = 'Т3: Приемка (грузополучатель)';
            MOVE PROPERTY(sendConsigneeSignedETRN(e));
        }
    }
}
