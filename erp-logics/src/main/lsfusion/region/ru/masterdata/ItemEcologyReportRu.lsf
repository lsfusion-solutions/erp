MODULE ItemEcologyReportRu;

REQUIRE ItemEcologyRu, SaleLedger, PurchaseLedger, PurchaseShipment;

NAMESPACE Item;

CLASS TypeReport 'Тип отчета' {
    in 'По приходу',
    out 'По расходу'
}
name 'Наименование' (TypeReport r) = staticCaption(r) IF r IS TypeReport CHARWIDTH 15;

FORM typeReports 'Типы отчета'
    OBJECTS t=TypeReport
    PROPERTIES(t) READONLY name
    ORDERS name(t)
    LIST TypeReport OBJECT t
;
DESIGN typeReports { BOX { size = (600, 400); } }


quantityIn 'К-во' = DATA  LOCAL NUMERIC[16,5](Sku,LegalEntity,Stock);


value 'Содержание (кг. на единицу товара)' = DATA LOCAL NUMERIC[16,6](Sku,EcologyMaterial);

//quantityIn 'К-во'(Sku s, LegalEntity su, Stock st, EcologyMaterial em) = NUMERIC[20,6](quantityIn(s,su,st)*value (s, em)) ;


quantityIn 'К-во' = DATA  LOCAL NUMERIC[16,5](Sku,LegalEntity,Stock,DATE);
value 'Содержание (кг. на единицу товара)' = DATA LOCAL NUMERIC[16,6](Sku,EcologyMaterial,DATE);

quantityIn 'К-во' = DATA  LOCAL NUMERIC[20,6](Sku,LegalEntity,Stock,EcologyMaterial);

quantityInMaterial 'К-во' =  GROUP SUM quantityIn(Sku s, LegalEntity su, Stock st, EcologyMaterial m) BY s,su,st;

// Настройка для отчета
exclude 'Исключить' = DATA BOOLEAN (EcologyMaterial);

quantityIn 'К-во'(Sku s, LegalEntity su, Stock st, EcologyMaterial em, DATE date) = NUMERIC[20,6](quantityIn(s,su,st,date)*value (s, em, date)) ;

inEcology 'Отм.' = DATA LOCAL NESTED BOOLEAN (LegalEntity);
countInEcologyLegalEntity 'Отм.'  = GROUP SUM 1 IF inEcology(LegalEntity l);
nameInEcologyLegalEntity 'Поставщик' = GROUP CONCAT name(LegalEntity l) IF inEcology(l) ,', ' ORDER l CHARWIDTH 30;

inEcology 'Отм.' = DATA LOCAL NESTED BOOLEAN (Country);
countInEcologyCountry 'Отм.'  = GROUP SUM 1 IF inEcology(Country l);
nameInEcologyCountry 'Страна (поставщика)' = GROUP CONCAT name(Country l) IF inEcology(l) ,', ' ORDER l CHARWIDTH 30;

inEcology 'Отм.' = DATA LOCAL NESTED BOOLEAN (Stock);
countInEcologyStock 'Отм.'   = GROUP SUM 1 IF inEcology(Stock l);
nameInEcologyStock 'Склад' = GROUP CONCAT name(Stock l) IF inEcology(l) ,', ' ORDER l CHARWIDTH 30;

inEcology 'Отм.' = DATA LOCAL NESTED BOOLEAN (Region);
countInEcologyRegion 'Отм.'   = GROUP SUM 1 IF inEcology(Region l);
nameInEcologyRegion 'Регион' = GROUP CONCAT name(Region l) IF inEcology(l) ,', ' ORDER l CHARWIDTH 30;

FORM selectParamsEcology 'Параметры'
    OBJECTS c = Country
    PROPERTIES (c) inEcology
    PROPERTIES (c) READONLY  name, sid
    FILTERGROUP def0 FILTER 'Не РФ' NOT c == defaultCountry() 'F8' DEFAULT
    
    OBJECTS su = LegalEntity
    PROPERTIES (su) inEcology
    PROPERTIES (su) READONLY  name, id
    FILTERS isSupplier(su)
    FILTERGROUP def1 FILTER 'Не РФ' NOT country(su)== defaultCountry() 'F8' DEFAULT
    
    OBJECTS r = Region
    PROPERTIES (r) inEcology
    PROPERTIES (r) READONLY  name, id
    
    OBJECTS st = Stock
    PROPERTIES (st) inEcology
    PROPERTIES (st) READONLY  name, id, nameRegion
    FILTERS isCompany(st)
    PROPERTIES countInEcologyLegalEntity() TOOLBAR DRAW su
    PROPERTIES countInEcologyStock() TOOLBAR DRAW st
    PROPERTIES countInEcologyRegion() TOOLBAR DRAW r
    PROPERTIES countInEcologyCountry() TOOLBAR DRAW c
    
    FILTERGROUP inactive1 FILTER 'Активные' active(su) 'F10' DEFAULT
    FILTERGROUP inactive2 FILTER 'Активные' active(st) 'F9' DEFAULT
;
DESIGN selectParamsEcology{
    size = (1024, 768);
    OBJECTS {
        NEW row1{
            fill=1;
            horizontal = TRUE;
            NEW row11{
                caption = 'ПОСТАВЩИК';
                fill = 1;
                horizontal = FALSE;
                fill = 1;
                MOVE BOX(c);
                MOVE BOX(su);
            }
            
            NEW row12{
                caption = 'СКЛАД';
                fill = 1;
                horizontal = FALSE;
                fill = 1;
                MOVE BOX(r);
                MOVE BOX(st);                
            }            
        }        
    }
}



resetEcologyReport(){
    quantityIn(Sku s, LegalEntity su, Stock st) <- NULL;
    value (Sku s, EcologyMaterial em) <- NULL;

    quantityIn(Sku s, LegalEntity su, Stock st, DATE date) <- NULL;
    value (Sku s, EcologyMaterial em, DATE date) <- NULL;
    quantityIn(Sku s, LegalEntity su, Stock st, EcologyMaterial em) <- NULL;
        
    formRefresh();
}
changeSelectForm() {
    inEcology(Country l) <- NULL;
    inEcology(LegalEntity l) <- NULL;
    inEcology(Stock l) <- NULL;
    inEcology(Region l) <- NULL;
    resetEcologyReport();
    SHOW selectParamsEcology;
    formRefresh();
}

isEcology 'Экология' = DATA BOOLEAN (Purchase.Operation) PREREAD;

EXTEND FORM Purchase.operation
    PROPERTIES(o) isEcology
;
DESIGN Purchase.operation {
    paramsContainer {
        MOVE PROPERTY(isEcology(o));
    }
}

isEcologyMigarte(){
    isEcology(Purchase.Operation op) <- id(op)=='purchaseStoreWarehouse' OR id(op)=='import';
}

@defOnStartMigrate(isEcologyMigarte, '');

quantityPurchaseEcology (sku, stock, supplier, date) = GROUP SUM quantity(PurchaseLedger d) IF active(d) AND isEcology(operation(d))
    BY sku(d), stock(d), supplier(d), date(d);


fillEcologyReport 'Заполнить' (DATE df, DATE dt, TypeReport t) {
    resetEcologyReport();

    LOCAL  to = BOOLEAN (Stock);
    LOCAL  to = INTEGER (Sku);
    LOCAL  to = BOOLEAN (LegalEntity);
    to(Sku s) <- (GROUP SUM 1 IF valueData(s, EcologyPackType et, EcologyMaterial em, DATE date) AND date <= dt AND NOT exclude(em));
    FOR iterate(DATE date, df,dt) DO {
        value (Sku s, EcologyMaterial em, date) <- (GROUP SUM value(s, EcologyPackType et, em, date)) WHERE to(s) AND NOT exclude(em);
    }    

    IF (countInEcologyLegalEntity() OR countInEcologyCountry()) THEN {
        to(LegalEntity l) <- (inEcology(l) OR inEcology(country(l)));
    } ELSE {
        to(LegalEntity l) <- (l IS LegalEntity);
    }

    to(Stock l) <- isCompany(l) AND (inEcology(l) OR inEcology(region(l)));
    IF NOT (GROUP SUM 1 IF  to(Stock l)) THEN {
        to(Stock l) <- isCompany(l);
    }
    IF t == TypeReport.in THEN {
        quantityIn(Sku s, LegalEntity su, Stock st, DATE date) <- quantityPurchaseEcology (s, st, su, date) WHERE date >= df AND date <= dt AND to(s) AND to(su) AND to(st);
        quantityIn(Sku s, LegalEntity su, Stock st, EcologyMaterial em) <- GROUP SUM quantityIn( s,  su,  st, em, DATE date) IF NOT exclude(em);
        quantityIn(Sku s, LegalEntity su, Stock st) <- (GROUP SUM quantityIn (s, su,st, DATE date));
    } ELSE {
        quantityIn(Sku s, LegalEntity su, Stock st, DATE date) <- (GROUP SUM quantitySold (Batch bt, st, date)
            IF date>=df AND date<=dt AND to(sku(bt)) AND to(supplier(bt)) AND to(st) AND isEcology(operation(invoiceDetail(bt))) AND sku(bt) == s AND supplier(bt)==su);
        quantityIn(Sku s, LegalEntity su, Stock st, EcologyMaterial em) <- GROUP SUM quantityIn( s,  su,  st, em, DATE date) IF NOT exclude(em);
        quantityIn(Sku s, LegalEntity su, Stock st) <- (GROUP SUM quantityIn (s, su,st, DATE date));
    }
}

ecologyReportPrint = DATA LOCAL STRING ();

notNullDetail 'Без пустых строк' = DATA LOCAL NESTED BOOLEAN ();
// Предполагаем, что период будет в пределах одного года, чтобы не усложнять
sumIn(Sku s,LegalEntity su, Stock st,EcologyMaterial em, DATE dt) = round2(NUMERIC[18,4](quantityIn(s,su,st,em)*coeff(em)*norm(em,dt)*base(em,dt)/1000.0));

sumIn 'Сумма' = GROUP SUM sumIn(Sku s,LegalEntity su, Stock st,EcologyMaterial em, DATE dt) BY s, su, st,dt;
sumIn 'Сумма' = GROUP SUM sumIn(Sku s,LegalEntity su, Stock st,EcologyMaterial em, DATE dt) BY dt;

FORM ecologyReportPrint 'Экологический отчет'
    OBJECTS dates = (df = DATE, dt = DATE, t = TypeReport) PANEL
    PROPERTIES from =VALUE (df), to = VALUE (dt), name(t)
    PROPERTIES isInType = (t == TypeReport.in)
    PROPERTIES () TOOLBAR DRAW dates nameInEcologyCountry, nameInEcologyLegalEntity, nameInEcologyRegion, nameInEcologyStock
    OBJECTS em = EcologyMaterial
    FILTERS  NOT exclude(em)
    OBJECTS dd = (s=Sku, su=LegalEntity, st=Stock) SUBREPORT 
    PROPERTIES READONLY idBarcode(s), id(s), name(s)
    PROPERTIES READONLY quantityIn(s,su,st) FOOTER (GROUP SUM quantityIn(Sku ss,LegalEntity sus, Stock stst)), 
                        quantityIn(s,su,st,em) COLUMNS (em) HEADER name(em)  FOOTER  (GROUP SUM quantityIn(Sku ss,LegalEntity sus, Stock stst,em))
    PROPERTIES READONLY sumIn(s,su,st,dt) FOOTER sumIn(dt)
    PROPERTIES name(su) HEADER 'Поставщик', name(st) HEADER  'ТО', nameRegion(st)
    ORDERS nameRegion(st)
    FILTERS ((quantityIn(s,su,st)  AND NOT notNullDetail()) OR (quantityInMaterial(s,su,st) AND notNullDetail())) AND df IS DATE
    REPORTFILES  dd ecologyReportPrint()
;

ecologyReportPrint 'Печать' (DATE df, DATE dt, TypeReport t){
    ecologyReportPrint() <- 'Item_ecologyReportPrint_dd.jrxml';
    PRINT ecologyReportPrint OBJECTS df=df,dt=dt,t=t;
} IMAGE 'print.png' IN print;
ecologyReportPrintXls 'Печать (xls)' (DATE df, DATE dt, TypeReport t){
    ecologyReportPrint() <- 'Item_ecologyReportPrint_dd.jrxml';
    PRINT ecologyReportPrint OBJECTS df=df,dt=dt,t=t XLSX;
} IMAGE 'print.png' IN print;

changeExclude(EcologyMaterial m) {
    NEWSESSION {
        INPUT b = exclude(m) DO {
            exclude(m)<-b;
        }        
        APPLY;
    }
    resetEcologyReport();
}

FORM ecologyReport 'Экологический отчет'
    OBJECTS dates = (df = DATE, dt = DATE) PANEL
    PROPERTIES from =VALUE (df), to = VALUE (dt)

    OBJECTS  t = TypeReport PANEL
    PROPERTIES name(t) SELECTOR    

    OBJECTS  p = EcologyMaterial
    PROPERTIES (p) READONLY name, id SHOWIF showIDs()
    PROPERTIES (p) exclude ON CHANGE changeExclude(p)
    
    PROPERTIES () ON CHANGE changeSelectForm() nameInEcologyCountry, nameInEcologyLegalEntity, nameInEcologyRegion, nameInEcologyStock

    OBJECTS em = EcologyMaterial
    FILTERS NOT exclude(em)

    OBJECTS dd = (s=Sku, su=LegalEntity, st=Stock)
    PROPERTIES READONLY idBarcode(s), id(s), name(s)
    PROPERTIES READONLY SHOWIF (t==TypeReport.in) quantityIn(s,su,st) FOOTER (GROUP SUM quantityIn(Sku ss,LegalEntity sus, Stock stst)),
        quantityIn(s,su,st,em) COLUMNS (em) HEADER name(em)  FOOTER  (GROUP SUM quantityIn(Sku ss,LegalEntity sus, Stock stst,em))
    PROPERTIES name(su) HEADER 'Поставщик', name(st) HEADER  'ТО', nameRegion(st)
    ORDERS nameRegion(st)
    FILTERS  ((quantityIn(s,su,st) AND NOT notNullDetail()) OR (quantityInMaterial(s,su,st) AND notNullDetail()))
    PROPERTIES READONLY sumIn(s,su,st,dt) FOOTER sumIn(dt)
    PROPERTIES () notNullDetail TOOLBAR DRAW dd
    PROPERTIES  TOOLBAR DRAW dd fillEcologyReport(df,dt,t), ecologyReportPrint(df,dt,t), ecologyReportPrintXls(df,dt,t)    

    EVENTS ON CHANGE df resetEcologyReport()
    EVENTS ON CHANGE dt resetEcologyReport()
    EVENTS ON CHANGE t resetEcologyReport()

;
DESIGN ecologyReport{
    OBJECTS {
        NEW filters{
            caption = 'Параметры';
            horizontal = FALSE;
            NEW filters1{
                horizontal = TRUE;
                lines = 1;
                MOVE PROPERTY (from){caption = 'Дата с';}
                MOVE PROPERTY (to){caption = 'Дата по';}
                MOVE PROPERTY (name(t));
            }
            NEW filters2{
                horizontal = TRUE;
                lines = 1;
                MOVE PROPERTY (nameInEcologyCountry());
                MOVE PROPERTY (nameInEcologyLegalEntity());
                MOVE PROPERTY (nameInEcologyRegion());
                MOVE PROPERTY (nameInEcologyStock());
            }
        }
        NEW tab{
            fill = 1;
            tabbed = TRUE;
            MOVE BOX(dd);
            MOVE BOX(p){
                caption ='Настройка параметров';
            }
        }
    }
}
NAVIGATOR {
    stockReports {
        NEW ecologyReport;
    }    
}


