MODULE PurchaseOrderVATRu;

REQUIRE PurchaseOrder, OrderVATRu;

NAMESPACE Purchase;

@defineWithVATOrder(supplier);

notNullQuantityOrders 'Запретить в заказах (закупка) строки с пустым количеством' = DATA BOOLEAN () PREREAD;

EXTEND FORM options
    PROPERTIES() notNullQuantityPurchaseOrders = notNullQuantityOrders
;

DESIGN options {
    optionsContainer {
        MOVE PROPERTY(notNullQuantityPurchaseOrders);
    }
}

CONSTRAINT (CHANGED(sku(OrderDetail d)) OR CHANGED(quantity(d))) AND sku(d) AND notNullQuantityOrders() AND NOT quantity(d)
    MESSAGE 'Количество в строке заказа (закупка) должно быть заполнено';