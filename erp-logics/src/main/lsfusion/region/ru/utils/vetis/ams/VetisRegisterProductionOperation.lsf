FORM registerProductionOperationResponse FORMEXTID 'merc=http://api.vetrf.ru/schema/cdm/mercury/g2b/applications/v2:registerProductionOperationResponse'
//    PROPERTIES() IN stockEntryListR countR ATTR, totalR ATTR, offsetR ATTR

    OBJECTS stockEntry = INTEGER EXTID 'vd=http://api.vetrf.ru/schema/cdm/mercury/vet-document/v2:stockEntry' IN stockEntryListR

    PROPERTIES(stockEntry) guidR EXTID 'bs:guid', activeR EXTID 'bs:active', lastR EXTID 'bs:last', statusR EXTID 'bs:status', createDateR EXTID 'bs:createDate', updateDateR EXTID 'bs:updateDate', previousR EXTID 'bs:previous', entryNumberR EXTID 'vd:entryNumber'
    PROPERTIES(stockEntry) IN vetDocumentR uuidR EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:uuid'
    FILTERS imported(stockEntry)
    PROPERTIES(stockEntry) IN batchR productTypeR EXTID 'vd:productType', volumeR EXTID 'vd:volume', batchIDR EXTID 'vd:batchID', perishableR EXTID 'vd:perishable', lowGradeCargoR EXTID 'vd:lowGradeCargo'
    PROPERTIES(stockEntry) IN product uuid2R EXTID 'bs:uuid', guid1R EXTID 'bs:guid', nameR EXTID 'dt=http://api.vetrf.ru/schema/cdm/dictionary/v2:name'
    PROPERTIES(stockEntry) IN subProductR uuid3R EXTID 'bs:uuid', guid2R EXTID 'bs:guid', name1R EXTID 'dt:name'
    PROPERTIES(stockEntry) IN productItemR uuid4R EXTID 'bs:uuid', guid3R EXTID 'bs:guid', globalIDR EXTID 'dt:globalID', name2R EXTID 'dt:name', codeR EXTID 'dt:code'
    PROPERTIES(stockEntry) IN unitR uuid5R EXTID 'bs:uuid', guid4R EXTID 'bs:guid', name3R EXTID 'dt:name'
    PROPERTIES(stockEntry) IN firstDateR yearR EXTID 'dt:year', monthR EXTID 'dt:month', dayR EXTID 'dt:day'
    PROPERTIES(stockEntry) IN firstDate1R year1R EXTID 'dt:year', month1R EXTID 'dt:month', day1R EXTID 'dt:day'
    PROPERTIES(stockEntry) IN productItem1R uuid6R EXTID 'bs:uuid', guid5R EXTID 'bs:guid', globalID1R EXTID 'dt:globalID', name4R EXTID 'dt:name', code1R EXTID 'dt:code'
    PROPERTIES(stockEntry) IN countryR uuid7R EXTID 'bs:uuid', guid6R EXTID 'bs:guid', name5R EXTID 'dt:name'
    PROPERTIES(stockEntry) IN producerR roleR EXTID 'dt:role'
    PROPERTIES(stockEntry) IN enterpriseR uuid8R EXTID 'bs:uuid', guid7R EXTID 'bs:guid', name6R EXTID 'dt:name'
    PROPERTIES(stockEntry) IN packageR levelR EXTID 'dt:level', quantityR EXTID 'dt:quantity', productMarksR EXTID 'dt:productMarks'
    PROPERTIES(stockEntry) IN packingTypeR uuid9R EXTID 'bs:uuid', guid8R EXTID 'bs:guid', globalID2R EXTID 'dt:globalID', name7R EXTID 'dt:name'
    PROPERTIES(stockEntry) IN productMarks1R classR ATTR
    PROPERTIES(stockEntry) IN ownerR uuid10R EXTID 'bs:uuid', guid9R EXTID 'bs:guid'
    PROPERTIES() IN vetDocument1R vetDocumentUuidR EXTID 'bs:uuid', issueDateR EXTID 'vd:issueDate', vetDFormR EXTID 'vd:vetDForm', vetDTypeR EXTID 'vd:vetDType', vetDStatusR EXTID 'vd:vetDStatus', finalizedR EXTID 'vd:finalized', lastUpdateDateR EXTID 'vd:lastUpdateDate'
    PROPERTIES() IN batch1R productType1R EXTID 'vd:productType', volume1R EXTID 'vd:volume', batchID1R EXTID 'vd:batchID', perishable1R EXTID 'vd:perishable', lowGradeCargo1R EXTID 'vd:lowGradeCargo'
    PROPERTIES() IN product1R uuid12R EXTID 'bs:uuid', guid10R EXTID 'bs:guid', name8R EXTID 'dt:name'
    PROPERTIES() IN subProduct1R uuid13R EXTID 'bs:uuid', guid11R EXTID 'bs:guid', name9R EXTID 'dt:name'
    PROPERTIES() IN productItem2R uuid14R EXTID 'bs:uuid', guid12R EXTID 'bs:guid', name10R EXTID 'dt:name', code2R EXTID 'dt:code'
    PROPERTIES() IN unit1R uuid15R EXTID 'bs:uuid', guid13R EXTID 'bs:guid', name11R EXTID 'dt:name'
    PROPERTIES() IN firstDate2R year2R EXTID 'dt:year', month2R EXTID 'dt:month', day2R EXTID 'dt:day'
    PROPERTIES() IN firstDate3R year3R EXTID 'dt:year', month3R EXTID 'dt:month', day3R EXTID 'dt:day'
    PROPERTIES() IN country1R uuid16R EXTID 'bs:uuid', guid14R EXTID 'bs:guid', name12R EXTID 'dt:name'
    PROPERTIES() IN producer1R role1R EXTID 'dt:role'
    PROPERTIES() IN enterprise1R uuid17R EXTID 'bs:uuid', guid15R EXTID 'bs:guid', name13R EXTID 'dt:name'
    PROPERTIES() IN owner1R uuid18R EXTID 'bs:uuid', guid16R EXTID 'bs:guid'
    PROPERTIES() IN authenticationR cargoExpertizedR EXTID 'vd:cargoExpertized'
    PROPERTIES() IN statusChangeR status1R EXTID 'vd:status', actualDateTimeR EXTID 'vd:actualDateTime'
    PROPERTIES() IN specifiedPersonR fioR EXTID 'vd:fio', workEmailR EXTID 'vd:workEmail'
    PROPERTIES() IN organizationR name14R EXTID 'dt:name'
    PROPERTIES() IN regionR uuid19R EXTID 'bs:uuid', guid17R EXTID 'bs:guid', name15R EXTID 'dt:name';

process (RegisterProductionOperationRequest r) + {
    NEWSESSION {
        stringToFile(response(r));
        IMPORT registerProductionOperationResponse XML FROM resultFile();

        IF vetDocumentUuidR() AND NOT vetDocument(vetDocumentUuidR()) THEN NEW d = VetDocument {
            uuid(d) <- vetDocumentUuidR();
        }

        FOR uuid(VetDocument d) = vetDocumentUuidR() DO {
            issueDate(d) <- toDateFormat(issueDateR(), 'YYYY-MM-DD');

            type(d) <- vetDocumentType(vetDTypeR());
            status(d) <- vetDocumentStatus(vetDStatusR());

            productType(d) <- productType(productType1R());
            product(d) <- product(guid10R());
            subProduct(d) <- subProduct(guid11R());

            productItem(d) <- productItem(guid12R());
            productItemXml(d) <- name10R();

            volume(d) <- NUMERIC[16,5](volume1R());
            unit(d) <- unit(guid13R());

            dateOfProduction(d) <- toDateFormat(year2R() + '-' + month2R() + '-' + day2R(), 'YYYY-MM-DD');
//            dateOfProductionHour(d) <- dateOfProductionHour();
//            dateOfProductionXml(d) <- dateOfProductionXml();

            expiryDate(d) <- toDateFormat(year3R() + '-' + month3R() + '-' + day3R(), 'YYYY-MM-DD');
//            expiryDateHour(d) <- expiryDateHour();
//            expiryDateXml(d) <- expiryDateXml();

            batchID(d) <- batchID1R();
            perishable(d) <- perishable1R();
//            origin(d) <- origin();
            lowGradeCargo(d) <- lowGradeCargo1R();
//            packageList(d) <- packageList();

//            authentication(d) <- authentication();
//            purpose(d) <- purpose(purposeGuid());

        }

        FOR  guidR(INTEGER i) AND NOT stockEntry(guidR(i)) DO NEW d = StockEntry {
            guid(d) <- guidR(i);
            enterprise(d) <- enterprise(guid7R(i));
        }

        FOR guid(StockEntry d) = guidR(INTEGER i) DO {
            active(d) <- activeR(i);
            number(d) <- entryNumberR(i);
            volume(d) <- NUMERIC[16,5](volumeR(i));
            unit(d) <- unit(uuid5R(i));
            dateOfProduction(d) <- toDateFormat(yearR(i) + '-' + monthR(i) + '-' + dayR(i), 'YYYY-MM-DD');
//            dateOfProductionHour(d) <- hourR(i);
            expiryDate(d) <- toDateFormat(year1R(i) + '-' + month1R(i)+ '-' + day1R(i), 'YYYY-MM-DD');
//            expiryDateHour(d) <- hour1R(i);
//
            in(d, VetDocument vd) <- TRUE IF GROUP SUM 1 IF uuid(vd) = uuidR(i);
//
            in(d, ProductItem pi) <- TRUE IF pi = productItem(guid3R(i));
        }
//
        APPLY;
//        processed(r) <- TRUE;
        APPLY;
    }
}