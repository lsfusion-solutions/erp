MODULE KonturEDI;

REQUIRE Utils, Time, Integration, Certificate, Authentication;

NAMESPACE KonturEDI;

url 'Url' = DATA STRING ();
clientId 'Ключ разработчика' = DATA STRING ();
useTest 'Тест' = DATA BOOLEAN ();

CLASS User 'Пользователь Контур.EDI';
TABLE user (User);

login 'Логин' = DATA STRING (User) IN id INDEXED CHARWIDTH 50 NONULL;
user (login) = GROUP AGGR User user BY login(user);
password 'Пароль' = DATA STRING (User) IN id ECHO CHARWIDTH 50 NONULL;

FORM konturUserEDI 'Пользователь Контур.EDI'
    OBJECTS u = User PANEL
    PROPERTIES(u) login, password

    EDIT User OBJECT u
;

FORM konturUsersEDI 'Пользователи EDI'
    OBJECTS u = User
    PROPERTIES(u) READONLY login
    PROPERTIES(u) NEWSESSION NEW, EDIT, DELETE

    LIST User OBJECT u
;

token = DATA LOCAL STRING();
token = DATA STRING (User);
tokenDateTime = DATA DATETIME (User);
countMinutesEDITokenData 'Перезапрашивать токен каждые (минут)' = DATA INTEGER ();
countMinutesEDIToken 'Перезапрашивать токен каждые (минут)' () = OVERRIDE countMinutesEDITokenData(), 480;

userKonturEDI 'Пользователь Контур.EDI' = DATA User (CustomUser);
loginKonturEDI 'Пользователь Контур.EDI' (CustomUser u) = login(userKonturEDI(u));

httpHeadersKontur(TEXT name) = CASE
    WHEN name == 'Authorization' THEN 'KonturEdiAuth konturediauth_api_client_id='+clientId() +
        ',konturediauth_login=' + login(userKonturEDI(currentUser())) + ',konturediauth_password=' + password(userKonturEDI(currentUser()));

httpHeadersTokenUser(TEXT name) = CASE
    WHEN name == 'Authorization' THEN 'KonturEdiAuth konturediauth_api_client_id=' + clientId() + ',konturediauth_token=' + token()
    WHEN name == 'Accept' THEN 'application/json';

getTokenUser (User u) {
    IF NOT tokenDateTime(u) > sumMinutes(currentDateTime(), -countMinutesEDIToken()) OR NOT token(u) THEN {
        NEWSESSION NESTED LOCAL {
            LOCAL result = STRING ();
            TRY {
                EXTERNAL HTTP POST url() + '/V1/Authenticate' HEADERS httpHeadersKontur TO result;

                token(u) <- result();
                tokenDateTime(u) <- currentDateTime();
            } CATCH {
                MESSAGE 'Ошибка авторизации ' + statusHttp() + ' ' + result();
            }
            APPLY;
        }
    }
    token() <- token(u);
}


EXTEND FORM employee
    PROPERTIES(e) loginKonturEDI
;

DESIGN employee {
    authentication {
        MOVE PROPERTY(loginKonturEDI(e));
    }
}

EXTEND FORM integrationData
    PROPERTIES urlKonturEDI = url(), clientIdKonturEDI = clientId(), useTest(), countMinutesEDITokenData()
;

DESIGN integrationData {
    pane {
        NEW konturEDI {
            caption = 'Контур.EDI';
            MOVE PROPERTY(urlKonturEDI);
            MOVE PROPERTY(clientIdKonturEDI);
            MOVE PROPERTY(useTest());
            MOVE PROPERTY(countMinutesEDITokenData());
        }
    }
}

NAVIGATOR {
    financeNavigator {
        NEW FOLDER konturEDI 'Контур.EDI' {
            NEW konturUsersEDI;
        }
    }
}
