loadDefaultStatisticGroups () + {  loadDefaultStatisticGroupsRu(); }


importExcel 'Импорт строк из xls' (StatisticReportType type) {
    IF NOT statisticGroupType(type) THEN {
        MESSAGE 'Не задан классификатор' NOWAIT;
        RETURN;
    }
    INPUT f = EXCELFILE DO {
        LOCAL name, number, id = STRING (INTEGER);
        IMPORT XLS FROM f TO name, number, id;
        FOR imported(INTEGER  r) ORDER  r DO NEW d = StatisticReportTypeDetail{
            statisticReportType(d) <- type;
            name(d) <- name(r);
            number(d) <- number(r);
            statisticGroup(d) <- groupIdTypeIdGroup(id(statisticGroupType(type)), id(r));            
        }
    }
}
EXTEND FORM statisticReportType
    PROPERTIES (r) importExcel TOOLBAR DRAW d
;

createStatisticReportTypeDetail(StatisticReportType type, STRING  name, STRING number, id){
    NEW d = StatisticReportTypeDetail{
        statisticReportType(d) <- type;
        name(d) <- name;
        number(d) <- number;
        statisticGroup(d) <- groupIdTypeIdGroup(id(statisticGroupType(type)), id);
    }
}

