loadDefaultStatisticGroups () + {  loadDefaultStatisticGroupTypesRu(); }

loadDefaultStatisticGroupsRuApply 'Загрузить данные для статистики'()  {
    NEWSESSION {
        loadDefaultStatisticGroupsRu();
        loadDefaultStatisticGroupTypesRu();
        APPLY;
    }
}
EXTEND FORM defaultData
    PROPERTIES () loadDefaultStatisticGroupsRuApply
;
DESIGN defaultData {
    commons{
        MOVE PROPERTY (loadDefaultStatisticGroupsRuApply());
    }
}


//DESIGN statisticReportType{
//    REMOVE PROPERTY (isPositiveReport(r));
//}

DESIGN statisticReport{
    REMOVE PROPERTY (soldSumResident (d));
    REMOVE PROPERTY (prevYearSoldSum (d));
    REMOVE PROPERTY (soldSumCorporate (d));
    REMOVE PROPERTY (soldSumInternet (d));
    REMOVE PROPERTY (soldSumCatering (d));
    REMOVE PROPERTY (prevYearSoldSumCatering (d));
    REMOVE PROPERTY (balanceSum (d));
    REMOVE PROPERTY (isPeriod (r));
    REMOVE PROPERTY (selectReports(r));
}

DESIGN statisticReports{
    REMOVE PROPERTY (soldSumResident (d));
    REMOVE PROPERTY (prevYearSoldSum (d));
    REMOVE PROPERTY (soldSumCorporate (d));
    REMOVE PROPERTY (soldSumInternet (d));
    REMOVE PROPERTY (soldSumCatering (d));
    REMOVE PROPERTY (prevYearSoldSumCatering (d));
    REMOVE PROPERTY (balanceSum (d));
}

fillSumReportCustom 'Заполнить данные' ABSTRACT CASE (StatisticReport);
fillSumReports 'Заполнить данные'(StatisticReport r){
    IF NOT statisticReportType(r) THEN {
        MESSAGE 'Не задан тип отчета';
        RETURN;
    }
    IF NOT reportKind(r) THEN {
        MESSAGE 'Не задан вид отчета';
        RETURN;
    }
    resetParams(r);
    fillSumReportCustom(r);
};

EXTEND FORM statisticReport
    PROPERTIES (r) fillSumReports TOOLBAR DRAW d
;
DESIGN statisticReport{
    REMOVE PROPERTY (fillData(r));
    REMOVE PROPERTY (fillRegionData(r));
    REMOVE PROPERTY (fillLegalEntityData(r));
    REMOVE PROPERTY (fillSumData(r));
    REMOVE PROPERTY (fillSumRegionData(r));
    REMOVE PROPERTY (fillSumLegalEntityData(r));
}

//fillSumRegionData DRAW d SHOWIF isRegionSum(r),
CLASS MonthStatisticReportDetail 'Строка периода';
TABLE MonthStatisticReportDetail (MonthStatisticReportDetail);

@defineDocumentRelation(statisticReport, StatisticReport, MonthStatisticReportDetail, );
@defineDocumentDetailIndex(statisticReport, MonthStatisticReportDetail);

date = DATA DATE (MonthStatisticReportDetail);
extractMonth 'Месяц' (MonthStatisticReportDetail d) = extractMonthName(date(d));
name 'Наименование'  = DATA STRING (MonthStatisticReportDetail);
name(MonthStatisticReportDetail d) <- extractMonth(d) WHEN CHANGED(date(d));

soldSum 'Оборот розничной торговли' = DATA NUMERIC[16,3] (MonthStatisticReportDetail);
numberData 'Код строки' = DATA STRING[10] (MonthStatisticReportDetail);
number 'Код строки' (MonthStatisticReportDetail d) = OVERRIDE numberData(d), STRING[10](lpad(STRING(index(d)),2,'0'));

@defineDocumentDetailActions(statisticReport, MonthStatisticReportDetail);

roundMonth 'Точность для месяцев' = DATA INTEGER (StatisticReportType) IN documentPrm;
EXTEND FORM statisticReportType
    PROPERTIES (r) roundMonth
;
roundMonth 'Точность для месяцев' = DATA INTEGER (StatisticReport) IN documentPrm;
EXTEND FORM statisticReport
    PROPERTIES (r) roundMonth
;
roundMonth(StatisticReport r) <- roundMonth(statisticReportType(r)) WHEN CHANGED(statisticReportType(r));
roundMonth(MonthStatisticReportDetail d) = roundMonth(statisticReport(d));

EXTEND FORM statisticReport
    OBJECTS  m = MonthStatisticReportDetail
    PROPERTIES (m) index HEADER 'Порядок', name, extractMonth READONLY, number, soldSum
    PROPERTIES (m) NEW, deleteM=DELETE GRID
    PROPERTIES(r) DRAW m deleteMonthStatisticReportDetail
    FILTERS statisticReport (m) == r
    ORDERS index(m)
;
DESIGN statisticReport{
    specificationBox{
        MOVE BOX (m){caption = 'По месяцам';}
    }
}
EXTEND FORM statisticReports
    OBJECTS  m = MonthStatisticReportDetail
    PROPERTIES (m) READONLY index HEADER 'Порядок', name, extractMonth READONLY, number, soldSum
    FILTERS statisticReport (m) == r
    ORDERS index(m)
;
DESIGN statisticReports{
    documentDetail{
        MOVE BOX (m) AFTER BOX(d) {caption = 'По месяцам';}
    }
}

totalRetailStatisticGroupData = DATA StatisticGroup();
totalRetailStatisticGroup = ABSTRACT CASE StatisticGroup();
totalRetailStatisticGroup()+= WHEN groupIdTypeIdGroup('RURetail','47.01.02.001.АГ') THEN groupIdTypeIdGroup('RURetail','47.01.02.001.АГ');
totalRetailStatisticGroup() += WHEN totalRetailStatisticGroupData() THEN totalRetailStatisticGroupData();

checkParamsDetail(StatisticReport report){
    IF rate(report) THEN {
        soldSum(StatisticReportDetail d) <- NUMERIC[16,3](soldSum(d) / rate(report)) WHERE statisticReport(d) == report;
        soldSum(MonthStatisticReportDetail d) <- NUMERIC[16,3](soldSum(d) / rate(report)) WHERE statisticReport(d) == report;
    }
    soldSum(StatisticReportDetail d) <- round(soldSum(d), round(d)) WHERE round(d) AND statisticReport(d) == report;
    soldSum(MonthStatisticReportDetail d) <- round(soldSum(d), roundMonth(d)) WHERE roundMonth(d) AND statisticReport(d) == report;

    IF isPositiveReport(report) THEN {
        soldSum(StatisticReportDetail d) <- 0.0 WHERE soldSum(d) <0 AND statisticReport(d) == report;
        soldSum(MonthStatisticReportDetail d) <- 0.0 WHERE soldSum(d) <0 AND statisticReport(d) == report;
    }
    soldSum(StatisticReportDetail d) <- (GROUP SUM soldSum(StatisticReportDetail detail)  IF in(detail, d)) WHERE count(d) AND statisticReport(d) == report AND NOT skip(d);
    dataIndex(MonthStatisticReportDetail d) <- defaultIndex(d)+1;
    FOR NUMERIC[16,3] sum ==(OVERRIDE (GROUP SUM soldSum(MonthStatisticReportDetail dd) IF  statisticReport(dd) == report), 0.0 IF report IS StatisticReport) DO NEW d = MonthStatisticReportDetail {
        dataIndex(d)<- 1;
        statisticReport(d) <- report;
        name(d) <- 'За отчетный год – всегов том числе';
        soldSum(d) <- sum;
    }
}

fillSumReportCustom(StatisticReport report) + WHEN isRegion(report) THEN {
    deleteMonthStatisticReportDetail(report);
    FOR StatisticGroup s == statisticGroup(StatisticReportDetail d) AND statisticReport(d) == report AND
        LegalEntity c == company(report) AND Region r == region(report) AND DATE dFrom == fromDate(report) AND DATE dTo == toDate(report)
        NOINLINE DO {
        soldSum(d) <- NUMERIC[16,3](totalSumSoldBy(s, c, r, dFrom, dTo));        
    }
    LOCAL to = BOOLEAN (DATE);
    to (DATE  date) <- TRUE WHERE iterate(date,fromDate(report) ,toDate(report)) AND firstDayOfMonth(date)==date;
    
    FOR StatisticGroup s == totalRetailStatisticGroup() AND to(DATE dFrom) AND lastDayOfMonth(dFrom) == DATE dTo
        AND LegalEntity c == company(report) AND Region r == region(report)  ORDER dFrom DO NEW d = MonthStatisticReportDetail {
        statisticReport(d) <- report;
        date(d) <- dFrom;
        soldSum(d) <- NUMERIC[16,3](totalSumSoldBy(s, c, r, dFrom, dTo));
    }

    checkParamsDetail(report);
}
fillSumReportCustom(StatisticReport report) + WHEN isLegalEntity(report) THEN {
    deleteMonthStatisticReportDetail(report);
    FOR StatisticGroup s == statisticGroup(StatisticReportDetail d) AND statisticReport(d) == report AND
        LegalEntity c == company(report) AND DATE dFrom == fromDate(report) AND DATE dTo == toDate(report) NOINLINE DO {    
        soldSum(d) <- NUMERIC[16,3](totalSumSoldBy(s, c, dFrom, dTo));
    }
    LOCAL to = BOOLEAN (DATE);
    to (DATE  date) <- TRUE WHERE iterate(date,fromDate(report) ,toDate(report)) AND firstDayOfMonth(date)==date;

    FOR StatisticGroup s == totalRetailStatisticGroup() AND to(DATE dFrom) AND lastDayOfMonth(dFrom) == DATE dTo
        AND LegalEntity c == company(report) ORDER dFrom DO NEW d = MonthStatisticReportDetail {
        statisticReport(d) <- report;
        date(d) <- dFrom;
        soldSum(d) <- NUMERIC[16,3](totalSumSoldBy(s, c, dFrom, dTo));
    }
    checkParamsDetail(report);
}
fillSumReportCustom(StatisticReport report) + WHEN isStock(report) THEN {
    deleteMonthStatisticReportDetail(report);
    FOR StatisticGroup s == statisticGroup(StatisticReportDetail d) AND statisticReport(d) == report AND
        Stock st == stock(report) AND DATE dFrom == fromDate(report) AND DATE dTo == toDate(report) NOINLINE DO {
        soldSum(d) <- NUMERIC[16,3](totalSumSoldBy(s, st, dFrom, dTo));
    }
    LOCAL to = BOOLEAN (DATE);
    to (DATE  date) <- TRUE WHERE iterate(date,fromDate(report) ,toDate(report)) AND firstDayOfMonth(date)==date;

    FOR StatisticGroup s == totalRetailStatisticGroup() AND to(DATE dFrom) AND lastDayOfMonth(dFrom) == DATE dTo
        AND Stock st == stock(report) ORDER dFrom DO NEW d = MonthStatisticReportDetail {
        statisticReport(d) <- report;
        date(d) <- dFrom;
        soldSum(d) <- NUMERIC[16,3](totalSumSoldBy(s, st, dFrom, dTo));
    }
    checkParamsDetail(report);
}

FORM print1TorgTable2 'Таблица 2 (1-ТОРГ)'
    OBJECTS r = StatisticReport PANEL 
    OBJECTS d = StatisticReportDetail 
    PROPERTIES (d) name, index, number, sidStatisticGroup, soldSum
    ORDERS index(d)
    FILTERS statisticReport(d)==r 
;
print1TorgTable2 'Таблица 2 (1-ТОРГ)'(StatisticReport r) {
    PRINT print1TorgTable2 OBJECTS r = r;
} TOOLBAR IMAGE 'print.png' IN print;

print1TorgTable2Xls 'Таблица 2 (1-ТОРГ) xls'(StatisticReport r) {
    PRINT print1TorgTable2 OBJECTS r = r XLSX;
} TOOLBAR IMAGE 'print.png' IN print;

FORM print1TorgTable3 'Таблица 3 (1-ТОРГ)'
    OBJECTS r = StatisticReport PANEL
    OBJECTS  d = MonthStatisticReportDetail
    PROPERTIES (d) index HEADER 'Порядок', name, extractMonth READONLY, number, soldSum
    ORDERS index(d)
    FILTERS statisticReport(d)==r
;
print1TorgTable3 'Таблица 3 (1-ТОРГ)'(StatisticReport r) {
    PRINT print1TorgTable3 OBJECTS r = r;
} TOOLBAR IMAGE 'print.png' IN print;
print1TorgTable3Xls 'Таблица 3 (1-ТОРГ) xls'(StatisticReport r) {
    PRINT print1TorgTable3 OBJECTS r = r XLSX ;
} TOOLBAR IMAGE 'print.png' IN print;
EXTEND FORM statisticReports
    PROPERTIES (r) print1TorgTable2, print1TorgTable2Xls, print1TorgTable3, print1TorgTable3Xls
;
DESIGN statisticReports{
    printContainer{
        MOVE PROPERTY (print1TorgTable2(r));
        MOVE PROPERTY (print1TorgTable2Xls(r));
        MOVE PROPERTY (print1TorgTable3(r));
        MOVE PROPERTY (print1TorgTable3Xls(r));
    }
}