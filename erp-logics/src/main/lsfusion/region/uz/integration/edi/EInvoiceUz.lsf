MODULE EInvoiceUz;

REQUIRE EDIUz, LegalEntityUz, ItemUz;

NAMESPACE EDI;

//-----------------------------------------Электронная накладная----------------------------------------------//
CLASS EInvoice 'Электронный документ';
TABLE eInvoice(EInvoice);

waybillJSON = DATA JSONFILE (EInvoice);

dateTimeCreated 'Создана' = DATA DATETIME (EInvoice);
dateTimeCreated(EInvoice i) <- currentDateTime() WHEN (i IS EInvoice);

externalId 'Внешний id' = DATA STRING (EInvoice) IN id INDEXED CHARWIDTH 10;
eInvoiceByExternalId (STRING externalId) = GROUP AGGR EInvoice eInvoice BY externalId(eInvoice);


@defineExternalizable(eInvoice, STRING[100]);

exportedSupplier 'Отправлен (поставщик)' = DATA BOOLEAN (EInvoice);

isCancelled 'Отменена (поставщик)' = DATA BOOLEAN (EInvoice);
isAccepted 'Принята (покупатель)' = DATA BOOLEAN (EInvoice);
isRejected 'Отклонена (покупатель)' = DATA BOOLEAN (EInvoice);

isCancel(EInvoice ei) = isCancelled(ei) OR isRejected(ei);

// WaybillDoc
deliveryNoteNumber 'Номер' = DATA STRING[43] (EInvoice) NONULL INDEXED IN id CHARWIDTH 30; // WaybillNo
deliveryNoteDate 'Дата' = DATA DATE (EInvoice) NONULL INDEXED; // WaybillDate

//Contract
contractNumber 'Документ, который служит основанием отпуска' = DATA STRING[70] (EInvoice); //ContractNo
contractDate 'Дата документа, служащего основанием отпуска' = DATA DATE (EInvoice); // ContractDate

legalEntityByInn = GROUP MAX LegalEntity le BY INN(le);

//Consignor (Грузоотправитель)
dataSupplier 'Поставщик' = DATA LegalEntity (EInvoice);
dataNameSupplier = DATA STRING[275] (EInvoice);
dataAddressSupplier = DATA STRING[150] (EInvoice);
dataInnSupplier = DATA STRING[9] (EInvoice);

supplier 'Покупатель' (EInvoice e) = OVERRIDE dataSupplier(e), legalEntityByInn(dataInnSupplier(e));
nameSupplier 'Поставщик' (EInvoice i) = OVERRIDE fullName(supplier(i)), dataNameSupplier(i); // Name
addressSupplier 'Адрес поставщика' (EInvoice i) = OVERRIDE address(supplier(i)), dataAddressSupplier(i);
innSupplier 'ИНН поставщика' (EInvoice i) = OVERRIDE INN(supplier(i)), dataInnSupplier(i); //TinOrPinfl

// Склад погрузки (выбор вручную)
supplierStock 'Пункт погрузки' = DATA Stock (EInvoice);
dataNameSupplierStock = DATA STRING[150] (EInvoice);
nameSupplierStock 'Пункт погрузки' (EInvoice i) = OVERRIDE name(supplierStock(i)), dataNameSupplierStock(i);
dataAddressSupplierStock = DATA STRING[150] (EInvoice);
addressSupplierStock 'Адрес пункта погрузки' (EInvoice i) = OVERRIDE address(supplierStock(i)), dataAddressSupplierStock(i);

// Consignee (Грузополучатель)
dataCustomer 'Покупатель' = DATA LegalEntity (EInvoice);
dataNameCustomer = DATA STRING[9] (EInvoice);
dataAddressCustomer = DATA STRING[250] (EInvoice);
dataInnCustomer = DATA STRING[9] (EInvoice);

customer 'Покупатель' (EInvoice e) = OVERRIDE dataCustomer(e), legalEntityByInn(dataInnCustomer(e));
innCustomer 'ИНН покупателя' (EInvoice i) = OVERRIDE INN(customer(i)), dataInnCustomer(i) ;// TinOrPinfl
addressCustomer 'Адрес покупателя' (EInvoice i) = OVERRIDE address(customer(i)), dataAddressCustomer(i);
nameCustomer 'Покупатель' (EInvoice i) = OVERRIDE fullName(customer(i)), dataNameCustomer(i); // Name

// Склад разгрузки (выбор вручную)
customerStock 'Склад покупателя' = DATA Stock (EInvoice);
nameCustomerStock 'Склад покупателя' (EInvoice i) = name(customerStock(i));
dataAddressCustomerStock = DATA STRING[150] (EInvoice);
addressCustomerStock 'Адрес склада покупателя' (EInvoice i) = OVERRIDE address(customerStock(i)), dataAddressCustomerStock(i);

// Carrier (Перевозчик)
transporter 'Автомобильный перевозчик' = DATA LegalEntity (EInvoice);
dataNameTransporter = DATA STRING[9] (EInvoice);
nameTransporter 'Автомобильный перевозчик' (EInvoice i) = OVERRIDE fullName(transporter(i)), dataNameTransporter(i); // Name
dataInnTransporter = DATA STRING[9] (EInvoice);
innTransporter 'ИНН автомобильного перевозчика' (EInvoice i) = OVERRIDE INN(transporter(i)), dataInnTransporter(i); // TinOrPinfl

// Driver
pinflTransportContact'id водителя' = DATA STRING[100] (EInvoice); // Pinfl
transportContact 'Водитель' = DATA STRING[150] (EInvoice) INDEXED MATCH; // FullName

// Truck
transportRegNo 'Рег. номер автомобиля' = DATA STRING[35] (EInvoice); 
transportModel 'Марка' = DATA STRING[35] (EInvoice);

// Trailer
trailerRegNo 'Марка и рег. номер автомобиля' = DATA STRING[35] (EInvoice);
trailerModel 'Марка и рег. номер автомобиля' = DATA STRING[35] (EInvoice);

notes 'Примечания' = DATA STRING (EInvoice);

CLASS EInvoiceType 'Тип электронного документа' {
    default 'Стандартный (0)',
    additional 'Дополнительный (1)',
    amendOfExpenses 'Возмещение расходов (2)',
    withoutPayment 'Без оплаты (3)',
    corrective 'Исправительный (4)',
    correctiveAmendOfExpenses 'Исправительный с возмещением расходов (5)',
    additionalAmendOfExpenses 'Дополнительный с возмещением расходов (6)',
    correctiveWithoutPayment 'Исправительный без оплаты (8)',
    additionalWithoutPayment 'Дополнительный без оплаты (9)'
}
invoiceType = DATA EInvoiceType (EInvoice);
nameInvoiceType 'Тип документа' (EInvoice i) = staticCaption(invoiceType(i));

CLASS EInvoiceDocType 'Вид электронного документа' {
    esf 'ЭСФ',
    ettn 'ЭТТН'
}
docType = DATA EInvoiceDocType (EInvoice);
nameDocType 'Вид документа' (EInvoice i) = staticCaption(docType(i));
index 'Тип инвойса (индекс)' (EInvoiceType t) = CASE
    WHEN t == EInvoiceType.default THEN 0
    WHEN t == EInvoiceType.additional THEN 1
    WHEN t == EInvoiceType.amendOfExpenses THEN 2
    WHEN t == EInvoiceType.withoutPayment THEN 3
    WHEN t == EInvoiceType.corrective THEN 4
    WHEN t == EInvoiceType.correctiveAmendOfExpenses THEN 5
    WHEN t == EInvoiceType.additionalAmendOfExpenses THEN 6
    WHEN t == EInvoiceType.correctiveWithoutPayment THEN 8
    WHEN t == EInvoiceType.additionalWithoutPayment THEN 9
;
invoiceTypeIndex (EInvoice i) = index(invoiceType(i));

CLASS EInvoiceSingleSideType 'Односторонний тип документа' {
    forPerson 'Физическому лицу (1)',
    forForeignExportService 'Экспорт услуг иностранному лицу (2)',
    forImportService 'Импорт услуг (3)',
    forGovernmentSecret 'Государственная тайна (4)',
    forFinancialService 'Финансовые услуги (5)',
    belowMarketPrice 'Ниже рыночной цены (6)',
    belowCustomsPrice 'Ниже таможенной цены (7)',
    forExportService 'Экспорт услуг (8)',
    otherIncome 'Прочие доходы (9)',
    exciseSubmissionForOwnNeeds 'Акциз - представление для собственных нужд (10)',
    exciseUsageForOwnNeeds 'Акциз - использование для собственных нужд (11)',
    priceAndPrimeCostDifference 'Разница в цене и себестоимости (12)',
    lossAndDamageOfGoods 'Потеря или порча товаров (13)'
}
singleSideType = DATA EInvoiceSingleSideType (EInvoice);
nameSingleSideType 'Односторонний тип' (EInvoice i) = staticCaption(singleSideType(i));
index 'Односторонний тип (индекс)' (EInvoiceSingleSideType t) = CASE
    WHEN t == EInvoiceSingleSideType.forPerson THEN 1
    WHEN t == EInvoiceSingleSideType.forForeignExportService THEN 2
    WHEN t == EInvoiceSingleSideType.forImportService THEN 3
    WHEN t == EInvoiceSingleSideType.forGovernmentSecret THEN 4
    WHEN t == EInvoiceSingleSideType.forFinancialService THEN 5
    WHEN t == EInvoiceSingleSideType.belowMarketPrice THEN 6
    WHEN t == EInvoiceSingleSideType.belowCustomsPrice THEN 7
    WHEN t == EInvoiceSingleSideType.forExportService THEN 8
    WHEN t == EInvoiceSingleSideType.otherIncome THEN 9
    WHEN t == EInvoiceSingleSideType.exciseSubmissionForOwnNeeds THEN 10
    WHEN t == EInvoiceSingleSideType.exciseUsageForOwnNeeds THEN 11
    WHEN t == EInvoiceSingleSideType.priceAndPrimeCostDifference THEN 12
    WHEN t == EInvoiceSingleSideType.lossAndDamageOfGoods THEN 13
;
singleSideTypeIndex (EInvoice i) = index(singleSideType(i));

CLASS EInvoiceIncomeType 'Тип дохода' {
    exitValueOfTransferredGoods 'Стоимость выбывших переданных товаров (1) ',
    redemptionValueOfTransferredGoodsToShareholders 'Выкупная стоимость переданных товаров акционерам (2)',
    goodAndServicesTransferAsCompensationToIndividuals 'Передача товаров и услуг в качестве компенсации физлицам (3)',
    transferOfGoodsAndOtherAssetsOnBailmentBasis 'Передача товаров и других активов на основе ответственного хранения (4)',
    voucherValueForRedeemableGoodsAndServices 'Стоимость ваучера для товаров и услуг (5)',
    valueOfSoldFixedAssetsAndOtherProperty 'Стоимость проданных основных средств и другого имущества (6)',
    revenuesFromTheSaleOfBusinessAsGoingConcern 'Доходы от продажи бизнеса как действующего предприятия (7)'
}
incomeType = DATA EInvoiceIncomeType (EInvoice);
nameIncomeType 'Тип дохода' (EInvoice i) = staticCaption(incomeType(i));
index 'Тип дохода (индекс)' (EInvoiceIncomeType t) = CASE
    WHEN t == EInvoiceIncomeType.exitValueOfTransferredGoods THEN 1
    WHEN t == EInvoiceIncomeType.redemptionValueOfTransferredGoodsToShareholders THEN 2
    WHEN t == EInvoiceIncomeType.goodAndServicesTransferAsCompensationToIndividuals THEN 3
    WHEN t == EInvoiceIncomeType.transferOfGoodsAndOtherAssetsOnBailmentBasis THEN 4
    WHEN t == EInvoiceIncomeType.voucherValueForRedeemableGoodsAndServices THEN 5
    WHEN t == EInvoiceIncomeType.valueOfSoldFixedAssetsAndOtherProperty THEN 6
    WHEN t == EInvoiceIncomeType.revenuesFromTheSaleOfBusinessAsGoingConcern THEN 7
;
incomeTypeIndex (EInvoice i) = index(incomeType(i));

CLASS EInvoiceDetailGroup 'Группа строк электронного документа';
eInvoice = DATA EInvoice(EInvoiceDetailGroup) NONULL DELETE INDEXED;

//LoadingPoint (пункт погрузки)
districtCodeLoadingPoint 'Код округа погрузки' = DATA STRING[100] (EInvoiceDetailGroup); // DistrictCode
districtNameLoadingPoint 'Наименование округа погрузки' = DATA STRING[150] (EInvoiceDetailGroup); // DistrictName

mahallaIdLoadingPoint 'Код района погрузки' = DATA STRING[100] (EInvoiceDetailGroup); // MahallaId
mahallaNameLoadingPoint 'Наименование района погрузки' = DATA STRING[150] (EInvoiceDetailGroup); // MahallaName

regionIdLoadingPoint 'Код района погрузки' = DATA STRING[100] (EInvoiceDetailGroup); // RegionId
regionNameLoadingPoint 'Наименование района погрузки' = DATA STRING[150] (EInvoiceDetailGroup); // RegionName

addressLoadingPoint 'Адрес погрузки' = DATA STRING[150] (EInvoiceDetailGroup); // Address

//LoadingTrustee
pinflLoadingTrustee 'id доверенного лица погрузки' = DATA STRING[100] (EInvoiceDetailGroup); // Pinfl
fullLoadingTrustee 'Доверенное лицо погрузки' = DATA STRING[150] (EInvoiceDetailGroup); // FullName

// UnloadingPoint (пункт разгрузки)
districtCodeUnloadingPoint 'Код округа разгрузки' = DATA STRING[100] (EInvoiceDetailGroup); // DistrictCode
districtUnloadingPoint 'Наименование округа разгрузки' = DATA STRING[150] (EInvoiceDetailGroup); // DistrictName

mahallaIdUnloadingPoint 'Код района разгрузки' = DATA STRING[100] (EInvoiceDetailGroup); // MahallaId
mahallaNameUnloadingPoint 'Наименование района разгрузки' = DATA STRING[150] (EInvoiceDetailGroup); // MahallaName

regionIdUnloadingPoint 'Код района разгрузки' = DATA STRING[100] (EInvoiceDetailGroup); // RegionId
regionNameUnloadingPoint 'Наименование района разгрузки' = DATA STRING[150] (EInvoiceDetailGroup); // RegionName

addressUnloadingPoint 'Адрес разгрузки'  = DATA STRING[150] (EInvoiceDetailGroup); // Address

// UnloadingTrustee
pinflUnloadingTrustee 'id доверенного лица разгрузки' = DATA STRING[100] (EInvoiceDetailGroup); // Pinfl
fullUnloadingTrustee 'Доверенное лицо разгрузки' = DATA STRING[150] (EInvoiceDetailGroup); // FullName

CLASS EInvoiceDetail 'Строка электронного документа';
TABLE eInvoiceDetail(EInvoiceDetail);

@defineExternalizable(eInvoiceDetail, STRING[100]);

in 'Вкл.' = DATA LOCAL BOOLEAN (EInvoice);

eInvoice = DATA EInvoice(EInvoiceDetail) NONULL DELETE INDEXED;
eInvoiceDetailGroup = DATA EInvoiceDetailGroup(EInvoiceDetail) NONULL DELETE;

// Products
dataIndex = DATA INTEGER (EInvoiceDetail) ; // "OrdNo":1,
defaultIndex (EInvoiceDetail d) = PARTITION SUM 1 ORDER d BY eInvoice(d);
index 'Порядковый номер' (EInvoiceDetail d) = OVERRIDE dataIndex(d), defaultIndex(d) MATERIALIZED;

committent 'Комитент' = DATA LegalEntity (EInvoiceDetail);
dataNameCommittentFirst = DATA STRING[200] (EInvoiceDetail);
dataNameCommittent = DATA STRING[275] (EInvoiceDetail);
nameCommittent 'Комитент' (EInvoiceDetail d) = OVERRIDE dataNameCommittentFirst(d), fullName(committent(d)), dataNameCommittent(d); // CommittentName
dataInnCommittent = DATA STRING[9] (EInvoiceDetail);
innCommittent 'ИНН комитента' (EInvoiceDetail d) = OVERRIDE dataInnCommittent(d), INN(committent(d));// CommittentTinOrPinfl

barcode 'Штрихкод' = DATA STRING[100] (EInvoiceDetail) CHARWIDTH 15 IN id;
productName 'Наименование товара' = DATA STRING[500] (EInvoiceDetail) CHARWIDTH 30 IN id; // ProductName
catalogCode 'Код товара (каталог)'= DATA STRING[100] (EInvoiceDetail) CHARWIDTH 15 IN id; // CatalogCode
catalogName 'Наименование товара (каталог)' = DATA STRING[500] (EInvoiceDetail) CHARWIDTH 30 IN id; //CatalogName
packageCode 'Код товара (упаковка)'= DATA STRING[100] (EInvoiceDetail) CHARWIDTH 15; // PackageCode
packageName 'Наименование товара (упаковка)' = DATA STRING[500] (EInvoiceDetail) CHARWIDTH 30 IN id; // PackageName

grossWeightValue 'Масса груза брутто' = DATA NUMERIC[12,6] (EInvoiceDetail); // WeightBrutto
netWeightValue 'Масса груза нетто' = DATA NUMERIC[12,6] (EInvoiceDetail); // WeightNetto
quantityDespatched 'Кол-во отгружаемого товара' = DATA NUMERIC[16,5] (EInvoiceDetail);// Amount
price 'Цена за единицу товара' = DATA NUMERIC[16,2] (EInvoiceDetail); // Price
sum 'Cумма товарной позиции' = DATA NUMERIC[18,2] (EInvoiceDetail);// DeliverySum

valueVAT 'Ставка НДС, %' = DATA NUMERIC[10,2] (EInvoiceDetail); // nds_rate
VATSum 'Сумма НДС' = DATA NUMERIC[18,2] (EInvoiceDetail); // nds_value
invoiceSum 'Сумма с НДС' = DATA NUMERIC[18,2] (EInvoiceDetail); // total_with_nds

CLASS EInvoicePositionOriginType 'Происхождение товара' {
    individualManufacture 'Собственное производство (1)',
    resale 'Купля-продажа (2)',
    service 'Услуга (3)',
    notIncluded 'Не указано (4)'
}
originType 'Происхождение товара' = DATA EInvoicePositionOriginType (EInvoiceDetail);
nameOriginType 'Происхождение товара' (EInvoiceDetail d) = staticCaption(originType(d));
index 'Происхождение товара (индекс)' (EInvoicePositionOriginType t) = CASE
    WHEN t == EInvoicePositionOriginType.individualManufacture THEN 1
    WHEN t == EInvoicePositionOriginType.resale THEN 2
    WHEN t == EInvoicePositionOriginType.service THEN 3
    WHEN t == EInvoicePositionOriginType.notIncluded THEN 4
;
originTypeIndex (EInvoiceDetail d) = index(originType(d));

CLASS EInvoiceLotDetail 'Марки электронного документа EDI';
TABLE eInvoiceLotDetail (EInvoiceLotDetail);

eInvoiceDetail = DATA EInvoiceDetail (EInvoiceLotDetail) NONULL DELETE INDEXED;
eInvoice (EInvoiceLotDetail d) = eInvoice(eInvoiceDetail(d));

id 'Код маркировки единицы товара' = DATA STRING[200] (EInvoiceLotDetail);
type 'Тип' = DATA STRING[100] (EInvoiceLotDetail);
eInvoiceLotDetail = GROUP AGGR EInvoiceLotDetail d BY id(d), eInvoiceDetail(d);
quantity 'Кол-во' = DATA NUMERIC[14,3] (EInvoiceLotDetail);
codeGroupLot 'Код типа маркировки'= DATA INTEGER (EInvoiceLotDetail);

parent = DATA EInvoiceLotDetail(EInvoiceLotDetail) INDEXED;
idParent 'Родитель' (EInvoiceLotDetail d) = id(parent(d));

//Итого
totalSum 'Общая сумма' (eInvoice) = GROUP SUM sum(EInvoiceDetail d) BY eInvoice(d);
totalCount 'Всего количество товарных позиций' (eInvoice) = GROUP SUM 1 BY eInvoice(EInvoiceDetail d);
totalQuantity 'Всего количество единиц' (eInvoice) = GROUP SUM quantityDespatched(EInvoiceDetail d) BY eInvoice(d);
totalGrossWeight 'Всего масса груза брутто' (eInvoice) = GROUP SUM grossWeightValue(EInvoiceDetail d) BY eInvoice(d);
totalNetWeight 'Всего масса груза нетто' (eInvoice) = GROUP SUM netWeightValue(EInvoiceDetail d) BY eInvoice(d);

CONSTRAINT SET(EInvoice i IS EInvoice) AND NOT (GROUP SUM 1 IF eInvoice(EInvoiceDetail d) == i)
    MESSAGE 'Запрещено создавать электронный документ без строк';

background = ABSTRACT CASE COLOR (EInvoice);
accept 'Подтвердить (покупатель)' ABSTRACT LIST (EInvoice);
reject 'Отклонить (покупатель)' ABSTRACT LIST (EInvoice);

send 'Отправить (поставщик)' ABSTRACT LIST (EInvoice);
cancel 'Отменить (поставщик)' ABSTRACT LIST (EInvoice);

openWaybillJSON 'Открыть JSON' (EInvoice e) {
    open(waybillJSON(e));
}

FORM eInvoices 'Электронные документы'
    OBJECTS e = EInvoice LAST
    PROPERTIES(e) in
    PROPERTIES(e) BACKGROUND background(e) READONLY exportedSupplier, isAccepted, isRejected, isCancelled, deliveryNoteNumber, 
        deliveryNoteDate, nameInvoiceType, nameSingleSideType, nameIncomeType, contractNumber, contractDate, notes,
        nameSupplier, addressSupplier, innSupplier, nameSupplierStock, addressSupplierStock,
        nameCustomer, addressCustomer, innCustomer, nameCustomerStock, addressCustomerStock,
        nameTransporter, innTransporter, transportContact, transportRegNo, transportModel, trailerRegNo, trailerModel,
        totalSum, totalCount, totalQuantity, totalGrossWeight, totalNetWeight

    OBJECTS eg = EInvoiceDetailGroup
    PROPERTIES(eg) READONLY districtNameLoadingPoint, mahallaNameLoadingPoint, regionNameLoadingPoint, fullLoadingTrustee, addressLoadingPoint,
        districtUnloadingPoint, mahallaNameUnloadingPoint, regionNameUnloadingPoint, fullUnloadingTrustee, addressUnloadingPoint
    FILTERS eInvoice(eg) == e
    
    OBJECTS ed = EInvoiceDetail
    PROPERTIES(ed) READONLY index, 
        nameCommittent, innCommittent,
        productName, barcode, catalogCode, catalogName, packageCode, packageName,
        grossWeightValue, netWeightValue, quantityDespatched, price, sum,
        valueVAT, VATSum, invoiceSum, nameOriginType
                               
    FILTERS eInvoice(ed) == e, eInvoiceDetailGroup(ed) == eg

    OBJECTS dl = EInvoiceDetail
    PROPERTIES (dl) READONLY index, productName
    FILTERS eInvoice(dl) == e
    FILTERGROUP marked
        FILTER 'С марками' GROUP SUM 1 IF eInvoiceDetail(EInvoiceLotDetail eld1) = dl DEFAULT

    TREE eLotTr eld = EInvoiceLotDetail PARENT parent(eld)
    PROPERTIES(eld) READONLY id, type, quantity
    FILTERS eInvoiceDetail(eld) = dl

    EVENTS ON CHANGE dl {EXPAND ALL eInvoices.eld;}
    
    PROPERTIES(e) accept, reject, send, cancel, openWaybillJSON
;
@extendFormEditable(eInvoices);

DESIGN eInvoices {
    BOX {
        NEW topContainer {
            fill = 1;
            horizontal = TRUE;
            MOVE BOX(e);
        }
        TOOLBARBOX (e){
            horizontal = TRUE;
        }
        NEW tab {
            fill = 1;
            tabbed = TRUE;
            NEW detail {
                fill = 1;
                caption = 'Спецификация';
                MOVE BOX(eg);
                MOVE BOX(ed);
            }
            NEW actionContainer {
                caption = 'Действия';
                horizontal = TRUE;
                NEW supplierActions {
                    caption = 'Поставщик';
                    MOVE PROPERTY(send(e));
                    MOVE PROPERTY(cancel(e));
                }
                NEW customerActions {
                    caption = 'Покупатель';
                    MOVE PROPERTY(accept(e));
                    MOVE PROPERTY(reject(e));
                }
            }
            NEW eLotDetail {
                caption = 'Маркировка';
                horizontal = TRUE;
                fill = 1;
                MOVE BOX(dl);
                MOVE BOX(TREE eLotTr);
            }
            NEW printTab {
                fill = 1;
                caption = 'Печатные формы';
                NEW printEI {
                    horizontal = TRUE;
                }
                NEW exportEI {
                    horizontal = TRUE;
                    MOVE PROPERTY(openWaybillJSON(e));
                }
            }
        }

        MOVE TOOLBARBOX {
            TOOLBAR(e) {
                lines = 3;
            }
        }
    }
}

NAVIGATOR {
    edi 'EDI' {
        NEW eInvoices;
    }
}

FORM eInvoice 'Электронный документ'
    OBJECTS e = EInvoice PANEL
    PROPERTIES(e) BACKGROUND background(e) deliveryNoteNumber,
        deliveryNoteDate, nameDocType, nameInvoiceType, nameSingleSideType, nameIncomeType, contractNumber, contractDate, notes,
        nameSupplier, addressSupplier, innSupplier, nameSupplierStock, addressSupplierStock,
        nameCustomer, addressCustomer, innCustomer, nameCustomerStock, addressCustomerStock,
        nameTransporter, innTransporter, transportContact, transportRegNo, transportModel, trailerRegNo, trailerModel,
        totalSum, totalCount, totalQuantity, totalGrossWeight, totalNetWeight

    OBJECTS g = EInvoiceDetailGroup
    PROPERTIES(g) READONLY districtNameLoadingPoint, mahallaNameLoadingPoint, regionNameLoadingPoint, fullLoadingTrustee, addressLoadingPoint,
        districtUnloadingPoint, mahallaNameUnloadingPoint, regionNameUnloadingPoint, fullUnloadingTrustee, addressUnloadingPoint
    FILTERS eInvoice(g) == e
    
    OBJECTS ed = EInvoiceDetail
    PROPERTIES (ed) index,
        nameCommittent, innCommittent,
        productName, barcode, catalogCode, catalogName, packageCode, packageName,
        grossWeightValue, netWeightValue, quantityDespatched, price, sum,
        valueVAT, VATSum, invoiceSum, nameOriginType
    FILTERS eInvoice(ed) == e,  eInvoiceDetailGroup(ed) == g

    OBJECTS dl = EInvoiceDetail
    PROPERTIES (dl) READONLY index, productName
    FILTERS eInvoice(dl) == e
    FILTERGROUP marked
        FILTER 'С марками' GROUP SUM 1 IF eInvoiceDetail(EInvoiceLotDetail eld1) = dl DEFAULT

    TREE eLotTr eld = EInvoiceLotDetail PARENT parent(eld)
    PROPERTIES(eld) READONLY id, type, quantity
    FILTERS eInvoiceDetail(eld) = dl

    EVENTS ON CHANGE dl {EXPAND ALL eInvoice.eld;}

    EDIT EInvoice OBJECT e
;

DESIGN eInvoice {
    OBJECTS {
        NEW mainTabs {
            tabbed = TRUE;
            fill = 1;
            NEW main {
                caption = 'Данные документа';
                fill = 1;
                NEW mainPanel{
                    lines = 2;
                    MOVE PROPERTY (deliveryNoteNumber(e));
                    MOVE PROPERTY (deliveryNoteDate(e));
                    
                    NEW shipper {
                        align = STRETCH;
                        caption = 'Информация о грузоотправителе';
                        
                        MOVE PROPERTY (nameSupplier(e));
                        MOVE PROPERTY (addressSupplier(e));
                        MOVE PROPERTY (innSupplier(e));
                    }
                    NEW receiver {
                        align = STRETCH;
                        caption = 'Информация о грузополучателе';
                        MOVE PROPERTY (nameCustomer(e));
                        MOVE PROPERTY (addressCustomer(e));
                        MOVE PROPERTY (innCustomer(e));
                    }
                    NEW shipFrom {
                        align = STRETCH;
                        caption = 'Информация о пункте погрузки';                       
                        MOVE PROPERTY (nameSupplierStock(e));
                        MOVE PROPERTY (addressSupplierStock(e));
                    }
                    NEW shipTo {
                        align = STRETCH;
                        caption = 'Информация о пункте разгрузки';                       
                        
                        MOVE PROPERTY (nameCustomerStock(e));
                        MOVE PROPERTY (addressCustomerStock(e));
                    }
                    NEW carrier1 {
                        align = STRETCH;
                        caption = 'Информация о транспортировке';
                        MOVE PROPERTY (transportContact(e));                      
                    }
                    NEW carrier2 {
                        align = STRETCH;
                        caption = 'Информация о транспортировке';
                        showIf = docType(e) == EInvoiceDocType.ettn;
                        MOVE PROPERTY (nameTransporter(e));
                        MOVE PROPERTY (innTransporter(e));
                        MOVE PROPERTY (transportRegNo(e));
                        MOVE PROPERTY (transportModel(e));
                        MOVE PROPERTY (trailerRegNo(e));
                        MOVE PROPERTY (trailerModel(e));
                    }
                    NEW contract {
                        align = STRETCH;
                        MOVE PROPERTY (contractNumber(e));
                        MOVE PROPERTY (contractDate(e));
                    }
                    NEW docTypeBlock {
                        align = STRETCH;
                        MOVE PROPERTY (nameDocType(e));
                    }
                    NEW types {
                        align = STRETCH;
                        caption = 'Типы документа';
                        showIf = docType(e) == EInvoiceDocType.esf;
                        MOVE PROPERTY (nameInvoiceType(e));
                        MOVE PROPERTY (nameSingleSideType(e));
                        MOVE PROPERTY (nameIncomeType(e));
                    }
                    NEW totals {
                        align = STRETCH;
                        caption = 'Итого';
                        MOVE PROPERTY (totalSum(e));
                        MOVE PROPERTY (totalCount(e));
                        MOVE PROPERTY (totalQuantity(e));
                        MOVE PROPERTY (totalGrossWeight(e));
                        MOVE PROPERTY (totalNetWeight(e));
                    }
                    NEW notes {
                        align = STRETCH;
                        MOVE PROPERTY (notes(e));
                    }
                }
                NEW tabs {
                    tabbed = TRUE;
                    fill = 1;
                    NEW detail {
                        fill = 1;
                        caption = 'Спецификация';
                        MOVE BOX(g);
                        MOVE BOX(ed);
                    }
                    NEW eLotDetail {
                        caption = 'Маркировка';
                        horizontal = TRUE;
                        fill = 1;
                        MOVE BOX(dl);
                        MOVE BOX(TREE eLotTr);
                    }
                }
            }
            NEW add {
                caption = 'Дополнительная информация';
                fill = 1;
            }
        }
    }
}

editAttributesEInvoice 'Редактировать' (EInvoice i) {
    NEWSESSION {
        SHOW eInvoice OBJECTS e = i DOCKED;
    }
} TOOLBAR IMAGE 'edit.png';

EXTEND FORM eInvoices
    PROPERTIES (e) editAttributesEInvoice
;

