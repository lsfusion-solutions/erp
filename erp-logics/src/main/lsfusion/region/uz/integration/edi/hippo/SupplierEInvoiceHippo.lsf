MODULE SupplierEInvoiceHippo;

REQUIRE EInvoiceUz, Hippo, EImzoUz;

NAMESPACE Hippo;

GROUP contract_info;
GROUP invoice_info;
GROUP executor;
GROUP marking;
GROUP customer;

FORM sendHashCode

    OBJECTS value = EInvoice

    PROPERTIES(value) invoiceTypeIndex EXTID 'type', singleSideTypeIndex EXTID 'single_sided_type', incomeTypeIndex EXTID 'income_type',
                     deliveryNoteDate EXTID 'date', deliveryNoteNumber EXTID 'number'
    
    PROPERTIES(value) IN contract_info contractDate EXTID 'date', contractNumber EXTID 'number'
    PROPERTIES IN invoice_info  dateInvoice = deliveryNoteDate(value) EXTID 'date', numberInvoice = deliveryNoteNumber(value) EXTID 'number'
    PROPERTIES(value) IN executor addressSupplier EXTID 'address', nameSupplier EXTID 'name', innSupplier EXTID 'inn'
    PROPERTIES(value) IN customer addressCustomer EXTID 'address', nameCustomer EXTID 'name', innCustomer EXTID 'inn'

    OBJECTS items = EInvoiceDetail
    FILTERS eInvoice(items) == value
    PROPERTIES(items) VATSum EXTID 'vat_sum', invoiceSum EXTID 'total_with_vat', price, catalogCode EXTID 'catalog_code', 
            barcode, valueVAT EXTID 'vat_rate', catalogName EXTID 'catalog_name', quantityDespatched EXTID 'quantity', originTypeIndex EXTID 'origin',
            productName EXTID 'name'
    PROPERTIES IN marking product_type = codeGroupLot(items)

    OBJECTS ident_trans_upak = EInvoiceLotDetail IN marking
    PROPERTIES(ident_trans_upak) id EXTID 'value'
    FILTERS eInvoiceDetail(ident_trans_upak) == items, type(ident_trans_upak) == 'GROUP'

    OBJECTS kiz = EInvoiceLotDetail IN marking
    PROPERTIES(kiz) id EXTID 'value'
    FILTERS eInvoiceDetail(kiz) == items, type(kiz) == 'UNIT'

    OBJECTS nom_upak = EInvoiceLotDetail IN marking
    PROPERTIES(nom_upak) id EXTID 'value'
    FILTERS eInvoiceDetail(nom_upak) == items, type(nom_upak) == 'NOM'
    
;

send(EInvoice ei) + {
    IF EDIProvider(supplier(ei)) == EDIProvider.hippo THEN {
        IF NOT apiUrlHippo() OR NOT clientIDHippo() OR NOT clientSecretHippo() THEN {
            logToFile('edi', deliveryNoteNumber(ei) + ' ' + deliveryNoteDate(ei) + ' Не настроены параметры API Hippo');
            MESSAGE 'Не настроены параметры API Hippo' NOWAIT;
            RETURN;
        }

        NEWSESSION {
            LOCAL hashcode = STRING();
            LOCAL pkcs7 = STRING();
            LOCAL extId = STRING();

            TRY {
                EXPORT sendHashCode OBJECTS value = ei JSON;

                // 1. Получение хеш-кода для отправки
                sendPostRequestEDI(clientIDHippo(), clientSecretHippo(), apiUrlHippo() + '/document-generator-client-api/roaming/invoice/generate/send-hash-code',  exportFile(), TRUE, NULL);
                
                IF sendRequestEDIStatus() != 200 THEN {
                    logToFile('edi', deliveryNoteNumber(ei) + ' ' + deliveryNoteDate(ei) + ' Ошибка при получении хеш-кода для отправки: ' + sendRequestEDIStatus());
                    MESSAGE 'Ошибка при получении хеш-кода для отправки: ' + sendRequestEDIStatus() NOWAIT;
                    RETURN;
                }

                IMPORT JSON FROM sendRequestEDIResponse() TO() hashcode;
                
                IF NOT hashcode() THEN {
                    logToFile('edi', deliveryNoteNumber(ei) + ' ' + deliveryNoteDate(ei) + ' Не получен хеш-код в ответе');
                    MESSAGE 'Не получен хеш-код' NOWAIT;
                    RETURN;
                }

                // 2. Подписание хеш-кода (без attach для отправки)
                signClientAction(RAWFILE(hashcode()), supplier(ei), NULL);
            
                IF NOT encodedSignature() THEN {
                    logToFile('edi', deliveryNoteNumber(ei) + ' ' + deliveryNoteDate(ei) + ' Подпись не сформирована');
                    MESSAGE 'Подпись не сформирована' NOWAIT;
                    RETURN;
                }
                
                EXPORT JSON FROM signature = encodedSignature();
                
                // 3. Получение метки времени
                sendPostRequestEDI(clientIDHippo(), clientSecretHippo(), apiUrlHippo() + '/eimzo-client-api/pkcs7/attach-timestamp', exportFile(), TRUE, NULL);
                
                IF sendRequestEDIStatus() != 200 THEN {
                    logToFile('edi', deliveryNoteNumber(ei) + ' ' + deliveryNoteDate(ei) + ' Ошибка при получении метки времени: ' + sendRequestEDIStatus());
                    MESSAGE 'Ошибка при получении метки времени: ' + sendRequestEDIStatus() NOWAIT;
                    RETURN;
                }

                IMPORT JSON FROM sendRequestEDIResponse() TO() pkcs7 = pkcs7b64;
                
                IF NOT pkcs7() THEN {
                    logToFile('edi', deliveryNoteNumber(ei) + ' ' + deliveryNoteDate(ei) + ' Не получен pkcs7 в ответе attach-timestamp');
                    MESSAGE 'Не получен pkcs7' NOWAIT;
                    RETURN;
                }

                EXPORT JSON FROM signature = pkcs7(), lang = 'ru';
                
                // 4. Финальная отправка документа
                sendPostRequestEDI(clientIDHippo(), clientSecretHippo(), apiUrlHippo() + '/roaming-client-api/invoice/send', exportFile(), TRUE, NULL);
                
                IF sendRequestEDIStatus() != 200 THEN {
                    logToFile('edi', deliveryNoteNumber(ei) + ' ' + deliveryNoteDate(ei) + ' Ошибка при финальной отправке: ' + sendRequestEDIStatus());
                    MESSAGE 'Ошибка при финальной отправке: ' + sendRequestEDIStatus() NOWAIT;
                    RETURN;
                }

                IMPORT JSON FROM sendRequestEDIResponse() TO() extId;
                externalId(ei) <- extId();
                exportedSupplier(ei) <- TRUE;
                APPLY;
                logToFile('edi', deliveryNoteNumber(ei) + ' ' + deliveryNoteDate(ei) + ' Документ успешно отправлен. Внешний ID: ' + extId());
                MESSAGE 'Документ успешно отправлен' NOWAIT;
            } CATCH {
                logToFile('edi', deliveryNoteNumber(ei) + ' ' + deliveryNoteDate(ei) + ' Критическая ошибка при отправке Hippo: ' + messageCaughtException());
                logToFile('edi', deliveryNoteNumber(ei) + ' ' + deliveryNoteDate(ei) + ' ' + lsfStackTraceCaughtException());
                logToFile('edi', CONCAT ' ', deliveryNoteNumber(ei) + ' ' + deliveryNoteDate(ei) + ' Request:', STRING(sendRequestEDIRequest()));
                logToFile('edi', CONCAT ' ', deliveryNoteNumber(ei) + ' ' + deliveryNoteDate(ei) + ' Response:', STRING(sendRequestEDIResponse()));
                MESSAGE 'Критическая ошибка при отправке Hippo: ' + messageCaughtException() NOWAIT;
            }
        }
    }
}