MODULE StockDocumentGestori;

REQUIRE StockDocument, AccountDocument, Range, PurchaseInvoiceRu, SaleInvoiceRu, PurchaseReturnInvoiceVATRu,
        EmployeeGestori, ZReport, Disparity, SaleReportsRu;

NAMESPACE StockDocument;

DESIGN options {
    commons {
        documents {
            MOVE PROPERTY(documentsClosedDate()) {showIf = NULL;};
            MOVE PROPERTY(dialogCloseDocumentsDate()){showIf = NULL;};
        }
    }
}

documentsClosedDate 'Дата закрытия документов' = DATA DATE(LegalEntity);
isSelect 'Вкл.'= DATA LOCAL BOOLEAN (LegalEntity);

DESIGN closingDocuments{
    REMOVE BOX (TREE stockTree);
    REMOVE BOX (s);
    REMOVE TOOLBARBOX;
    REMOVE OBJECTS;
    REMOVE PANEL;
}

calculateClosedAndCreateDocument 'Закрытие отчетного периода' (LegalEntity l) {
    IF NOT [GROUP SUM 1 IF isSelect(LegalEntity le)]() THEN isSelect(l) <- TRUE;
    FOR isSelect(LegalEntity le) DO {
        ASK 'Закрытие отчетного периода ' + name(extractMonth(documentsClosedDate(le))) +' ' + extractYear(documentsClosedDate(le)) DO {
            IF (GROUP SUM 1 IF date(StockDocumentLedger sl) <= lastDayOfMonth(documentsClosedDate(le)) AND date(sl) >= documentsClosedDate(le) AND legalEntity(stock(sl)) = le AND NOT isPosted(sl)) THEN {
                MESSAGE 'Есть не проведенные документа в закрываемом месяце';
                RETURN;
            }
            calculateClosedAndCreateDocument(firstDayOfMonth(documentsClosedDate(le)), le);
            documentsClosedDate(le) <- sum(lastDayOfMonth(documentsClosedDate(le)), 1);
            isSelect(Stock s) <- TRUE IF legalEntity(s) = le;
            closeDocumentsStocks();
            APPLY;
            MESSAGE 'Период закрыт ' + name(extractMonth(sum(documentsClosedDate(le), -1))) +' ' + extractYear(sum(documentsClosedDate(le), -1)) + ' отчетный период ' + name(extractMonth(documentsClosedDate(le))) +' ' + extractYear(documentsClosedDate(le));
        }
    }
}

calculateAndCreateDocument 'Пересчитать учетные цены' (LegalEntity l) {
    IF NOT [GROUP SUM 1 IF isSelect(LegalEntity le)]() THEN isSelect(l) <- TRUE;
    FOR isSelect(LegalEntity le) DO {
        ASK 'Пересчитать учетные цены' DO {
            DIALOG dialogDate OBJECTS d = (MIN currentDate(), lastDayOfMonth(documentsClosedDate(le))) INPUT dd DO {
                IF dd < documentsClosedDate(le) THEN {
                    MESSAGE 'Дата не может быть меньше даты отчетного периода';
                    RETURN;
                }
                IF dd > lastDayOfMonth(documentsClosedDate(le)) THEN {
                    MESSAGE 'Дата не может быть больше чем на месяц даты отчетного периода';
                    RETURN;
                }
                calculateAndCreateDocument(firstDayOfMonth(dd), le);
            }
            APPLY;
            MESSAGE 'Пересчитан месяц ' + name(extractMonth(documentsClosedDate(le))) + ' ' + extractYear(documentsClosedDate(le));
        }
    }
}

FORM  noPostedDocument
    OBJECTS date = (df = DATE, dt = DATE) PANEL
    OBJECTS le = LegalEntity PANEL
    //    PROPERTIES df 'Дата с' = VALUE(df), dt 'Дата по' = VALUE (dt)

    OBJECTS sl = StockDocumentLedger
    PROPERTIES (sl) READONLY isPosted, number, date, series, nameStock, nameOperation, nameLegalEntity
    FILTERS iterate(date(sl), df, dt) AND legalEntity(stock(sl)) = le AND NOT isPosted(sl)
;

noPostedDocument 'Не проведенные документы' (LegalEntity le) {
    SHOW noPostedDocument OBJECTS df = documentsClosedDate(le), dt = lastDayOfMonth(documentsClosedDate(le)), le = le;
}

openDocumentsStocks 'Открыть отчетный период ' (LegalEntity le) {
    ASK 'Открытие отчетного периода ' + name(extractMonth(sum(documentsClosedDate(le), -1))) +' ' + extractYear(sum(documentsClosedDate(le), -1)) DO {
        isSelect(Stock s) <- TRUE IF legalEntity(s) = le;
        documentsClosedDate(le) <- firstDayOfMonth(sum(documentsClosedDate(le), -1));
        documentsClosedDate(Stock s) <- documentsClosedDate(legalEntity(s)) WHERE legalEntity(s) = le;
        FOR AccountDocument a AND isSelect(stock(a)) AND date(a) >= documentsClosedDate(le) AND isClosed(a) DO {
            isClosed(a) <- NULL;
        }
        apply();
    }
};

FORM closingDocumentsGestori 'Закрытие периода по организациям'
    OBJECTS l = LegalEntity
    PROPERTIES(l) READONLY isSelect CHANGEABLE, id, name, documentsClosedDate
    PROPERTIES(l) TOOLBAR openDocumentsStocks, noPostedDocument, calculateClosedAndCreateDocument, calculateAndCreateDocument
    ORDERS name(l)
    FILTERS isCompany(l)
    FILTERGROUP active FILTER 'Активные' active(l) DEFAULT
;

NAVIGATOR {
    application {
        NEW closingDocumentsGestori;
    }
}

DESIGN accountDocuments{
    REMOVE BOX(df);
    REMOVE PROPERTY (number(m));
    REMOVE PROPERTY (series(m));
    REMOVE PROPERTY (note(m));
    REMOVE TOOLBAR(m) ;
}

overCloseDocumentsStocks() + {
    FOR AccountDocument a AND isSelect(stock(a))
        AND date(a) < documentsClosedDate(stock(a)) AND isOpened(a) DO {
        isClosed(a) <- TRUE;
    }
}

denyNotInRange 'Запрет использование товаров не из ассортимента' = DATA BOOLEAN ();

EXTEND FORM options PROPERTIES denyNotInRange();

DESIGN options {
    invoices {
        topInvoicesContainer{
            horizontal = FALSE;
            MOVE PROPERTY(denyNotInRange());
        }
    }
}

useRangeGestori 'Использовать ограничения ассортиментной матрицы' = DATA  BOOLEAN (Store);

EXTEND FORM store PROPERTIES (s) useRangeGestori;

DESIGN store {
    row2 {
        MOVE PROPERTY(useRangeGestori(s));
    }
}
useRangeGestori 'Использовать ограничения ассортиментной матрицы' (DepartmentStore s) = useRangeGestori(store(s));

CONSTRAINT (SETCHANGED(sku(SkuLedger d)) OR SETCHANGED(stock(d)) OR SETCHANGED(date(d)) OR SETCHANGED(isPosted(d))) AND isPosted(d)
    AND useRangeGestori(stock(d)) AND NOT (d IS SaleZReportSkuLedger OR d IS ReturnZReportSkuLedger)
    AND NOT disableRangeControl(currentUser()) AND denyNotInRange() AND sku(d) IS Item AND NOT countRange(sku(d), stock(d), date(d))
    AND NOT disparityItem(sku(d))
    MESSAGE 'Запрещено использовать товары не включенные в ассортимент';

CONSTRAINT (SET(isPosted(Purchase.OrderDetail d)) OR SETCHANGED(sku(d)) OR SETCHANGED(customerStock(d))) AND isPosted(d) AND useRangeGestori(customerStock(d))
    AND NOT disableRangeControl(currentUser()) AND denyNotInRange() AND sku(d) IS Item AND NOT countRange(sku(d), stock(d), date(d))
    AND NOT disparityItem(sku(d))
    MESSAGE 'В заказ включены товары не включенные в ассортимент';

skipOpen(Purchase.UserInvoice i) += WHEN postedTime(i) AND date(i) < documentsClosedDate(customer(i)) THEN TRUE;
skipOpen(PurchaseReturn.UserInvoice i) += WHEN postedTime(i) AND date(i) < documentsClosedDate(customer(i)) THEN TRUE;
skipOpen(Sale.UserInvoice i) += WHEN postedTime(i) AND date(i) < documentsClosedDate(supplier(i)) THEN TRUE;


skipEditBeforeClosingDate = DATA BOOLEAN();

CONSTRAINT (CHANGED(date(StockDocumentLedger d)) AND active(d) OR CHANGED(active(d)))
    AND documentsClosedDate(stock(d)) AND PREV(date(d)) < documentsClosedDate(stock(d))
    AND NOT skipEditBeforeClosingDate()
    MESSAGE 'Запрещено редактировать документы до даты закрытия';

CONSTRAINT (SETCHANGED(sku(SkuLedger d)) OR SETCHANGED(stock(d)) OR SETCHANGED(date(d)) OR SETCHANGED(quantity(d)) OR SETCHANGED(sum(d))  OR CHANGED(active(d)))
    AND documentsClosedDate(stock(d)) AND PREV(date(d)) < documentsClosedDate(stock(d))
    AND skipEditBeforeClosingDate()
    MESSAGE 'Запрещено редактировать документы до даты закрытия';
typeExchangeGestori 'Тип обмена' = DATA LOCAL TypeExchange();
nameTypeExchangeGestori 'Тип обмена' = name(typeExchangeGestori());

rateNat (DATE d) =
    IF defaultCurrency() = currency(typeExchangeGestori())
    THEN 1.0
    ELSE rateOn(typeExchangeGestori(), defaultCurrency(), d);

isInc 'Приход' (StockDocumentLedger l) = l IS IncStockDocumentLedger;

idStock 'Код подразделения' (StockDocumentLedger l) = id(stock(l));

sumBaseAcc 'Сумма в баз.в. (уч.ц.)' (StockDocumentLedger l) = sum(l);
sumNatAcc 'Сумма в нац.в. (уч.ц.)' (StockDocumentLedger l) =
    NUMERIC[18,4](round2(sum(l) * rateNat(date(l))));

sumBaseRel 'Сумма в баз.в. (отп.ц.)' =
    GROUP SUM round2(signedQuantity(SkuLedger sl) *
        prevPriceB(retailPriceListType(stock(sl)), sku(sl), stock(sl), dateTime(sl)))
    BY stockDocumentLedger(sl);
sumNatRel 'Сумма в нац.в. (отп.ц.)' (StockDocumentLedger l) =
    NUMERIC[18,4](round2(sumBaseRel(l) * rateNat(date(l))));

signedCostSum(SkuLedger sl) =
    IF signedQuantity(sl) >= 0 THEN costSum(sl) ELSE -costSum(sl);

sumBaseCost 'Сумма в баз.в. (себест.)' =
    GROUP SUM round2(signedCostSum(SkuLedger sl) /
        (1.0 + (OVERRIDE valueVAT(sku(sl), country(stock(sl)), date(sl)), 0.0) / 100.0))
    BY stockDocumentLedger(sl);
sumNatCost 'Сумма в нац.в. (себест.)' (StockDocumentLedger l) =
    NUMERIC[18,4](round2(sumBaseCost(l) * rateNat(date(l))));

changeStocksSDL() { DIALOG dialogStocksSaleReportRu; }

titleReport (DATE df, DATE dt) =
    'Товарный отчет за период с ' + toDateDDMMYYYY(df) + ' по ' + toDateDDMMYYYY(dt);

subtitleReport () =
    CONCAT ' | ', 'Тип обмена: ' + nameTypeExchangeGestori();

balBaseAccB 'Входящий остаток в баз.в.' (DATE dtFrom) =
    GROUP SUM sumAccountBDocumentLedger(Stock s, dtFrom) IF inSaleReport(s);
balNatAccB 'Входящий остаток в нац.в.' (DATE dtFrom) =
    NUMERIC[18,4](round2(balBaseAccB(dtFrom) * rateNat(dtFrom)));

balBaseAccA 'Исходящий остаток в баз.в.' (DATE dtTo) =
    GROUP SUM sumAccountADocumentLedger(Stock s, dtTo) IF inSaleReport(s);
balNatAccA 'Исходящий остаток в нац.в.' (DATE dtTo) =
    NUMERIC[18,4](round2(balBaseAccA(dtTo) * rateNat(dtTo)));

balBaseAccBStock (StockDocumentLedger l, DATE d) = sumAccountBDocumentLedger(stock(l), d);
balNatAccBStock (StockDocumentLedger l, DATE d) = NUMERIC[18,4](round2(balBaseAccBStock(l, d) * rateNat(d)));
balBaseAccAStock (StockDocumentLedger l, DATE d) = sumAccountADocumentLedger(stock(l), d);
balNatAccAStock (StockDocumentLedger l, DATE d) = NUMERIC[18,4](round2(balBaseAccAStock(l, d) * rateNat(d)));

FORM printStockDocGestori 'Отчет'
    OBJECTS dtFrom = DATE PANEL, dtTo = DATE PANEL, ds = Stock PANEL

    PROPERTIES titleReport = titleReport(dtFrom, dtTo)
    PROPERTIES subtitleReport = subtitleReport()
    PROPERTIES balBaseAccB = balBaseAccB(dtFrom), balNatAccB = balNatAccB(dtFrom),
        balBaseAccA = balBaseAccA(dtTo), balNatAccA = balNatAccA(dtTo)

    OBJECTS dl = StockDocumentLedger
    PROPERTIES(dl) READONLY isInc, idStock, date, nameStock, objectClassName, description,
        nameOperation, nameLegalEntity, nameLegalEntityStock,
        seriesNumber, sumBaseAcc, sumNatAcc, sumBaseRel, sumNatRel, sumBaseCost, sumNatCost
    PROPERTIES(dl, dtFrom) READONLY balBaseAccBStock, balNatAccBStock
    PROPERTIES(dl, dtTo) READONLY balBaseAccAStock, balNatAccAStock
    FILTERS active(dl),
        inSaleReport(stock(dl)),
        date(dl) >= dtFrom,
        date(dl) <= dtTo
    ORDERS nameStock(dl), nameOperation(dl), isInc(dl), date(dl)
;

printStockDocReport 'Отчет' (DATE dtFrom, DATE dtTo, Stock ds) {
    PRINT printStockDocGestori OBJECTS dtFrom = dtFrom, dtTo = dtTo, ds = ds XLSX;
} IMAGE 'print.png';

EXTEND FORM sumStockDocumentLedger
    PROPERTIES nameStockListSDL 'Список подразделений' = nameStockList() READONLY SHOWIF stockList()
    PROPERTIES inSaleReportStocksSDL 'Подразделения' = inSaleReportStocks()
    ON CHANGE changeStocksSDL() READONLYIF stockList()
    PROPERTIES() nameTypeExchangeGestori

    OBJECTS dl = StockDocumentLedger
    PROPERTIES(dl) READONLY isClosed, isPosted, isInc, idStock, date, nameStock,
        objectClassName, description,
        nameOperation, nameLegalEntity, nameLegalEntityStock,
        seriesNumber, sumBaseAcc, sumNatAcc, sumBaseRel, sumNatRel, sumBaseCost, sumNatCost
    PROPERTIES(dl) EDIT SHOWIF allowedEdit(dl) NEWSESSION, close SHOWIF isOpened(dl)
    FILTERS active(dl),
        inSaleReport(stock(dl)),
        date(dl) >= dtFrom,
        date(dl) <= dtTo
    ORDERS date(dl)

    FILTERGROUP directionFilter
        FILTER 'Приход' isInc(dl) 'F7'
        FILTER 'Расход' NOT isInc(dl) 'F8'

    PROPERTIES printStockDocReport(dtFrom, dtTo, ds)
;

DESIGN sumStockDocumentLedger {
    header {
        MOVE print AFTER dates;
    }

    print {
        MOVE PROPERTY(printStockDocReport(dtFrom, dtTo, ds)) { valueClass = 'btn-primary'; }
    }

    topContainer {
        tabbed = TRUE;

        NEW baseTab {
            caption = 'Основной';
            NEW baseHeader {
                horizontal = TRUE;
                alignment = STRETCH;
                MOVE department;
                MOVE legalEntity;
                MOVE actionContainer;
            }
            NEW baseSums {
                caption = 'Суммы';
                MOVE GROUP(ledgerItem, ds);
                MOVE GROUP(ledgerContainer, ds);
                MOVE GROUP(ledger, ds);
            }
            MOVE BOX(il) { fill = 1; }
            MOVE BOX(ol) { fill = 1; }
        }

        NEW gestoriTab {
            caption = 'Отчет';
            NEW gestoriHeader {
                alignment = STRETCH;
                MOVE PROPERTY(nameStockListSDL) { alignment = STRETCH; }
                MOVE PROPERTY(inSaleReportStocksSDL) { alignment = STRETCH; }
                MOVE PROPERTY(nameTypeExchangeGestori()) { alignment = STRETCH; }
            }
            MOVE BOX(dl) { fill = 1; }
        }
    }

    REMOVE sums;
}