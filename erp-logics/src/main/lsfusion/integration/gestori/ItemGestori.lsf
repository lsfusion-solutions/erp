MODULE ItemGestori;

REQUIRE Item;

NAMESPACE Item;

@definePrimitiveItemAttribute(amountPackLayer, INTEGER, 'Количество мест в слое', itemBase);

@definePrimitiveItemAttribute(amountPackPallet, INTEGER, 'Количество мест в паллете', itemBase);

@definePrimitiveItemAttribute(top500Rank, INTEGER, 'Порядковый номер в ТОП 500', itemBase);

amountPackLayerShown 'Количество мест в слое' (Sku s) = amountPackLayer(s) IF showAmountPackLayer(s);
amountPackPalletShown 'Количество мест в паллете' (Sku s) = amountPackPallet(s) IF showAmountPackPallet(s);
top500RankShown 'Порядковый номер в ТОП 500' (Sku s) = top500Rank(s) IF showTop500Rank(s);