MODULE VetisProductItemGestori;

REQUIRE VetisProductItem, VetisProductItemImport, VetisProductItemExport, VetisStockEntry, VetisItem,
        VetisIncomingConsignment, VetisStock, VetisEnterpriseGestori, VetisUnitImport;

NAMESPACE Vetis;

// --- Блок 1: UI ---

ownProductGestori 'Собственная продукция' (ProductItem o) = own(producer(o));
nameProductTypeGestori 'Тип продукции' (ProductItem o) = name(productType(product(subProduct(o))));
nameProductGestori 'Продукция' (ProductItem o) = name(product(subProduct(o)));

// служебный признак ошибки обмена с Ветис (не редактируется через интерфейс)
exchangeErrorGestori 'Ошибка обмена' = DATA BOOLEAN (ProductItem);

EXTEND FORM productItems
    PROPERTIES(o) READONLY nameProductTypeGestori BEFORE nameSubProduct(o)
    PROPERTIES(o) READONLY nameProductGestori BEFORE nameSubProduct(o)
    PROPERTIES(o) READONLY ownProductGestori AFTER nameProducer(o)
    PROPERTIES(o) READONLY exchangeErrorGestori AFTER isExported(o)

    FILTERGROUP own
        FILTER 'Собственная' ownProductGestori(o) DEFAULT
    FILTERGROUP exchangeErrorGroupGestori
        FILTER 'Ошибки обмена' exchangeErrorGestori(o)
;

// 7.1: выбор номенклатуры Ветис для связи с товаром — без фильтра «Собственная»
FORM dialogSelectProductItemGestori 'Номенклатура Ветис'
    OBJECTS o = ProductItem
    PROPERTIES(o) READONLY guid, name, nameProducer, ownProductGestori
    LIST ProductItem OBJECT o
;

addProductItemGestori 'Добавить' (Item i) {
    DIALOG dialogSelectProductItemGestori OBJECTS o INPUT DO
        in(i, o) <- TRUE;
}

EXTEND FORM item
    PROPERTIES addProductItemGestori(i) DRAW pi TOOLBAR
;

DESIGN item {
    PROPERTY(addProductItem(i)) { hide = TRUE; }
}

hideNewProductItem() += TRUE;

// --- Дополнительные поля номенклатуры (таблица полей карточки) ---

correspondsToGost 'Соответствует ГОСТу' = DATA BOOLEAN (ProductItem);
gost 'ГОСТ' = DATA STRING[50] (ProductItem);

packagingType 'Тип упаковки' = DATA STRING[50] (ProductItem);
packagingQuantity 'Кол-во единиц упаковки' = DATA INTEGER (ProductItem);
packagingVolume 'Объем единицы упаковки' = DATA NUMERIC[16,6] (ProductItem);
packagingUnit 'Ед.изм. объема единицы упаковки' = DATA STRING[30] (ProductItem);

statusVetisGestori 'Статус Ветис' = DATA STRING[5] (ProductItem) CHARWIDTH 5;

// выбор единицы измерения объёма упаковки из справочника Единиц измерения Ветис
FORM dialogPackagingUnitGestori 'Единица измерения'
    OBJECTS u = Unit
    PROPERTIES(u) READONLY guid, name, nameCommonUnit
    LIST Unit OBJECT u
;
changePackagingUnitGestori (ProductItem p) {
    DIALOG dialogPackagingUnitGestori OBJECTS u INPUT DO
        packagingUnit(p) <- name(u);
}

// выбор типа упаковки из справочника (реализация в VetisDocumentGestori — там определён справочник типов упаковки)
changePackagingTypeGestori ABSTRACT (ProductItem);

EXTEND FORM productItem
    PROPERTIES(o) READONLY nameProductTypeGestori, nameProductGestori
    PROPERTIES(o) READONLYIF readonlyProductItem(o) correspondsToGost, gost
    PROPERTIES(o) READONLYIF readonlyProductItem(o) OR uuid(o)
        packagingType ON CHANGE changePackagingTypeGestori(o), packagingQuantity, packagingVolume,
        packagingUnit ON CHANGE changePackagingUnitGestori(o)
    PROPERTIES(o) READONLY statusVetisGestori
;

// поля карточки в одну колонку в порядке тегов <vd:productItem>
DESIGN productItem {
    NEW mainColumnGestori FIRST {
        fill = 1;
        lines = 1;
        MOVE PROPERTY(guid(o)) { caption = 'GUID номенклатуры'; charWidth = 50; }
        MOVE PROPERTY(uuid(o)) { caption = 'UUID номенклатуры'; charWidth = 50; }
        MOVE PROPERTY(name(o)) { charWidth = 100; }
        MOVE PROPERTY(globalID(o)) { charWidth = 50; }
        MOVE PROPERTY(code(o)) { charWidth = 50; }
        MOVE PROPERTY(correspondsToGost(o));
        MOVE PROPERTY(gost(o)) { charWidth = 50; }
        MOVE PROPERTY(nameProductTypeGestori(o)) { charWidth = 100; }
        MOVE PROPERTY(nameProductGestori(o)) { charWidth = 100; }
        MOVE PROPERTY(nameSubProduct(o)) { charWidth = 100; }
        MOVE PROPERTY(nameProducer(o)) { charWidth = 100; }
        MOVE PROPERTY(nameOwner(o)) { charWidth = 100; }
        MOVE PROPERTY(nameEnterprises(o)) { charWidth = 100; }
        MOVE PROPERTY(packagingType(o)) { charWidth = 50; }
        MOVE PROPERTY(packagingQuantity(o)) { charWidth = 15; }
        MOVE PROPERTY(packagingVolume(o)) { charWidth = 15; }
        MOVE PROPERTY(packagingUnit(o)) { charWidth = 30; }
        MOVE PROPERTY(statusVetisGestori(o));
        MOVE PROPERTY(inactive(o));
        MOVE PROPERTY(isExported(o));
    }
}

// Заполнение доп. полей в запросах CREATE/UPDATE
fillProducerStockList(ProductItemRequest r, ProductItem p) + {
    correspondsToGostE(r) <- 'true' IF correspondsToGost(p);
    gostE(r) <- gost(p);
    packagingTypeE(r) <- packagingType(p);
    packagingQuantityE(r) <- packagingQuantity(p);
    packagingVolumeE(r) <- packagingVolume(p);
    packagingUnitE(r) <- packagingUnit(p);
}

// Обновление доп. полей из положительного ответа
afterProcessProducerStockList(ProductItemRequest r) + {
    correspondsToGost(productItem(r)) <- TRUE IF correspondsToGostR() = 'true';
    gost(productItem(r)) <- STRING[50](gostR());
    statusVetisGestori(productItem(r)) <- STRING[5](statusR());
}

DESIGN productItems {
    PROPERTY(guid(o)) { caption = 'GUID номенклатуры'; }
    PROPERTY(uuid(o)) { caption = 'UUID номенклатуры'; }
}

// --- Блок 2: Ограничения и автоматизация ---

hasVetDocument 'Есть ВСД' (ProductItem p) = GROUP SUM 1 IF productItem(VetDocument d) = p;
hasStockEntry 'Есть записи журнала' (ProductItem p) = GROUP SUM 1 IF in(StockEntry s, p);

CONSTRAINT DROPPED(ProductItem p IS ProductItem) AND PREV(hasVetDocument(p))
    MESSAGE 'Нельзя удалять номенклатуру: связана с ВСД';

CONSTRAINT DROPPED(ProductItem p IS ProductItem) AND PREV(hasStockEntry(p))
    MESSAGE 'Нельзя удалять номенклатуру: связана с записями складского журнала';

hasItem 'Есть товары' (ProductItem p) = GROUP SUM 1 IF in(Item i, p);

CONSTRAINT DROPPED(ProductItem p IS ProductItem) AND PREV(hasItem(p))
    MESSAGE 'Нельзя удалять номенклатуру: связана со справочником товаров';

// связь со спецификациями документов системы — через входящие партии (ВСД номенклатуры сопоставлен строке документа поставки)
hasDocumentSpec 'Есть связь с документами' (ProductItem p) = GROUP SUM 1 IF productItem(vetDocument(IncomingConsignment c)) = p;

CONSTRAINT DROPPED(ProductItem p IS ProductItem) AND PREV(hasDocumentSpec(p))
    MESSAGE 'Нельзя удалять номенклатуру: связана со спецификациями документов системы';

CONSTRAINT DROPPED(ProductItem p IS ProductItem) AND PREV(uuid(p)) AND PREV(ownProductGestori(p))
    MESSAGE 'Для удаления собственной номенклатуры используйте кнопку "Удалить"';

// после отправки запроса на удаление — запрет связывания со справочником товаров
pendingDeleteProductItem (ProductItem p) = GROUP SUM 1 IF productItem(ProductItemRequest r) = p AND operationType(r) = 'DELETE' AND NOT processed(r);

CONSTRAINT SETCHANGED(in(Item i, ProductItem p)) AND in(i, p) AND pendingDeleteProductItem(p)
    MESSAGE 'Нельзя связывать с товаром: по номенклатуре отправлен запрос на удаление в Ветис';

// запрос удаления: vd:affectedList и только bs:uuid (resultingList/bs:guid схема для DELETE не допускает)
GROUP affectedListGestori EXTID 'vd=http://api.vetrf.ru/schema/cdm/mercury/vet-document/v2:affectedList' : modificationOperation;
GROUP productItemAffectedGestori EXTID 'dt=http://api.vetrf.ru/schema/cdm/dictionary/v2:productItem' : affectedListGestori;

FORM modifyProducerStockListDeleteGestori FORMEXTID 'merc=http://api.vetrf.ru/schema/cdm/mercury/g2b/applications/v2:modifyProducerStockListRequest'
    OBJECTS r = ProductItemRequest PANEL
    PROPERTIES(r) localTransactionId EXTID 'merc:localTransactionId'
    PROPERTIES(r) IN initiator loginMercury EXTID 'vd=http://api.vetrf.ru/schema/cdm/mercury/vet-document/v2:login'
    PROPERTIES(r) IN modificationOperation type EXTID 'vd=http://api.vetrf.ru/schema/cdm/mercury/vet-document/v2:type'
    PROPERTIES(r) IN productItemAffectedGestori uuid EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:uuid'
;

deleteModifyProducerStockList 'Удалить номенклатуру' (ProductItem p) {
    NEWSESSION {
        NEW r = ProductItemRequest {
            businessEntity(r) <- producer(p);
            productItem(r) <- p;
            operationType(r) <- 'DELETE';
            isExported(p) <- TRUE;
            type(r) <- 'DELETE';
            uuid(r) <- uuid(p);
            EXPORT modifyProducerStockListDeleteGestori OBJECTS r=r XML;
            submit(r, exportFile());
        }
        APPLY;
    }
}

// при положительном ответе на удаление номенклатуру не удаляем физически, а помечаем неактивной и обновляем из ответа
deactivateOnDeleteProducerStockList() += TRUE;

// --- Блок 3: Форма редактирования ---

// Диалог выбора вида продукции с деревом классификатора Ветис
FORM selectSubProduct 'Выбор вида продукции'
    TREE tree pt = ProductType, p = Product
    PROPERTIES READONLY name(pt), name(p)
    FILTERS productType(p) = pt

    OBJECTS o = SubProduct
    PROPERTIES(o) READONLY name, nameProduct
    FILTERS (product(o) = p OR NOT p) AND NOT inactive(o)

    LIST SubProduct OBJECT o
;

changeSubProduct(ProductItem pi) + {
    DIALOG selectSubProduct OBJECTS o = subProduct(pi) INPUT DO
        subProduct(pi) <- o;
}

// Обязательные поля для собственной продукции
// producer: требуем при создании (ownProductGestori зависит от producer, поэтому нельзя проверять через ownProductGestori)
CONSTRAINT SET(ProductItem p IS ProductItem) AND NOT producer(p) AND NOT skipOwnConstraint()
    MESSAGE 'Укажите Производителя';

CONSTRAINT ownProductGestori(ProductItem p) AND NOT owner(p) AND NOT skipOwnConstraint()
    CHECKED BY owner[ProductItem] MESSAGE 'Для собственной продукции обязательно укажите Владельца';

CONSTRAINT ownProductGestori(ProductItem p) AND NOT (GROUP SUM 1 IF in(p, Enterprise e)) AND NOT skipOwnConstraint()
    MESSAGE 'Для собственной продукции обязательно укажите хотя бы одну Площадку';

// --- Контроли значений полей карточки (таблица п.4, колонка Примечание) ---

// Наименование — непустое значение
CONSTRAINT ownProductGestori(ProductItem p) AND NOT name(p) AND NOT skipOwnConstraint()
    MESSAGE 'Укажите наименование номенклатуры';

// Артикул — уникальный в пределах ХС-производителя
countProducerCodeGestori (BusinessEntity be, ISTRING[100] c) = GROUP SUM 1 IF producer(ProductItem p) = be AND code(p) = c;
CONSTRAINT ownProductGestori(ProductItem p) AND code(p) AND producer(p)
    AND countProducerCodeGestori(producer(p), code(p)) > 1 AND NOT skipOwnConstraint()
    MESSAGE 'Артикул должен быть уникальным в пределах ХС-производителя';

// ГОСТ — непустое значение, если отмечено "Соответствует ГОСТу"
CONSTRAINT ownProductGestori(ProductItem p) AND correspondsToGost(p) AND NOT gost(p) AND NOT skipOwnConstraint()
    MESSAGE 'Укажите ГОСТ: отмечено "Соответствует ГОСТу"';

// Кол-во единиц упаковки — больше нуля
CONSTRAINT ownProductGestori(ProductItem p) AND packagingQuantity(p) AND NOT (packagingQuantity(p) > 0) AND NOT skipOwnConstraint()
    MESSAGE 'Количество единиц упаковки должно быть больше нуля';

// Объём единицы упаковки — больше нуля
CONSTRAINT ownProductGestori(ProductItem p) AND packagingVolume(p) AND NOT (packagingVolume(p) > 0) AND NOT skipOwnConstraint()
    MESSAGE 'Объём единицы упаковки должен быть больше нуля';

// submit делает внешний HTTP-вызов, недопустимый в транзакции события — событие только помечает запись,
// а сам запрос отправляется после сохранения карточки (вне apply) через sendPendingProductItemRequestsGestori
needCreateRequestGestori = DATA BOOLEAN (ProductItem);
needUpdateRequestGestori = DATA BOOLEAN (ProductItem);

WHEN SET(ProductItem p IS ProductItem) AND ownProductGestori(p) AND NOT skipOwnConstraint() DO
    needCreateRequestGestori(p) <- TRUE;

WHEN (CHANGED(name(ProductItem p)) OR CHANGED(globalID(p)) OR CHANGED(code(p)) OR
      CHANGED(subProduct(p)) OR CHANGED(producer(p)) OR CHANGED(owner(p)) OR
      CHANGED(inactive(p)) OR CHANGED(correspondsToGost(p)) OR CHANGED(gost(p)) OR CHANGED(nameEnterprises(p))) AND ownProductGestori(p) AND uuid(p) AND NOT isExported(p)
      AND NOT needCreateRequestGestori(p) AND NOT skipOwnConstraint() DO
    needUpdateRequestGestori(p) <- TRUE;

// ошибка обмена: при ошибке отправки/получения ответа — пометить запись и сбросить «Экспортируемый»;
// при успешной отправке запроса — снять пометку
WHEN SET(error(ProductItemRequest r)) AND productItem(r) IS ProductItem DO {
    exchangeErrorGestori(productItem(r)) <- TRUE;
    isExported(productItem(r)) <- NULL;
}
WHEN SET(ProductItemRequest r IS ProductItemRequest) AND NOT error(r) AND productItem(r) IS ProductItem DO
    exchangeErrorGestori(productItem(r)) <- NULL;

// отправка накопленных запросов создания/изменения — вызывается после сохранения карточки, вне транзакции apply
sendPendingProductItemRequestsGestori () {
    FOR needCreateRequestGestori(ProductItem p) DO {
        createModifyProducerStockList(p);
        NEWSESSION { needCreateRequestGestori(p) <- NULL; APPLY; }
    }
    FOR needUpdateRequestGestori(ProductItem p) DO {
        updateModifyProducerStockList(p);
        NEWSESSION { needUpdateRequestGestori(p) <- NULL; APPLY; }
    }
}

// кнопка создания с предустановленным видом продукции по выбранному узлу дерева
createProductItemGestori 'Добавить' (SubProduct sp) {
    NEWSESSION {
        NEW p = ProductItem {
            subProduct(p) <- sp;
            SHOW productItem OBJECTS o = p DOCKED WAIT MANAGESESSION;
        }
    }
    // карточка сохранена (её apply завершён) — отправляем запрос в Ветис вне транзакции
    sendPendingProductItemRequestsGestori();
}

// редактирование собственной номенклатуры с отправкой запроса изменения после сохранения
editProductItemGestori 'Изменить' (ProductItem p) {
    NEWSESSION {
        SHOW productItem OBJECTS o = p DOCKED WAIT MANAGESESSION;
    }
    sendPendingProductItemRequestsGestori();
}

EXTEND FORM productItems
    PROPERTIES DRAW o TOOLBAR createProductItemGestori(sp)
    PROPERTIES(o) TOOLBAR editProductItemGestori SHOWIF ownProductGestori(o) AND NOT isExported(o) DRAW o
;

// --- Блок 4: Действия в справочнике ---

// ХС — только собственные; если площадка выбрана — только её ХС-владелец
FORM dialogGetProductItemBE 'Хозяйствующий субъект'
    OBJECTS o = BusinessEntity
    PROPERTIES(o) READONLY guid, name
    FILTERS own(o) AND (NOT enterprise() OR owner(enterprise()) = o)
    LIST BusinessEntity OBJECT o
;

// площадки — только с собственным владельцем; если ХС выбран — только его площадки
FORM dialogGetProductItemEnterprise 'Площадка'
    OBJECTS o = Enterprise
    PROPERTIES(o) READONLY guid, name, nameOwner
    FILTERS own(owner(o)) AND (NOT businessEntity() OR owner(o) = businessEntity())
    LIST Enterprise OBJECT o
;

changeGetProductItemListBE() + {
    DIALOG dialogGetProductItemBE OBJECTS o = businessEntity() INPUT DO {
        businessEntity() <- o;
        IF enterprise() AND owner(enterprise()) != businessEntity() THEN
            enterprise() <- NULL;
    }
}

changeGetProductItemListEnterprise() + {
    DIALOG dialogGetProductItemEnterprise OBJECTS o = enterprise() INPUT DO {
        enterprise() <- o;
        IF NOT businessEntity() AND enterprise() THEN
            businessEntity() <- owner(enterprise());
    }
}

// ХС-владелец в параметрах запроса — выбор из собственных ХС
FORM dialogGetProductItemOwnerGestori 'ХС-владелец'
    OBJECTS o = BusinessEntity
    PROPERTIES(o) READONLY guid, name
    FILTERS own(o)
    LIST BusinessEntity OBJECT o
;
changeGetProductItemListOwner() + {
    DIALOG dialogGetProductItemOwnerGestori OBJECTS o = businessEntityOwner() INPUT DO
        businessEntityOwner() <- o;
}


// Скрыть кнопки ручного запроса в Ветис — запросы выполняются автоматически
hideManualProducerStockList() += TRUE;

// Стандартная кнопка «Редактировать» скрыта — вместо неё editProductItemGestori (с отправкой запроса после сохранения)
hideEditProductItem(ProductItem o) += TRUE IF o IS ProductItem;
// Стандартная кнопка DELETE скрыта везде — вместо неё используется deleteProductItemGestori
hideDeleteProductItem(ProductItem o) += TRUE IF o IS ProductItem;

// Производитель и Владелец становятся только для чтения после регистрации в Ветис (uuid заполнен)
readonlyProductItemOwner(ProductItem i) += TRUE IF uuid(i) AND ownProductGestori(i);

// --- Производственная площадка + автозаполнение списка площадок ---

productionStockGestori 'Производственная площадка' = DATA BOOLEAN (Stock);

EXTEND FORM departmentStore PROPERTIES(d) productionStockGestori;
EXTEND FORM warehouse PROPERTIES(w) productionStockGestori;

// площадка, на которой ведётся производство (есть связанный склад-производственная площадка)
productionEnterpriseGestori (Enterprise e) = GROUP SUM 1 IF enterprise(Stock st) = e AND productionStockGestori(st);

// --- выбор Производителя/Владельца ТМ с учётом прав доступа пользователя ---

accessBusinessEntityGestori (BusinessEntity b) = GROUP SUM 1 IF accessCompany(currentUser(), Enterprise e) AND owner(e) = b;
availableBusinessEntityGestori (BusinessEntity b) = own(b) AND (accessBusinessEntityGestori(b) OR NOT limitAccess(currentUser()));

FORM dialogOwnBusinessEntityGestori 'Выбор ХС'
    OBJECTS o = BusinessEntity
    PROPERTIES(o) READONLY guid, name
    FILTERS availableBusinessEntityGestori(o)
    LIST BusinessEntity OBJECT o
;

// автозаполнение площадок производителя, на которых ведётся производство
fillProducingEnterprisesGestori (ProductItem pi) {
    in(pi, Enterprise e) <- NULL WHERE in(pi, e);
    in(pi, Enterprise e) <- TRUE WHERE owner(e) = producer(pi) AND productionEnterpriseGestori(e);
}

changeProducer(ProductItem pi) + {
    DIALOG dialogOwnBusinessEntityGestori OBJECTS o = producer(pi) INPUT DO {
        producer(pi) <- o;
        IF NOT owner(pi) THEN owner(pi) <- o;
        fillProducingEnterprisesGestori(pi);
    }
}

changeOwner(ProductItem pi) + {
    DIALOG dialogOwnBusinessEntityGestori OBJECTS o = owner(pi) INPUT DO owner(pi) <- o;
}

// Открыть карточку номенклатуры в режиме просмотра
viewProductItem 'Просмотр' (ProductItem p) {
    SHOW productItem OBJECTS o = p DOCKED WAIT READONLY;
}

// Удаление: собственная с uuid — отправить запрос на удаление в Ветис; иначе — удалить напрямую
deleteProductItemGestori 'Удалить' (ProductItem p) {
    ASK 'Удалить номенклатуру?' DO {
        IF ownProductGestori(p) AND uuid(p) THEN
            NEWTHREAD NEWSESSION NEWSQL deleteModifyProducerStockList(p);
        ELSE NEWSESSION {
            DELETE p;
            APPLY;
        }
    }
}

EXTEND FORM productItems
    PROPERTIES(o) TOOLBAR viewProductItem DRAW o
    PROPERTIES(o) TOOLBAR deleteProductItemGestori SHOWIF NOT isExported(o) DRAW o
;

// переименование кнопки загрузки
DESIGN productItems {
    PROPERTY(getProductItemList()) { caption = 'Загрузить номенклатуру'; }
}

// --- Запрос связанных справочников после загрузки номенклатуры ---

// доп. парсинг списочного ответа: продукция (dt:product), ХС-владелец (dt:tmOwner) и ед.изм. (dt:unit)
productGuidPIGestori = DATA LOCAL STRING (INTEGER);
tmOwnerGuidPIGestori = DATA LOCAL STRING (INTEGER);
unitGuidPIGestori = DATA LOCAL STRING (INTEGER);

GROUP piListProductGestori EXTID 'dt=http://api.vetrf.ru/schema/cdm/dictionary/v2:product';
GROUP piListTmOwnerGestori EXTID 'dt=http://api.vetrf.ru/schema/cdm/dictionary/v2:tmOwner';
GROUP piListUnitGestori EXTID 'dt=http://api.vetrf.ru/schema/cdm/dictionary/v2:unit';

EXTEND FORM getProductItemListResponse
    PROPERTIES(i) productGuidPIGestori EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:guid' IN piListProductGestori
    PROPERTIES(i) tmOwnerGuidPIGestori EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:guid' IN piListTmOwnerGestori
    PROPERTIES(i) unitGuidPIGestori EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:guid' IN piListUnitGestori
;

// UUID справочников (служебные, для определения необходимости запроса)
uuid 'UUID' = DATA STRING[50] (Product) CHARWIDTH 36;
uuid 'UUID' = DATA STRING[50] (SubProduct) CHARWIDTH 36;
uuid 'UUID' = DATA STRING[50] (Unit) CHARWIDTH 36;

searchDictGuidGestori = DATA LOCAL STRING();

// Продукция (GetProductByGuid); Тип продукции — перечисление, заполняется из ответа
GROUP getProductByGuidRequest EXTID 'v2=http://api.vetrf.ru/schema/cdm/registry/ws-definitions/v2:getProductByGuidRequest' : body;

FORM getProductByGuidRequestGestori FORMEXTID 'soapenv=http://schemas.xmlsoap.org/soap/envelope/:Envelope'
    PROPERTIES() header EXTID 'soapenv:Header'
    PROPERTIES() IN getProductByGuidRequest searchDictGuidGestori EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:guid'
;

GROUP getProductByGuidResponse EXTID 'v2=http://api.vetrf.ru/schema/cdm/registry/ws-definitions/v2:getProductByGuidResponse' : body;
GROUP getProductByGuidResponseP EXTID 'dt=http://api.vetrf.ru/schema/cdm/dictionary/v2:product' : getProductByGuidResponse;

prGuidBGG = DATA LOCAL STRING();
prUuidBGG = DATA LOCAL STRING();
prNameBGG = DATA LOCAL STRING();
prActiveBGG = DATA LOCAL STRING();
prTypeBGG = DATA LOCAL STRING();

FORM getProductByGuidResponseGestori FORMEXTID 'soapenv=http://schemas.xmlsoap.org/soap/envelope/:Envelope'
    PROPERTIES() IN getProductByGuidResponseP
        prGuidBGG EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:guid',
        prUuidBGG EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:uuid',
        prActiveBGG EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:active',
        prNameBGG EXTID 'dt:name',
        prTypeBGG EXTID 'dt:productType'
;

loadProductByGuidGestori (STRING g) {
    NEWSESSION {
        searchDictGuidGestori() <- g;
        LOCAL requestFile = FILE();
        EXPORT getProductByGuidRequestGestori XML TO requestFile;
        LOCAL response = FILE();
        TRY {
            EXTERNAL HTTP urlProduct() HEADERS httpHeaders PARAMS requestFile() TO response;
        } CATCH {
            fileToString(response());
            logToFile('vetis', CONCAT ' ', 'GetProductByGuid error:', g, resultString());
            RETURN;
        }
        IMPORT getProductByGuidResponseGestori XML FROM response();
        IF NOT prGuidBGG() THEN {
            logToFile('vetis', CONCAT ' ', 'GetProductByGuid: не найдена продукция', g);
            RETURN;
        }
        IF NOT product(prGuidBGG()) THEN NEW p = Product {
            guid(p) <- prGuidBGG();
        }
        // связанный справочник Тип продукции (dt:productType) — создать запись, если отсутствует
        IF prTypeBGG() AND NOT productType(INTEGER(prTypeBGG())) THEN NEW pt = ProductType {
            id(pt) <- INTEGER(prTypeBGG());
        }
        FOR Product p = product(prGuidBGG()) DO {
            name(p) <- ISTRING(prNameBGG());
            uuid(p) <- STRING[50](prUuidBGG());
            productType(p) <- productType(INTEGER(prTypeBGG()));
            inactive(p) <- TRUE IF prActiveBGG() = 'false';
        }
        APPLY;
    }
}

// Вид продукции (GetSubProductByGuid)
GROUP getSubProductByGuidRequest EXTID 'v2=http://api.vetrf.ru/schema/cdm/registry/ws-definitions/v2:getSubProductByGuidRequest' : body;

FORM getSubProductByGuidRequestGestori FORMEXTID 'soapenv=http://schemas.xmlsoap.org/soap/envelope/:Envelope'
    PROPERTIES() header EXTID 'soapenv:Header'
    PROPERTIES() IN getSubProductByGuidRequest searchDictGuidGestori EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:guid'
;

GROUP getSubProductByGuidResponse EXTID 'v2=http://api.vetrf.ru/schema/cdm/registry/ws-definitions/v2:getSubProductByGuidResponse' : body;
GROUP getSubProductByGuidResponseSP EXTID 'dt=http://api.vetrf.ru/schema/cdm/dictionary/v2:subProduct' : getSubProductByGuidResponse;

spGuidBGG = DATA LOCAL STRING();
spUuidBGG = DATA LOCAL STRING();
spNameBGG = DATA LOCAL STRING();
spActiveBGG = DATA LOCAL STRING();
spProductGuidBGG = DATA LOCAL STRING();

FORM getSubProductByGuidResponseGestori FORMEXTID 'soapenv=http://schemas.xmlsoap.org/soap/envelope/:Envelope'
    PROPERTIES() IN getSubProductByGuidResponseSP
        spGuidBGG EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:guid',
        spUuidBGG EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:uuid',
        spActiveBGG EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:active',
        spNameBGG EXTID 'dt:name',
        spProductGuidBGG EXTID 'dt:productGuid'
;

loadSubProductByGuidGestori (STRING g) {
    NEWSESSION NESTED LOCAL {
        searchDictGuidGestori() <- g;
        LOCAL requestFile = FILE();
        EXPORT getSubProductByGuidRequestGestori XML TO requestFile;
        LOCAL response = FILE();
        TRY {
            EXTERNAL HTTP urlProduct() HEADERS httpHeaders PARAMS requestFile() TO response;
        } CATCH {
            fileToString(response());
            logToFile('vetis', CONCAT ' ', 'GetSubProductByGuid error:', g, resultString());
            RETURN;
        }
        IMPORT getSubProductByGuidResponseGestori XML FROM response();
        IF NOT spGuidBGG() THEN {
            logToFile('vetis', CONCAT ' ', 'GetSubProductByGuid: не найден вид продукции', g);
            RETURN;
        }
        IF NOT subProduct(spGuidBGG()) THEN NEW s = SubProduct {
            guid(s) <- spGuidBGG();
        }
        FOR SubProduct s = subProduct(spGuidBGG()) DO {
            name(s) <- ISTRING(spNameBGG());
            uuid(s) <- STRING[50](spUuidBGG());
            inactive(s) <- TRUE IF spActiveBGG() = 'false';
        }
        APPLY NESTED LOCAL;
        // связанный справочник Продукция (dt:productGuid) — запрос в Ветис, если запись пустая
        IF spProductGuidBGG() AND (NOT product(spProductGuidBGG()) OR NOT name(product(spProductGuidBGG()))) THEN
            loadProductByGuidGestori(spProductGuidBGG());
        FOR SubProduct s = subProduct(spGuidBGG()) AND Product p = product(spProductGuidBGG()) DO
            product(s) <- p;
        APPLY NESTED LOCAL;
    }
}

// Единица измерения (GetUnitByGuid, DictionaryService)
GROUP getUnitByGuidRequest EXTID 'v2=http://api.vetrf.ru/schema/cdm/registry/ws-definitions/v2:getUnitByGuidRequest' : body;

FORM getUnitByGuidRequestGestori FORMEXTID 'soapenv=http://schemas.xmlsoap.org/soap/envelope/:Envelope'
    PROPERTIES() header EXTID 'soapenv:Header'
    PROPERTIES() IN getUnitByGuidRequest searchDictGuidGestori EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:guid'
;

GROUP getUnitByGuidResponse EXTID 'v2=http://api.vetrf.ru/schema/cdm/registry/ws-definitions/v2:getUnitByGuidResponse' : body;
GROUP getUnitByGuidResponseU EXTID 'dt=http://api.vetrf.ru/schema/cdm/dictionary/v2:unit' : getUnitByGuidResponse;

unGuidBGG = DATA LOCAL STRING();
unUuidBGG = DATA LOCAL STRING();
unNameBGG = DATA LOCAL STRING();
unFullNameBGG = DATA LOCAL STRING();
unCommonGuidBGG = DATA LOCAL STRING();
unFactorBGG = DATA LOCAL STRING();

FORM getUnitByGuidResponseGestori FORMEXTID 'soapenv=http://schemas.xmlsoap.org/soap/envelope/:Envelope'
    PROPERTIES() IN getUnitByGuidResponseU
        unGuidBGG EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:guid',
        unUuidBGG EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:uuid',
        unNameBGG EXTID 'dt:name',
        unFullNameBGG EXTID 'dt:fullName',
        unCommonGuidBGG EXTID 'dt:commonUnitGuid',
        unFactorBGG EXTID 'dt:factor'
;

loadUnitByGuidGestori (STRING g) {
    NEWSESSION {
        searchDictGuidGestori() <- g;
        LOCAL requestFile = FILE();
        EXPORT getUnitByGuidRequestGestori XML TO requestFile;
        LOCAL response = FILE();
        TRY {
            EXTERNAL HTTP urlDictionary() HEADERS httpHeaders PARAMS requestFile() TO response;
        } CATCH {
            fileToString(response());
            logToFile('vetis', CONCAT ' ', 'GetUnitByGuid error:', g, resultString());
            RETURN;
        }
        IMPORT getUnitByGuidResponseGestori XML FROM response();
        IF NOT unGuidBGG() THEN {
            logToFile('vetis', CONCAT ' ', 'GetUnitByGuid: не найдена ед.изм.', g);
            RETURN;
        }
        IF NOT unit(unGuidBGG()) THEN NEW u = Unit {
            guid(u) <- unGuidBGG();
        }
        FOR Unit u = unit(unGuidBGG()) DO {
            name(u) <- ISTRING(unNameBGG());
            uuid(u) <- STRING[50](unUuidBGG());
            fullName(u) <- ISTRING(unFullNameBGG());
            commonUnit(u) <- unit(unCommonGuidBGG());
            factor(u) <- INTEGER(unFactorBGG());
        }
        APPLY;
    }
}

// ХС (producer/tmOwner): создать при отсутствии, запросить данные; площадки ХС грузит сам getBusinessEntityByGUID 
loadDictBusinessEntityGestori (STRING g) {
    IF NOT g THEN RETURN;
    IF NOT businessEntity(g) THEN NEWSESSION {
        NEW b = BusinessEntity { guid(b) <- g; }
        APPLY;
    }
    IF businessEntity(g) AND NOT name(businessEntity(g)) THEN
        getBusinessEntityByGUID(businessEntity(g));
}

afterGetProductItemList() + {
    // справочники по собранным из ответа GUID (только записи без данных); продукция — до видов продукции
    FOR [GROUP SUM 1 BY producerGuid(INTEGER i)](STRING g) DO loadDictBusinessEntityGestori(g);
    FOR [GROUP SUM 1 BY tmOwnerGuidPIGestori(INTEGER i)](STRING g) DO loadDictBusinessEntityGestori(g);
    FOR [GROUP SUM 1 BY productGuidPIGestori(INTEGER i)](STRING g) AND (NOT product(g) OR NOT name(product(g))) DO loadProductByGuidGestori(g);
    FOR [GROUP SUM 1 BY subProductGuid(INTEGER i)](STRING g) AND (NOT subProduct(g) OR NOT name(subProduct(g))) DO loadSubProductByGuidGestori(g);
    FOR [GROUP SUM 1 BY unitGuidPIGestori(INTEGER i)](STRING g) AND (NOT unit(g) OR NOT name(unit(g))) DO loadUnitByGuidGestori(g);

    // дозаполнить ссылки номенклатуры на созданные при дозагрузке записи
    FOR guid(INTEGER i) = guid(ProductItem p) DO {
        IF NOT subProduct(p) THEN subProduct(p) <- subProduct(subProductGuid(i));
        IF NOT producer(p) THEN producer(p) <- businessEntity(producerGuid(i));
        IF NOT owner(p) THEN owner(p) <- businessEntity(tmOwnerGuidPIGestori(i));
    }
    APPLY;
}

// --- Запрос номенклатуры по GUID (GetProductItemByGuid_v2) ---

searchProductItemGuid 'GUID номенклатуры' = DATA LOCAL STRING() CHARWIDTH 50;

GROUP getProductItemByGuidRequest EXTID 'v2=http://api.vetrf.ru/schema/cdm/registry/ws-definitions/v2:getProductItemByGuidRequest' : body;

FORM getProductItemByGuidRequest FORMEXTID 'soapenv=http://schemas.xmlsoap.org/soap/envelope/:Envelope'
    PROPERTIES() header EXTID 'soapenv:Header'
    PROPERTIES() IN getProductItemByGuidRequest searchProductItemGuid EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:guid'
;

GROUP getProductItemByGuidResponse EXTID 'v2=http://api.vetrf.ru/schema/cdm/registry/ws-definitions/v2:getProductItemByGuidResponse' : body;
GROUP getProductItemByGuidResponsePI EXTID 'dt=http://api.vetrf.ru/schema/cdm/dictionary/v2:productItem' : getProductItemByGuidResponse;
GROUP getProductItemByGuidResponseProduct EXTID 'dt:product' : getProductItemByGuidResponsePI;
GROUP getProductItemByGuidResponseSubProduct EXTID 'dt:subProduct' : getProductItemByGuidResponsePI;
GROUP getProductItemByGuidResponseProducer EXTID 'dt:producer' : getProductItemByGuidResponsePI;
GROUP getProductItemByGuidResponseTmOwner EXTID 'dt:tmOwner' : getProductItemByGuidResponsePI;
GROUP getProductItemByGuidResponseUnit EXTID 'dt:unit' : getProductItemByGuidResponsePI;
GROUP getProductItemByGuidResponseLocation EXTID 'dt=http://api.vetrf.ru/schema/cdm/dictionary/v2:location';

piGuidBG = DATA LOCAL STRING();
piUuidBG = DATA LOCAL STRING();
piStatusBG = DATA LOCAL STRING();
piProducingGuidBG = DATA LOCAL STRING(INTEGER);
piActiveBG = DATA LOCAL STRING();
piNameBG = DATA LOCAL STRING();
piGlobalIDBG = DATA LOCAL STRING();
piCodeBG = DATA LOCAL STRING();
piCorrespondsBG = DATA LOCAL STRING();
piGostBG = DATA LOCAL STRING();
piProductGuidBG = DATA LOCAL STRING();
piSubProductGuidBG = DATA LOCAL STRING();
piProducerGuidBG = DATA LOCAL STRING();
piTmOwnerGuidBG = DATA LOCAL STRING();
piUnitGuidBG = DATA LOCAL STRING();

FORM getProductItemByGuidResponse FORMEXTID 'soapenv=http://schemas.xmlsoap.org/soap/envelope/:Envelope'
    PROPERTIES() IN getProductItemByGuidResponsePI
        piUuidBG EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:uuid',
        piGuidBG EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:guid',
        piStatusBG EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:status',
        piActiveBG EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:active',
        piGlobalIDBG EXTID 'dt:globalID',
        piNameBG EXTID 'dt:name',
        piCodeBG EXTID 'dt:code',
        piCorrespondsBG EXTID 'dt:correspondsToGost',
        piGostBG EXTID 'dt:gost'
    PROPERTIES() IN getProductItemByGuidResponseProduct piProductGuidBG EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:guid'
    PROPERTIES() IN getProductItemByGuidResponseSubProduct piSubProductGuidBG EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:guid'
    PROPERTIES() IN getProductItemByGuidResponseProducer piProducerGuidBG EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:guid'
    PROPERTIES() IN getProductItemByGuidResponseTmOwner piTmOwnerGuidBG EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:guid'
    PROPERTIES() IN getProductItemByGuidResponseUnit piUnitGuidBG EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:guid'
    OBJECTS pgg = INTEGER EXTID 'dt=http://api.vetrf.ru/schema/cdm/dictionary/v2:producing' IN getProductItemByGuidResponsePI
    PROPERTIES(pgg) piProducingGuidBG EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:guid' IN getProductItemByGuidResponseLocation
;

FORM inputProductItemGuid 'Запрос номенклатуры по GUID'
    PROPERTIES() searchProductItemGuid
;

// ядро без диалога — используется и при дозагрузке из ВСД 
loadProductItemByGuidCoreGestori (STRING g) {
    NEWSESSION NESTED LOCAL {
            skipOwnConstraint() <- TRUE;
            searchProductItemGuid() <- g;
            LOCAL requestFile = FILE();
            EXPORT getProductItemByGuidRequest XML TO requestFile;
            LOCAL response = FILE();
            TRY {
                EXTERNAL HTTP urlProduct() HEADERS httpHeaders PARAMS requestFile() TO response;
            } CATCH {
                fileToString(response());
                MESSAGE CONCAT ' ', 'Ошибка при запросе к службе:', resultString();
                RETURN;
            }
            IMPORT getProductItemByGuidResponse XML FROM response();
            IF NOT piGuidBG() THEN {
                MESSAGE 'Номенклатура не найдена';
                RETURN;
            }
            IF NOT productItem(piGuidBG()) THEN NEW p = ProductItem {
                guid(p) <- piGuidBG();
            }
            FOR ProductItem p = productItem(piGuidBG()) DO {
                uuid(p) <- piUuidBG();
                statusVetisGestori(p) <- STRING[5](piStatusBG());
                name(p) <- ISTRING(piNameBG());
                globalID(p) <- piGlobalIDBG();
                code(p) <- ISTRING(piCodeBG());
                correspondsToGost(p) <- TRUE IF piCorrespondsBG() = 'true';
                gost(p) <- STRING[50](piGostBG());
                subProduct(p) <- subProduct(piSubProductGuidBG());
                IF piProducerGuidBG() AND NOT businessEntity(piProducerGuidBG()) THEN NEW b = BusinessEntity {
                    guid(b) <- piProducerGuidBG();
                }
                producer(p) <- businessEntity(piProducerGuidBG());
                IF piTmOwnerGuidBG() AND NOT businessEntity(piTmOwnerGuidBG()) THEN NEW b = BusinessEntity {
                    guid(b) <- piTmOwnerGuidBG();
                }
                owner(p) <- businessEntity(piTmOwnerGuidBG());
                inactive(p) <- TRUE IF piActiveBG() = 'false';
            }
            APPLY NESTED LOCAL; // LOCAL-значения ответа нужны дозагрузке ниже

            // дозагрузка связанных справочников (продукция — до вида продукции)
            loadDictBusinessEntityGestori(piProducerGuidBG());
            loadDictBusinessEntityGestori(piTmOwnerGuidBG());
            IF piProductGuidBG() AND (NOT product(piProductGuidBG()) OR NOT name(product(piProductGuidBG()))) THEN
                loadProductByGuidGestori(piProductGuidBG());
            IF piSubProductGuidBG() AND (NOT subProduct(piSubProductGuidBG()) OR NOT name(subProduct(piSubProductGuidBG()))) THEN
                loadSubProductByGuidGestori(piSubProductGuidBG());
            IF piUnitGuidBG() AND (NOT unit(piUnitGuidBG()) OR NOT name(unit(piUnitGuidBG()))) THEN
                loadUnitByGuidGestori(piUnitGuidBG());
            // площадки производства (dt:producing/dt:location) — создать недостающие (в этой же сессии, чтобы LOCAL был виден)
            FOR piProducingGuidBG(INTEGER i) AND NOT enterprise(piProducingGuidBG(i)) DO
                NEW e = Enterprise { guid(e) <- piProducingGuidBG(i); }
            APPLY NESTED LOCAL;
            // предварительно дозагрузить данные площадок (5.6)
            FOR Enterprise e = enterprise(piProducingGuidBG(INTEGER i)) AND NOT name(e) DO
                loadEnterpriseDetails(e);
            // связать номенклатуру с площадками и дозаполнить вид продукции
            FOR ProductItem p = productItem(piGuidBG()) DO {
                IF NOT subProduct(p) THEN subProduct(p) <- subProduct(piSubProductGuidBG());
                in(p, Enterprise e) <- NULL WHERE in(p, e);
                FOR Enterprise e = enterprise(piProducingGuidBG(INTEGER i)) DO
                    in(p, e) <- TRUE;
            }
            APPLY NESTED LOCAL;
    }
}

loadProductItemByGuid 'Загрузить номенклатуру по GUID' (ProductItem o) {
    searchProductItemGuid() <- guid(o); // подставить GUID текущей записи, если он есть
    DIALOG inputProductItemGuid DO {
        IF NOT searchProductItemGuid() THEN {
            MESSAGE 'Укажите GUID номенклатуры';
            RETURN;
        }
        loadProductItemByGuidCoreGestori(searchProductItemGuid());
    }
}

EXTEND FORM productItems
    PROPERTIES(o) loadProductItemByGuid TOOLBAR
;
