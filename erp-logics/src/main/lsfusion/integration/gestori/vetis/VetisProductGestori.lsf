MODULE VetisProductGestori;

REQUIRE VetisSubProductImport, VetisProductImport, VetisSubProductGestori;

NAMESPACE Vetis;

// --- Новые свойства продукции ---

idProductTypeProduct 'Код типа продукции' (Product p) = id(productType(p));
code 'Код ТН ВЭД' = DATA STRING (Product) CHARWIDTH 10;

// --- Импорт Код ТН ВЭД для Product ---

codeProductL = DATA LOCAL STRING(INTEGER);

EXTEND FORM getProductByTypeListResponse
    PROPERTIES(i) codeProductL EXTID 'dt:code'
;

afterImportProductByTypeList(ProductType pt, FILE response) + {
    FOR guid(INTEGER i) = guid(Product p) DO
        IF codeProductL(i) THEN code(p) <- codeProductL(i);
}

// --- Групповая отметка продукции ---

inGestori 'Отм.' = DATA LOCAL BOOLEAN (Product);

// --- Импорт Код ТН ВЭД для SubProduct ---

codeSubL = DATA LOCAL STRING(INTEGER);

FORM getSubProductByProductListExtResponse FORMEXTID 'soapenv=http://schemas.xmlsoap.org/soap/envelope/:Envelope'
    OBJECTS i = INTEGER EXTID 'dt:subProduct' IN getSubProductByProductListResponseList
    PROPERTIES(i) guid EXTID 'bs:guid',
                  codeSubL EXTID 'dt:code'
;

afterImportSubProductByProductList(Product pt, FILE response) + {
    IMPORT getSubProductByProductListExtResponse XML FROM response;
    FOR guid(INTEGER i) = guid(SubProduct sp) DO {
        IF codeSubL(i) THEN code(sp) <- codeSubL(i);
    }
}

// --- Загрузка видов продукции по отмеченной продукции ---

loadSubProductsByMarkedGestori 'Загрузить виды продукции' (Product current) {
    NEWSESSION NESTED LOCAL {
        offset() <- 0;
        count() <- 1000;
        DIALOG getSubProductByProductListRequestParams NOMANAGESESSION DO {
            IF GROUP SUM 1 IF inGestori(Product p) THEN {
                FOR inGestori(Product p) DO
                    importSubProductByProductList(p);
            } ELSE {
                importSubProductByProductList(current);
            }
            APPLY;
        }
    }
}

// --- Ограничения ---

CONSTRAINT DROPPED(p IS Product) AND PREV(p IS Product)
    MESSAGE 'Удаление записей продукции не допускается. Справочник загружается только из Ветис.';

CONSTRAINT CHANGED(guid(Product p)) AND PREV(guid(p))
    MESSAGE 'Изменение кода (GUID) продукции не допускается.';

CONSTRAINT CHANGED(productType(Product p)) AND PREV(productType(p))
    MESSAGE 'Изменение ссылки на тип продукции не допускается.';

// --- Расширение формы "Продукция" ---

EXTEND FORM products
    PROPERTIES(o) inGestori BEFORE guid(o)
    PROPERTIES(o) READONLY idProductTypeProduct AFTER nameProductType(o)
    PROPERTIES(o) READONLY code AFTER idProductTypeProduct(o)
    PROPERTIES(o) DRAW o TOOLBAR loadSubProductsByMarkedGestori
;

EXTEND FORM product
    PROPERTIES(o) READONLY code
    PROPERTIES(s) READONLY code
;


DESIGN products {
    PROPERTY(guid(o)) { caption = 'GUID продукции'; }
    PROPERTY(getProductByTypeList()) { caption = 'Загрузить продукцию'; }
    PROPERTY(new) { hide = TRUE; }
    PROPERTY(edit) { hide = TRUE; }
    PROPERTY(delete) { hide = TRUE; }
}
