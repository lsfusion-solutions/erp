MODULE VetisPurposeGestori;

REQUIRE VetisPurpose;

NAMESPACE Vetis;

CONSTRAINT CHANGED(guid(Purpose u)) AND PREV(guid(u))
    MESSAGE 'Изменение GUID назначения груза не допускается';

DESIGN purposes {
    PROPERTY(guid(o)) { caption = 'GUID назначения груза'; }
}

DESIGN purpose {
    PROPERTY(guid(o)) { caption = 'GUID назначения груза'; }
}

DESIGN dialogPurposes {
    PROPERTY(guid(o)) { caption = 'GUID назначения груза'; }
}
