MODULE VetisBusinessEntityGestori;

REQUIRE VetisBusinessEntityImport, VetisLegalEntity, VetisEnterpriseImport;

NAMESPACE Vetis;

// --- Новые свойства ХС ---

fullName 'Наименование полное' = DATA ISTRING (BusinessEntity) CHARWIDTH 100;
status 'Статус Ветис' = DATA STRING[5] (BusinessEntity) CHARWIDTH 5;
uuid 'UUID ХС' = DATA STRING (BusinessEntity) CHARWIDTH 36; // 1.16, служебное — на формы не выводится

showFio(BusinessEntity b) += type(b) = '2' OR type(b) = '3';
readonlyGuid(BusinessEntity b) += TRUE IF guid(b);

typeDescription 'Тип ХС' (BusinessEntity b) = CASE
    WHEN type(b) = '1' THEN 'ЮЛ'
    WHEN type(b) = '2' THEN 'ФЛ'
    WHEN type(b) = '3' THEN 'ИП'
    ELSE type(b);

// 2.1.6: Наименование и Наименование полное — только для ЮЛ (тип = 1)
isLegalEntityBE 'ЮЛ' (BusinessEntity b) = type(b) = '1';
nameBE 'Наименование' (BusinessEntity b) = name(b);

// --- GetBusinessEntityByGuid ---

GROUP getBusinessEntityByGuidRequest EXTID 'v2=http://api.vetrf.ru/schema/cdm/registry/ws-definitions/v2:getBusinessEntityByGuidRequest' : body;

FORM getBusinessEntityByGuidRequest FORMEXTID 'soapenv=http://schemas.xmlsoap.org/soap/envelope/:Envelope'
    OBJECTS b = BusinessEntity PANEL
    PROPERTIES(b) IN getBusinessEntityByGuidRequest guid EXTID 'base=http://api.vetrf.ru/schema/cdm/base:guid'
;

GROUP getBusinessEntityByGuidResponse EXTID 'v2=http://api.vetrf.ru/schema/cdm/registry/ws-definitions/v2:getBusinessEntityByGuidResponse' : body;
GROUP getBusinessEntityByGuidResponseEntity EXTID 'dt=http://api.vetrf.ru/schema/cdm/dictionary/v2:businessEntity' : getBusinessEntityByGuidResponse;
GROUP getBusinessEntityByGuidResponseJuridicalAddress EXTID 'dt:juridicalAddress' : getBusinessEntityByGuidResponseEntity;

beStatus = DATA LOCAL STRING();
beUuid = DATA LOCAL STRING();
beType = DATA LOCAL STRING();
beName = DATA LOCAL ISTRING();
beFullName = DATA LOCAL ISTRING();
beFio = DATA LOCAL ISTRING();
beInn = DATA LOCAL STRING();
beKpp = DATA LOCAL STRING();
beOgrn = DATA LOCAL STRING();
beAddressView = DATA LOCAL ISTRING();

FORM getBusinessEntityByGuidResponse FORMEXTID 'soapenv=http://schemas.xmlsoap.org/soap/envelope/:Envelope'
    PROPERTIES() IN getBusinessEntityByGuidResponseEntity
        beStatus EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:status',
        beUuid EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:uuid',
        beType EXTID 'dt:type',
        beName EXTID 'dt:name',
        beFullName EXTID 'dt:fullName',
        beFio EXTID 'dt:fio',
        beInn EXTID 'dt:inn',
        beKpp EXTID 'dt:kpp',
        beOgrn EXTID 'dt:ogrn'
    PROPERTIES() IN getBusinessEntityByGuidResponseJuridicalAddress
        beAddressView EXTID 'dt=http://api.vetrf.ru/schema/cdm/dictionary/v2:addressView'
;

getBusinessEntityByGUID 'Обновить ХС' (BusinessEntity b) {
    NEWSESSION {
        LOCAL requestFile = FILE();
        EXPORT getBusinessEntityByGuidRequest OBJECTS b = b XML TO requestFile;
        LOCAL response = FILE();
        TRY {
            EXTERNAL HTTP urlCerberus() HEADERS httpHeaders PARAMS requestFile() TO response;
        } CATCH {
            fileToString(response());
            MESSAGE CONCAT ' ', 'Ошибка при запросе к службе:', resultString();
            RETURN;
        }
        IMPORT getBusinessEntityByGuidResponse XML FROM response();
        IF beStatus() THEN status(b) <- beStatus();
        IF beUuid() THEN uuid(b) <- beUuid(); // 1.16.1
        IF beType() THEN type(b) <- beType();
        IF beName() THEN name(b) <- beName();
        IF beFullName() THEN fullName(b) <- beFullName();
        IF beFio() THEN fio(b) <- beFio();
        IF beInn() THEN inn(b) <- STRING[12](beInn());
        IF beKpp() THEN kpp(b) <- STRING[9](beKpp());
        IF beOgrn() THEN ogrn(b) <- STRING[15](beOgrn());
        IF beAddressView() THEN addressView(b) <- beAddressView();
        APPLY;
        // 1.15: после загрузки данных по ХС — запрос площадок ХС
        IF name(b) THEN getActivityLocationList(b);
    }
}

// --- Загрузить ХС (поиск по параметрам) ---

searchGuid 'GUID' = DATA LOCAL STRING ();
searchInn 'ИНН' = DATA LOCAL STRING ();
searchKpp 'КПП' = DATA LOCAL STRING ();
searchOgrn 'ОГРН/ОГРНИП' = DATA LOCAL STRING ();

FORM getBusinessEntityListSearchRequest FORMEXTID 'soapenv=http://schemas.xmlsoap.org/soap/envelope/:Envelope'
    PROPERTIES() header EXTID 'soapenv:Header'
    PROPERTIES() IN getBusinessEntityListRequestListOptions count EXTID 'base:count', offset EXTID 'base:offset'
    PROPERTIES() IN getBusinessEntityListRequestBusinessEntity
        searchGuid EXTID 'base=http://api.vetrf.ru/schema/cdm/base:guid',
        searchInn EXTID 'dt:inn',
        searchKpp EXTID 'dt:kpp',
        searchOgrn EXTID 'dt:ogrn'
;

typeL = DATA LOCAL STRING(INTEGER);
uuidL = DATA LOCAL STRING(INTEGER);
nameL = DATA LOCAL STRING(INTEGER);
fullNameL = DATA LOCAL STRING(INTEGER);
statusL = DATA LOCAL STRING(INTEGER);
fioL = DATA LOCAL STRING(INTEGER);
kppL = DATA LOCAL STRING(INTEGER);
ogrnL = DATA LOCAL STRING(INTEGER);
addressViewL = DATA LOCAL STRING(INTEGER);

FORM getBusinessEntityListExtResponse FORMEXTID 'soapenv=http://schemas.xmlsoap.org/soap/envelope/:Envelope'
    PROPERTIES() IN getBusinessEntityListResponseList total EXTID 'dt:total' ATTR
    OBJECTS businessEntity = INTEGER EXTID 'dt:businessEntity' IN getBusinessEntityListResponseList
    PROPERTIES(businessEntity) guid EXTID 'base=http://api.vetrf.ru/schema/cdm/base:guid',
                               statusL EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:status',
                               uuidL EXTID 'bs=http://api.vetrf.ru/schema/cdm/base:uuid',
                               fullNameL EXTID 'dt:fullName',
                               nameL EXTID 'dt:name',
                               inn EXTID 'dt:inn',
                               typeL EXTID 'dt:type',
                               fioL EXTID 'dt:fio',
                               kppL EXTID 'dt:kpp',
                               ogrnL EXTID 'dt:ogrn'
    PROPERTIES(businessEntity) IN juridicalAddress addressViewL EXTID 'dt=http://api.vetrf.ru/schema/cdm/dictionary/v2:addressView'
;

afterGetBusinessEntityList(BusinessEntity b, FILE response) + {
    IMPORT getBusinessEntityListExtResponse XML FROM response;
    IF guid(0) THEN {
        status(b) <- statusL(0);
        uuid(b) <- uuidL(0); // 1.16.1
        name(b) <- ISTRING(OVERRIDE nameL(0), fullNameL(0));
        Vetis.inn(b) <- STRING[12](inn(0));
        Vetis.fullName(b) <- ISTRING(fullNameL(0));
        type(b) <- typeL(0);
        fio(b) <- ISTRING(fioL(0));
        kpp(b) <- STRING[9](kppL(0));
        ogrn(b) <- STRING[15](ogrnL(0));
        addressView(b) <- ISTRING(addressViewL(0));
    }
}

FORM loadBusinessEntitiesDialog 'Загрузить ХС'
    PROPERTIES() searchGuid, searchInn, searchKpp, searchOgrn
    PROPERTIES() count, offset
;

loadBusinessEntities 'Загрузить ХС' () {
    DIALOG loadBusinessEntitiesDialog DO {
        IF NOT (searchGuid() OR searchInn() OR searchKpp() OR searchOgrn()) THEN {
            MESSAGE 'Укажите хотя бы один параметр поиска: GUID, ИНН, КПП или ОГРН';
            RETURN;
        }
        NEWSESSION NESTED LOCAL {
            LOCAL requestFile = FILE();
            EXPORT getBusinessEntityListSearchRequest XML TO requestFile;
            LOCAL response = FILE();
            TRY {
                EXTERNAL HTTP urlCerberus() HEADERS httpHeaders PARAMS requestFile() TO response;
            } CATCH {
                fileToString(response());
                MESSAGE CONCAT ' ', 'Ошибка при запросе к службе:', resultString();
                RETURN;
            }
            IMPORT getBusinessEntityListExtResponse XML FROM response();
            FOR guid(INTEGER i) AND NOT businessEntity(guid(i)) NEW b = BusinessEntity DO {
                guid(b) <- guid(i);
            }
            FOR BusinessEntity b = businessEntity(guid(INTEGER i)) DO {
                name(b) <- ISTRING(OVERRIDE nameL(i), fullNameL(i));
                Vetis.fullName(b) <- ISTRING(fullNameL(i));
                Vetis.inn(b) <- STRING[12](inn(i));
                Vetis.status(b) <- statusL(i);
                type(b) <- typeL(i);
                fio(b) <- ISTRING(fioL(i));
                kpp(b) <- STRING[9](kppL(i));
                ogrn(b) <- STRING[15](ogrnL(i));
                addressView(b) <- ISTRING(addressViewL(i));
            }
            IF (GROUP SUM 1 IF guid(INTEGER i)) THEN
                MESSAGE 'Найдено: ' + (GROUP SUM 1 IF guid(INTEGER i)) + ' хозяйствующих субъектов';
            APPLY NESTED LOCAL; // значения ответа нужны циклу 1.16.2 ниже
            // 1.16.2: UUID ХС не задан или отличается — выполнить запрос данных по ХС (byGuid запишет uuid и площадки — 1.15)
            FOR BusinessEntity b = businessEntity(guid(INTEGER i)) AND NOT uuid(b) = uuidL(i) DO
                getBusinessEntityByGUID(b);
        }
    }
}

// --- Загрузить ХС по GLN ---

searchGlnBusinessEntity 'GLN' = DATA LOCAL STRING();

GROUP beGLNRequest EXTID 'v2=http://api.vetrf.ru/schema/cdm/registry/ws-definitions/v2:getBusinessMemberByGLNRequest' : body;

FORM getBeByGLNRequest FORMEXTID 'soapenv=http://schemas.xmlsoap.org/soap/envelope/:Envelope'
    PROPERTIES() header EXTID 'soapenv:Header'
    PROPERTIES() IN beGLNRequest
        searchGlnBusinessEntity EXTID 'dt=http://api.vetrf.ru/schema/cdm/dictionary/v2:globalID'
;

GROUP beGLNResponse EXTID 'v2=http://api.vetrf.ru/schema/cdm/registry/ws-definitions/v2:getBusinessMemberByGLNResponse' : body;
GROUP beGLNResponseMember EXTID 'dt=http://api.vetrf.ru/schema/cdm/dictionary/v2:businessMember' : beGLNResponse;
GROUP beGLNResponseEnt EXTID 'dt:enterprise' : beGLNResponseMember;
GROUP beGLNResponseEntOwner EXTID 'dt:owner' : beGLNResponseEnt;

beOwnerGuid = DATA LOCAL STRING();

FORM getBeByGLNResponse FORMEXTID 'soapenv=http://schemas.xmlsoap.org/soap/envelope/:Envelope'
    PROPERTIES() IN beGLNResponseEntOwner beOwnerGuid EXTID 'base=http://api.vetrf.ru/schema/cdm/base:guid'
;

// GLN — ровно 13 цифр (GLNType в схеме Ветис)
isGlnGestori = FORMULA NULL BOOLEAN 'CASE WHEN $1 ~ \'^[0-9]{13}$\' THEN 1 ELSE NULL END';

FORM inputGlnBusinessEntity 'Загрузить ХС по GLN'
    PROPERTIES() searchGlnBusinessEntity
;

loadBusinessEntityByGLN 'Загрузить ХС по GLN' () {
    DIALOG inputGlnBusinessEntity DO {
        IF NOT searchGlnBusinessEntity() THEN {
            MESSAGE 'Укажите GLN';
            RETURN;
        }
        searchGlnBusinessEntity() <- trim(searchGlnBusinessEntity());
        IF NOT isGlnGestori(searchGlnBusinessEntity()) THEN {
            MESSAGE 'Некорректный GLN: должно быть ровно 13 цифр';
            RETURN;
        }
        NEWSESSION NESTED LOCAL {
            LOCAL requestFile = FILE();
            EXPORT getBeByGLNRequest XML TO requestFile;
            LOCAL response = FILE();
            TRY {
                EXTERNAL HTTP urlCerberus() HEADERS httpHeaders PARAMS requestFile() TO response;
            } CATCH {
                fileToString(response());
                MESSAGE CONCAT ' ', 'Ошибка при запросе к службе:', resultString();
                RETURN;
            }
            IMPORT getBeByGLNResponse XML FROM response();
            IF beOwnerGuid() AND NOT businessEntity(beOwnerGuid()) THEN NEW b = BusinessEntity {
                guid(b) <- beOwnerGuid();
            }
            APPLY;
        }
        IF beOwnerGuid() THEN
            getBusinessEntityByGUID(businessEntity(beOwnerGuid()));
        ELSE
            MESSAGE 'ХС по указанному GLN не найден';
    }
}

// --- Выбор ХС в форме организации (п.1.8) ---

filterOwnForLE = DATA LOCAL BOOLEAN();

FORM dialogBEForLE 'Выбор ХС'
    OBJECTS o = BusinessEntity
    PROPERTIES(o) READONLY guid, name
    FILTERS (filterOwnForLE() AND own(o)) OR (NOT filterOwnForLE() AND NOT own(o))
    LIST BusinessEntity OBJECT o
;

changeBusinessEntityLE(LegalEntity l) + {
    filterOwnForLE() <- isCompany(l);
    DIALOG dialogBEForLE OBJECTS o = businessEntity(l) INPUT DO businessEntity(l) <- o;
}

// --- Запрет удаления и изменения GUID ---

CONSTRAINT DROPPED(b IS BusinessEntity) AND (PREV(own(b)) OR (GROUP SUM 1 IF PREV(businessEntity(LegalEntity l)) = b)
        OR (GROUP SUM 1 IF PREV(owner(Enterprise e)) = b)) // 1.14: связь с площадками
    MESSAGE 'Невозможно удалить: хозяйствующий субъект является собственным, связан с организацией или площадками';

CONSTRAINT SETCHANGED(guid(BusinessEntity b)) AND PREV(guid(b))
    MESSAGE 'Изменение GUID ХС не допускается';

// --- Расширение форм ---

EXTEND FORM businessEntity
    PROPERTIES(o) READONLY nameBE SHOWIF isLegalEntityBE(o)
    PROPERTIES(o) READONLY fullName SHOWIF isLegalEntityBE(o)
    PROPERTIES(o) READONLY status, typeDescription
    PROPERTIES(o) getBusinessEntityByGUID DRAW o TOOLBAR
    PROPERTIES(l) READONLY kpp, ogrn AFTER inn(l)
;

EXTEND FORM businessEntities
    PROPERTIES(o) READONLY fullName, status
    PROPERTIES(o) READONLY typeDescription AFTER type(o)
    PROPERTIES() DRAW o TOOLBAR loadBusinessEntities, loadBusinessEntityByGLN
;

DESIGN businessEntity {
    tabPane {
        fill = 1;
    }
    tabProperties {
        MOVE PROPERTY(own(o)) FIRST;
        MOVE PROPERTY(nameBE(o)) AFTER PROPERTY(guid(o));
        MOVE PROPERTY(fullName(o)) AFTER PROPERTY(nameBE(o));
        MOVE PROPERTY(fio(o)) AFTER PROPERTY(fullName(o));
        MOVE PROPERTY(typeDescription(o)) AFTER PROPERTY(fio(o));
        MOVE PROPERTY(status(o)) AFTER PROPERTY(addressView(o));
        MOVE PROPERTY(getBusinessEntityByGUID(o)) LAST;
    }
    PROPERTY(guid(o)) { caption = 'GUID ХС'; }
    PROPERTY(name(o)) { hide = TRUE; }
    PROPERTY(type(o)) { hide = TRUE; }
    PROPERTY(typeDescription(o)) { charWidth = 5; }
    PROPERTY(fio(o)) { charWidth = 50; }
    PROPERTY(addressView(o)) { charWidth = 255; }
    PROPERTY(getBusinessEntityByGUID(o)) { caption = 'Обновить ХС'; }
}

DESIGN businessEntities {
    PROPERTY(getBusinessEntityList()) { caption = 'Обновить ХС'; }
    PROPERTY(getBusinessEntityList(o)) { caption = 'Обновить ХС'; }
    PROPERTY(type(o)) { hide = TRUE; }
}
