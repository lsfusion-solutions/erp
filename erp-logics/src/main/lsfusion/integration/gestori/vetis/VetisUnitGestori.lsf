MODULE VetisUnitGestori;

REQUIRE VetisUnit;

NAMESPACE Vetis;

CONSTRAINT CHANGED(guid(Unit u)) AND PREV(guid(u))
    MESSAGE 'Изменение GUID единицы измерения не допускается';

DESIGN units {
    PROPERTY(guid(o)) { caption = 'GUID единицы измерения'; }
}

DESIGN unit {
    PROPERTY(guid(o)) { caption = 'GUID единицы измерения'; }
}

DESIGN dialogUnits {
    PROPERTY(guid(o)) { caption = 'GUID единицы измерения'; }
}
