MODULE ProductionOrderGestori;

REQUIRE ProductionOrder, ProductionOutput, ManufacturingTransferDashboard, ManufacturingTransferDashboardReturn,
        BOMOperation, BomStock, ProductionConsumption, StockList, PriceListStore;

NAMESPACE Production;

isProduction 'Производство' = DATA BOOLEAN (Operation);
isElaboration 'Проработка' = DATA BOOLEAN (Operation);

isRecComponents 'Рекурсивно' = DATA BOOLEAN (Order)  IN documentPrm;
isRecComponents 'Рекурсивно' = DATA BOOLEAN (ProductDetail);
EXTEND FORM order
    PROPERTIES(o) isRecComponents
    PROPERTIES(pd) isRecComponents
;

productionDetail = DATA ProductDetail(ComponentDetail);
componentDetail = DATA ComponentDetail(ProductDetail);

WHEN LOCAL FORMS order SETCHANGED(productsStock(Order o)) DO {
    componentsStock(o) <- productsStock(o);
}

isDefault 'По умолчанию'  = DATA BOOLEAN (BOM) IN documentPrm;

EXTEND FORM BOM
    PROPERTIES (b) isDefault
;

CONSTRAINT (SET(isDefault(BOM bom)) OR CHANGED(in(bom, Stock st))) AND isDefault(bom) AND (GROUP SUM 1 IF isDefault(BOM b) AND NOT b = bom AND products(b) = products(bom)
    AND in(b, st) = in(bom, st) AND isActive(b)) MESSAGE 'Спецификация по умолчанию может быть только 1';

countProductsKirovsky (sku, Stock stock, DATE date) = GROUP SUM 1 IF isActive(BOM(Product p), stock, date) AND isDefault(BOM(p)) AND isProduction(operation(BOM(p))) BY sku(p);
defaultProductKirovsky (sku, Stock stock, DATE date)= GROUP MIN Product p IF isActive(BOM(p), stock, date) AND isDefault(BOM(p)) AND isProduction(operation(BOM(p))) BY sku(p);

WHEN LOCAL FORMS order CHANGED(sku(ProductDetail d)) AND NOT CHANGED(product(d)) AND countProductsKirovsky(sku(d), componentsStock(d), date(d)) NOINLINE DO{
    product(d) <- defaultProductKirovsky(sku(d), componentsStock(d), date(d));
}

countComponentsKirovsky (sku, Stock stock, DATE date) = GROUP SUM 1 IF isActive(BOM(Component p), stock, date) AND isDefault(BOM(p)) BY sku(p);
defaultComponentKirovsky (sku, Stock stock, DATE date)= GROUP MIN Component p IF isActive(BOM(p), stock, date) AND isDefault(BOM(p)) BY sku(p);

WHEN LOCAL FORMS order CHANGED(bruttoSku(ComponentDetail d)) AND NOT CHANGED(component(d)) AND countComponentsKirovsky(sku(d), componentsStock(d), date(d)) NOINLINE DO{
    component(d) <- defaultComponentKirovsky(sku(d), componentsStock(d), date(d));
    BOM(d) <- BOM(defaultComponentKirovsky(sku(d), componentsStock(d), date(d)));
}
skipCheckProduction = DATA BOOLEAN (Order);
skipCheckComponent = DATA BOOLEAN (Order);

WHEN LOCAL FORMS order (CHANGED(BOM(ProductDetail pd))  OR CHANGED(quantity(pd))) AND BOM(pd) AND quantity(pd) AND NOT isRecComponents(pd) AND isProduction(operation(pd)) DO {
    skipCheckProduction(order(pd)) <- TRUE;
    DELETE ComponentDetail cd WHERE productionDetail(cd) = pd;
    FOR BOM(pd) = BOM(Component c) AND quantityProducts(BOM(pd), order(pd)) NEW cd = ComponentDetail DO {
        order(cd) <- order(pd);
        productionDetail(cd) <- pd;
        component(cd) <- c;
        BOM(cd) <- BOM(pd);
        bruttoQuantity(cd) <- bruttoQuantity(c, date(order(pd))) * quantityProducts(BOM(pd),order(pd));
        BOMQuantity(cd) <- bruttoQuantity(c, date(order(pd)));
        IF material(c) IS Sku THEN {
            bruttoSku(cd) <- material(c);
        } ELSE {
            IF material(c) IS Product THEN {
                product(cd) <- material(c);
                bruttoSku(cd) <- sku[Product](material(c));
            }
        }
        product(cd) <- defaultProductKirovsky(sku(cd), componentsStock(cd), date(cd));
        markup(productionDetail(cd)) <- 0.0;
    }
}

WHEN LOCAL FORMS order (CHANGED(BOM(ProductDetail pd)) OR CHANGED(quantity(pd))) AND BOM(pd) AND quantity(pd) AND isRecComponents(pd)  AND isProduction(operation(pd))  DO {
    skipCheckProduction(order(pd)) <- TRUE;
    DELETE ComponentDetail cd WHERE productionDetail(cd) = pd;
    FOR BOM(pd) = BOM(Component c) AND NUMERIC[91,46] q == recBruttoQuantity(BOM(pd), order(pd), c) IF material(c) IS Sku ORDER BOM(pd) NEW d = ComponentDetail DO {
        productionDetail(d) <- pd;
        order(d) <- order(pd);
        BOM(d) <- BOM(pd);
        bruttoSku(d) <- material(c);
        component(d) <- c;
        bruttoQuantity(d) <- q;
        BOMQuantity(d) <- recBOMQuantity(BOM(pd), order(pd), c);
        product(d) <- defaultProductKirovsky(sku(d), componentsStock(d), date(d));
    }
    FOR product(ComponentDetail d) AND isRecComponents(productionDetail(d)) DO expand(d);
}

WHEN LOCAL FORMS order (CHANGED(BOM(ComponentDetail cd))  OR CHANGED(quantity(cd))) AND BOM(cd) AND quantity(cd) AND isElaboration(operation(cd)) DO {
    DELETE ProductDetail pd WHERE  componentDetail(pd) = cd;
    FOR NUMERIC[35,19] q == quantityComponents(BOM(cd), order(cd)) AND BOM(cd) = BOM(Product product) NEW d = ProductDetail DO {
        componentDetail(d) <- cd;
        order(d) <- order(cd);
        sku(d) <- sku(product);
        product(d) <- product;
        quantity(d) <- round3(quantity(product) * q);
        BOMQuantity(d) <- quantity(product);
        pricePercent(d) <- pricePercent(product);
    }
}

overCreate(ComponentDetail new, ComponentDetail old) + {
    productionDetail(new) <- productionDetail(old);
}

WHEN LOCAL FORMS order CHANGED(price(ComponentDetail cd)) OR CHANGED(quantity(cd)) DO {
    IF isProduction(operation(cd)) THEN fillPrice(productionDetail(cd));
    FOR isElaboration(operation(cd)) AND componentDetail(ProductDetail pd) = cd DO fillPrice(pd);
    FOR isElaboration(operation(cd)) AND NOT sum(cd) = (GROUP SUM sum(ProductDetail pd) IF componentDetail(pd) = cd) AND
        ProductDetail d = (GROUP LAST ProductDetail pd IF componentDetail(pd) = cd ORDER price(pd)) DO {
        sum(d) <- (sum(d) + (sum(cd) (-)(GROUP SUM sum(ProductDetail pd) IF componentDetail(pd) = cd)));
        price(d) <- round(sum(d)/quantity(d), 2);
        outputProductsSum(d) <- sum(d);
    }
}

WHEN LOCAL FORMS order isElaboration(operation(ComponentDetail cd)) AND CHANGED(GROUP SUM quantity(ProductDetail idetail) IF  componentDetail(idetail) =cd) DO {
    FOR isElaboration(operation(cd)) AND componentDetail(ProductDetail pd) = cd DO fillPrice(pd);
    FOR isElaboration(operation(cd)) AND NOT sum(cd) = (GROUP SUM sum(ProductDetail pd) IF componentDetail(pd) = cd) AND
        ProductDetail d = (GROUP LAST ProductDetail pd IF componentDetail(pd) = cd ORDER price(pd)) DO {
        sum(d) <- (sum(d) + (sum(cd) (-)(GROUP SUM sum(ProductDetail pd) IF componentDetail(pd) = cd)));
        price(d) <- round(sum(d)/quantity(d), 2);
        outputProductsSum(d) <- sum(d);
    }
}

overFillPriceAfter(ProductDetail detail) + {
    IF isProduction(operation(detail)) THEN {
        markup(detail) <- 0.0;
        changeValueMarkup(detail);
    }
    IF isElaboration(operation(detail)) THEN {
        componentsPrice(detail) <- NUMERIC[16,4](quantity(componentDetail(detail))*price(componentDetail(detail))*pricePercent(detail)/(GROUP SUM quantity(ProductDetail d)*pricePercent(d) IF componentDetail(detail) = componentDetail(d)));
        costPrice(detail) <- NUMERIC[16,4](calcCost(detail));
        changeValueMarkup(detail);
        sum(detail) <- NUMERIC[18,4](round2(quantity(detail) * price(detail)));
        outputProductsSum(detail) <- sum(detail);
    }
}

WHEN LOCAL FORMS order DROPPED(productionDetail(ComponentDetail cd)) DO {
    DELETE cd;
}

WHEN LOCAL FORMS order DROPPED(componentDetail(ProductDetail pd)) DO {
    DELETE pd;
}

idBruttoSku 'Код ' (ComponentDetail componentDetail) = id(bruttoSku(componentDetail));
idBarcodeBruttoSku 'Штрихкод' (ComponentDetail componentDetail) = idBarcode(bruttoSku(componentDetail));

EXTEND FORM order
    //    PROPERTIES READONLY nameProductsPriceListType 'Вид цен (изделие)'= nameProductsPriceListType(o)
    PROPERTIES READONLY createConsumption 'Создать документ списания сырья'= createConsumption(o)
    PROPERTIES READONLY createOutput 'Создать документ производства'= createOutput(o)
    PROPERTIES (pd) idSku, idBarcodeSku
    PROPERTIES (cd) AFTER bruttoNameSku(cd) idBruttoSku, idBarcodeBruttoSku
;

DESIGN order{
    REMOVE PROPERTY (nameComponentsStock(o));
    REMOVE PROPERTY (fromDate(o));
    REMOVE PROPERTY (toDate(o));
    REMOVE PROPERTY (nameCalcPriceListType(o));
    REMOVE PROPERTY (VATProduct(o));
    REMOVE PROPERTY (createConsumption(o));
    REMOVE PROPERTY (createOutput(o));
    REMOVE PROPERTY (VATProduct(o));
    REMOVE PROPERTY (nameProductsPriceListType(o));
    REMOVE PROPERTY (createComponents(o));
    REMOVE PROPERTY (createProducts(o));
    REMOVE PROPERTY (createRecComponents(o));
    REMOVE PROPERTY (createForRecComponents(o));
    REMOVE PROPERTY (deleteComponents(o));
    REMOVE PROPERTY (deleteComponents(o));
    REMOVE PROPERTY (fillOutputQuantityProductDetail(o));
    REMOVE PROPERTY (useBatchSkuAllFIFO(o));
    REMOVE PROPERTY (deleteProductDetail(o));
    REMOVE PROPERTY (fillPriceProducts(o));
    PROPERTY (add) {showIf = isElaboration(operation(o)) OR NOT isProduction(operation(o));};
    PROPERTY (newpd) {showIf = isProduction(operation(o)) OR NOT isElaboration(operation(o));};
    REMOVE PROPERTY (createOutputComponent(o));
    REMOVE PROPERTY (useBatchSkuAll(o));
    PROPERTY(isRecComponents(o)) {showIf = isProduction(operation(o));}
    PROPERTY(isRecComponents(pd)) {showIf = isProduction(operation(o));}
    //    row111 {
    //        PROPERTY (nameProductsPriceListType);
    //    }
    selectPane{
        showIf = isProduction(operation(o)) OR NOT isElaboration(operation(o));
    }
    selectPane1{
        showIf = isElaboration(operation(o)) OR NOT isProduction(operation(o));
    }

    headerRow112{
        PROPERTY (createConsumption);
    }
    headerRow112{
        PROPERTY (createOutput);
    }
    REMOVE price;
    REMOVE options;

}

isRecComponents 'Значение по умолчанию Рекурсивно' = DATA BOOLEAN (Operation);

WHEN LOCAL FORMS operation SET(isProduction(Operation o)) DO isElaboration(o) <- NULL;
WHEN LOCAL FORMS operation SET(isElaboration(Operation o)) DO isProduction(o) <- NULL;

WHEN LOCAL FORMS order SETCHANGED(operation(Order o)) DO isRecComponents(o) <- isRecComponents(operation(o));
WHEN LOCAL FORMS order SET(ProductDetail pd IS ProductDetail) DO isRecComponents(pd) <- isRecComponents(order(pd));

EXTEND FORM operation
    PROPERTIES(o) isRecComponents, isProduction, isElaboration
;

DESIGN operation {
    paramsContainer {
        MOVE PROPERTY(isRecComponents(o));
        MOVE PROPERTY(isProduction(o));
        MOVE PROPERTY(isElaboration(o));
    }
}

@defineOperationProperty(isPrice, 'Запрет проведения производственного заказа с нулевой ценой компонент или изделий', BOOLEAN, constraintContainer);

CONSTRAINT SET(isPosted(Order o)) AND isPrice(operation(o)) AND ((GROUP SUM 1 IF NOT(price(ProductDetail pd)) AND order(pd) = o) OR  (GROUP SUM 1 IF NOT(price(ComponentDetail cd)) AND order(cd) = o))
    MESSAGE 'Запрещено проведения производственного заказа с нулевой ценой компонент или изделий';

NAVIGATOR {
    manufacturingTransfer 'Перемещение в цех производства';
    manufacturingTransferReturn 'Возврат из цеха производства';
}

//WHEN LOCAL FORMS order SET(ProductDetail pd IS ProductDetail) AND isElaboration(operation(pd)) AND NOT skipCheckComponent(order(pd)) DO {
//    MESSAGE 'Это проработка';
//    DELETE pd;
//};

WHEN LOCAL FORMS order SET(ComponentDetail cd IS ComponentDetail) AND isProduction(operation(cd)) AND NOT skipCheckProduction(order(cd)) DO {
    MESSAGE 'Это производство';
    DELETE cd;
};

WHEN LOCAL FORMS order (CHANGED(bruttoQuantity(ComponentDetail d)) OR CHANGED(cost(d)) OR (CHANGED(price(d)) AND PREV(price(d))) OR (CHANGED(sum(d)) AND PREV(sum(d))) OR
    CHANGED(component(d)) OR CHANGED(bruttoSku(d)) OR CHANGED(BOM(d))) AND isProduction(operation(d)) AND NOT skipCheckProduction(order(d)) DO {
    MESSAGE 'Это производство';
    component(d) <- PREV(component(d));
    BOM(d) <- PREV(BOM(d));
    bruttoSku(d) <- PREV(bruttoSku(d));

    bruttoQuantity(d) <- PREV(bruttoQuantity(d));
    cost(d) <- PREV(cost(d));
    price(d) <- PREV(price(d));
    sum(d) <- PREV(sum(d));
};

WHEN LOCAL FORMS order (CHANGED(quantity(ProductDetail d)) OR (CHANGED(price(d)) AND PREV(price(d))) OR CHANGED(sum(d)) OR
    CHANGED(sku(d))) AND isElaboration(operation(d)) AND NOT skipCheckComponent(order(d)) AND NULL DO {
    MESSAGE 'Это проработка';
    sku(d) <- PREV(sku(d));

    quantity(d) <- PREV(quantity(d));
    price(d) <- PREV(price(d));
    sum(d) <- PREV(sum(d));
};

WHEN LOCAL FORMS order GOAFTER sum[ComponentDetail] CHANGED(sum(ComponentDetail d)) DO
    skipCheckProduction(order(d)) <- NULL;


WHEN LOCAL FORMS BOM SET(Product p IS Product) AND isProduction(operation(BOM(p))) AND (GROUP SUM 1 IF BOM(Product pr) = BOM(p)) > 1 DO {
    MESSAGE 'Это производство. Изделия может быть только 1';
    DELETE p;
};

WHEN LOCAL FORMS BOM SET(Component c IS Component) AND isElaboration(operation(BOM(c))) AND (GROUP SUM 1 IF BOM(Component co) = BOM(c)) > 1 DO {
    MESSAGE 'Это проработка. Компонентов может быть только 1';
    DELETE c;
};

EXTEND FORM productsChange
    FILTERS isActiveCurrent(BOM(p))
;

DESIGN productsChange {REMOVE FILTERGROUP (inactiveBOM);}

idStrictChangeSubstitutes 'Cтрогая замена' = DATA BOOLEAN ();

EXTEND FORM options
    PROPERTIES() idStrictChangeSubstitutes
;
DESIGN options {
    manufacturing {
        MOVE PROPERTY(idStrictChangeSubstitutes());
    }
}

DESIGN substitutesSku {
    FILTERGROUP (filter2){ showIf = NOT idStrictChangeSubstitutes();}
    FILTERGROUP (filter3){ showIf = NOT idStrictChangeSubstitutes();}
}

CONSTRAINT CHANGED(component(ComponentDetail d)) AND component(d) AND NOT operation(d) == operation(BOM(component(d))) AND NOT skipBom(order(d))
    CHECKED BY component[ComponentDetail] MESSAGE 'Операция спецификации должна быть равна операции заказа';

CONSTRAINT CHANGED(product(ComponentDetail d)) AND product(d) AND isElaboration(operation(d)) AND NOT skipBom(order(d))
    CHECKED BY product[ComponentDetail] MESSAGE 'Операция спецификации должна быть равна операции заказа';

BOMQuantity(ComponentDetail d) <- quantity(component(d))
    WHEN CHANGED (component(d)) AND isElaboration(operation(d));

copyGestori 'Копировать'(Order order)  {
    NEWSESSION {
        NEW o = Order {
            company(o) <- company(order);
            componentsStock(o) <- componentsStock(order);
            productsStock(o) <- productsStock(order);
            date(o) <- currentDate();
            time(o) <- currentTime();
            productsPriceListType(o) <- productsPriceListType(order);
            priceListType(o) <- priceListType(order);
            VATProduct(o) <- VATProduct(order);
            VATComponent(o) <- VATComponent(order);
            note(o) <- note(order);
            operation(o) <- operation(order);
            isRecComponents(o) <- isRecComponents(order);

            IF isProduction(operation(o)) THEN {
                FOR order(ProductDetail productDetail) == order NEW p=ProductDetail DO {
                    order(p) <- o;
                    sku(p) <- sku(productDetail);
                    product(p) <- product(productDetail);
                    quantity(p) <- quantity(productDetail);
                    BOMQuantity(p) <- BOMQuantity(productDetail);
                    markup(p) <- markup(productDetail);
                    pricePercent(p) <- pricePercent(productDetail);
                    IF isRecComponents(o) THEN {
                        FOR BOM(p) = BOM(Component c) AND NUMERIC[91,46] q == recBruttoQuantity(BOM(p), order(p), c) IF material(c) IS Sku ORDER BOM(p) NEW d = ComponentDetail DO {
                            productionDetail(d) <- p;
                            order(d) <- order(p);
                            BOM(d) <- BOM(p);
                            bruttoSku(d) <- material(c);
                            component(d) <- c;
                            bruttoQuantity(d) <- q;
                            BOMQuantity(d) <- recBOMQuantity(BOM(p), order(p), c);
                            product(d) <- defaultProductKirovsky(sku(d), componentsStock(d), date(d));
                        }
                        FOR product(ComponentDetail d) AND isRecComponents(productionDetail(d)) DO expand(d);
                    }ELSE {
                        FOR BOM(p) = BOM(Component c) AND quantityProducts(BOM(p), order(p)) NEW cd = ComponentDetail DO {
                            order(cd) <- order(p);
                            productionDetail(cd) <- p;
                            component(cd) <- c;
                            BOM(cd) <- BOM(p);
                            bruttoQuantity(cd) <- bruttoQuantity(c, date(order(p))) * quantityProducts(BOM(p),order(p));
                            BOMQuantity(cd) <- bruttoQuantity(c, date(order(p)));
                            IF material(c) IS Sku THEN {
                                bruttoSku(cd) <- material(c);
                            } ELSE {
                                IF material(c) IS Product THEN {
                                    product(cd) <- material(c);
                                    bruttoSku(cd) <- sku[Product](material(c));
                                }
                            }
                            product(cd) <- defaultProductKirovsky(sku(cd), componentsStock(cd), date(cd));
                            markup(productionDetail(cd)) <- 0.0;
                        }
                    }
                }
            }
            IF isElaboration(operation(o)) THEN
                FOR order(ComponentDetail componentDetail) == order NEW c=ComponentDetail DO {
                order(c) <- o;
                bruttoSku(c) <- bruttoSku(componentDetail);
                substituteSku(c) <- substituteSku(componentDetail);
                substituteQuantity(c) <- substituteQuantity(componentDetail);
                product(c) <- product(componentDetail);
                component(c) <- component(componentDetail);
                bruttoQuantity(c) <- bruttoQuantity(componentDetail);
                //            BOMQuantityComponentDetail(c) <- BOMQuantityComponentDetail(componentDetail);
                BOM(c) <- BOM(componentDetail);
                price(c) <- prevAccountPriceB(bruttoSku(c), componentsStock(c), dateTime(c));
                FOR BOM(c) = BOM(Product product) NEW d = ProductDetail DO {
                    componentDetail(d) <- c;
                    order(d) <- order(c);
                    sku(d) <- sku(product);
                    product(d) <- product;
                    quantity(d) <- round3(quantity(product) * quantityComponents(BOM(c), order(c)));
                    BOMQuantity(d) <- quantity(product);
                    pricePercent(d) <- pricePercent(product);
                    componentsPrice(d) <- NUMERIC[16,4](quantity(componentDetail(d))*price(componentDetail(d))*pricePercent(d)/(GROUP SUM quantity(ProductDetail d1)*pricePercent(d1) IF componentDetail(d) = componentDetail(d1)));
                    costPrice(d) <- NUMERIC[16,4](calcCost(d));
                    changeValueMarkup(d);
                    sum(d) <- NUMERIC[18,4](round2(quantity(d) * price(d)));
                    outputProductsSum(d) <- sum(d);
                }
            }
            SHOW order OBJECTS o = o DOCKED NOCANCEL;
        }
    }
} TOOLBAR;

EXTEND FORM orders
    PROPERTIES(o) copyGestori
;

DESIGN orders{
    REMOVE PROPERTY (copy(o));
}

banRepeat 'Запрет повтора' = DATA BOOLEAN (BOM);

EXTEND FORM BOMs
    PROPERTIES (b) READONLY banRepeat SHOWIF isElaboration(operation(b))
;

EXTEND FORM BOM 
    PROPERTIES (b) banRepeat SHOWIF isElaboration(operation(b))
;

DESIGN BOM {
    row11 {
    MOVE PROPERTY (banRepeat(b));
    }
}

CONSTRAINT SET(BOM o IS BOM) AND isElaboration(operation(o)) AND banRepeat(BOM o1) AND o != o1 AND
    (GROUP SUM 1 IF BOM(Product pd) = o) = (GROUP SUM 1 IF BOM(Product pd) = o1) AND 
    (GROUP SUM 1 IF sku(Component cd) = sku(Component cd1) AND BOM(cd) = o AND BOM(cd1) = o1) AND
    (GROUP SUM 1 IF sku(Product pd) = sku(Product pd1) AND BOM(pd) = o AND BOM(pd1) = o1) = (GROUP SUM 1 IF BOM(Product pd) = o) AND
    (GROUP SUM 1 IF sku(Product pd) = sku(Product pd1) AND BOM(pd) = o AND BOM(pd1) = o1) = (GROUP SUM 1 IF BOM(Product pd) = o1) MESSAGE 'Запрещено повторять спецификацию ' 
    PROPERTIES '' = number(o), number(o1);

CLASS ProductionReportFlow 'Тип движения' {
    income 'Приход',
    expense 'Расход'
}
name 'Тип движения' (ProductionReportFlow o) = staticCaption(o) IF o IS ProductionReportFlow CHARWIDTH 10;

CLASS SkuFilterType {
    sku 'Товары',
    skuGroups 'Товарные группы',
    skuLists 'Списки товаров'
}
name 'Тип фильтра' (SkuFilterType o) = staticCaption(o) IF o IS SkuFilterType CHARWIDTH 20;

FORM dialogSkuFilterType 'Способ выбора товаров'
    OBJECTS t = SkuFilterType
    PROPERTIES(t) READONLY name
    LIST SkuFilterType OBJECT t
;

prDateFrom 'Дата (с)' = DATA LOCAL DATE ();
prDateTo 'Дата (по)' = DATA LOCAL DATE ();

prIncludeExpense 'С учетом расходной части по операциям' = DATA LOCAL BOOLEAN ();

prInStock 'Отм.' = DATA LOCAL BOOLEAN (Stock);
prAnyStock () = GROUP MAX prInStock(Stock s);
prNameStocks 'Подразделения' () = GROUP CONCAT (CONCAT ' ', id(Stock s), name(s)) IF prInStock(s), ', '
ORDER id(s), s CHARWIDTH 40;

prStockList = DATA LOCAL StockList();
prNameStockList 'Список подразделений' () = name(prStockList());

prShop = DATA LOCAL Stock();
prNameShop 'Магазин' () = CONCAT ' ', id(prShop()), name(prShop());

prFirstSelectedStock () = GROUP LAST Stock s IF prInStock(s) AND isCompany(s) ORDER DESC id(s), s;

prAutoFillShop () {
    IF NOT prShop() THEN {
        prShop() <- prFirstSelectedStock();
    }
}

prChangeStockList 'Список подразделений' () {
    DIALOG stockLists OBJECTS o INPUT DO {
        prStockList() <- o;
        prInStock(Stock s) <- NULL;
        prInStock(Stock s) <- TRUE WHERE in(o, s) AND isCompany(s);
        prAutoFillShop();
    }
}

prDeleteStockList 'Сбросить список' () {
    prStockList() <- NULL;
    prInStock(Stock s) <- NULL;
} ASON CONTEXTMENU prNameStockList;

prSelectAllStocks 'Выбрать все' () {
    prStockList() <- NULL;
    prInStock(Stock s) <- TRUE WHERE isCompany(s) AND active(s);
    prAutoFillShop();
} ASON CONTEXTMENU prNameStocks;

prDeselectAllStocks 'Сбросить все' () {
    prStockList() <- NULL;
    prInStock(Stock s) <- NULL;
} ASON CONTEXTMENU prNameStocks;

FORM prDialogStocks 'Выбор подразделений'
    TREE stockTree a = BPSTRING[3], sg = StockGroup PARENT parent(sg)
    PROPERTIES READONLY VALUE(a), name(sg)
    ORDERS name(sg)
    FILTERS stringEqualsAll(a)

    OBJECTS s = Stock
    PROPERTIES(s) prInStock READONLYIF prStockList()
    PROPERTIES(s) READONLY id, name, address, nameRegion
    PROPERTIES prChangeStockList() TOOLBAR
    ORDERS name(s)
    FILTERS isParent(sg, s) OR (s IS Stock AND NOT sg),
        isCompany(s)
    FILTERGROUP inactiveStock FILTER 'Активный' active(s) 'ctrl F10' DEFAULT
    FILTERGROUP selectedStock FILTER 'Отмеченные' prInStock(s) 'F9'
;

DESIGN prDialogStocks {
    BOX {
        size = (1024, 768);
        NEW topContainer {
            horizontal = TRUE;
            fill = 1;
            MOVE BOX(TREE stockTree) { caption = 'Группы складов'; }
            MOVE BOX(s) {
                fill = 3;
                GRID(s) { defaultComponent = TRUE; }
            }
        }
        MOVE TOOLBARBOX;
    }
}

prChangeStocks 'Подразделения' () {
    DIALOG prDialogStocks;
    prAutoFillShop();
}

prChangeShop 'Магазин' () {
    DIALOG companysStock OBJECTS s = prShop() CHANGE LIST name(s);
}

prDeleteShop 'Сбросить магазин' () {
    prShop() <- NULL;
} ASON CONTEXTMENU prNameShop;

prInSku 'Отм.' = DATA LOCAL BOOLEAN (Sku);
prInSkuGroup 'Отм.' = DATA LOCAL BOOLEAN (SkuGroup);
prInSkuList 'Отм.' = DATA LOCAL BOOLEAN (List);

prAnySkuList () = GROUP MAX prInSkuList(List l);
prAnySkuGroup () = GROUP MAX prInSkuGroup(SkuGroup g);
prAnySku () = GROUP MAX prInSku(Sku s);
prAnySkuSelected () = prAnySku() OR prAnySkuGroup();

prNameSkuLists 'Списки товаров' () = GROUP CONCAT name(List l) IF prInSkuList(l), ', '
ORDER name(l), l CHARWIDTH 30;
prNameSkuGroups 'Товарные группы' () = GROUP CONCAT name(SkuGroup o) IF prInSkuGroup(o) AND NOT prInSkuGroup(parent(o)), '; '
ORDER o CHARWIDTH 30;

prInSkuByGroup (Sku s) = GROUP MAX prInSkuGroup(SkuGroup g) IF isParent(g, s);

prSelectedSkuNames () = GROUP CONCAT name(Sku s) IF prInSku(s), '; ' ORDER name(s), s;
prSkuNamesFromGroups () = GROUP CONCAT name(Sku s) IF prInSkuByGroup(s) AND name(s), '; ' ORDER name(s), s;
prInSkus 'Товары' () = OVERRIDE prSelectedSkuNames(), prSkuNamesFromGroups();

prDeleteSkuLists 'Сбросить список' () {
    prInSkuList(List l) <- NULL;
    prInSku(Sku s) <- NULL;
} ASON CONTEXTMENU prNameSkuLists;

prDeleteSkuGroups 'Сбросить группы' () {
    prInSkuGroup(SkuGroup g) <- NULL;
} ASON CONTEXTMENU prNameSkuGroups;

FORM prSelectSku 'Выбор товаров'
    TREE skuTree sg = SkuGroup PARENT parent(sg)
    PROPERTIES READONLY order(sg), skuGroupName = name(sg)
    FILTERGROUP inactive FILTER 'Активные' active(sg) 'F6' DEFAULT
    ORDERS order(sg), skuGroupName

    OBJECTS s = Sku
    PROPERTIES(s) prIn = prInSku
    PROPERTIES(s) READONLY id SHOWIF showIDs()
    PROPERTIES(s) READONLY name, idBarcode, shortNameUOM
    FILTERS isParent(sg, s), name(s)
    ORDERS name(s)
;

FORM prDialogSkuGroups 'Выбор товарных групп'
    TREE skuGroupTree sg = SkuGroup PARENT parent(sg)
    PROPERTIES(sg) prInSkuGroup
    PROPERTIES READONLY order(sg), sgName = name(sg)
    FILTERGROUP inactive FILTER 'Активные' active(sg) 'F6' DEFAULT
    ORDERS order(sg), sgName
;

FORM prDialogSkuLists 'Выбор списков товаров'
    OBJECTS o = List
    PROPERTIES(o) prInSkuList
    PROPERTIES(o) READONLY name
    ORDERS name(o)
;

prSelectSkus 'Фильтр по товарам' () {
    DIALOG dialogSkuFilterType OBJECTS t INPUT DO {
        CASE
            WHEN t = SkuFilterType.sku THEN {
                prInSkuList(List l) <- NULL;
                prInSkuGroup(SkuGroup g) <- NULL;
                SHOW prSelectSku;
            }
            WHEN t = SkuFilterType.skuGroups THEN {
                prInSkuList(List l) <- NULL;
                prInSku(Sku s) <- NULL;
                SHOW prDialogSkuGroups;
            }
            WHEN t = SkuFilterType.skuLists THEN {
                prInSkuGroup(SkuGroup g) <- NULL;
                DIALOG prDialogSkuLists DO {
                    prInSku(Sku s) <- NULL;
                    FOR prInSkuList(list(ListDetail ld)) AND Sku s == sku(ld) DO
                        prInSku(s) <- TRUE;
                }
            };
    }
}

prSkuFilter (Sku s) = NOT prAnySkuSelected() OR prInSku(s) OR prInSkuByGroup(s);

prInOperation 'Отм.' = DATA LOCAL BOOLEAN (Operation);
prAnyOperation () = GROUP MAX prInOperation(Operation o);
prNameOperations 'Операции' () = OVERRIDE
    (GROUP CONCAT name(Operation o) IF prInOperation(o), ', ' ORDER name(o), o),
    'Все операции производства' CHARWIDTH 30;

prSelectAllOperations 'Выбрать все' () {
    prInOperation(Operation o) <- TRUE;
} ASON CONTEXTMENU prNameOperations;

prDeselectAllOperations 'Сбросить все' () {
    prInOperation(Operation o) <- NULL;
} ASON CONTEXTMENU prNameOperations;

FORM prDialogOperations 'Выбор операций производства'
    OBJECTS o = Operation
    PROPERTIES(o) prInOperation
    PROPERTIES(o) READONLY name, id
    PROPERTIES TOOLBAR prSelectAllOperations(), prDeselectAllOperations()
    ORDERS name(o)
;

prChangeOperations 'Операции' () {
    DIALOG prDialogOperations;
}

prInitDates () {
    prDateTo() <- currentDate();
    prDateFrom() <- sumMonth(currentDate(), -1);
    prIncludeExpense() <- NULL;
    prInOperation(Operation o) <- TRUE WHERE o IS Operation;
}

prOperationFilter (Operation op) = NOT prAnyOperation() OR prInOperation(op);

prFlowFilter (ProductionReportFlow flow) =
    flow == ProductionReportFlow.income OR (flow == ProductionReportFlow.expense AND prIncludeExpense());

prOrderFilter (Order o) =
    isPosted(o)
        AND date(o) >= prDateFrom()
        AND date(o) <= prDateTo()
        AND prOperationFilter(operation(o));

prProductDetailFilter (ProductDetail d) =
    prOrderFilter(order(d))
        AND prInStock(productsStock(order(d)))
        AND prSkuFilter(sku(d));

prComponentDetailFilter (ComponentDetail d) =
    prOrderFilter(order(d))
        AND prInStock(componentsStock(order(d)))
        AND prSkuFilter(sku(d));

prPackWeight 'Фасовка, кг (вес нетто)' (Sku s) = netWeight(s);

prShopRetailPrice (Sku s) =
    retailPriceA(s, prShop(), toDateTime(prDateTo())) IF prShop();

prAccountPrice (Sku s, Stock st) =
    accountPriceA(s, st, toDateTime(prDateTo()));

prVatRate (Sku s, Stock st) = valueVAT(s, country(st), prDateTo());

prVatCoef (Sku s, Stock st) = 1.0 + (OVERRIDE prVatRate(s, st), 0.0) / 100.0;

prRowProduct 'Кол-во прихода' (Stock st, Operation op, Sku s) =
    GROUP SUM quantity(ProductDetail d)
        IF prProductDetailFilter(d)
            AND productsStock(order(d)) == st
            AND operation(order(d)) == op
            AND sku(d) == s;

prRowProductSum 'Сумма прихода (документ, с НДС)' (Stock st, Operation op, Sku s) =
    GROUP SUM sum(ProductDetail d)
        IF prProductDetailFilter(d)
            AND productsStock(order(d)) == st
            AND operation(order(d)) == op
            AND sku(d) == s;

prRowComponent 'Кол-во расхода' (Stock st, Operation op, Sku s) =
    GROUP SUM quantity(ComponentDetail d)
        IF prComponentDetailFilter(d)
            AND componentsStock(order(d)) == st
            AND operation(order(d)) == op
            AND sku(d) == s;

prRowComponentSum 'Сумма расхода (документ, с НДС)' (Stock st, Operation op, Sku s) =
    GROUP SUM sum(ComponentDetail d)
        IF prComponentDetailFilter(d)
            AND componentsStock(order(d)) == st
            AND operation(order(d)) == op
            AND sku(d) == s;

prQty (Stock st, Operation op, Sku s, ProductionReportFlow flow) =
    CASE
        WHEN flow == ProductionReportFlow.income THEN prRowProduct(st, op, s)
        WHEN flow == ProductionReportFlow.expense THEN prRowComponent(st, op, s);

prQtyKg (Stock st, Operation op, Sku s, ProductionReportFlow flow) =
    NUMERIC[18,3](round3(prQty(st, op, s, flow) * prPackWeight(s)));

prSumDocWithVat (Stock st, Operation op, Sku s, ProductionReportFlow flow) =
    NUMERIC[18,2](round2(
            CASE
                WHEN flow == ProductionReportFlow.income THEN prRowProductSum(st, op, s)
                WHEN flow == ProductionReportFlow.expense THEN prRowComponentSum(st, op, s)));

prSumAccountWithVat (Stock st, Operation op, Sku s, ProductionReportFlow flow) =
    NUMERIC[18,2](round2(prQty(st, op, s, flow) * prAccountPrice(s, st)))
        IF prQty(st, op, s, flow) AND prAccountPrice(s, st);

prSumAccountNoVat (Stock st, Operation op, Sku s, ProductionReportFlow flow) =
    NUMERIC[18,2](round2(prSumAccountWithVat(st, op, s, flow) / prVatCoef(s, st)))
        IF prSumAccountWithVat(st, op, s, flow);

prSumWorkshopWithVat (Stock st, Operation op, Sku s, ProductionReportFlow flow) =
    prSumDocWithVat(st, op, s, flow);

prSumWorkshopNoVat (Stock st, Operation op, Sku s, ProductionReportFlow flow) =
    NUMERIC[18,2](round2(prSumWorkshopWithVat(st, op, s, flow) / prVatCoef(s, st)))
        IF prSumWorkshopWithVat(st, op, s, flow);

prSumShopWithVat (Stock st, Operation op, Sku s, ProductionReportFlow flow) =
    NUMERIC[18,2](round2(prQty(st, op, s, flow) * prShopRetailPrice(s)))
        IF prQty(st, op, s, flow) AND prShopRetailPrice(s);

prSumShopNoVat (Stock st, Operation op, Sku s, ProductionReportFlow flow) =
    NUMERIC[18,2](round2(prSumShopWithVat(st, op, s, flow) / prVatCoef(s, st)))
        IF prSumShopWithVat(st, op, s, flow);

prWorkshopProfitNoVat (Stock st, Operation op, Sku s, ProductionReportFlow flow) =
    prSumWorkshopNoVat(st, op, s, flow) (-) prSumAccountNoVat(st, op, s, flow);

prShopGrossIncomeWithVat (Stock st, Operation op, Sku s, ProductionReportFlow flow) =
    prSumShopWithVat(st, op, s, flow) (-) prSumWorkshopWithVat(st, op, s, flow);

prShopMarkupNoVat (Stock st, Operation op, Sku s, ProductionReportFlow flow) =
    prSumShopNoVat(st, op, s, flow) (-) prSumWorkshopNoVat(st, op, s, flow);

prShopMarkupPct (Stock st, Operation op, Sku s, ProductionReportFlow flow) =
    NUMERIC[18,2](round2(prShopMarkupNoVat(st, op, s, flow) * 100.0 / prSumWorkshopNoVat(st, op, s, flow)))
        IF prSumWorkshopNoVat(st, op, s, flow) > 0.0;

prHasFlowData (Stock st, Operation op, Sku s, ProductionReportFlow flow) =
    prFlowFilter(flow) AND prQty(st, op, s, flow);

prHasAnyDataForRow (Stock st, Sku s) = GROUP MAX 1
    IF prHasFlowData(st, Operation op, s, ProductionReportFlow flow)
        AND prOperationFilter(op);

prHasRow (Stock st, Sku s) =
    prInStock(st) AND prSkuFilter(s) AND prHasAnyDataForRow(st, s);

FORM productionReport 'Отчёт по производству'
    PROPERTIES() prDateFrom, prDateTo
    PROPERTIES() prIncludeExpense
    PROPERTIES prNameStockList() READONLY SHOWIF prStockList()
    PROPERTIES prStocksCaption = prNameStocks() ON CHANGE prChangeStocks() READONLYIF prStockList()
    PROPERTIES prShopCaption = prNameShop() ON CHANGE prChangeShop()
    PROPERTIES prNameSkuLists() READONLY SHOWIF prAnySkuList()
    PROPERTIES prSkuGroupsCaption = prNameSkuGroups() READONLY SHOWIF prAnySkuGroup()
    PROPERTIES prSkusCaption = prInSkus() ON CHANGE prSelectSkus() READONLYIF prAnySkuList() OR prAnySkuGroup()
    PROPERTIES prOperationsCaption = prNameOperations() ON CHANGE prChangeOperations()

    OBJECTS report = (st = Stock, s = Sku, op = Operation, flow = ProductionReportFlow)
    PROPERTIES(op) READONLY 'Операция' = name
    PROPERTIES(flow) READONLY 'Тип движения' = staticCaption
    PROPERTIES(st) READONLY 'Код подразделения' = id, 'Наименование подразделения' = name
    PROPERTIES(s) READONLY 'Код товарной группы' = idSkuGroup3, 'Наименование товарной группы' = nameSkuGroup3
    PROPERTIES(s) READONLY 'Код товара' = id, 'Наименование товара' = name
    PROPERTIES(s) READONLY 'Единица измерения' = shortNameUOM
    PROPERTIES(s) READONLY prPackWeight
    PROPERTIES READONLY
    'Кол-во' = prQty(st, op, s, flow),
        'Кол-во в кг' = prQtyKg(st, op, s, flow),
        'Сумма по учетной цене без НДС, руб.' = prSumAccountNoVat(st, op, s, flow),
        'Сумма по учетной цене с НДС, руб.' = prSumAccountWithVat(st, op, s, flow),
        'Сумма по отпускной цене цеха без НДС, руб.' = prSumWorkshopNoVat(st, op, s, flow),
        'Сумма по отпускной цене цеха с НДС, руб.' = prSumWorkshopWithVat(st, op, s, flow),
        'Сумма по отпускной цене магазина с НДС, руб.' = prSumShopWithVat(st, op, s, flow),
        'Прибыль цеха без НДС, руб.' = prWorkshopProfitNoVat(st, op, s, flow),
        'Валовой доход магазина с НДС, руб.' = prShopGrossIncomeWithVat(st, op, s, flow),
        'Торговая наценка без НДС, руб.' = prShopMarkupNoVat(st, op, s, flow),
        'Торговая наценка, %' = prShopMarkupPct(st, op, s, flow)
    FILTERS prHasRow(st, s),
        prOperationFilter(op),
        prHasFlowData(st, op, s, flow)
    ORDERS name(op), staticCaption(flow), id(st), idSkuGroup3(s), id(s)

    EVENTS ON INIT prInitDates()
;

FORM productionReportPrint 'Отчёт по производству'
    PROPERTIES() 'Дата с' = prDateFrom, 'Дата по' = prDateTo

    OBJECTS st = Stock, s = Sku, op = Operation, flow = ProductionReportFlow
    PROPERTIES(op) READONLY 'Операция' = name
    PROPERTIES(flow) READONLY 'Тип движения' = staticCaption
    PROPERTIES(st) READONLY 'Код подразделения' = id, 'Наименование подразделения' = name
    PROPERTIES(s) READONLY 'Код товарной группы' = idSkuGroup3, 'Наименование товарной группы' = nameSkuGroup3,
        'Код товара' = id, 'Наименование товара' = name,
        'Единица измерения' = shortNameUOM
    PROPERTIES(s) READONLY 'Фасовка, кг (вес нетто)' = prPackWeight
    PROPERTIES READONLY
    'Кол-во' = prQty(st, op, s, flow),
        'Кол-во в кг' = prQtyKg(st, op, s, flow),
        'Сумма по учетной цене без НДС, руб.' = prSumAccountNoVat(st, op, s, flow),
        'Сумма по учетной цене с НДС, руб.' = prSumAccountWithVat(st, op, s, flow),
        'Сумма по отпускной цене цеха без НДС, руб.' = prSumWorkshopNoVat(st, op, s, flow),
        'Сумма по отпускной цене цеха с НДС, руб.' = prSumWorkshopWithVat(st, op, s, flow),
        'Сумма по отпускной цене магазина с НДС, руб.' = prSumShopWithVat(st, op, s, flow),
        'Прибыль цеха без НДС, руб.' = prWorkshopProfitNoVat(st, op, s, flow),
        'Валовой доход магазина с НДС, руб.' = prShopGrossIncomeWithVat(st, op, s, flow),
        'Торговая наценка без НДС, руб.' = prShopMarkupNoVat(st, op, s, flow),
        'Торговая наценка, %' = prShopMarkupPct(st, op, s, flow)
    FILTERS prHasRow(st, s),
        prOperationFilter(op),
        prHasFlowData(st, op, s, flow)
    ORDERS name(op), staticCaption(flow), id(st), idSkuGroup3(s), id(s)
;

prPrintReport 'Отчёт' () { PRINT productionReportPrint XLSX; } IMAGE 'print.png';

EXTEND FORM productionReport
    PROPERTIES() DISABLEIF NOT prDateFrom() OR NOT prDateTo() OR NOT prAnyStock() prPrintReport
;

DESIGN productionReport {
    NEW filters FIRST {
        alignment = STRETCH;
        NEW topRow {
            horizontal = TRUE;
            alignment = STRETCH;
            MOVE PROPERTY(prDateFrom());
            MOVE PROPERTY(prDateTo());
            MOVE PROPERTY(prIncludeExpense());
            MOVE PROPERTY(prPrintReport()) { valueClass = 'btn-primary'; }
        }
        MOVE PROPERTY(prNameStockList()) { alignment = STRETCH; }
        MOVE PROPERTY(prStocksCaption) { alignment = STRETCH; }
        MOVE PROPERTY(prShopCaption) { alignment = STRETCH; }
        MOVE PROPERTY(prNameSkuLists()) { alignment = STRETCH; }
        MOVE PROPERTY(prSkuGroupsCaption) { alignment = STRETCH; }
        MOVE PROPERTY(prSkusCaption) { alignment = STRETCH; }
        MOVE PROPERTY(prOperationsCaption) { alignment = STRETCH; }
    }
    BOX(report) {
        caption = 'Отчёт по производству';
    }
}

NAVIGATOR {
    manufacturingReports {
        NEW productionReport;
    }
}