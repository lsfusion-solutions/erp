MODULE PurchaseOrderGestori;

REQUIRE PurchaseOrderStatus, SaleReportsRu, ReportFileNameGestori;

NAMESPACE Purchase;

dataDelayDaysOrder 'Задержка поставок в днях' = DATA INTEGER (LegalEntity);
delayDaysOrder 'Задержка поставок в днях' (LegalEntity l) = OVERRIDE dataDelayDaysOrder(l), 0 IF isSupplier(l);

EXTEND FORM legalEntity
    PROPERTIES(l) SHOWIF isSupplier(l) delayDaysOrder
;

DESIGN legalEntity {
    row11 {
        MOVE PROPERTY(delayDaysOrder(l));
    }
}

dataDelayDaysOrder 'Задержка поставок в днях' = ABSTRACT INTEGER (Stock);
delayDaysOrder 'Задержка поставок в днях' (Stock st) = OVERRIDE dataDelayDaysOrder(st), delayDaysOrder(legalEntity(st)), 0 IF isCompany(st);

dataDelayDaysOrder 'Задержка поставок в днях' = DATA INTEGER (DepartmentStore);
dataDelayDaysOrder (DepartmentStore ds) += dataDelayDaysOrder(ds);

EXTEND FORM departmentStore
    PROPERTIES(d) SHOWIF isCompany(d) delayDaysOrder
;

DESIGN departmentStore {
    headerExtraParams {
        MOVE PROPERTY(delayDaysOrder(d));
    }
}

dataDelayDaysOrder 'Задержка поставок в днях' = DATA INTEGER (Warehouse);
dataDelayDaysOrder (Warehouse ds) += dataDelayDaysOrder(ds);

EXTEND FORM warehouse
    PROPERTIES(w) SHOWIF isCompany(w) delayDaysOrder
;

DESIGN warehouse {
    headerExtraParams {
        MOVE PROPERTY(delayDaysOrder(w));
    }
}

overCloseDate (Order o) += sum(shipmentDate(o), delayDaysOrder(supplierStock(o)) + 1);
filterStatus = DATA LOCAL StatusOrder();
nameFilterStatus 'Статус' = name(filterStatus());
filterStatus(Purchase.Order o) = status(o) == filterStatus() OR (o IS Purchase.Order AND NOT filterStatus());
template = DATA LOCAL STRING[100]();

EXTEND FORM orders
    PROPERTIES() nameFilterStatus
    FILTERS filterStatus(o)
;

DESIGN orders {
    topFilters1 {
        MOVE PROPERTY(nameFilterStatus()) { charWidth = 15; flex = 0; }
    }
}

status(Purchase.OrderDetail d) = status(order(d));
nameStatus 'Статус' (Purchase.OrderDetail d) = name(status(d));
invoices 'Накладные' (Purchase.OrderDetail d) = invoices(order(d));
filterStatus(Purchase.OrderDetail d) = filterStatus(order(d));
filterDateFrom(Purchase.OrderDetail d) = filterDateFrom(order(d));
filterDateTo(Purchase.OrderDetail d) = filterDateTo(order(d));
filterSupplier(Purchase.OrderDetail d) = filterSupplier(order(d));
filterSupplierStock(Purchase.OrderDetail d) = filterSupplierStock(order(d));
filterCustomer(Purchase.OrderDetail d) = filterCustomer(order(d));
filterCustomerStock(Purchase.OrderDetail d) = filterCustomerStock(order(d));
filterCustomUser(Purchase.OrderDetail d) = filterCustomUser(order(d));
filterComputer(Purchase.OrderDetail d) = filterComputer(order(d));

codeSupplier 'Код поставщика' (LegalEntity l) = id(l);
idNameSupplier 'Поставщик' (LegalEntity l) = CONCAT ' — ', id(l), name(l);
idNameSupplier 'Поставщик' (Purchase.OrderDetail d) = idNameSupplier(supplier(order(d)));

idNameCustomerStock 'Склад покупателя' (Purchase.OrderDetail d) = CONCAT ' — ', id(customerStock(order(d))), nameCustomerStock(d);
idNameStock 'Склад' (Stock st) = CONCAT ' — ', id(st), name(st);

receivedPrice 'Цена из приходной накладной (с НДС)' (Purchase.OrderDetail d) =
    GROUP LAST invoicePrice(Purchase.InvoiceDetail id) IF countInvoiceDetail(order(d), invoice(id)) AND sku(id) = sku(d) ORDER dateTime(id), id;

specPrice 'Цена из спецификации' (Purchase.OrderDetail d) =
    prevPriceA(priceListType(d), sku(d), customerStock(d), supplier(d), dateTime(d));

orderSum 'Сумма заказа (с НДС)' (Purchase.OrderDetail d) = invoiceSum(d);

receivedSum 'Сумма из приходной накладной (с НДС)' (Purchase.OrderDetail d) =
    shipped(d) * receivedPrice(d);

dateConfirmed 'Дата подтверждения' = DATA DATE (Purchase.Order);
dateConfirmed 'Дата подтверждения' (Purchase.OrderDetail d) = dateConfirmed(order(d));
dateUnconfirmed 'Дата неподтв. заказа' (Purchase.OrderDetail d) = date(order(d));

WHEN SET(isConfirmed(Purchase.Order o)) AND NOT dateConfirmed(o) DO
    dateConfirmed(o) <- currentDate();

EXTEND FORM userOrder
    PROPERTIES(o) dateConfirmed
;

DESIGN userOrder {
    headerExtraParams {
        NEW headerDateConfirmed {
            caption = 'Подтверждение';
            MOVE PROPERTY(dateConfirmed(o));
        }
    }
}

EXTEND FORM orders
    PROPERTIES(o) READONLYIF isReadonly() BACKGROUND backgroundSku(o) dateConfirmed AFTER closeDate(o)
;

discrepancyOrderConfirm 'Расхождение заказ/подтв.' (Purchase.OrderDetail d) =
    ((OVERRIDE originalQuantity(d), quantity(d)) (-) quantity(d)) IF isConfirmed(d);

discrepancyConfirmReceived 'Расхождение подтв./приход' (Purchase.OrderDetail d) =
    quantity(d) (-) shipped(d);

numberInvoiceDetail 'Номер накладной' (Purchase.InvoiceDetail id) = number(invoice(id));
dateInvoiceDetail 'Дата накладной' (Purchase.InvoiceDetail id) = date(invoice(id));
quantityInvoiceDetail 'Кол-во в накладной' (Purchase.InvoiceDetail id) = quantity(id);
priceInvoiceDetail 'Цена в накладной (с НДС)' (Purchase.InvoiceDetail id) = invoicePrice(id);
sumInvoiceDetail 'Сумма в накладной (с НДС)' (Purchase.InvoiceDetail id) = invoiceSum(id);

reportDateFrom 'Дата с' = DATA LOCAL DATE();
reportDateTo 'Дата по' = DATA LOCAL DATE();

initReportDates() {
    reportDateFrom() <- currentDate();
    reportDateTo() <- currentDate();
}

reportStatus = DATA LOCAL StatusOrder();
nameReportStatus 'Статус' = name(reportStatus());

inReportSupplier 'Отм.' = DATA LOCAL BOOLEAN (LegalEntity);
anyReportSupplier() = GROUP MAX inReportSupplier(LegalEntity l);
nameReportSuppliers 'Поставщики' () = OVERRIDE
    (GROUP CONCAT name(LegalEntity l) IF inReportSupplier(l), ', ' ORDER name(l), l),
    'Все поставщики' CHARWIDTH 30;

reportSupplierList = DATA LOCAL LegalEntityList();
nameReportSupplierList 'Список организаций' () = name(reportSupplierList());

changeReportSupplierList 'Список организаций'() {
    DIALOG legalEntityLists OBJECTS o INPUT DO {
        reportSupplierList() <- o;
        inReportSupplier(LegalEntity s) <- in(s, o);
    }
}

deleteReportSupplierList 'Сбросить список'() {
    reportSupplierList() <- NULL;
    inReportSupplier(LegalEntity l) <- NULL;
} ASON CONTEXTMENU nameReportSupplierList;

selectAllReportSuppliers 'Выбрать всех' () {
    reportSupplierList() <- NULL;
    inReportSupplier(LegalEntity l) <- TRUE WHERE isSupplier(l) AND active(l);
} ASON CONTEXTMENU nameReportSuppliers;

deselectAllReportSuppliers 'Сбросить всех' () {
    reportSupplierList() <- NULL;
    inReportSupplier(LegalEntity l) <- NULL;
} ASON CONTEXTMENU nameReportSuppliers;

FORM dialogReportSuppliers 'Выбор поставщиков'
    TREE legalEntityGroupTree lg = LegalEntityGroup PARENT parent(lg)
    PROPERTIES READONLY lgTreeName = name(lg)

    OBJECTS o = LegalEntity
    PROPERTIES(o) inReportSupplier READONLYIF reportSupplierList()
    PROPERTIES(o) READONLY name, id SHOWIF showIDs(), fullName, shortNameOwnership,
        nameLegalEntityGroup, address, phone
    PROPERTIES changeReportSupplierList() TOOLBAR
    ORDERS name(o)
    FILTERGROUP inactiveSupplier FILTER 'Активные' active(o) 'shift F10' DEFAULT
    FILTERGROUP inReportSupplierFilter FILTER 'Отмеченные' inReportSupplier(o) 'F9'
    FILTERS isSupplier(o)
    FILTERS isParent(legalEntityGroup(o), lg) OR
        o IS LegalEntity AND NOT lg IS LegalEntityGroup OR
        o IS LegalEntity AND lg IS LegalEntityGroup AND NOT legalEntityGroup(o)
;

DESIGN dialogReportSuppliers {
    BOX {
        NEW topContainer {
            horizontal = TRUE;
            fill = 1;
            MOVE BOX(TREE legalEntityGroupTree) { caption = 'Группы организаций'; }
            MOVE BOX(o) { fill = 3; GRID(o) { defaultComponent = TRUE; } }
        }
        MOVE TOOLBARBOX;
    }
}

changeReportStocks() { DIALOG dialogStocksSaleReportRu; }

CLASS ReportSkuFilterType 'Тип фильтра по товарам' {
    sku 'Товары',
    skuGroups 'Товарные группы',
    skuLists 'Списки товаров'
}

FORM reportSkuFilterType 'Типы фильтра по товарам'
    OBJECTS t = ReportSkuFilterType
    PROPERTIES(t) READONLY '' = staticCaption
    LIST ReportSkuFilterType OBJECT t
;

inReportSkuList 'Отм.' = DATA LOCAL BOOLEAN (List);
anyReportSkuList() = GROUP MAX inReportSkuList(List l);
nameReportSkuLists 'Списки товаров' () = GROUP CONCAT name(List l) IF inReportSkuList(l), ', ' ORDER name(l), l CHARWIDTH 30;

inReportSku 'Отм.' = DATA LOCAL BOOLEAN (Sku);

deleteReportSkuLists 'Сбросить список' () {
    inReportSkuList(List l) <- NULL;
    inReportSku(Sku s) <- NULL;
} ASON CONTEXTMENU nameReportSkuLists;

inReportSkuGroup 'Отм.' = DATA LOCAL BOOLEAN (SkuGroup);
anyReportSkuGroup() = GROUP MAX inReportSkuGroup(SkuGroup g);
nameReportSkuGroups 'Товарные группы' () = GROUP CONCAT name(SkuGroup o) IF inReportSkuGroup(o) AND NOT inReportSkuGroup(parent(o)), '; ' ORDER o CHARWIDTH 30;

deleteReportSkuGroups 'Сбросить группы' () {
    inReportSkuGroup(SkuGroup g) <- NULL;
} ASON CONTEXTMENU nameReportSkuGroups;

inReportSkuByGroup(Sku s) = GROUP MAX inReportSkuGroup(SkuGroup g) IF isParent(g, s);

FORM selectReportSku 'Выбор товаров'
    TREE skuTree sg = SkuGroup PARENT parent(sg)
    PROPERTIES READONLY order(sg), skuGroupName = name(sg)
    FILTERGROUP inactive FILTER 'Активные' active(sg) 'F6' DEFAULT
    ORDERS order(sg), skuGroupName

    OBJECTS s = Sku
    PROPERTIES(s) inReportSku
    PROPERTIES(s) READONLY id SHOWIF showIDs()
    PROPERTIES(s) READONLY name, idBarcode, shortNameUOM
    FILTERS isParent(sg, s), name(s)
    ORDERS name(s)
;

FORM dialogReportSkuGroups 'Выбор товарных групп'
    TREE skuGroupTree sg = SkuGroup PARENT parent(sg)
    PROPERTIES(sg) inReportSkuGroup
    PROPERTIES READONLY order(sg), sgName = name(sg)
    FILTERGROUP inactive FILTER 'Активные' active(sg) 'F6' DEFAULT
    ORDERS order(sg), sgName
;

FORM dialogReportSkuLists 'Выбор списков товаров'
    OBJECTS o = List
    PROPERTIES(o) inReportSkuList
    PROPERTIES(o) READONLY name
    ORDERS name(o)
;

selectReportSkus 'Фильтр по товарам' () {
    DIALOG reportSkuFilterType OBJECTS t INPUT DO {
        CASE
            WHEN t = ReportSkuFilterType.sku THEN {
                inReportSkuList(List l) <- NULL;
                inReportSkuGroup(SkuGroup g) <- NULL;
                SHOW selectReportSku;
            }
            WHEN t = ReportSkuFilterType.skuGroups THEN {
                inReportSkuList(List l) <- NULL;
                inReportSku(Sku s) <- NULL;
                SHOW dialogReportSkuGroups;
            }
            WHEN t = ReportSkuFilterType.skuLists THEN {
                inReportSkuGroup(SkuGroup g) <- NULL;
                DIALOG dialogReportSkuLists DO {
                    inReportSku(Sku s) <- NULL;
                    FOR inReportSkuList(list(ListDetail ld)) AND Sku sk = sku(ld) DO
                        inReportSku(sk) <- TRUE;
                }
            };
    }
}

selectedReportSkuNames = GROUP CONCAT name(Sku s) IF inReportSku(s), '; ' ORDER name(s), s;
skuNamesFromReportGroups = GROUP CONCAT name(Sku s) IF inReportSkuByGroup(s) AND name(s), '; ' ORDER name(s), s;
reportInSkus 'Товары' = OVERRIDE selectedReportSkuNames(), skuNamesFromReportGroups();

anyReportSkuSelected() = (GROUP MAX inReportSku(Sku s)) OR anyReportSkuGroup();

inReportDateFrom(Purchase.OrderDetail d) = date(order(d)) >= reportDateFrom() OR (d IS Purchase.OrderDetail AND NOT reportDateFrom());
inReportDateTo(Purchase.OrderDetail d) = date(order(d)) <= reportDateTo() OR (d IS Purchase.OrderDetail AND NOT reportDateTo());
inReportStatus(Purchase.OrderDetail d) = status(order(d)) == reportStatus() OR (d IS Purchase.OrderDetail AND NOT reportStatus());
inReportSupplierFilter(Purchase.OrderDetail d) =
    NOT anyReportSupplier() OR inReportSupplier(supplier(order(d)));
inReportStockFilter(Purchase.OrderDetail d) = inSaleReport(customerStock(order(d)));
inReportSkuFilter(Purchase.OrderDetail d) = NOT anyReportSkuSelected() OR inReportSku(sku(d)) OR inReportSkuByGroup(sku(d));

deliveryDateChanged (Order order) = shipmentDate(order) AND date(order) AND shipmentDate(order) != date(order);

countDeliveryDateChanged (LegalEntity supplier, DATE dateFrom, DATE dateTo) =
    GROUP SUM 1 IF deliveryDateChanged(Order order)
        AND date(order) >= dateFrom
        AND date(order) <= dateTo
        AND isPosted(order)
    BY supplier(order);

countDeliveryDateChangedZ 'Число изменений даты поставки' (LegalEntity s, DATE dFrom, DATE dTo) =
    OVERRIDE countDeliveryDateChanged(s, dFrom, dTo), 0;

quantityOrder (LegalEntity supplier, DATE dateFrom, DATE dateTo) =
    GROUP SUM quantityOrderDetail(Purchase.Order order)
        IF date(order) >= dateFrom AND date(order) <= dateTo AND isPosted(order)
    BY supplier(order);

quantityShippedSupplier (LegalEntity supplier, DATE dateFrom, DATE dateTo) =
    GROUP SUM shippedShipmentDetail(Purchase.Order order)
        IF date(order) >= dateFrom AND date(order) <= dateTo AND isPosted(order)
    BY supplier(order);

sumOrder (LegalEntity supplier, DATE dateFrom, DATE dateTo) =
    GROUP SUM sumOrderDetail(Purchase.Order order)
        IF date(order) >= dateFrom AND date(order) <= dateTo AND isPosted(order)
    BY supplier(order);

quantityOrderZ 'Количество (заказ)' (LegalEntity s, DATE dFrom, DATE dTo) =
    OVERRIDE quantityOrder(s, dFrom, dTo), 0.0;

quantityShippedSupplierZ 'Количество (приход)' (LegalEntity s, DATE dFrom, DATE dTo) =
    OVERRIDE quantityShippedSupplier(s, dFrom, dTo), 0.0;

sumOrderZ 'Сумма (заказ)' (LegalEntity s, DATE dFrom, DATE dTo) =
    OVERRIDE sumOrder(s, dFrom, dTo), 0.0;

sumShippedZ 'Сумма (приход)' (LegalEntity s, DATE dFrom, DATE dTo) =
    OVERRIDE sumShipped(s, dFrom, dTo), 0.0;

percentQuantityExecutionZ '% исполнения (кол-во)' (LegalEntity s, DATE dFrom, DATE dTo) =
    OVERRIDE percentQuantityExecution(s, dFrom, dTo), 0.0;

percentSumExecutionZ '% исполнения (сумма)' (LegalEntity s, DATE dFrom, DATE dTo) =
    OVERRIDE percentSumExecution(s, dFrom, dTo), 0.0;

anyReportStock() = GROUP MAX inSaleReport(Stock s);

orderHasFilteredSku(Purchase.Order o) = NOT anyReportSkuSelected() OR
    (GROUP MAX TRUE IF order(Purchase.OrderDetail d) = o AND (inReportSku(sku(d)) OR inReportSkuByGroup(sku(d))));

quantityOrderFiltered(LegalEntity supplier, DATE dateFrom, DATE dateTo) =
    GROUP SUM quantity(Purchase.OrderDetail d)
        IF date(order(d)) >= dateFrom AND date(order(d)) <= dateTo AND isPosted(order(d))
            AND (NOT anyReportStock() OR inSaleReport(customerStock(order(d))))
            AND (NOT anyReportSkuSelected() OR inReportSku(sku(d)) OR inReportSkuByGroup(sku(d)))
            AND (status(order(d)) == reportStatus() OR NOT reportStatus())
    BY supplier(order(d));

quantityOrderFilteredZ 'Количество (заказ)' (LegalEntity s, DATE dFrom, DATE dTo) =
    OVERRIDE quantityOrderFiltered(s, dFrom, dTo), 0.0;

quantityShippedFiltered(LegalEntity supplier, DATE dateFrom, DATE dateTo) =
    GROUP SUM shipped(Purchase.OrderDetail d)
        IF date(order(d)) >= dateFrom AND date(order(d)) <= dateTo AND isPosted(order(d))
            AND (NOT anyReportStock() OR inSaleReport(customerStock(order(d))))
            AND (NOT anyReportSkuSelected() OR inReportSku(sku(d)) OR inReportSkuByGroup(sku(d)))
            AND (status(order(d)) == reportStatus() OR NOT reportStatus())
    BY supplier(order(d));

quantityShippedFilteredZ 'Количество (приход)' (LegalEntity s, DATE dFrom, DATE dTo) =
    OVERRIDE quantityShippedFiltered(s, dFrom, dTo), 0.0;

percentQuantityExecutionFiltered(LegalEntity s, DATE dFrom, DATE dTo) =
    (NUMERIC[18,4](quantityShippedFiltered(s, dFrom, dTo)) * 100.0 / quantityOrderFiltered(s, dFrom, dTo)) IF quantityOrderFiltered(s, dFrom, dTo);

percentQuantityExecutionFilteredZ '% исполнения (кол-во)' (LegalEntity s, DATE dFrom, DATE dTo) =
    OVERRIDE percentQuantityExecutionFiltered(s, dFrom, dTo), 0.0;

sumOrderFiltered(LegalEntity supplier, DATE dateFrom, DATE dateTo) =
    GROUP SUM invoiceSum(Purchase.OrderDetail d)
        IF date(order(d)) >= dateFrom AND date(order(d)) <= dateTo AND isPosted(order(d))
            AND (NOT anyReportStock() OR inSaleReport(customerStock(order(d))))
            AND (NOT anyReportSkuSelected() OR inReportSku(sku(d)) OR inReportSkuByGroup(sku(d)))
            AND (status(order(d)) == reportStatus() OR NOT reportStatus())
    BY supplier(order(d));

sumOrderFilteredZ 'Сумма (заказ)' (LegalEntity s, DATE dFrom, DATE dTo) =
    OVERRIDE sumOrderFiltered(s, dFrom, dTo), 0.0;

sumShippedFiltered(LegalEntity supplier, DATE dateFrom, DATE dateTo) =
    GROUP SUM receivedSum(Purchase.OrderDetail d)
        IF date(order(d)) >= dateFrom AND date(order(d)) <= dateTo AND isPosted(order(d))
            AND (NOT anyReportStock() OR inSaleReport(customerStock(order(d))))
            AND (NOT anyReportSkuSelected() OR inReportSku(sku(d)) OR inReportSkuByGroup(sku(d)))
            AND (status(order(d)) == reportStatus() OR NOT reportStatus())
    BY supplier(order(d));

sumShippedFilteredZ 'Сумма (приход)' (LegalEntity s, DATE dFrom, DATE dTo) =
    OVERRIDE sumShippedFiltered(s, dFrom, dTo), 0.0;

percentSumExecutionFiltered(LegalEntity s, DATE dFrom, DATE dTo) =
    (sumShippedFiltered(s, dFrom, dTo) * 100.0 / sumOrderFiltered(s, dFrom, dTo)) IF sumOrderFiltered(s, dFrom, dTo);

percentSumExecutionFilteredZ '% исполнения (сумма)' (LegalEntity s, DATE dFrom, DATE dTo) =
    OVERRIDE percentSumExecutionFiltered(s, dFrom, dTo), 0.0;

countDeliveryDateChangedFiltered(LegalEntity supplier, DATE dateFrom, DATE dateTo) =
    GROUP SUM 1 IF deliveryDateChanged(Purchase.Order order)
        AND date(order) >= dateFrom AND date(order) <= dateTo AND isPosted(order)
        AND (NOT anyReportStock() OR inSaleReport(customerStock(order)))
        AND orderHasFilteredSku(order)
        AND (status(order) == reportStatus() OR NOT reportStatus())
    BY supplier(order);

countDeliveryDateChangedFilteredZ 'Число изменений даты поставки' (LegalEntity s, DATE dFrom, DATE dTo) =
    OVERRIDE countDeliveryDateChangedFiltered(s, dFrom, dTo), 0;

quantityOrderFilteredReport 'Количество (заказ)' (LegalEntity s) = quantityOrderFilteredZ(s, reportDateFrom(), reportDateTo());
quantityShippedFilteredReport 'Количество (приход)' (LegalEntity s) = quantityShippedFilteredZ(s, reportDateFrom(), reportDateTo());
percentQuantityExecutionFilteredReport '% исполнения (кол-во)' (LegalEntity s) = percentQuantityExecutionFilteredZ(s, reportDateFrom(), reportDateTo());
sumOrderFilteredReport 'Сумма (заказ)' (LegalEntity s) = sumOrderFilteredZ(s, reportDateFrom(), reportDateTo());
sumShippedFilteredReport 'Сумма (приход)' (LegalEntity s) = sumShippedFilteredZ(s, reportDateFrom(), reportDateTo());
percentSumExecutionFilteredReport '% исполнения (сумма)' (LegalEntity s) = percentSumExecutionFilteredZ(s, reportDateFrom(), reportDateTo());
countDeliveryDateChangedFilteredReport 'Число изменений даты поставки' (LegalEntity s) = countDeliveryDateChangedFilteredZ(s, reportDateFrom(), reportDateTo());
hasDataFilteredReport(LegalEntity s) = quantityOrderFiltered(s, reportDateFrom(), reportDateTo()) OR quantityShippedFiltered(s, reportDateFrom(), reportDateTo());

deficiencySum 'Сумма недопоставки' (Purchase.OrderDetail d) = receivedSum(d) (-) orderSum(d);

EXTEND FORM executionSupplierOrder
    PROPERTIES READONLY countDeliveryDateChangedZ(s, dFrom, dTo)
;

FORM execSupplierReportPrint 'Отчет по исполнению заказов поставщиками'
    OBJECTS dFrom = DATE, dTo = DATE

    OBJECTS s = LegalEntity
    PROPERTIES(s) READONLY idNameSupplier, codeSupplier, name
    PROPERTIES(s, dFrom, dTo) READONLY
    quantityOrderFilteredZ, quantityShippedFilteredZ, percentQuantityExecutionFilteredZ,
        sumOrderFilteredZ, sumShippedFilteredZ, percentSumExecutionFilteredZ,
        countDeliveryDateChangedFilteredZ
    FILTERS isSupplier(s),
        NOT anyReportSupplier() OR inReportSupplier(s),
        quantityOrderFiltered(s, dFrom, dTo) OR quantityShippedFiltered(s, dFrom, dTo)
;

execSupplierReportPrint 'Отчет по исполнению' () {
    PRINT execSupplierReportPrint OBJECTS dFrom = reportDateFrom(), dTo = reportDateTo() XLSX TO printReportFile;
    buildPrintReportFileName('execSupplierReportPrint', 'Отчет по исполнению заказов поставщиками');
    open(printReportFile(), builtPrintReportFileName());
} IMAGE 'print.png';

FORM printPurchaseOrderReport 'Отчет по заказам поставщикам (печать)'
    OBJECTS d = Purchase.OrderDetail
    PROPERTIES(d) READONLY idNameSupplier, idNameCustomerStock, number, date, dateConfirmed, shipmentDate, nameStatus,
        idSku, nameSku,
        originalQuantity, quantity, shipped,
        discrepancyOrderConfirm, discrepancyConfirmReceived,
        invoicePrice, specPrice, receivedPrice,
        orderSum, invoiceSum, receivedSum, deficiencySum,
        invoices
    PROPERTIES() reportDateFrom, reportDateTo
    ORDERS idNameSupplier(d), idNameCustomerStock(d), date(d)
    FILTERS isPosted(order(d)),
        inReportDateFrom(d),
        inReportDateTo(d),
        inReportStatus(d),
        inReportSupplierFilter(d),
        inReportStockFilter(d),
        inReportSkuFilter(d)
;

@definePrintReport(printPurchaseOrderReport, 'Отчет по заказам поставщикам');

FORM purchaseOrderReportForm 'Отчет по заказам поставщикам'
    PROPERTIES() reportDateFrom, reportDateTo, nameReportStatus
    PROPERTIES() nameReportSupplierList READONLY SHOWIF reportSupplierList()
    PROPERTIES() nameReportSuppliers ON CHANGE { DIALOG dialogReportSuppliers; } READONLYIF reportSupplierList()
    PROPERTIES nameStockList() READONLY SHOWIF stockList()
    PROPERTIES reportStocks 'Подразделения' = inSaleReportStocks() ON CHANGE changeReportStocks() READONLYIF stockList()
    PROPERTIES() nameReportSkuLists READONLY SHOWIF anyReportSkuList()
    PROPERTIES reportSelectedSkuGroups 'Товарные группы' = nameReportSkuGroups() READONLY SHOWIF anyReportSkuGroup()
    PROPERTIES reportSkus 'Товары' = reportInSkus() ON CHANGE selectReportSkus() READONLYIF anyReportSkuList() OR anyReportSkuGroup()

    OBJECTS d = Purchase.OrderDetail
    PROPERTIES(d) READONLY idNameSupplier, idNameCustomerStock, number, date, dateConfirmed, shipmentDate, nameStatus,
        idSku, nameSku,
        originalQuantity, quantity, shipped,
        discrepancyOrderConfirm, discrepancyConfirmReceived,
        invoicePrice, specPrice, receivedPrice,
        orderSum, invoiceSum, receivedSum, deficiencySum,
        invoices
    ORDERS idNameSupplier(d), idNameCustomerStock(d), date(d)
    FILTERS isPosted(order(d)),
        inReportDateFrom(d),
        inReportDateTo(d),
        inReportStatus(d),
        inReportSupplierFilter(d),
        inReportStockFilter(d),
        inReportSkuFilter(d)

    OBJECTS s = LegalEntity
    PROPERTIES(s) READONLY idNameSupplier
    PROPERTIES(s) READONLY
    quantityOrderFilteredReport, quantityShippedFilteredReport, percentQuantityExecutionFilteredReport,
        sumOrderFilteredReport, sumShippedFilteredReport, percentSumExecutionFilteredReport,
        countDeliveryDateChangedFilteredReport
    ORDERS idNameSupplier(s)
    FILTERS isSupplier(s),
        NOT anyReportSupplier() OR inReportSupplier(s),
        hasDataFilteredReport(s)

    EVENTS ON INIT initReportDates()
;

EXTEND FORM purchaseOrderReportForm
    PROPERTIES() DISABLEIF NOT reportDateFrom() OR NOT reportDateTo() printPurchaseOrderReport, execSupplierReportPrint
;

NAVIGATOR {
    purchasesReports {
        NEW purchaseOrderReportForm;
    }
}

inReportDateFromOrder(Purchase.InvoiceDetail d) = date(d) >= reportDateFrom() OR (d IS Purchase.InvoiceDetail AND NOT reportDateFrom());
inReportDateToOrder(Purchase.InvoiceDetail d) = date(d) <= reportDateTo() OR (d IS Purchase.InvoiceDetail AND NOT reportDateTo());
inReportSupplierFilterOrder(Purchase.InvoiceDetail d) = NOT anyReportSupplier() OR inReportSupplier(supplier(d));
inReportStockFilterOrder(Purchase.InvoiceDetail d) = inSaleReport(customerStock(d));
inReportSkuFilterOrder(Purchase.InvoiceDetail d) = NOT anyReportSkuSelected() OR inReportSku(sku(d)) OR inReportSkuByGroup(sku(d));

quantityUnconfirmed 'Количество неподтвержд.' = DATA LOCAL NUMERIC[16,5] (Sku, LegalEntity, Stock);
quantityAgreed 'Количество согласованное' = DATA LOCAL NUMERIC[16,5] (Sku, LegalEntity, Stock);
quantityShipped 'Количество получено' = DATA LOCAL NUMERIC[16,5] (Sku, LegalEntity, Stock);
priceContract 'Цена по договору' = DATA LOCAL NUMERIC[16,4] (Sku, LegalEntity, Stock);
sumPurchase 'Сумма прихода' = DATA LOCAL NUMERIC[16,4] (Sku, LegalEntity, Stock);

FORM printPurchaseOrderReportSummary
    OBJECTS s = (s = Sku, l = LegalEntity, st = Stock)
    PROPERTIES(s) name, id
    PROPERTIES(l) idNameSupplier, name
    PROPERTIES(st) idNameStock
    PROPERTIES() reportDateFrom, reportDateTo
    PROPERTIES(s, l, st) quantityUnconfirmed, quantityAgreed, quantityShipped, priceContract, sumPurchase
    ORDERS idNameSupplier(l), idNameStock(st), name(s)
    FILTERS quantityUnconfirmed(s, l, st) OR quantityAgreed(s, l, st) OR quantityShipped(s, l, st) OR sumPurchase(s, l, st)
    REPORT template()
;

orderReceiptReconSummary 'Акт сверки (сводная)' () {
    LOCAL lastOrderDetail = Purchase.OrderDetail (Sku, LegalEntity, Stock);

    quantityUnconfirmed(Sku sk, LegalEntity l, Stock st) <- NULL;
    quantityAgreed(Sku sk, LegalEntity l, Stock st) <- NULL;
    quantityShipped(Sku sk, LegalEntity l, Stock st) <- NULL;
    priceContract(Sku sk, LegalEntity l, Stock st) <- NULL;
    sumPurchase(Sku sk, LegalEntity l, Stock st) <- NULL;

    quantityUnconfirmed(Sku sk, LegalEntity l, Stock st) <- GROUP SUM quantity(Purchase.OrderDetail d) IF isPosted(order(d)) AND NOT isConfirmed(d) AND
        sku(d) = sk AND supplier(d) = l AND customerStock(d) = st AND
        inReportDateFrom(d) AND inReportDateTo(d) AND inReportStatus(d) AND
        inReportSupplierFilter(d) AND inReportStockFilter(d) AND inReportSkuFilter(d);

    quantityAgreed(Sku sk, LegalEntity l, Stock st) <- GROUP SUM quantity(Purchase.OrderDetail d) IF isPosted(order(d)) AND isConfirmed(d) AND
        sku(d) = sk AND supplier(d) = l AND customerStock(d) = st AND
        inReportDateFrom(d) AND inReportDateTo(d) AND inReportStatus(d) AND
        inReportSupplierFilter(d) AND inReportStockFilter(d) AND inReportSkuFilter(d);

    quantityShipped(Sku sk, LegalEntity l, Stock st) <- GROUP SUM shipped(Purchase.OrderDetail d) IF isPosted(order(d)) AND
        sku(d) = sk AND supplier(d) = l AND customerStock(d) = st AND
        inReportDateFrom(d) AND inReportDateTo(d) AND inReportStatus(d) AND
        inReportSupplierFilter(d) AND inReportStockFilter(d) AND inReportSkuFilter(d);

    lastOrderDetail(Sku sk, LegalEntity l, Stock st) <- GROUP LAST Purchase.OrderDetail d ORDER dateTime(d), d WHERE isPosted(order(d)) AND
        sku(d) = sk AND supplier(d) = l AND customerStock(d) = st AND
        inReportDateFrom(d) AND inReportDateTo(d) AND inReportStatus(d) AND
        inReportSupplierFilter(d) AND inReportStockFilter(d) AND inReportSkuFilter(d);

    priceContract(Sku sk, LegalEntity l, Stock st) <-
    prevPriceA(priceListType(lastOrderDetail(sk, l, st)), sk, st, l, dateTime(lastOrderDetail(sk, l, st)));

    sumPurchase(Sku sk, LegalEntity l, Stock st) <- GROUP SUM invoiceSum(Purchase.InvoiceDetail d) IF
        sku(d) = sk AND supplier(d) = l AND customerStock(d) = st AND
            inReportDateFromOrder(d) AND inReportDateToOrder(d) AND
            inReportSupplierFilterOrder(d) AND inReportStockFilterOrder(d) AND inReportSkuFilterOrder(d);

    template() <- 'OrderReceiptReconSummaryGestori.jrxml';
    PRINT printPurchaseOrderReportSummary XLSX TO printReportFile;
    buildPrintReportFileName('printPurchaseOrderReportSummary', 'Акт сверки (сводная)');
    open(printReportFile(), builtPrintReportFileName());
} IMAGE 'print.png';

odRpt = DATA LOCAL Purchase.OrderDetail (INTEGER);
idRpt = DATA LOCAL Purchase.InvoiceDetail (INTEGER);

supRpt(INTEGER i) = idNameSupplier(odRpt(i));
stRpt(INTEGER i) = idNameCustomerStock(odRpt(i));
numRpt(INTEGER i) = number(odRpt(i));
dtUncRpt(INTEGER i) = dateUnconfirmed(odRpt(i));
dtCnfRpt(INTEGER i) = dateConfirmed(odRpt(i));
dtShpRpt(INTEGER i) = shipmentDate(odRpt(i));
statRpt(INTEGER i) = nameStatus(odRpt(i));
idSkRpt(INTEGER i) = idSku(odRpt(i));
nmSkRpt(INTEGER i) = nameSku(odRpt(i));
origQtyRpt(INTEGER i) = originalQuantity(odRpt(i));
qtyRpt(INTEGER i) = quantity(odRpt(i));
shpRpt(INTEGER i) = shipped(odRpt(i));
discOCRpt(INTEGER i) = discrepancyOrderConfirm(odRpt(i));
discCRRpt(INTEGER i) = discrepancyConfirmReceived(odRpt(i));
invPrcRpt(INTEGER i) = invoicePrice(odRpt(i));
specPrcRpt(INTEGER i) = specPrice(odRpt(i));
rcvPrcRpt(INTEGER i) = receivedPrice(odRpt(i));
ordSumRpt(INTEGER i) = orderSum(odRpt(i));
rcvSumRpt(INTEGER i) = receivedSum(odRpt(i));
defSumRpt 'Сумма недопоставки' (INTEGER i) = rcvSumRpt(i) (-) ordSumRpt(i);

invNumRpt(INTEGER i) = numberInvoiceDetail(idRpt(i));
invDtRpt(INTEGER i) = dateInvoiceDetail(idRpt(i));
invQtyRpt(INTEGER i) = quantityInvoiceDetail(idRpt(i));
invPrcDtRpt(INTEGER i) = priceInvoiceDetail(idRpt(i));
invSumRpt(INTEGER i) = sumInvoiceDetail(idRpt(i));

FORM printPurchaseOrderReportDetailed 'Акт сверки (детальная)'
    OBJECTS d = INTEGER
    PROPERTIES() reportDateFrom, reportDateTo
    PROPERTIES(d) READONLY
    supRpt, stRpt, numRpt,
        dtUncRpt, dtCnfRpt, dtShpRpt,
        statRpt, idSkRpt, nmSkRpt,
        origQtyRpt, qtyRpt, shpRpt,
        discOCRpt, discCRRpt,
        invPrcRpt, specPrcRpt, rcvPrcRpt,
        ordSumRpt, rcvSumRpt, defSumRpt,
        invNumRpt, invDtRpt, invQtyRpt, invPrcDtRpt, invSumRpt
    FILTERS odRpt(d)
    ORDERS stRpt(d), supRpt(d), dtUncRpt(d), numRpt(d), idSkRpt(d), invDtRpt(d)
;

orderReceiptReconDetailed 'Акт сверки (детальная по заказам)' () {
    odRpt(INTEGER i) <- NULL;
    idRpt(INTEGER i) <- NULL;

    LOCAL idx = INTEGER();
    idx() <- 0;

    FOR isPosted(order(Purchase.OrderDetail od)) AND inReportStatus(od) AND inReportDateFrom(od) AND inReportDateTo(od) AND
        inReportSupplierFilter(od) AND inReportStockFilter(od) AND inReportSkuFilter(od)
        ORDER idNameCustomerStock(od), idNameSupplier(od), dateUnconfirmed(od), number(od), idSku(od), od DO {

        LOCAL hasInv = BOOLEAN();
        hasInv() <- NULL;

        FOR countInvoiceDetail(order(od), invoice(Purchase.InvoiceDetail id)) AND sku(id) = sku(od)
            ORDER dateInvoiceDetail(id), id DO {
            hasInv() <- TRUE;
            idx() <- idx() + 1;
            odRpt(idx()) <- od;
            idRpt(idx()) <- id;
        }

        IF NOT hasInv() THEN {
            idx() <- idx() + 1;
            odRpt(idx()) <- od;
        }
    }

    PRINT printPurchaseOrderReportDetailed XLSX TO printReportFile;
    buildPrintReportFileName('printPurchaseOrderReportDetailed', 'Акт сверки (детальная)');
    open(printReportFile(), builtPrintReportFileName());
} IMAGE 'print.png';

EXTEND FORM purchaseOrderReportForm
    PROPERTIES() DISABLEIF NOT reportDateFrom() OR NOT reportDateTo() orderReceiptReconDetailed, orderReceiptReconSummary
;

DESIGN purchaseOrderReportForm {
    NEW filters FIRST {
        alignment = STRETCH;
        NEW topRow {
            horizontal = TRUE;
            MOVE PROPERTY(reportDateFrom());
            MOVE PROPERTY(reportDateTo());
            MOVE PROPERTY(nameReportStatus()) { fill = 1; }
            MOVE PROPERTY(printPurchaseOrderReport()) { valueClass = 'btn-primary'; }
            MOVE PROPERTY(execSupplierReportPrint()) { valueClass = 'btn-primary'; }
            MOVE PROPERTY(orderReceiptReconDetailed()) { valueClass = 'btn-primary'; }
            MOVE PROPERTY(orderReceiptReconSummary()) { valueClass = 'btn-primary'; }
        }
        MOVE PROPERTY(nameReportSupplierList()) { alignment = STRETCH; }
        MOVE PROPERTY(nameReportSuppliers()) { alignment = STRETCH; }
        MOVE PROPERTY(nameStockList()) { alignment = STRETCH; }
        MOVE PROPERTY(reportStocks) { alignment = STRETCH; }
        MOVE PROPERTY(nameReportSkuLists()) { alignment = STRETCH; }
        MOVE PROPERTY(reportSelectedSkuGroups) { alignment = STRETCH; }
        MOVE PROPERTY(reportSkus) { alignment = STRETCH; }
    }
    OBJECTS {
        NEW tabs {
            tabbed = TRUE;
            fill = 1;
            MOVE BOX(d) { caption = 'Детали заказов'; }
            MOVE BOX(s) { caption = 'Исполнение по поставщикам'; }
        }
    }
}