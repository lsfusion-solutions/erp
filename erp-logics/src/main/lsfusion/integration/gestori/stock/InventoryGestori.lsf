MODULE InventoryGestori;

REQUIRE SaleReportsRu, DateSkuLedger, PurchaseReturnShipment, SaleReturnShipment, RangeSimple, RangeLevel, ItemGestori;

NAMESPACE Inventory;

dateFrom 'Дата (с)' = DATA LOCAL DATE ();
dateTo 'Дата (по)' = DATA LOCAL DATE ();

initDates() {
    dateFrom() <- currentDate();
    dateTo() <- currentDate();
}

titleInterval = 'за период с ' + toDateDDMMYYYY(dateFrom()) + ' по ' + toDateDDMMYYYY(dateTo());

displayName 'Подразделение' (Stock o) = CONCAT ' ', id(o), name(o);
unit 'Подразделение' (CollationSheet o) = displayName(stock(o));
unitID 'ID подразделения' (CollationSheet o) = id(stock(o));
numDoc 'Номер акта' (CollationSheet o) = number(inventory(o));
dateDoc 'Дата акта' (CollationSheet o) = date(inventory(o));
basis 'Основание' (CollationSheet o) = name(inventory(o));

inInterval (CollationSheet o) = dateFrom() <= toDate(dateTime(o)) AND dateTo() >= toDate(dateTime(o));
filter (CollationSheet o) = isPosted(inventory(o)) AND inInterval(o) AND inSaleReport(stock(o));

amountSurplus 'Сумма излишков (учетная цена)' (CollationSheet o) =
    (GROUP SUM sumShortage(o, Sku s) IF sumShortage(o, s) > 0) IF filter(o);
amountShortage 'Сумма недостач (учетная цена)' (CollationSheet o) =
    (GROUP SUM sumShortage(o, Sku s) IF sumShortage(o, s) < 0) IF filter(o);
amountVATSurplus 'Сумма НДС по излишкам (учетная цена)' (CollationSheet o) =
    (round2(GROUP SUM sumShortage(o, Sku s) * valueVAT(s, stock(o)) / (100 (+) valueVAT(s, stock(o)))
        IF sumShortage(o, s) > 0)) IF filter(o);
amountVATShortage 'Сумма НДС по недостачам (учетная цена)' (CollationSheet o) =
    (round2(GROUP SUM sumShortage(o, Sku s) * valueVAT(s, stock(o)) / (100 (+) valueVAT(s, stock(o)))
        IF sumShortage(o, s) < 0)) IF filter(o);
total 'Итоги (учетная цена)' (CollationSheet o) =
    amountSurplus(o) (+) amountShortage(o);
sumRegrading 'Сумма пересорта (учетная цена)' = ABSTRACT NUMERIC[18,4] (CollationSheet, Sku);
amountRegrading 'Сумма пересорта (учетная цена)' (CollationSheet o) =
    (GROUP SUM sumRegrading(o, Sku s)) IF filter(o);
totalRegrading 'Итоги с учетом пересорта (учетная цена)' (CollationSheet o) =
    total(o) (+) amountRegrading(o);
sumBeforeInventory 'Сумма до инвентаризации (учетная цена)' = ABSTRACT NUMERIC[18,4] (CollationSheet);

sumShortageCost 'Сумма недостачи / излишка (бух. себестоимость)' (CollationSheet o, Sku s) =
    NUMERIC[18,4](round2(sumShortage(o, s) /
        (1.0 + (OVERRIDE valueVAT(s, stock(o)), 0.0) / 100.0)));

amountSurplusCost 'Сумма излишков (бух. себестоимость)' (CollationSheet o) =
    (GROUP SUM sumShortageCost(o, Sku s) IF sumShortageCost(o, s) > 0) IF filter(o);
amountShortageCost 'Сумма недостач (бух. себестоимость)' (CollationSheet o) =
    (GROUP SUM sumShortageCost(o, Sku s) IF sumShortageCost(o, s) < 0) IF filter(o);
amountVATSurplusCost 'Сумма НДС по излишкам (бух. себестоимость)' (CollationSheet o) =
    (round2(GROUP SUM sumShortageCost(o, Sku s) * valueVAT(s, stock(o)) / 100
        IF sumShortageCost(o, s) > 0)) IF filter(o);
amountVATShortageCost 'Сумма НДС по недостачам (бух. себестоимость)' (CollationSheet o) =
    (round2(GROUP SUM sumShortageCost(o, Sku s) * valueVAT(s, stock(o)) / 100
        IF sumShortageCost(o, s) < 0)) IF filter(o);
totalCost 'Итоги (бух. себестоимость)' (CollationSheet o) =
    amountSurplusCost(o) (+) amountShortageCost(o);
sumRegradingCost 'Сумма пересорта (бух. себестоимость)' = ABSTRACT NUMERIC[18,4] (CollationSheet, Sku);
amountRegradingCost 'Сумма пересорта (бух. себестоимость)' (CollationSheet o) =
    (GROUP SUM sumRegradingCost(o, Sku s)) IF filter(o);
totalRegradingCost 'Итоги с учетом пересорта (бух. себестоимость)' (CollationSheet o) =
    totalCost(o) (+) amountRegradingCost(o);
sumBeforeInventoryCost 'Сумма до инвентаризации (бух. себестоимость)' = ABSTRACT NUMERIC[18,4] (CollationSheet);

sumShortageRetail (CollationSheet o, Sku s) =
    round2(quantityShortage(o, s) * retailPriceB(s, stock(o)));

amountSurplusRetail 'Сумма излишков (отпускная цена)' (CollationSheet o) =
    (GROUP SUM sumShortageRetail(o, Sku s) IF sumShortageRetail(o, s) > 0) IF filter(o);
amountShortageRetail 'Сумма недостач (отпускная цена)' (CollationSheet o) =
    (GROUP SUM sumShortageRetail(o, Sku s) IF sumShortageRetail(o, s) < 0) IF filter(o);
amountVATSurplusRetail 'Сумма НДС по излишкам (отпускная цена)' (CollationSheet o) =
    (round2(GROUP SUM sumShortageRetail(o, Sku s) * valueVAT(s, stock(o)) / (100 (+) valueVAT(s, stock(o)))
        IF sumShortageRetail(o, s) > 0)) IF filter(o);
amountVATShortageRetail 'Сумма НДС по недостачам (отпускная цена)' (CollationSheet o) =
    (round2(GROUP SUM sumShortageRetail(o, Sku s) * valueVAT(s, stock(o)) / (100 (+) valueVAT(s, stock(o)))
        IF sumShortageRetail(o, s) < 0)) IF filter(o);
totalRetail 'Итоги (отпускная цена)' (CollationSheet o) =
    amountSurplusRetail(o) (+) amountShortageRetail(o);
sumRegradingRetail 'Сумма пересорта (отпускная цена)' = ABSTRACT NUMERIC[18,4] (CollationSheet, Sku);
amountRegradingRetail 'Сумма пересорта (отпускная цена)' (CollationSheet o) =
    (GROUP SUM sumRegradingRetail(o, Sku s)) IF filter(o);
totalRegradingRetail 'Итоги с учетом пересорта (отпускная цена)' (CollationSheet o) =
    totalRetail(o) (+) amountRegradingRetail(o);
sumBeforeInventoryRetail 'Сумма до инвентаризации (отпускная цена)' = ABSTRACT NUMERIC[18,4] (CollationSheet);

amountSurplusByStock 'Сумма излишков (учетная цена)' = GROUP SUM amountSurplus(CollationSheet o) BY stock(o);
amountShortageByStock 'Сумма недостач (учетная цена)' = GROUP SUM amountShortage(CollationSheet o) BY stock(o);
amountVATSurplusByStock 'Сумма НДС по излишкам (учетная цена)' = GROUP SUM amountVATSurplus(CollationSheet o) BY stock(o);
amountVATShortageByStock 'Сумма НДС по недостачам (учетная цена)' = GROUP SUM amountVATShortage(CollationSheet o) BY stock(o);
totalByStock 'Итоги (учетная цена)' = GROUP SUM total(CollationSheet o) BY stock(o);
amountRegradingByStock 'Сумма пересорта (учетная цена)' = GROUP SUM amountRegrading(CollationSheet o) BY stock(o);
totalRegradingByStock 'Итоги с учетом пересорта (учетная цена)' (Stock stock) = totalByStock(stock) (+) amountRegradingByStock(stock);
sumBeforeInventoryByStock 'Сумма до инвентаризации (учетная цена)' = GROUP SUM sumBeforeInventory(CollationSheet o) BY stock(o);

amountSurplusCostByStock 'Сумма излишков (бух. себестоимость)' = GROUP SUM amountSurplusCost(CollationSheet o) BY stock(o);
amountShortageCostByStock 'Сумма недостач (бух. себестоимость)' = GROUP SUM amountShortageCost(CollationSheet o) BY stock(o);
amountVATSurplusCostByStock 'Сумма НДС по излишкам (бух. себестоимость)' = GROUP SUM amountVATSurplusCost(CollationSheet o) BY stock(o);
amountVATShortageCostByStock 'Сумма НДС по недостачам (бух. себестоимость)' = GROUP SUM amountVATShortageCost(CollationSheet o) BY stock(o);
totalCostByStock 'Итоги (бух. себестоимость)' = GROUP SUM totalCost(CollationSheet o) BY stock(o);
amountRegradingCostByStock 'Сумма пересорта (бух. себестоимость)' = GROUP SUM amountRegradingCost(CollationSheet o) BY stock(o);
totalRegradingCostByStock 'Итоги с учетом пересорта (бух. себестоимость)' (Stock stock) = totalCostByStock(stock) (+) amountRegradingCostByStock(stock);
sumBeforeInventoryCostByStock 'Сумма до инвентаризации (бух. себестоимость)' = GROUP SUM sumBeforeInventoryCost(CollationSheet o) BY stock(o);

amountSurplusRetailByStock 'Сумма излишков (отпускная цена)' = GROUP SUM amountSurplusRetail(CollationSheet o) BY stock(o);
amountShortageRetailByStock 'Сумма недостач (отпускная цена)' = GROUP SUM amountShortageRetail(CollationSheet o) BY stock(o);
amountVATSurplusRetailByStock 'Сумма НДС по излишкам (отпускная цена)' = GROUP SUM amountVATSurplusRetail(CollationSheet o) BY stock(o);
amountVATShortageRetailByStock 'Сумма НДС по недостачам (отпускная цена)' = GROUP SUM amountVATShortageRetail(CollationSheet o) BY stock(o);
totalRetailByStock 'Итоги (отпускная цена)' = GROUP SUM totalRetail(CollationSheet o) BY stock(o);
amountRegradingRetailByStock 'Сумма пересорта (отпускная цена)' = GROUP SUM amountRegradingRetail(CollationSheet o) BY stock(o);
totalRegradingRetailByStock 'Итоги с учетом пересорта (отпускная цена)' (Stock stock) = totalRetailByStock(stock) (+) amountRegradingRetailByStock(stock);
sumBeforeInventoryRetailByStock 'Сумма до инвентаризации (отпускная цена)' = GROUP SUM sumBeforeInventoryRetail(CollationSheet o) BY stock(o);

title = 'Реестр инвентаризаций ' + titleInterval();

changeStocksInventory() { DIALOG dialogStocksSaleReportRu; }

FORM invRegPrint 'Реестр инвентаризаций'
    OBJECTS i = CollationSheet
    PROPERTIES(i) READONLY
    unit, unitID, numDoc, dateDoc, basis,
        amountSurplus, amountVATSurplus, amountShortage, amountVATShortage, total,
        amountRegrading, totalRegrading, sumBeforeInventory,
        amountSurplusCost, amountVATSurplusCost, amountShortageCost, amountVATShortageCost, totalCost,
        amountRegradingCost, totalRegradingCost, sumBeforeInventoryCost,
        amountSurplusRetail, amountVATSurplusRetail, amountShortageRetail, amountVATShortageRetail, totalRetail,
        amountRegradingRetail, totalRegradingRetail, sumBeforeInventoryRetail
    FILTERS amountSurplus(i) OR amountVATSurplus(i) OR amountShortage(i)
        OR amountVATShortage(i) OR total(i)
    PROPERTIES() title
    REPORT 'InventoryRegister.jrxml'
;

invRegPrint 'Отчет' () { PRINT invRegPrint XLSX; } IMAGE 'print.png';

FORM inventoryRegister 'Реестр инвентаризаций'
    PROPERTIES() dateFrom, dateTo
    PROPERTIES nameStockList() READONLY SHOWIF stockList()
    PROPERTIES inSaleReportStocks 'Подразделения' = inSaleReportStocks()
    ON CHANGE changeStocksInventory() READONLYIF stockList()

    OBJECTS i = CollationSheet
    PROPERTIES(i) READONLY
    unit, numDoc, dateDoc, basis,
        amountSurplus, amountVATSurplus, amountShortage, amountVATShortage, total,
        amountRegrading, totalRegrading, sumBeforeInventory,
        amountSurplusCost, amountVATSurplusCost, amountShortageCost, amountVATShortageCost, totalCost,
        amountRegradingCost, totalRegradingCost, sumBeforeInventoryCost,
        amountSurplusRetail, amountVATSurplusRetail, amountShortageRetail, amountVATShortageRetail, totalRetail,
        amountRegradingRetail, totalRegradingRetail, sumBeforeInventoryRetail
    FILTERS amountSurplus(i) OR amountVATSurplus(i) OR amountShortage(i)
        OR amountVATShortage(i) OR total(i)

    OBJECTS s = Stock
    PROPERTIES(s) READONLY
    displayName,
        amountSurplusByStock, amountVATSurplusByStock, amountShortageByStock, amountVATShortageByStock,
        totalByStock, amountRegradingByStock, totalRegradingByStock, sumBeforeInventoryByStock,
        amountSurplusCostByStock, amountVATSurplusCostByStock, amountShortageCostByStock, amountVATShortageCostByStock,
        totalCostByStock, amountRegradingCostByStock, totalRegradingCostByStock, sumBeforeInventoryCostByStock,
        amountSurplusRetailByStock, amountVATSurplusRetailByStock, amountShortageRetailByStock, amountVATShortageRetailByStock,
        totalRetailByStock, amountRegradingRetailByStock, totalRegradingRetailByStock, sumBeforeInventoryRetailByStock
    FILTERS amountSurplusByStock(s) OR amountVATSurplusByStock(s)
        OR amountShortageByStock(s) OR amountVATShortageByStock(s) OR totalByStock(s)

    PROPERTIES() DISABLEIF NOT dateFrom() OR NOT dateTo() invRegPrint

    EVENTS ON INIT initDates()
;

DESIGN inventoryRegister {
    NEW filters FIRST {
        alignment = STRETCH;
        NEW topRow {
            horizontal = TRUE;
            MOVE PROPERTY(dateFrom());
            MOVE PROPERTY(dateTo());
            MOVE PROPERTY(invRegPrint()) { valueClass = 'btn-primary'; }
        }
        MOVE PROPERTY(nameStockList()) { alignment = STRETCH; }
        MOVE PROPERTY(inSaleReportStocks) { alignment = STRETCH; }
    }
}

netTotalWeight 'Вес общий' (SkuLedger o) = signedQuantity(o) * netWeight(sku(o));

retailPrice 'Отпускная цена' (SkuLedger o) =
    prevPriceB(retailPriceListType(stock(o)), sku(o), stock(o), dateTime(o));

sumRetail 'Сумма по отпускной цене' (SkuLedger o) =
    round2(retailPrice(o) * signedQuantity(o));

valueVAT 'Ставка НДС' (SkuLedger o) = valueVAT(sku(o), date(o));

sumVAT 'Сумма НДС' (SkuLedger o) = round2(sumRetail(o) * valueVAT(o) / (100 (+) valueVAT(o)));

sumCost 'Сумма по бух. себест-ти' (SkuLedger o) =
    round2(signedSum(o) * 100.0 / (100 (+) valueVAT(o)));

cost 'Бух. себестоимость' (SkuLedger o) =
    NUMERIC[18,4](round2(sumCost(o) / signedQuantity(o))) IF signedQuantity(o);

profit 'Прибыль (%)' (SkuLedger o) =
    round2(((sumRetail(o) (-) sumVAT(o)) (-) sumCost(o)) * 100 / (sumRetail(o) (-) sumVAT(o)))
        IF (sumRetail(o) (-) sumVAT(o));

EXTEND FORM skuLedger
    PROPERTIES(s) netTotalWeight, cost, sumCost, retailPrice,
        sumRetail, valueVAT, sumVAT, profit
;

DESIGN skuLedger {
    PROPERTY(costSum(s)) { showIf = NULL; }
}

inInterval (SkuLedger o) = dateFrom() <= date(o) AND dateTo() >= date(o);

nameUOM 'Ед.изм.' (SkuLedger o) = nameUOM(sku(o));
netWeight 'Вес ед. товара' (SkuLedger o) = netWeight(sku(o));
idStock 'Код подр.' (SkuLedger o) = idStock(o);
idSku 'Код товара' (SkuLedger o) = idSku(o);
nameSku 'Наименование' (SkuLedger o) = nameSku(o);
dateDocument 'Дата документа' (SkuLedger o) = date(stockDocumentLedger(o));
accountPrice 'Учетная цена' (SkuLedger o) = signedPrice(o);
sumByAccountPrice 'Сумма по учетной цене' (SkuLedger o) = signedSum(o);
supplier 'Поставщик' (SkuLedger o) = nameSupplier[Document](stockDocumentLedger(o));

stockFullName 'Подразделение' (SkuLedger o) = CONCAT ' ', idStock(o), nameStock(o);
skuGroup2Full 'Код и наименование Отдела' (SkuLedger o) = CONCAT ' ', idSkuGroup2(sku(o)), nameSkuGroup2(sku(o));
skuGroup3Full 'Код и наименование Группы' (SkuLedger o) = CONCAT ' ', idSkuGroup3(sku(o)), nameSkuGroup3(sku(o));
skuGroup4Full 'Код и наименование Подгруппы' (SkuLedger o) = CONCAT ' ', idSkuGroup4(sku(o)), nameSkuGroup4(sku(o));

isRetailSale (SkuLedger o) = o IS DateSaleSkuLedger;
isRetailReturn (SkuLedger o) = o IS DateReturnSkuLedger;
isRetailOperation (SkuLedger o) = isRetailSale(o) OR isRetailReturn(o);

isPurchaseReturnInvoice (SkuLedger o) = stockDocumentLedger(o) IS PurchaseReturn.InvoiceShipment;
isSaleReturnInvoice (SkuLedger o) = stockDocumentLedger(o) IS SaleReturn.InvoiceShipment;
isReturnDocument (SkuLedger o) = isPurchaseReturnInvoice(o) OR isSaleReturnInvoice(o);

nameOperationEx 'Операция' (SkuLedger o) =
    IF isRetailSale(o) THEN 'Кассовые продажи'
    ELSE IF isRetailReturn(o) THEN 'Кассовые возвраты'
    ELSE IF isReturnDocument(o) AND nameReturn(operationDocument(o))
        THEN nameReturn(operationDocument(o))
        ELSE nameOperationDocument(o);

sortByDates 'Сортировка по датам' = DATA LOCAL BOOLEAN ();
nameSortType 'Сортировка' () = IF sortByDates() THEN '📅 По датам' ELSE '📦 По товарам';
changeSortType() {
    sortByDates() <- NOT sortByDates();
    formRefresh();
}

sortKey1 (SkuLedger o) = IF sortByDates() THEN STRING[200](date(o)) ELSE nameSku(o);
sortKey2 (SkuLedger o) = IF sortByDates() THEN nameSku(o) ELSE STRING[200](date(o));

inSkuList 'Отм.' = DATA LOCAL BOOLEAN (List);
anySkuList() = GROUP MAX inSkuList(List l);
nameSkuLists 'Списки товаров' () = GROUP CONCAT name(List l) IF inSkuList(l), ', ' ORDER name(l), l CHARWIDTH 30;

deleteIncludeSkuLists 'Сбросить список'() {
    inSkuList(List l) <- NULL;
    in(Sku s) <- NULL;
} ASON CONTEXTMENU nameSkuLists;

anySkuGroup() = GROUP MAX inSession(SkuGroup g);
selectedSkuGroups 'Товарные группы' = GROUP CONCAT name(SkuGroup o) IF inSession(o) AND NOT inSession(parent(o)), '; ' ORDER o CHARWIDTH 30;

deleteIncludeSkuGroups 'Сбросить группы'() {
    inSession(SkuGroup g) <- NULL;
} ASON CONTEXTMENU selectedSkuGroups;

CLASS SkuFilterType 'Тип фильтра по товарам' {
    sku 'Товары',
    skuGroups 'Товарные группы',
    skuLists 'Списки товаров'
}

FORM skuFilterType 'Типы фильтра по товарам'
    OBJECTS t = SkuFilterType
    PROPERTIES(t) READONLY '' = staticCaption
    LIST SkuFilterType OBJECT t
;

FORM selectSku 'Выбор товаров'
    TREE skuTree sg = SkuGroup PARENT parent(sg)
    PROPERTIES READONLY order(sg), skuGroupName = name(sg)
    FILTERGROUP inactive FILTER 'Активные' active(sg) 'F6' DEFAULT
    ORDERS order(sg), skuGroupName

    OBJECTS s = Sku
    PROPERTIES(s) in
    PROPERTIES(s) READONLY id SHOWIF showIDs()
    PROPERTIES(s) READONLY name, idBarcode, shortNameUOM
    FILTERS isParent(sg, s), name(s)
    ORDERS name(s)
;

FORM dialogSkuLists 'Выбор списков товаров'
    OBJECTS o = List
    PROPERTIES(o) inSkuList
    PROPERTIES(o) READONLY name
    ORDERS name(o)
;

selectSkus 'Фильтр по товарам' () {
    DIALOG skuFilterType OBJECTS t INPUT DO {
        CASE
            WHEN t = SkuFilterType.sku THEN {
                inSkuList(List l) <- NULL;
                inSession(SkuGroup g) <- NULL;
                SHOW selectSku;
            }
            WHEN t = SkuFilterType.skuGroups THEN {
                inSkuList(List l) <- NULL;
                in(Sku s) <- NULL;
                SHOW filterGroupType;
            }
            WHEN t = SkuFilterType.skuLists THEN {
                inSession(SkuGroup g) <- NULL;
                DIALOG dialogSkuLists DO {
                    in(Sku s) <- NULL;
                    FOR inSkuList(list(ListDetail ld)) AND Sku sku = sku(ld) DO
                        in(sku) <- TRUE;
                }
            };
    }
}

selectedSkuNames = GROUP CONCAT name(Sku s) IF in(s), '; ' ORDER name(s), s;

inSessionParent(Sku s) = GROUP MAX inSession(SkuGroup g) IF isParent(g, s);

skuNamesFromGroups = GROUP CONCAT name(Sku s) IF inSessionParent(s) AND name(s), '; ' ORDER name(s), s;

inSkus 'Товары' = OVERRIDE selectedSkuNames(), skuNamesFromGroups();

anySkuSelected() = (GROUP MAX in(Sku s)) OR anySkuGroup();
inSkuFilter (SkuLedger o) = NOT anySkuSelected() OR in(sku(o)) OR inSessionParent(sku(o));
inSkuFilterSku (Sku s) = NOT anySkuSelected() OR in(s) OR inSessionParent(s);

inOperation 'Вкл.' = DATA LOCAL BOOLEAN (Operation.Operation);
inRetailSaleOp 'Кассовые продажи' = DATA LOCAL BOOLEAN ();
inRetailReturnOp 'Кассовые возвраты' = DATA LOCAL BOOLEAN ();

cntSelectedOps() = GROUP SUM 1 IF inOperation(Operation.Operation op);
anyRetailOp() = inRetailSaleOp() OR inRetailReturnOp();
allOperations() = NOT cntSelectedOps() AND NOT anyRetailOp();

inOpFilter (SkuLedger o) = allOperations()
    OR inOperation(operationDocument(o))
    OR (inRetailSaleOp() AND isRetailSale(o))
    OR (inRetailReturnOp() AND isRetailReturn(o));

hasData (Operation.Operation op) = GROUP SUM 1 IF inInterval(SkuLedger o)
    AND inSaleReport(stock(o))
    AND signedQuantity(o)
    AND active(o)
    AND operationDocument(o) = op;

hasRetailSaleData() = GROUP SUM 1 IF inInterval(SkuLedger o)
    AND inSaleReport(stock(o))
    AND signedQuantity(o)
    AND active(o)
    AND isRetailSale(o);

hasRetailReturnData() = GROUP SUM 1 IF inInterval(SkuLedger o)
    AND inSaleReport(stock(o))
    AND signedQuantity(o)
    AND active(o)
    AND isRetailReturn(o);

selectedOpNames() = GROUP CONCAT name(Operation.Operation op) IF inOperation(op), ', ' ORDER name(op);

inOperations 'Операции' () = IF allOperations() THEN 'ВСЕ'
    ELSE CONCAT ', ',
        selectedOpNames(),
        (IF inRetailSaleOp() THEN 'Кассовые продажи'),
        (IF inRetailReturnOp() THEN 'Кассовые возвраты');

FORM selectOperationsForm 'Выбор операций'
    PROPERTIES() inRetailSaleOp SHOWIF hasRetailSaleData(),
        inRetailReturnOp SHOWIF hasRetailReturnData()

    OBJECTS op = Operation.Operation
    PROPERTIES(op) inOperation
    PROPERTIES(op) READONLY name, nameReturn
    FILTERS hasData(op)
;

DESIGN selectOperationsForm {
    size = (600, 400);
    NEW retailPanel FIRST {
        horizontal = TRUE;
        MOVE PROPERTY(inRetailSaleOp());
        MOVE PROPERTY(inRetailReturnOp());
    }
}

selectOperations 'Выбрать операции' () { DIALOG selectOperationsForm; }

FORM operationReport 'Отчет по хозяйственной операции'
    PROPERTIES() dateFrom, dateTo
    PROPERTIES nameStockList() READONLY SHOWIF stockList()
    PROPERTIES inSaleReportStocks 'Подразделения' = inSaleReportStocks()
    ON CHANGE changeStocksInventory() READONLYIF stockList()
    PROPERTIES() inOperations ON CHANGE selectOperations()
    PROPERTIES() nameSortType ON CHANGE changeSortType()
    PROPERTIES nameSkuLists() READONLY SHOWIF anySkuList()
    PROPERTIES opSelectedSkuGroups 'Товарные группы' = selectedSkuGroups() READONLY SHOWIF anySkuGroup()
    PROPERTIES opInSkus 'Товары' = inSkus() ON CHANGE selectSkus() READONLYIF anySkuList() OR anySkuGroup()

    OBJECTS o = SkuLedger
    PROPERTIES(o) READONLY idSku, nameSku, nameUOM, netWeight, stockFullName,
        skuGroup2Full, skuGroup3Full, skuGroup4Full,
        nameOperationEx, numberDocument, dateDocument, supplier,
        signedQuantity, netTotalWeight, cost, sumCost, accountPrice,
        sumByAccountPrice, retailPrice, sumRetail, valueVAT, sumVAT, profit,
        sortKey1, sortKey2
    ORDERS supplier(o), stockFullName(o), skuGroup2Full(o), skuGroup3Full(o), skuGroup4Full(o), nameOperationEx(o), sortKey1(o), sortKey2(o)
    FILTERS inInterval(o),
        inSaleReport(stock(o)),
        signedQuantity(o),
        active(o),
        inOpFilter(o),
        inSkuFilter(o)
    PROPERTIES title = 'Отчет по хозяйственной операции ' + titleInterval()

    EVENTS ON INIT initDates()
;

printOperationReport 'Отчет' () { PRINT operationReport XLSX; } IMAGE 'print.png';

EXTEND FORM operationReport
    PROPERTIES() DISABLEIF NOT dateFrom() OR NOT dateTo() printOperationReport
;

DESIGN operationReport {
    NEW filters FIRST {
        alignment = STRETCH;
        NEW topRow {
            horizontal = TRUE;
            MOVE PROPERTY(dateFrom());
            MOVE PROPERTY(dateTo());
            MOVE PROPERTY(nameSortType()) { charWidth = 18; valueClass = 'btn-outline-warning'; }
            MOVE PROPERTY(printOperationReport()) { valueClass = 'btn-primary'; }
        }
        MOVE PROPERTY(nameStockList()) { alignment = STRETCH; }
        MOVE PROPERTY(inSaleReportStocks) { alignment = STRETCH; }
        MOVE PROPERTY(inOperations()) { alignment = STRETCH; }
        MOVE PROPERTY(nameSkuLists()) { alignment = STRETCH; }
        MOVE PROPERTY(opSelectedSkuGroups) { alignment = STRETCH; }
        MOVE PROPERTY(opInSkus) { alignment = STRETCH; }
    }
    REMOVE PROPERTY(title);
    BOX(o) { caption = ''; }
    PROPERTY(sortKey1(o)) { showIf = NULL; }
    PROPERTY(sortKey2(o)) { showIf = NULL; }
}

wrhReportDate 'Дата' = DATA LOCAL DATE ();
wrhDaysBack 'Сколько дней назад' = DATA LOCAL INTEGER ();
wrhMasterStock = DATA LOCAL Stock ();
nameWrhMasterStock 'Мастер-подразделение' () = CONCAT ' ', id(wrhMasterStock()), name(wrhMasterStock());

wrhEffectiveDays() = OVERRIDE wrhDaysBack(), 28;
wrhSalesDateTo() = sum((OVERRIDE wrhReportDate(), currentDate()), -1);
wrhSalesDateFrom() = sum(wrhSalesDateTo(), 1 - wrhEffectiveDays());

inWrhRC 'Отм.' = DATA LOCAL BOOLEAN (Stock);

wrhRCNames 'Подразделения-склад' () = GROUP CONCAT (CONCAT ' ', id(Stock s), name(s)) IF inWrhRC(s), ', ' ORDER id(s), s CHARWIDTH 40;

wrhRCCount() = GROUP SUM 1 IF inWrhRC(Stock s);

inWrhRCDialog 'Отм.' = DATA LOCAL BOOLEAN (Stock);

wrhRCStockList = DATA LOCAL StockList();
nameWrhRCStockList 'Список подразделений-склад' () = name(wrhRCStockList());

changeWrhRCStockList 'Список подразделений-склад'() {
    DIALOG stockLists OBJECTS o INPUT DO {
        wrhRCStockList() <- o;
        inWrhRCDialog(Stock stock) <- in(o, stock);
    }
}

deleteIncludeWrhRCStockLists 'Сбросить список'() {
    wrhRCStockList() <- NULL;
    inWrhRCDialog(Stock stock) <- NULL;
} ASON CONTEXTMENU nameWrhRCStockList;

FORM dialogWrhRCStocks 'Выбор складов (РЦ)'
    TREE stockTree a = BPSTRING[3], sg = StockGroup PARENT parent(sg)
    PROPERTIES READONLY VALUE(a), name(sg)
    ORDERS name(sg)
    FILTERS stringEqualsAll(a)

    OBJECTS s = Stock
    PROPERTIES(s) READONLY id, name, address, nameRegion
    PROPERTIES(s) inWrhRCDialog READONLYIF wrhRCStockList()
    PROPERTIES changeWrhRCStockList() TOOLBAR
    ORDERS name(s)
    FILTERS isParent(sg, s) OR (s IS Stock AND NOT sg),
        isCompany(s),
        countCompanyStock(sg)

    FILTERGROUP inactiveStock FILTER 'Активный' active(s) 'ctrl F10' DEFAULT
    FILTERGROUP select FILTER 'Отм.' inWrhRCDialog(s) 'F9'

    EVENTS
        ON INIT {
            inWrhRCDialog(Stock stock) <- inWrhRC(stock);
        },
        ON OK {
            inWrhRC(Stock stock) <- inWrhRCDialog(stock);
        }
;

DESIGN dialogWrhRCStocks {
    BOX {
        size = (1024, 768);
        NEW topContainer {
            horizontal = TRUE;
            fill = 1;
            MOVE BOX(TREE stockTree) {
                caption = 'Склады';
            }
            MOVE BOX(s) {
                fill = 3;
                GRID(s) {
                    defaultComponent = TRUE;
                }
                PROPERTY(name(s)){
                    charWidth = 35;
                }
            }
        }
        MOVE TOOLBARBOX;
    }
}

changeWrhRC() {
    DIALOG dialogWrhRCStocks DO {
        IF wrhRCCount() = 1 THEN {
            wrhMasterStock() <- GROUP MIN Stock stock IF inWrhRC(stock);
        } ELSE IF NOT inWrhRC(wrhMasterStock()) THEN {
            wrhMasterStock() <- GROUP MIN Stock stock IF inWrhRC(stock);
        }
    }
}

FORM dialogWrhMasterStock 'Мастер-подразделение'
    OBJECTS s = Stock
    PROPERTIES(s) READONLY id, name
    FILTERS inWrhRC(s)
    ORDERS name(s)
;

changeWrhMasterStock() {
    DIALOG dialogWrhMasterStock OBJECTS s INPUT DO {
        wrhMasterStock() <- s;
    }
}

wrhSkuFilter(Sku sku) = NOT anySkuSelected() OR in(sku) OR inSessionParent(sku);

wrhRetailPriceStock 'Подр. розничной цены' = DATA LOCAL Stock ();
nameWrhRetailPriceStock 'Подр. розничной цены' () = CONCAT ' ', id(wrhRetailPriceStock()), name(wrhRetailPriceStock());

FORM dialogWrhRetailPriceStock 'Подразделение розничной цены'
    OBJECTS s = Stock
    PROPERTIES(s) READONLY id, name
    FILTERS inSaleReport(s)
    ORDERS name(s)
;

changeWrhRetailPriceStock() {
    DIALOG dialogWrhRetailPriceStock OBJECTS s INPUT DO {
        wrhRetailPriceStock() <- s;
    }
}

inWrhRange 'Отм.' = DATA LOCAL BOOLEAN (Range.Range);

anyWrhRange() = GROUP MAX inWrhRange(Range.Range r);

wrhRangeNames 'Ассортиментные матрицы' () =
    IF anyWrhRange()
    THEN (GROUP CONCAT name(Range.Range r) IF inWrhRange(r), ', ' ORDER name(r), r)
    ELSE 'ВСЕ';

FORM dialogWrhRange 'Выбор ассортиментных матриц'
    OBJECTS r = Range.Range
    PROPERTIES(r) inWrhRange
    PROPERTIES(r) READONLY name
    FILTERS NOT inactive(r)
    ORDERS name(r)
;

changeWrhRange() {
    DIALOG dialogWrhRange;
}

wrhEffectiveDate() = OVERRIDE wrhReportDate(), currentDate();

wrhSkuInRange(Sku sku, Range.Range r) =
    (include(r, sku, wrhEffectiveDate()) OR level(r, sku, wrhEffectiveDate()))
        IF NOT inactive(r);

wrhInRange(Sku sku, Range.Range r) = '+' IF wrhSkuInRange(sku, r);

wrhInAnySelectedRange(Sku sku) =
    NOT anyWrhRange() OR (GROUP SUM 1 IF inWrhRange(Range.Range r) AND wrhSkuInRange(sku, r));

wrhInAnyActiveRange(Sku sku) =
    GROUP SUM 1 IF wrhSkuInRange(sku, Range.Range r);

wrhMatrixBelonging 'Принадлежность к матрицам' (Sku sku) =
    GROUP CONCAT name(Range.Range r) IF wrhSkuInRange(sku, r), ', ' ORDER name(r), r CHARWIDTH 30;

wrhShippedQty 'Отгружено со склада за период, кол-во' (Sku sku) =
    GROUP SUM abs(signedQuantity(OutFIFOSkuLedger l))
        IF sku(l) = sku AND inWrhRC(stock(l)) AND isPosted(l)
            AND date(l) >= wrhSalesDateFrom() AND date(l) <= wrhSalesDateTo();

wrhLastReceiptDate 'Дата последнего прихода на склад' (Sku sku) =
    GROUP LAST date(Purchase.ShipmentDetail d)
    ORDER date(d), d
    WHERE isPosted(d) AND inWrhRC(customerStock(d)) AND sku(d) = sku;

wrhSupplier = ABSTRACT LegalEntity (Sku);

wrhSupplierName 'Поставщик' (Sku sku) = name(wrhSupplier(sku));

wrhRetailSalesQty 'Розница - кол-во продаж' (Sku sku) =
    (GROUP SUM quantity(SaleLedger sl)
        IF sku(sl) = sku AND inSaleReport(stock(sl)) AND active(sl)
            AND sl IS DateSaleSkuLedger
            AND date(sl) >= wrhSalesDateFrom() AND date(sl) <= wrhSalesDateTo())
        (-)
        (GROUP SUM quantity(SaleLedger sl)
            IF sku(sl) = sku AND inSaleReport(stock(sl)) AND active(sl)
                AND sl IS DateReturnSkuLedger
                AND date(sl) >= wrhSalesDateFrom() AND date(sl) <= wrhSalesDateTo());

wrhReportDateTime() = toDateTime(OVERRIDE wrhReportDate(), currentDate());

wrhShopBalance 'Текущий остаток в магазинах, кол-во' (Sku sku) =
    GROUP SUM balanceA(sku, Stock stock, wrhEffectiveDate()) IF inSaleReport(stock);

wrhShopBalanceSum 'Сумма остатка в магазинах в учетных ценах' (Sku sku) =
    GROUP SUM round2(balanceA(sku, Stock stock, wrhEffectiveDate()) * accountPriceA(sku, stock, wrhReportDateTime()))
        IF inSaleReport(stock);

wrhDailyAvgSales(Sku sku) = wrhRetailSalesQty(sku) / wrhEffectiveDays();

wrhShopDaysOfSupply 'Запас в днях в магазинах' (Sku sku) =
    NUMERIC[10,1](round2(wrhShopBalance(sku) / wrhDailyAvgSales(sku))) IF wrhDailyAvgSales(sku) > 0;

wrhRCBalance 'Остаток на РЦ, кол-во' (Sku sku) =
    GROUP SUM balanceA(sku, Stock stock, wrhEffectiveDate()) IF inWrhRC(stock);

wrhRCBalanceSum 'Сумма остатка на РЦ в учетных ценах, руб.' (Sku sku) =
    GROUP SUM round2(balanceA(sku, Stock stock, wrhEffectiveDate()) * accountPriceA(sku, stock, wrhReportDateTime()))
        IF inWrhRC(stock);

wrhDailyAvgShipped(Sku sku) = wrhShippedQty(sku) / wrhEffectiveDays();

wrhRCDaysOfSupply 'Запас в днях на РЦ' (Sku sku) =
    NUMERIC[10,1](round2(wrhRCBalance(sku) / wrhDailyAvgShipped(sku))) IF wrhDailyAvgShipped(sku) > 0;

wrhTotalBalance 'Итог остаток в сети в штуках' (Sku sku) = wrhShopBalance(sku) (+) wrhRCBalance(sku);
wrhTotalBalanceSum 'Итог остаток в сети в рублях' (Sku sku) = wrhShopBalanceSum(sku) (+) wrhRCBalanceSum(sku);
wrhTotalDaysOfSupply 'Итого запас в днях' (Sku sku) = wrhShopDaysOfSupply(sku) (+) wrhRCDaysOfSupply(sku);

wrhAccountPrice 'Учетная цена на РЦ, руб.' (Sku sku) =
    accountPriceA(sku, wrhMasterStock(), wrhReportDateTime());

wrhRetailPriceSku 'Розничная цена, руб.' (Sku sku) =
    retailPriceA(sku, wrhRetailPriceStock(), wrhReportDateTime());

wrhMarkupPct '%ТН' (Sku sku) =
    NUMERIC[10,2](round2((wrhRetailPriceSku(sku) / wrhAccountPrice(sku) - 1.0) * 100.0))
        IF wrhAccountPrice(sku) > 0;

wrhAmountPack 'Кол-во шт в месте на РЦ' (Sku sku) = Purchase.amountPack(sku);

wrhReserve 'Резерв' (Sku sku) =
    OVERRIDE (abs(GROUP SUM currentReserve(sku, Stock stock) IF inWrhRC(stock))), 0.0;

wrhSupplierPriceListType() = dataPriceListType('supplier');

wrhSupplierPriceOperation() = PriceList.operation('supplier');

wrhSupplierPriceDetailByStock(Sku sku, Stock stock) =
    GROUP LAST PriceListLedger ledger
    ORDER fromDateTime(ledger, wrhSupplierPriceListType(), stock), ledger
    WHERE price(ledger, wrhSupplierPriceListType(), stock)
        AND operation(ledger) = wrhSupplierPriceOperation()
        AND fromDateTime(ledger, wrhSupplierPriceListType(), stock) <= wrhReportDateTime()
        AND NOT (toDateTime(ledger, wrhSupplierPriceListType(), stock) < wrhReportDateTime())
    BY sku(ledger, wrhSupplierPriceListType(), stock);

wrhSpecPrice 'Цена в действующей спецификации' (Sku sku) =
    GROUP MAX price(wrhSupplierPriceDetailByStock(sku, Stock stock), wrhSupplierPriceListType()) IF inWrhRC(stock);

wrhPriceSegment 'Ценовая сегментация' (Sku sku) = namePriceSegment(sku);

wrhHasData(Sku sku) = wrhSkuFilter(sku) AND wrhInAnySelectedRange(sku) AND
    (wrhShippedQty(sku) OR wrhRetailSalesQty(sku) OR wrhShopBalance(sku) OR wrhRCBalance(sku) OR wrhAccountPrice(sku) OR wrhReserve(sku) OR wrhSpecPrice(sku));

wrhInitDates() {
    wrhReportDate() <- currentDate();
    wrhDaysBack() <- 28;
    wrhMasterStock() <- GROUP MIN Stock stock IF inWrhRC(stock);
}

FORM warehouseReport 'Отчет по складу'
    PROPERTIES() wrhReportDate, wrhDaysBack
    PROPERTIES() nameWrhRCStockList READONLY SHOWIF wrhRCStockList()
    PROPERTIES() wrhRCNames ON CHANGE changeWrhRC() READONLYIF wrhRCStockList()
    PROPERTIES() nameWrhMasterStock ON CHANGE changeWrhMasterStock()
    PROPERTIES() nameWrhRetailPriceStock ON CHANGE changeWrhRetailPriceStock()
    PROPERTIES() wrhRangeNames ON CHANGE changeWrhRange()
    PROPERTIES nameStockList() READONLY SHOWIF stockList()
    PROPERTIES wrhStores 'Подразделения-магазины' = inSaleReportStocks() ON CHANGE changeStocksInventory() READONLYIF stockList()
    PROPERTIES nameSkuLists() READONLY SHOWIF anySkuList()
    PROPERTIES wrhSelectedSkuGroups 'Товарные группы' = selectedSkuGroups() READONLY SHOWIF anySkuGroup()
    PROPERTIES wrhSkus 'Товары' = inSkus() ON CHANGE selectSkus() READONLYIF anySkuList() OR anySkuGroup()

    OBJECTS r = Range.Range
    FILTERS (NOT anyWrhRange() OR inWrhRange(r)) AND NOT inactive(r)

    OBJECTS s = Sku
    PROPERTIES(s) READONLY
    id, idBarcode, name, wrhPriceSegment, wrhMatrixBelonging, wrhSupplierName,
        wrhShippedQty, wrhLastReceiptDate,
        wrhRetailSalesQty, wrhShopBalance, wrhShopBalanceSum, wrhShopDaysOfSupply,
        wrhRCBalance, wrhRCBalanceSum, wrhRCDaysOfSupply,
        wrhTotalBalance, wrhTotalBalanceSum, wrhTotalDaysOfSupply,
        wrhAmountPack, wrhAccountPrice, wrhRetailPriceSku, wrhMarkupPct,
        wrhReserve, wrhSpecPrice
    PROPERTIES READONLY COLUMNS (r) HEADER name(r) wrhInRange(s, r)
    FILTERS wrhHasData(s)
    ORDERS name(s)

    FILTERGROUP wrhDataFilter
        FILTER 'С остатками/продажами' wrhTotalBalance(s) OR wrhRetailSalesQty(s) OR wrhShippedQty(s) OR wrhReserve(s) OR wrhSpecPrice(s) DEFAULT

    EVENTS ON INIT wrhInitDates()
;

wrhPrintReport 'Отчет' () { PRINT warehouseReport XLSX; } IMAGE 'print.png';

EXTEND FORM warehouseReport
    PROPERTIES wrhPrintReport()
    PROPERTIES(s) READONLY Item.amountPackLayerShown, Item.amountPackPalletShown, Item.top500RankShown
;

DESIGN warehouseReport {
    REMOVE BOX(r);
    NEW filters FIRST {
        alignment = STRETCH;
        NEW topRow {
            horizontal = TRUE;
            MOVE PROPERTY(wrhReportDate());
            MOVE PROPERTY(wrhDaysBack()) { flex = 0; }
            MOVE PROPERTY(wrhPrintReport()) { valueClass = 'btn-primary'; }
        }
        NEW row2 {
            alignment = STRETCH;
            MOVE PROPERTY(nameWrhRCStockList()) { alignment = STRETCH; }
            MOVE PROPERTY(wrhRCNames()) { alignment = STRETCH; }
            MOVE PROPERTY(nameWrhMasterStock()) { alignment = STRETCH; }
            MOVE PROPERTY(nameWrhRetailPriceStock()) { alignment = STRETCH; }
            MOVE PROPERTY(wrhRangeNames()) { alignment = STRETCH; }
            MOVE PROPERTY(nameStockList()) { alignment = STRETCH; }
            MOVE PROPERTY(wrhStores) { alignment = STRETCH; }
        }
        NEW row3 {
            alignment = STRETCH;
            MOVE PROPERTY(nameSkuLists()) { alignment = STRETCH; }
            MOVE PROPERTY(wrhSelectedSkuGroups) { alignment = STRETCH; }
            MOVE PROPERTY(wrhSkus) { alignment = STRETCH; }
        }
    }
    BOX(s) {
        caption = 'Данные отчета';
    }
}

CLASS TrnDirection 'Направление операции' {
    direct 'Прямое',
    ret 'Возврат'
}

CLASS TrnDocKind 'Вид документа' {
    purchaseInvoice 'Накладная (закупка)',
    purchaseReturnInvoice 'Накладная (закупка-возврат)',
    saleInvoice 'Накладная (продажа)',
    saleReturnInvoice 'Накладная (продажа-возврат)',
    purchaseOrder 'Заказ (закупка)',
    purchaseReturnOrder 'Заказ (закупка-возврат)',
    saleOrder 'Заказ (продажа)',
    saleReturnOrder 'Заказ (продажа-возврат)',
    other 'Прочее'
}

CLASS TrnSection 'Раздел' {
    incoming 'Приход',
    outgoing 'Расход'
}

trnDocKindLedger (StockDocumentLedger l) = CASE
    WHEN (l IS Purchase.InvoiceShipment) AND NOT isReturn(l) THEN TrnDocKind.purchaseInvoice
    WHEN (l IS PurchaseReturn.InvoiceShipment) AND NOT isReturn(l) THEN TrnDocKind.purchaseInvoice
    WHEN (l IS Purchase.InvoiceShipment) AND isReturn(l) THEN TrnDocKind.purchaseReturnInvoice
    WHEN (l IS PurchaseReturn.InvoiceShipment) AND isReturn(l) THEN TrnDocKind.purchaseReturnInvoice
    WHEN (l IS Sale.InvoiceShipment) AND NOT isReturn(l) THEN TrnDocKind.saleInvoice
    WHEN (l IS SaleReturn.InvoiceShipment) AND NOT isReturn(l) THEN TrnDocKind.saleInvoice
    WHEN (l IS Sale.InvoiceShipment) AND isReturn(l) THEN TrnDocKind.saleReturnInvoice
    WHEN (l IS SaleReturn.InvoiceShipment) AND isReturn(l) THEN TrnDocKind.saleReturnInvoice
    ELSE TrnDocKind.other;

trnActionWordDefault (StockDocumentLedger l) = CASE
    WHEN (l IS Sale.InvoiceShipment OR l IS SaleReturn.InvoiceShipment) AND NOT isReturn(l) THEN 'Отгружено'
    WHEN (l IS Purchase.InvoiceShipment OR l IS PurchaseReturn.InvoiceShipment) AND NOT isReturn(l) THEN 'Принято'
    WHEN l IS IncStockDocumentLedger AND NOT isReturn(l) THEN 'Принято'
    WHEN l IS OutStockDocumentLedger AND NOT isReturn(l) THEN 'Отгружено'
    WHEN (l IS Sale.InvoiceShipment OR l IS SaleReturn.InvoiceShipment) AND isReturn(l) THEN 'Принято'
    WHEN (l IS Purchase.InvoiceShipment OR l IS PurchaseReturn.InvoiceShipment) AND isReturn(l) THEN 'Отгружено'
    WHEN l IS IncStockDocumentLedger AND isReturn(l) THEN 'Отгружено'
    WHEN l IS OutStockDocumentLedger AND isReturn(l) THEN 'Принято'
    ELSE 'Сумма';

trnSectionLedger (StockDocumentLedger l) = CASE
    WHEN (l IS Sale.InvoiceShipment OR l IS SaleReturn.InvoiceShipment) AND NOT isReturn(l) THEN TrnSection.outgoing
    WHEN (l IS Sale.InvoiceShipment OR l IS SaleReturn.InvoiceShipment) AND isReturn(l) THEN TrnSection.incoming
    WHEN (l IS Purchase.InvoiceShipment OR l IS PurchaseReturn.InvoiceShipment) AND NOT isReturn(l) THEN TrnSection.incoming
    WHEN (l IS Purchase.InvoiceShipment OR l IS PurchaseReturn.InvoiceShipment) AND isReturn(l) THEN TrnSection.outgoing
    WHEN l IS IncStockDocumentLedger AND NOT isReturn(l) THEN TrnSection.incoming
    WHEN l IS IncStockDocumentLedger AND isReturn(l) THEN TrnSection.outgoing
    WHEN l IS OutStockDocumentLedger AND NOT isReturn(l) THEN TrnSection.outgoing
    WHEN l IS OutStockDocumentLedger AND isReturn(l) THEN TrnSection.incoming
    ELSE TrnSection.outgoing;

trnPriceTypeNameDefault (StockDocumentLedger l) = CASE
    WHEN l IS Sale.InvoiceShipment OR l IS SaleReturn.InvoiceShipment THEN 'отпускных ценах'
    WHEN l IS Purchase.InvoiceShipment OR l IS PurchaseReturn.InvoiceShipment THEN 'закупочных ценах'
    ELSE 'учетных ценах';

trnCounterparty (StockDocumentLedger l) = legalEntity(l);

inTrnOperation 'Вкл.' = DATA LOCAL BOOLEAN (Operation.Operation);
inTrnReturnOperation 'Вкл. (возврат)' = DATA LOCAL BOOLEAN (Operation.Operation);
cntSelectedTrnOps() = GROUP SUM 1 IF inTrnOperation(Operation.Operation op);
cntSelectedTrnReturnOps() = GROUP SUM 1 IF inTrnReturnOperation(Operation.Operation op);
anyTrnOpSelected() = cntSelectedTrnOps() OR cntSelectedTrnReturnOps();

trnOpFilterOk (Operation.Operation op, TrnDirection dir) = NOT anyTrnOpSelected()
    OR (dir = TrnDirection.direct AND inTrnOperation(op))
    OR (dir = TrnDirection.ret AND inTrnReturnOperation(op));

inTrnDocKind 'Вкл.' = DATA LOCAL BOOLEAN (TrnDocKind);
anyTrnDocKindSelected() = GROUP SUM 1 IF inTrnDocKind(TrnDocKind dk);

trnDocKindFilterOk (TrnDocKind dk) = NOT anyTrnDocKindSelected() OR inTrnDocKind(dk);

inTrnStock 'Отм.' = DATA LOCAL BOOLEAN (Stock);
trnStockCount() = GROUP SUM 1 IF inTrnStock(Stock stock);
trnStockNames 'Подразделения' () =
    GROUP CONCAT (CONCAT ' ', id(Stock stock), name(stock)) IF inTrnStock(stock), ', ' ORDER id(stock), stock CHARWIDTH 40;

inTrnStockDialog 'Отм.' = DATA LOCAL BOOLEAN (Stock);

trnStockList = DATA LOCAL StockList();
nameTrnStockList 'Список подразделений' () = name(trnStockList());

changeTrnStockList 'Список подразделений' () {
    DIALOG stockLists OBJECTS o INPUT DO {
        trnStockList() <- o;
        inTrnStockDialog(Stock stock) <- in(o, stock);
    }
}

deleteIncludeTrnStockList 'Сбросить список' () {
    trnStockList() <- NULL;
    inTrnStockDialog(Stock stock) <- NULL;
} ASON CONTEXTMENU nameTrnStockList;

FORM dialogTrnStocks 'Выбор подразделений (грузооборот)'
    TREE stockTree a = BPSTRING[3], sg = StockGroup PARENT parent(sg)
    PROPERTIES READONLY VALUE(a), name(sg)
    ORDERS name(sg)
    FILTERS stringEqualsAll(a)

    OBJECTS s = Stock
    PROPERTIES(s) READONLY id, name, address, nameRegion
    PROPERTIES(s) inTrnStockDialog READONLYIF trnStockList()
    PROPERTIES changeTrnStockList() TOOLBAR
    ORDERS name(s)
    FILTERS isParent(sg, s) OR (s IS Stock AND NOT sg),
        isCompany(s),
        countCompanyStock(sg)
    FILTERGROUP inactiveStock FILTER 'Активный' active(s) 'ctrl F10' DEFAULT
    FILTERGROUP select FILTER 'Отм.' inTrnStockDialog(s) 'F9'

    EVENTS
        ON INIT { inTrnStockDialog(Stock stock) <- inTrnStock(stock); },
        ON OK { inTrnStock(Stock stock) <- inTrnStockDialog(stock); }
;

DESIGN dialogTrnStocks {
    BOX {
        size = (1024, 768);
        NEW topContainer {
            horizontal = TRUE;
            fill = 1;
            MOVE BOX(TREE stockTree) { caption = 'Подразделения'; }
            MOVE BOX(s) {
                fill = 3;
                PROPERTY(name(s)) { charWidth = 35; }
            }
        }
        MOVE TOOLBARBOX;
    }
}

changeTrnStocks() { DIALOG dialogTrnStocks; }

trnLedgerMatchesDir (StockDocumentLedger l, TrnDirection dir) =
    (dir = TrnDirection.direct AND NOT isReturn(l)) OR
        (dir = TrnDirection.ret AND isReturn(l));

trnActiveDoc (StockDocumentLedger l, Stock stock, Operation.Operation op, TrnDirection dir, LegalEntity cp, TrnDocKind dk) =
    active(l)
        AND stock(l) = stock
        AND operation(l) = op
        AND trnLedgerMatchesDir(l, dir)
        AND trnCounterparty(l) = cp
        AND trnDocKindLedger(l) = dk
        AND date(l) >= dateFrom()
        AND date(l) <= dateTo();

trnActiveDocSku (SkuLedger sl, Stock stock, Operation.Operation op, TrnDirection dir, LegalEntity cp, TrnDocKind dk) =
    active(stockDocumentLedger(sl))
        AND stock(stockDocumentLedger(sl)) = stock
        AND operation(stockDocumentLedger(sl)) = op
        AND trnLedgerMatchesDir(stockDocumentLedger(sl), dir)
        AND trnCounterparty(stockDocumentLedger(sl)) = cp
        AND trnDocKindLedger(stockDocumentLedger(sl)) = dk
        AND date(stockDocumentLedger(sl)) >= dateFrom()
        AND date(stockDocumentLedger(sl)) <= dateTo();

trnSumLedger 'Сумма (накл.)' (Stock stock, Operation.Operation op, TrnDirection dir, LegalEntity cp, TrnDocKind dk) =
    GROUP SUM sumItem(StockDocumentLedger l) IF trnActiveDoc(l, stock, op, dir, cp, dk);

trnSkuCountLedger 'Кол-во позиций (накл.)' (Stock stock, Operation.Operation op, TrnDirection dir, LegalEntity cp, TrnDocKind dk) =
    GROUP SUM 1 IF trnActiveDoc(StockDocumentLedger l, stock, op, dir, cp, dk);

trnWeightLedger 'Вес (накл.)' (Stock stock, Operation.Operation op, TrnDirection dir, LegalEntity cp, TrnDocKind dk) =
    GROUP SUM NUMERIC[16,3](netWeight(sku(SkuLedger sl)) * abs(signedQuantity(sl)))
        IF trnActiveDocSku(sl, stock, op, dir, cp, dk);

trnVolumeLedger 'Объём (накл.)' (Stock stock, Operation.Operation op, TrnDirection dir, LegalEntity cp, TrnDocKind dk) =
    GROUP SUM NUMERIC[16,3](volume(sku(SkuLedger sl)) * abs(signedQuantity(sl)))
        IF trnActiveDocSku(sl, stock, op, dir, cp, dk);

trnGrossWeightLedger 'Вес брутто (накл.)' (Stock stock, Operation.Operation op, TrnDirection dir, LegalEntity cp, TrnDocKind dk) =
    GROUP SUM NUMERIC[16,3](grossWeight(sku(SkuLedger sl)) * abs(signedQuantity(sl)))
        IF trnActiveDocSku(sl, stock, op, dir, cp, dk);

trnSectionByKey (Stock stock, Operation.Operation op, TrnDirection dir, TrnDocKind dk) =
    GROUP MAX trnSectionLedger(StockDocumentLedger l) IF active(l) AND stock(l) = stock AND operation(l) = op
        AND trnLedgerMatchesDir(l, dir)
        AND trnDocKindLedger(l) = dk
        AND date(l) >= dateFrom() AND date(l) <= dateTo();

trnActionWordByKey (Stock stock, Operation.Operation op, TrnDirection dir, TrnDocKind dk) =
    GROUP MAX trnActionWordDefault(StockDocumentLedger l) IF active(l) AND stock(l) = stock AND operation(l) = op
        AND trnLedgerMatchesDir(l, dir)
        AND trnDocKindLedger(l) = dk
        AND date(l) >= dateFrom() AND date(l) <= dateTo();

trnPriceTypeByKey (Stock stock, Operation.Operation op, TrnDirection dir, TrnDocKind dk) =
    GROUP MAX trnPriceTypeNameDefault(StockDocumentLedger l) IF active(l) AND stock(l) = stock AND operation(l) = op
        AND trnLedgerMatchesDir(l, dir)
        AND trnDocKindLedger(l) = dk
        AND date(l) >= dateFrom() AND date(l) <= dateTo();

trnActivePurchaseOrder (Purchase.OrderDetail d, Stock stock, Operation.Operation op, LegalEntity cp) =
    isPosted(d)
        AND customerStock(d) = stock
        AND operation(d) = op
        AND supplier(d) = cp
        AND date(d) >= dateFrom()
        AND date(d) <= dateTo();

trnActivePurchaseReturnOrder (PurchaseReturn.OrderDetail d, Stock stock, Operation.Operation op, LegalEntity cp) =
    isPosted(d)
        AND customerStock(d) = stock
        AND operation(d) = op
        AND supplier(d) = cp
        AND date(d) >= dateFrom()
        AND date(d) <= dateTo();

trnSumPurchaseOrder 'Сумма (зак. закуп.)' (Stock stock, Operation.Operation op, LegalEntity cp) =
    GROUP SUM invoiceSum(Purchase.OrderDetail d) IF trnActivePurchaseOrder(d, stock, op, cp);

trnSkuCountPurchaseOrder 'Кол-во поз. (зак. закуп.)' (Stock stock, Operation.Operation op, LegalEntity cp) =
    GROUP SUM 1 IF trnActivePurchaseOrder(Purchase.OrderDetail d, stock, op, cp);

trnWeightPurchaseOrder 'Вес (зак. закуп.)' (Stock stock, Operation.Operation op, LegalEntity cp) =
    GROUP SUM NUMERIC[16,3](netWeight(sku(Purchase.OrderDetail d)) * quantity(d))
        IF trnActivePurchaseOrder(d, stock, op, cp);

trnVolumePurchaseOrder 'Объём (зак. закуп.)' (Stock stock, Operation.Operation op, LegalEntity cp) =
    GROUP SUM NUMERIC[16,3](volume(sku(Purchase.OrderDetail d)) * quantity(d))
        IF trnActivePurchaseOrder(d, stock, op, cp);

trnGrossWeightPurchaseOrder 'Вес брутто (зак. закуп.)' (Stock stock, Operation.Operation op, LegalEntity cp) =
    GROUP SUM NUMERIC[16,3](grossWeight(sku(Purchase.OrderDetail d)) * quantity(d))
        IF trnActivePurchaseOrder(d, stock, op, cp);

hasTrnPurchaseOrder (Stock stock, Operation.Operation op, LegalEntity cp) =
    trnSkuCountPurchaseOrder(stock, op, cp) > 0;

trnSumPurchaseReturnOrder 'Сумма (зак. закуп.-возвр.)' (Stock stock, Operation.Operation op, LegalEntity cp) =
    GROUP SUM invoiceSum(PurchaseReturn.OrderDetail d) IF trnActivePurchaseReturnOrder(d, stock, op, cp);

trnSkuCountPurchaseReturnOrder 'Кол-во поз. (зак. закуп.-возвр.)' (Stock stock, Operation.Operation op, LegalEntity cp) =
    GROUP SUM 1 IF trnActivePurchaseReturnOrder(PurchaseReturn.OrderDetail d, stock, op, cp);

trnWeightPurchaseReturnOrder 'Вес (зак. закуп.-возвр.)' (Stock stock, Operation.Operation op, LegalEntity cp) =
    GROUP SUM NUMERIC[16,3](netWeight(sku(PurchaseReturn.OrderDetail d)) * quantity(d))
        IF trnActivePurchaseReturnOrder(d, stock, op, cp);

trnVolumePurchaseReturnOrder 'Объём (зак. закуп.-возвр.)' (Stock stock, Operation.Operation op, LegalEntity cp) =
    GROUP SUM NUMERIC[16,3](volume(sku(PurchaseReturn.OrderDetail d)) * quantity(d))
        IF trnActivePurchaseReturnOrder(d, stock, op, cp);

trnGrossWeightPurchaseReturnOrder 'Вес брутто (зак. закуп.-возвр.)' (Stock stock, Operation.Operation op, LegalEntity cp) =
    GROUP SUM NUMERIC[16,3](grossWeight(sku(PurchaseReturn.OrderDetail d)) * quantity(d))
        IF trnActivePurchaseReturnOrder(d, stock, op, cp);

hasTrnPurchaseReturnOrder (Stock stock, Operation.Operation op, LegalEntity cp) =
    trnSkuCountPurchaseReturnOrder(stock, op, cp) > 0;

trnActiveSaleOrder (Sale.OrderDetail d, Stock stock, Operation.Operation op, LegalEntity cp) =
    isPosted(d)
        AND supplierStock(d) = stock
        AND operation(d) = op
        AND customer(d) = cp
        AND date(d) >= dateFrom()
        AND date(d) <= dateTo();

trnActiveSaleReturnOrder (SaleReturn.OrderDetail d, Stock stock, Operation.Operation op, LegalEntity cp) =
    isPosted(d)
        AND supplierStock(d) = stock
        AND operation(d) = op
        AND customer(d) = cp
        AND date(d) >= dateFrom()
        AND date(d) <= dateTo();

trnSumSaleOrder 'Сумма (зак. прод.)' (Stock stock, Operation.Operation op, LegalEntity cp) =
    GROUP SUM invoiceSum(Sale.OrderDetail d) IF trnActiveSaleOrder(d, stock, op, cp);

trnSkuCountSaleOrder 'Кол-во поз. (зак. прод.)' (Stock stock, Operation.Operation op, LegalEntity cp) =
    GROUP SUM 1 IF trnActiveSaleOrder(Sale.OrderDetail d, stock, op, cp);

trnWeightSaleOrder 'Вес (зак. прод.)' (Stock stock, Operation.Operation op, LegalEntity cp) =
    GROUP SUM NUMERIC[16,3](netWeight(sku(Sale.OrderDetail d)) * quantity(d))
        IF trnActiveSaleOrder(d, stock, op, cp);

trnVolumeSaleOrder 'Объём (зак. прод.)' (Stock stock, Operation.Operation op, LegalEntity cp) =
    GROUP SUM NUMERIC[16,3](volume(sku(Sale.OrderDetail d)) * quantity(d))
        IF trnActiveSaleOrder(d, stock, op, cp);

trnGrossWeightSaleOrder 'Вес брутто (зак. прод.)' (Stock stock, Operation.Operation op, LegalEntity cp) =
    GROUP SUM NUMERIC[16,3](grossWeight(sku(Sale.OrderDetail d)) * quantity(d))
        IF trnActiveSaleOrder(d, stock, op, cp);

hasTrnSaleOrder (Stock stock, Operation.Operation op, LegalEntity cp) =
    trnSkuCountSaleOrder(stock, op, cp) > 0;

trnSumSaleReturnOrder 'Сумма (зак. прод.-возвр.)' (Stock stock, Operation.Operation op, LegalEntity cp) =
    GROUP SUM invoiceSum(SaleReturn.OrderDetail d) IF trnActiveSaleReturnOrder(d, stock, op, cp);

trnSkuCountSaleReturnOrder 'Кол-во поз. (зак. прод.-возвр.)' (Stock stock, Operation.Operation op, LegalEntity cp) =
    GROUP SUM 1 IF trnActiveSaleReturnOrder(SaleReturn.OrderDetail d, stock, op, cp);

trnWeightSaleReturnOrder 'Вес (зак. прод.-возвр.)' (Stock stock, Operation.Operation op, LegalEntity cp) =
    GROUP SUM NUMERIC[16,3](netWeight(sku(SaleReturn.OrderDetail d)) * quantity(d))
        IF trnActiveSaleReturnOrder(d, stock, op, cp);

trnVolumeSaleReturnOrder 'Объём (зак. прод.-возвр.)' (Stock stock, Operation.Operation op, LegalEntity cp) =
    GROUP SUM NUMERIC[16,3](volume(sku(SaleReturn.OrderDetail d)) * quantity(d))
        IF trnActiveSaleReturnOrder(d, stock, op, cp);

trnGrossWeightSaleReturnOrder 'Вес брутто (зак. прод.-возвр.)' (Stock stock, Operation.Operation op, LegalEntity cp) =
    GROUP SUM NUMERIC[16,3](grossWeight(sku(SaleReturn.OrderDetail d)) * quantity(d))
        IF trnActiveSaleReturnOrder(d, stock, op, cp);

hasTrnSaleReturnOrder (Stock stock, Operation.Operation op, LegalEntity cp) =
    trnSkuCountSaleReturnOrder(stock, op, cp) > 0;

trnRowMax = DATA LOCAL INTEGER ();

trnRowStock = DATA LOCAL Stock (INTEGER);
trnRowOp = DATA LOCAL Operation.Operation (INTEGER);
trnRowDir = DATA LOCAL TrnDirection (INTEGER);
trnRowCp = DATA LOCAL LegalEntity (INTEGER);
trnRowDocKind = DATA LOCAL TrnDocKind (INTEGER);
trnRowSum = DATA LOCAL NUMERIC[18,4] (INTEGER);
trnRowSkuCount = DATA LOCAL INTEGER (INTEGER);
trnRowWeight = DATA LOCAL NUMERIC[16,3] (INTEGER);
trnRowVolume = DATA LOCAL NUMERIC[16,3] (INTEGER);
trnRowGrossWeight = DATA LOCAL NUMERIC[16,3] (INTEGER);
trnRowSumTitle = DATA LOCAL STRING[100] (INTEGER);
trnRowSection = DATA LOCAL TrnSection (INTEGER);

trnRowActive (INTEGER i) = i >= 1 AND i <= trnRowMax() AND trnRowStock(i);

trnRowSectionName 'Раздел' (INTEGER i) = staticCaption(trnRowSection(i));
trnRowStockId 'Код подр.' (INTEGER i) = id(trnRowStock(i));
trnRowStockName 'Подразделение' (INTEGER i) = name(trnRowStock(i));
trnRowOpName 'Операция' (INTEGER i) =
    IF trnRowDir(i) = TrnDirection.ret THEN (OVERRIDE nameReturn(trnRowOp(i)), name(trnRowOp(i))) ELSE name(trnRowOp(i));
trnRowDocKindName 'Вид документа' (INTEGER i) = staticCaption(trnRowDocKind(i));
trnRowCounterpartyId 'Код КА' (INTEGER i) = id(trnRowCp(i));
trnRowCounterpartyName 'Наименование контрагента' (INTEGER i) = name(trnRowCp(i));

hasTrnDataCpLedger (Stock stock, Operation.Operation op, TrnDirection dir, LegalEntity cp, TrnDocKind dk) =
    trnSkuCountLedger(stock, op, dir, cp, dk) > 0;

clearTrnRows () {
    trnRowMax() <- 0;
    trnRowStock(INTEGER i) <- NULL;
    trnRowOp(INTEGER i) <- NULL;
    trnRowDir(INTEGER i) <- NULL;
    trnRowCp(INTEGER i) <- NULL;
    trnRowDocKind(INTEGER i) <- NULL;
    trnRowSum(INTEGER i) <- NULL;
    trnRowSkuCount(INTEGER i) <- NULL;
    trnRowWeight(INTEGER i) <- NULL;
    trnRowVolume(INTEGER i) <- NULL;
    trnRowGrossWeight(INTEGER i) <- NULL;
    trnRowSumTitle(INTEGER i) <- NULL;
    trnRowSection(INTEGER i) <- NULL;
}

fillTrnRows 'Заполнить данные' () {
    clearTrnRows();

    LOCAL idx = INTEGER ();
    idx() <- 0;

    FOR inTrnStock(Stock stock) AND hasTrnDataCpLedger(stock, Operation.Operation op, TrnDirection dir, LegalEntity cp, TrnDocKind dk)
        AND trnOpFilterOk(op, dir) AND trnDocKindFilterOk(dk) DO {
        idx() <- idx() + 1;
        trnRowStock(idx()) <- stock;
        trnRowOp(idx()) <- op;
        trnRowDir(idx()) <- dir;
        trnRowCp(idx()) <- cp;
        trnRowDocKind(idx()) <- dk;
        trnRowSum(idx()) <- trnSumLedger(stock, op, dir, cp, dk);
        trnRowSkuCount(idx()) <- trnSkuCountLedger(stock, op, dir, cp, dk);
        trnRowWeight(idx()) <- trnWeightLedger(stock, op, dir, cp, dk);
        trnRowVolume(idx()) <- trnVolumeLedger(stock, op, dir, cp, dk);
        trnRowGrossWeight(idx()) <- trnGrossWeightLedger(stock, op, dir, cp, dk);
        trnRowSumTitle(idx()) <- CONCAT ' ', (OVERRIDE trnActionWordByKey(stock, op, dir, dk), 'Сумма'), 'в', (OVERRIDE trnPriceTypeByKey(stock, op, dir, dk), 'ценах');
        trnRowSection(idx()) <- OVERRIDE trnSectionByKey(stock, op, dir, dk), TrnSection.outgoing;
    }

    FOR inTrnStock(Stock stock) AND hasTrnPurchaseOrder(stock, Operation.Operation op, LegalEntity cp)
        AND trnOpFilterOk(op, TrnDirection.direct) AND trnDocKindFilterOk(TrnDocKind.purchaseOrder) DO {
        idx() <- idx() + 1;
        trnRowStock(idx()) <- stock;
        trnRowOp(idx()) <- op;
        trnRowDir(idx()) <- TrnDirection.direct;
        trnRowCp(idx()) <- cp;
        trnRowDocKind(idx()) <- TrnDocKind.purchaseOrder;
        trnRowSum(idx()) <- trnSumPurchaseOrder(stock, op, cp);
        trnRowSkuCount(idx()) <- trnSkuCountPurchaseOrder(stock, op, cp);
        trnRowWeight(idx()) <- trnWeightPurchaseOrder(stock, op, cp);
        trnRowVolume(idx()) <- trnVolumePurchaseOrder(stock, op, cp);
        trnRowGrossWeight(idx()) <- trnGrossWeightPurchaseOrder(stock, op, cp);
        trnRowSumTitle(idx()) <- 'Заказано в закупочных ценах';
        trnRowSection(idx()) <- TrnSection.incoming;
    }

    FOR inTrnStock(Stock stock) AND hasTrnPurchaseReturnOrder(stock, Operation.Operation op, LegalEntity cp)
        AND trnOpFilterOk(op, TrnDirection.ret) AND trnDocKindFilterOk(TrnDocKind.purchaseReturnOrder) DO {
        idx() <- idx() + 1;
        trnRowStock(idx()) <- stock;
        trnRowOp(idx()) <- op;
        trnRowDir(idx()) <- TrnDirection.ret;
        trnRowCp(idx()) <- cp;
        trnRowDocKind(idx()) <- TrnDocKind.purchaseReturnOrder;
        trnRowSum(idx()) <- trnSumPurchaseReturnOrder(stock, op, cp);
        trnRowSkuCount(idx()) <- trnSkuCountPurchaseReturnOrder(stock, op, cp);
        trnRowWeight(idx()) <- trnWeightPurchaseReturnOrder(stock, op, cp);
        trnRowVolume(idx()) <- trnVolumePurchaseReturnOrder(stock, op, cp);
        trnRowGrossWeight(idx()) <- trnGrossWeightPurchaseReturnOrder(stock, op, cp);
        trnRowSumTitle(idx()) <- 'Заказано (возврат) в закупочных ценах';
        trnRowSection(idx()) <- TrnSection.outgoing;
    }

    FOR inTrnStock(Stock stock) AND hasTrnSaleOrder(stock, Operation.Operation op, LegalEntity cp)
        AND trnOpFilterOk(op, TrnDirection.direct) AND trnDocKindFilterOk(TrnDocKind.saleOrder) DO {
        idx() <- idx() + 1;
        trnRowStock(idx()) <- stock;
        trnRowOp(idx()) <- op;
        trnRowDir(idx()) <- TrnDirection.direct;
        trnRowCp(idx()) <- cp;
        trnRowDocKind(idx()) <- TrnDocKind.saleOrder;
        trnRowSum(idx()) <- trnSumSaleOrder(stock, op, cp);
        trnRowSkuCount(idx()) <- trnSkuCountSaleOrder(stock, op, cp);
        trnRowWeight(idx()) <- trnWeightSaleOrder(stock, op, cp);
        trnRowVolume(idx()) <- trnVolumeSaleOrder(stock, op, cp);
        trnRowGrossWeight(idx()) <- trnGrossWeightSaleOrder(stock, op, cp);
        trnRowSumTitle(idx()) <- 'Заказано в отпускных ценах';
        trnRowSection(idx()) <- TrnSection.outgoing;
    }

    FOR inTrnStock(Stock stock) AND hasTrnSaleReturnOrder(stock, Operation.Operation op, LegalEntity cp)
        AND trnOpFilterOk(op, TrnDirection.ret) AND trnDocKindFilterOk(TrnDocKind.saleReturnOrder) DO {
        idx() <- idx() + 1;
        trnRowStock(idx()) <- stock;
        trnRowOp(idx()) <- op;
        trnRowDir(idx()) <- TrnDirection.ret;
        trnRowCp(idx()) <- cp;
        trnRowDocKind(idx()) <- TrnDocKind.saleReturnOrder;
        trnRowSum(idx()) <- trnSumSaleReturnOrder(stock, op, cp);
        trnRowSkuCount(idx()) <- trnSkuCountSaleReturnOrder(stock, op, cp);
        trnRowWeight(idx()) <- trnWeightSaleReturnOrder(stock, op, cp);
        trnRowVolume(idx()) <- trnVolumeSaleReturnOrder(stock, op, cp);
        trnRowGrossWeight(idx()) <- trnGrossWeightSaleReturnOrder(stock, op, cp);
        trnRowSumTitle(idx()) <- 'Заказано (возврат) в отпускных ценах';
        trnRowSection(idx()) <- TrnSection.incoming;
    }

    trnRowMax() <- idx();
}

hasTrnDataOpDirAny (Operation.Operation op) =
    (GROUP SUM 1 IF hasTrnDataCpLedger(Stock stock, op, TrnDirection dir, LegalEntity cp, TrnDocKind dk) AND inTrnStock(stock))
        OR (GROUP SUM 1 IF hasTrnPurchaseOrder(Stock stock2, op, LegalEntity cp2) AND inTrnStock(stock2))
        OR (GROUP SUM 1 IF hasTrnPurchaseReturnOrder(Stock stock3, op, LegalEntity cp3) AND inTrnStock(stock3))
        OR (GROUP SUM 1 IF hasTrnSaleOrder(Stock stock4, op, LegalEntity cp4) AND inTrnStock(stock4))
        OR (GROUP SUM 1 IF hasTrnSaleReturnOrder(Stock stock5, op, LegalEntity cp5) AND inTrnStock(stock5));

selectedTrnOpNames() = GROUP CONCAT name(Operation.Operation op) IF inTrnOperation(op), ', ' ORDER name(op);
selectedTrnReturnOpNames() = GROUP CONCAT (OVERRIDE nameReturn(Operation.Operation op), name(op)) IF inTrnReturnOperation(op), ', ' ORDER name(op);

nameFilterTrnOps 'Операции' () = IF NOT anyTrnOpSelected() THEN 'Все операции'
    ELSE CONCAT ', ', selectedTrnOpNames(), selectedTrnReturnOpNames() CHARWIDTH 40;

nameFilterTrnDocKinds 'Виды документов' () = IF NOT anyTrnDocKindSelected() THEN 'Все виды документов'
    ELSE (GROUP CONCAT staticCaption(TrnDocKind dk) IF inTrnDocKind(dk), ', ' ORDER dk) CHARWIDTH 40;

FORM dialogTrnOperations 'Выбор операций'
    OBJECTS op = Operation.Operation
    PROPERTIES(op) inTrnOperation
    PROPERTIES(op) READONLY name
    PROPERTIES(op) inTrnReturnOperation
    PROPERTIES(op) READONLY nameReturn
    FILTERS hasTrnDataOpDirAny(op)
    ORDERS name(op)
;

DESIGN dialogTrnOperations {
    size = (700, 500);
}

FORM dialogTrnDocKinds 'Выбор видов документов'
    OBJECTS dk = TrnDocKind
    PROPERTIES(dk) inTrnDocKind
    PROPERTIES(dk) READONLY staticCaption
;

DESIGN dialogTrnDocKinds {
    size = (400, 300);
}

FORM turnoverByCounterpartyGestori 'Грузооборот по контрагентам'
    PROPERTIES() dateFrom, dateTo
    PROPERTIES() nameTrnStockList READONLY SHOWIF trnStockList()
    PROPERTIES() trnStockNames ON CHANGE changeTrnStocks() READONLYIF trnStockList()
    PROPERTIES() nameFilterTrnOps ON CHANGE { DIALOG dialogTrnOperations; }
    PROPERTIES() nameFilterTrnDocKinds ON CHANGE { DIALOG dialogTrnDocKinds; }
    PROPERTIES() fillTrnRows TOOLBAR

    OBJECTS r = INTEGER
    PROPERTIES(r) READONLY
    trnRowSectionName,
        trnRowStockId,
        trnRowStockName,
        trnRowOpName,
        trnRowDocKindName,
        trnRowCounterpartyId,
        trnRowCounterpartyName,
        trnRowSum,
        trnRowSumTitle,
        trnRowSkuCount,
        trnRowWeight,
        trnRowVolume,
        trnRowGrossWeight
    ORDERS trnRowSectionName(r), trnRowStockId(r), trnRowCounterpartyId(r), trnRowDocKindName(r), trnRowOpName(r)
    FILTERS trnRowActive(r)

    EVENTS ON INIT {
        initDates();
    }
;

fillTurnoverGestoriReport 'Выгрузить в XLSX' () {
    PRINT turnoverByCounterpartyGestori XLSX;
} IMAGE 'print.png';

EXTEND FORM turnoverByCounterpartyGestori
    PROPERTIES() DISABLEIF NOT dateFrom() OR NOT dateTo() OR NOT trnStockCount()
    fillTurnoverGestoriReport
;

DESIGN turnoverByCounterpartyGestori {
    NEW cnt {
        fill = 1;
        NEW filters {
            alignment = STRETCH;
            NEW topRow {
                horizontal = TRUE;
                MOVE PROPERTY(dateFrom());
                MOVE PROPERTY(dateTo());
                MOVE PROPERTY(fillTrnRows());
                MOVE PROPERTY(fillTurnoverGestoriReport()) { valueClass = 'btn-success'; }
            }
            MOVE PROPERTY(nameTrnStockList()) { alignment = STRETCH; }
            MOVE PROPERTY(trnStockNames()) { alignment = STRETCH; }
            MOVE PROPERTY(nameFilterTrnOps()) { alignment = STRETCH; }
            MOVE PROPERTY(nameFilterTrnDocKinds()) { alignment = STRETCH; }
        }
        NEW dataArea {
            fill = 1;
            alignment = STRETCH;
            MOVE BOX(r) {
                caption = 'Данные грузооборота';
                PROPERTY(trnRowSectionName(r)) { caption = 'Раздел'; charWidth = 10; background = #E3F2FD; }
                PROPERTY(trnRowStockId(r)) { caption = 'Код подр.'; charWidth = 8; }
                PROPERTY(trnRowStockName(r)) { caption = 'Подразделение'; charWidth = 25; }
                PROPERTY(trnRowOpName(r)) { caption = 'Операция'; charWidth = 35; }
                PROPERTY(trnRowDocKindName(r)) { caption = 'Вид документа'; charWidth = 25; }
                PROPERTY(trnRowCounterpartyId(r)) { caption = 'Код КА'; charWidth = 10; }
                PROPERTY(trnRowCounterpartyName(r)) { caption = 'Наименование контрагента'; charWidth = 35; }
                PROPERTY(trnRowSum(r)) { caption = 'Сумма'; charWidth = 18; background = #FFF9C4; }
                PROPERTY(trnRowSumTitle(r)) { caption = 'Вид суммы'; charWidth = 35; }
                PROPERTY(trnRowSkuCount(r)) { caption = 'Кол-во поз.'; charWidth = 12; }
                PROPERTY(trnRowWeight(r)) { caption = 'Вес'; charWidth = 12; }
                PROPERTY(trnRowVolume(r)) { caption = 'Объём'; charWidth = 12; }
                PROPERTY(trnRowGrossWeight(r)) { caption = 'Вес брутто'; charWidth = 14; }
            }
        }
    }
    MOVE TOOLBARBOX;
}

CLASS CSPriceType 'Тип цены для сличительной ведомости' {
    retail 'Цена продажи',
    account 'Учетная цена',
    cost 'Бухгалтерская себестоимость'
}

FORM dialogCSPriceType 'Тип цены'
    OBJECTS t = CSPriceType
    PROPERTIES(t) READONLY staticCaption
    LIST CSPriceType OBJECT t
;

csPriceType 'Тип цены' = DATA LOCAL CSPriceType (CollationSheet);
nameCSPriceType 'Тип цены' (CollationSheet o) = staticCaption(csPriceType(o));

initCSPriceType (CollationSheet o) {
    IF NOT csPriceType(o) THEN csPriceType(o) <- CSPriceType.retail;
}

csUnitPrice 'Цена, руб. коп.' (CollationSheet o, Sku s) =
    CASE
        WHEN csPriceType(o) = CSPriceType.retail
        THEN NUMERIC[18,4](retailPriceA(s, stock(o), dateTime(o)))
        WHEN csPriceType(o) = CSPriceType.account
        THEN NUMERIC[18,4](accountPriceA(s, stock(o), dateTime(o)))
        WHEN csPriceType(o) = CSPriceType.cost
        THEN NUMERIC[18,4](round2(accountPriceA(s, stock(o), dateTime(o)) /
            (1.0 + (OVERRIDE valueVAT(s, stock(o)), 0.0) / 100.0)))
        ELSE NUMERIC[18,4](priceBalance(o, s));

csUnitPriceCaption 'Название колонки цены' (CollationSheet o) =
    CASE
        WHEN csPriceType(o) = CSPriceType.retail
        THEN 'Отпускная цена, руб. коп.'
        WHEN csPriceType(o) = CSPriceType.account
        THEN 'Учетная цена, руб. коп.'
        WHEN csPriceType(o) = CSPriceType.cost
        THEN 'Бухгалтерская себестоимость, руб. коп.'
        ELSE 'Цена, руб. коп.';

csIdSku 'Код товара' (CollationSheet o, Sku s) = id(s);
csNameSku 'Наименование товара' (CollationSheet o, Sku s) = name(s);
csUOM 'Единица измерения' (CollationSheet o, Sku s) = shortNameUOM(s);

csQtyAccount 'Количество (учет)' (CollationSheet o, Sku s) = quantityBalance(o, s);
csSumAccount 'Сумма (учет)' (CollationSheet o, Sku s) =
    NUMERIC[18,4](round2(quantityBalance(o, s) * csUnitPrice(o, s)));

csQtyFact 'Количество (факт)' (CollationSheet o, Sku s) = quantityPageInventoryDetail(o, s);
csSumFact 'Сумма (факт)' (CollationSheet o, Sku s) =
    NUMERIC[18,4](round2(quantityPageInventoryDetail(o, s) * csUnitPrice(o, s)));

csQtyDiff 'Количество (расхождение)' (CollationSheet o, Sku s) =
    quantityPageInventoryDetail(o, s) (-) quantityBalance(o, s);
csSumDiff 'Сумма (расхождение)' (CollationSheet o, Sku s) =
    NUMERIC[18,4](round2(csQtyDiff(o, s) * csUnitPrice(o, s)));

csInclude (CollationSheet o, Sku s) =
    include(o, s) AND (quantityBalance(o, s) OR quantityPageInventoryDetail(o, s));

csNumberInventory 'Номер акта' (CollationSheet o) = number(inventory(o));
csDateInventory 'Дата акта' (CollationSheet o) = date(inventory(o));

FORM collationSheetPrice 'Сличительная ведомость (по типу цен)'
    OBJECTS o = CollationSheet PANEL
    PROPERTIES(o) READONLY csNumberInventory, csDateInventory, csUnitPriceCaption
    PROPERTIES(o) nameCSPriceType
    OBJECTS s = Sku
    PROPERTIES(o, s) READONLY
    csIdSku, csNameSku, csUOM, csUnitPrice,
        csQtyAccount, csSumAccount,
        csQtyFact, csSumFact,
        csQtyDiff, csSumDiff
    FILTERS csInclude(o, s)
    ORDERS csNameSku(o, s)
;

printCollationSheetPrice 'Печать в XLSX' (CollationSheet o) {
    PRINT collationSheetPrice OBJECTS o = o XLSX;
} IMAGE 'print.png';

EXTEND FORM collationSheetPrice
    PROPERTIES(o) printCollationSheetPrice
;

EXTEND FORM inventory
    OBJECTS csp = CollationSheet
    PROPERTIES(csp) READONLY name, nameTypeOfAddition, nameStock
    PROPERTIES(csp) nameCSPriceType ON CHANGE {
        DIALOG dialogCSPriceType OBJECTS t = csPriceType(csp) INPUT DO {
            csPriceType(csp) <- t;
        }
    }
    PROPERTIES(csp) printCollationSheetPrice
    FILTERS inventory(csp) == in

    OBJECTS sp = Sku
    PROPERTIES(csp, sp) READONLY
    csIdSku, csNameSku, csUOM, csUnitPrice,
        csQtyAccount, csSumAccount,
        csQtyFact, csSumFact,
        csQtyDiff, csSumDiff
    FILTERS csInclude(csp, sp)
    ORDERS csNameSku(csp, sp)

    EVENTS ON INIT {
        FOR inventory(CollationSheet c) == in DO initCSPriceType(c);
    }
;

DESIGN inventory {
    topContainer {
        NEW priceCSBox {
            caption = 'Сличительная ведомость по ценам';
            MOVE BOX(csp);
            MOVE BOX(sp) { fill = 1000; }
        }
    }
}

importInvFromExcelStock 'Загрузить из Excel' (Inventory inv, Stock st) {
    IF NOT inv THEN {
        MESSAGE 'Не выбрана инвентаризация';
        RETURN;
    }
    IF NOT st THEN {
        MESSAGE 'Не выбран склад';
        RETURN;
    }
    IF NOT include(st, inv) THEN {
        MESSAGE 'Выбранный склад не включен в инвентаризацию';
        RETURN;
    }

    LOCAL idSku = STRING[100] (INTEGER);
    LOCAL idBarcode = STRING[15] (INTEGER);
    LOCAL quantity = NUMERIC[16,5] (INTEGER);

    INPUT f = EXCELFILE DO {
        IMPORT XLS NOHEADER FROM f TO idSku = A, idBarcode = B, quantity = C;

        LOCAL skuByRow = Sku (INTEGER);
        skuByRow(INTEGER i) <- skuBarcode(trim(idBarcode(i))) WHERE imported(i) AND NOT trim(idSku(i)) AND trim(idBarcode(i));
        skuByRow(INTEGER i) <- sku(trim(idSku(i))) WHERE imported(i) AND trim(idSku(i));

        LOCAL countOk = INTEGER ();
        countOk() <- GROUP SUM 1 IF imported(INTEGER i) AND skuByRow(i) AND quantity(i);

        IF NOT countOk() THEN {
            MESSAGE 'Нет корректных строк для импорта';
            RETURN;
        }

        NEW li = ListInventory {
            stock(li) <- st;
            inventory(li) <- inv;

            NEW pg = PageInventory {
                listInventory(pg) <- li;
                LOCAL qty = NUMERIC[16,5] (Sku);
                qty(Sku s) <- GROUP SUM quantity(INTEGER i) IF imported(i) AND skuByRow(i) = s AND quantity(i);
                FOR qty(Sku s) NEW d = PageInventoryDetail DO {
                    pageInventory(d) <- pg;
                    sku(d) <- s;
                    quantity(d) <- qty(s);
                    price(d) <- prevAccountPriceA(s, st, dateTime(inv));
                }
            }
        }

        MESSAGE 'Импортировано строк: ' + countOk();
    }
}

EXTEND FORM inventory
    PROPERTIES(in, ds) importInvFromExcelStock SHOWIF (saved(in) AND NOT notShowAddListInventory(in))
;

NAVIGATOR {
    stockReports {
        NEW inventoryRegister;
        NEW operationReport;
        NEW warehouseReport;
        NEW turnoverByCounterpartyGestori;
    }
}