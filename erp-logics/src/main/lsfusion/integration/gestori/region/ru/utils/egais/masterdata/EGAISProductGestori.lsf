MODULE EGAISProductGestori;

REQUIRE EGAISProduct;

NAMESPACE EGAIS;

EXTEND FORM product 
    PROPERTIES txtFullName 'Наименование' = TEXT(fullName(o)),
        txtShortNameProducer 'Производитель' = TEXT(shortNameProducer(o)),
        txtDescriptionProducer 'Адрес' = TEXT(descriptionProducer(o))
;

DESIGN product {
    header {
        horizontal = FALSE;
        alignment = STRETCH;
        
        MOVE PROPERTY(id(o));
        REMOVE PROPERTY(fullName(o));
        MOVE PROPERTY(txtFullName);
        
        MOVE PROPERTY(capacity(o)) { charWidth = 10; alignment = START;};
        MOVE PROPERTY(unitTypeId(o));
        
        MOVE PROPERTY(alcVolume(o)) { charWidth = 10; alignment = START;};
        MOVE PROPERTY(nameType(o));
        
        MOVE PROPERTY(idProducer(o));
        REMOVE PROPERTY(shortNameProducer(o));
        MOVE PROPERTY(txtShortNameProducer);
        REMOVE PROPERTY(descriptionProducer(o));
        MOVE PROPERTY(txtDescriptionProducer);
    }
}

DESIGN client {
    products {
        caption = 'Алкогольная продукция';
        MOVE BOX(p);
    }
}

minProduct(Client c) = GROUP MIN Product p BY producer(p);
hideDelete (Client c) += TRUE IF minProduct(c);