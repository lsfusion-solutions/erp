MODULE EGAISQueryClientsv2Gestori;

REQUIRE EGAISQueryClientsv2, EGAISTicketGestori, EGAISClientGestori;

NAMESPACE EGAIS;

@defineInDocsFilterDocType(ReplyClient_v2, 'Запрос справочника организаций');

DESIGN clients {
    PROPERTY(queryClientsv2()){ caption = 'Запросить по коду организации или ИНН';};
}

overImportClient (Client c) +{
    synchronized(c) <- TRUE;
}
