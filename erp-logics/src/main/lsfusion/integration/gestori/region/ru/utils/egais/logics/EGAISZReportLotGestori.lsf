MODULE EGAISZReportLotGestori;

REQUIRE EGAISZReportLot, EGAISActWriteOffGestori;

NAMESPACE EGAIS;

createActWriteOff (Client c, DATE dFrom, DATE dTo, WriteOffType t) +{
    IF t == writeOffType('Розничная продажа') THEN {
        FOR iterate(DATE d, dFrom, dTo) DO {
            IF own(c) AND NOT actWriteOff(c, d, t) THEN createActWriteOff(c, d);
        }
    }
}

overFillActWriteOff (ActWriteOff a) + {
    dataSaleDateTime(a) <- dateTime(a);
}