MODULE EGAISPurchaseInvoiceGestori;

REQUIRE EGAISPurchaseInvoice, EGAISWayBillGestory,
        PurchaseInvoiceTerminal, PurchaseShipmentInvoiceTerminal, SkuLedgerLotGestori, 
        EGAISFRegLedgerGestori, EGAISWayBillLedger,
        EGAISItem;

PRIORITY Purchase;

NAMESPACE EGAISPurchase;

@defineOriginalLastDocumentWayBillAttributes(Purchase, Invoice);
@defineOriginalLastDocumentWayBillAttributes(Purchase, Invoice, customerStock);

@defineOriginalLastPositionDocumentWayBillAttributes(Purchase, invoice, InvoiceDetail);

unlink 'Отвязать ТТН' (Invoice i) {
    IF wayBillAct(wayBill(i)) THEN {
        MESSAGE 'Невозможно отвязать, т.к. для ТТН есть акт приемки ЕГАИС';
        RETURN;
    }
    
    quantity(UserInvoiceDetail d, WayBillPosition p) <- NULL WHERE userInvoice(d) = i;
    wayBill(i) <- NULL;
}

forbidAddUserInvoiceDetailTTN 'Запрещать добавлять в спецификацию накладной позиции из ЕГАИС ТТН при наличии не связанных позиций' = DATA BOOLEAN () PREREAD;
EXTEND FORM integrationData
    PROPERTIES() forbidAddUserInvoiceDetailTTN
;

DESIGN integrationData {
    EGAISParams {
        MOVE PROPERTY(forbidAddUserInvoiceDetailTTN());
    }
}

existOtherProduct (Invoice i) = 
    GROUP MIN TRUE IF NOT sku(UserInvoiceDetail d) == minItem(product(WayBillPosition pp)) AND sku(d) AND  minItem(product(pp)) AND wayBill(i) == wayBill(pp) AND invoice(d) == i;

existOtherWayBillPosition(Invoice i) = 
    GROUP MIN TRUE IF quantity(UserInvoiceDetail d, WayBillPosition p) AND NOT wayBill(i) == wayBill(p) AND wayBill(i) AND wayBill(p) AND invoice(d) == i;

quantityExceedsTTN 'Превышение количества поставлено над ЕГАИС' (UserInvoiceDetail d) = shipmentQuantity(d) > quantityWayBill(d);
backgroundShipmentQuantity(UserInvoiceDetail d) += RGB(255,212,212) IF  shipmentQuantity(d) > quantityWayBill(d);
hideCreateDetail(UserInvoice i) += forbidAddUserInvoiceDetailTTN() AND (existOtherProduct(i) OR existOtherWayBillPosition(i));

markPositionQuantity 'Кол-во по маркам позиции' (UserInvoiceDetail d, WayBillPosition p) =
    GROUP SUM 1 IF wayBillPosition(WayBillMark m) = p AND quantity(d, lot(markCode(m))) > 0;

wayBillPositionTTN (MarkCode c, WayBill b) =
    GROUP MAX wayBillPosition(WayBillMark m) BY markCode(m), wayBill(wayBillPosition(m));
// позиция ЕГАИС ТТН той накладной, к которой привязана строка
positionInvoiceTTN (UserInvoiceDetail d, Lot l) =
    wayBillPositionTTN(markCode(id(l)), wayBill(userInvoice(d)));

WHEN (SETCHANGED(quantity(UserInvoiceDetail d, Lot l)) OR DROPPED(quantity(d, l)))
        AND WayBillPosition p = positionInvoiceTTN(d, l) AND countMarkCodes(p)
    DO quantity(d, p) <- markPositionQuantity(d, p);

backgroundQuantityUserInvoice (WayBillPosition p) =
    RGB(255,212,212) IF quantityUserInvoice(p) AND NOT quantityUserInvoice(p) = quantity(p);

EXTEND FORM userInvoice
    PROPERTIES(i) unlink SHOWIF NOT wayBillAct(wayBill(i))
    PROPERTIES(wp) READONLY quantityUserInvoice BACKGROUND backgroundQuantityUserInvoice(wp)

    FILTERGROUP exceed
        FILTER 'Превышение количества поставлено над ЕГАИС' quantityExceedsTTN(ed)
;

DESIGN userInvoice {
    EGAISHeader {
        MOVE PROPERTY(unlink(i));
    }

    PROPERTY(numberDateWayBill(i)) { charWidth = 50; }
}

countProductDetails 'Кол-во строк алкогольной продукции' (Invoice i) =
    GROUP SUM 1 IF minProduct(sku(InvoiceDetail d)) BY invoice(d);

EXTEND FORM invoices
    FILTERGROUP egais
        FILTER 'С алкогольной продукцией' countProductDetails(i)
;

ttnQuantity(WayBill w, Product p) = GROUP SUM quantity(WayBillPosition wp) BY wayBill(wp), product(wp); 
shipmentQuantity(Invoice i, Product p) = GROUP SUM shipmentQuantity(InvoiceDetail d) BY invoice(d), minProduct(sku(d));
countDetailsShipmentBiggerTTN (Invoice i) = GROUP SUM 1 IF invoice(InvoiceDetail d) = i AND minProduct(sku(d)) AND shipmentQuantity(d)
    AND shipmentQuantity(i, minProduct(sku(d))) > ttnQuantity(wayBill(i), minProduct(sku(d)));

overCheckProcess(Invoice i) += IF countDetailsShipmentBiggerTTN(i) AND i IS Invoice THEN 'По ' + countDetailsShipmentBiggerTTN(i) + ' позициям принятое количество превышает количество по ЕГАИС ТТН';

@defineDenyEditDocumentEGAISDiffQuantity(consigneeF2Reg, wayBill, invoice);

hideCreateDetail(UserInvoice i) += NOT disableEGAISDocumentConstraints() AND activeWayBillAct(wayBill(i));
disableChangeWayBill(UserInvoice i) += TRUE IF NOT disableEGAISDocumentConstraints() AND activeWayBillAct(wayBill(i));

@defineDocumentWayBillConstraint(invoice, 'Накладная (закупка)');

DESIGN userInvoice {
    importTSD { showIf = disableEGAISDocumentConstraints() OR NOT activeWayBillAct(wayBill(invoice(d))); }
    importTSD2 { showIf = disableEGAISDocumentConstraints() OR NOT activeWayBillAct(wayBill(invoice(d))); }
}

minNoInItemWayBillPosition(WayBill w) = GROUP MIN TRUE IF WayBillPosition p IS WayBillPosition AND NOT minItem(product(p)) BY wayBill(p);
checkUserInvoiceConditions(WayBill w) += 'Не вся алкогольная продукция ТТН связана с товарами системы' IF minNoInItemWayBillPosition(w);

seekWayBill (UserInvoice d) += GROUP MAX WayBill w IF matches(d, w) AND toAccept(w) AND number(w) = number(d);

CONSTRAINT [GROUP SUM 1 BY wayBill(Invoice i)](WayBill w) > 1
    MESSAGE 'Запрещено привязывать несколько накладных закупки с одной ЕГАИС ТТН';

CONSTRAINT SETCHANGED(quantity(UserInvoiceDetail d, WayBillPosition p))
    AND wayBill(userInvoice(d)) AND NOT wayBill(p) = wayBill(userInvoice(d))
    MESSAGE 'Запрещено привязывать строку к справке Б из другой ЕГАИС ТТН';

countQuantityInvoice (WayBill w) = GROUP SUM 1 IF wayBill(WayBillPosition p) = w AND quantityInvoice(p) > 0;
realQuantityInvoiceDifferences (WayBill w) = GROUP SUM 1 IF wayBill(WayBillPosition p) = w AND NOT quantity(p) = quantityInvoice(p);
captionProcess = CASE
    WHEN w IS WayBill AND NOT countQuantityInvoice(w) THEN 'Отправить отказ в ЕГАИС'
    WHEN realQuantityInvoiceDifferences(w) THEN 'Отправить расхождение в ЕГАИС'
    ELSE 'Отправить подтверждение в ЕГАИС';

DESIGN invoices {
    PROPERTY (processEGAIS) {caption = captionProcess(w);}

    PROPERTY (cancelEGAIS) {caption = 'Отправить отмену акта в ЕГАИС';}
}

maxInvoice(WayBillPosition p) = GROUP MAX UserInvoice i IF wayBill(i) == wayBill(p);

showPurchaseInvoice 'Показать накладную (закупка)' (FRegLedger l)  {
    IF maxInvoice(position[WayBillInLedger](l)) THEN {
        SHOW userInvoice OBJECTS i = maxInvoice(position[WayBillInLedger](l));
    } ELSE {
        MESSAGE 'Накладная не найдена';
    }
}  ASON CONTEXTMENU number[FRegLedger];