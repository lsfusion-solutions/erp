MODULE EGAISQueryAPv2Gestori;

REQUIRE EGAISQueryAPv2, EGAISTicketGestori;

NAMESPACE EGAIS;

DESIGN products {
    PROPERTY (queryAPv2()) { caption = 'Запросить по коду производителя';};
    PROPERTY (queryAPv2Code()) { caption = 'Запросить по коду продукции';};
}

@defineInDocsFilterDocType(ReplyAP_v2, 'Запрос справочника продукции');

isReplyDocType(DocType t) += t == DocType.ReplyAP_v2;

DESIGN client {
    PROPERTY(queryAPv2(o)){ caption = 'Запросить по коду производителя';};
}