MODULE EGAISActWriteOffExchangeGestori;

REQUIRE EGAISActWriteOffExchange, EGAISActWriteOffGestori, EGAISTicketGestori, EGAISDocGestori;

NAMESPACE EGAIS;

@defineOutDocAbstractTypeNumberDate(actWriteOff);

@defineOutDocAbstractOriginalDocumentTypeNumberDate(actWriteOff);

DESIGN actWriteOffs {
    PROPERTY(id(odd)) { caption = 'Номер транспортного пакета'; }
}

checkConditions(ActWriteOff w) += 'Дата/время акта должна быть не старше трех дней от текущей даты/времени' 
    IF secondsBetweenDates(currentDateTime(), dateTime(w)) > 3*86400;

checkConditions(ActWriteOff w) += 'Дата/время акта должна быть не больше текущей даты/времени'
    IF dateTime(w) > currentDateTime();

minPosition(ActWriteOff w) = GROUP MIN ActWriteOffPosition p BY actWriteOff(p);
checkConditions(ActWriteOff w) += 'Отсутствуют записи в спецификации'
    IF w IS ActWriteOff AND NOT minPosition(w);

wrangQuantity (ActWriteOffPosition p) = NOT overQuantity(p) OR (NOT overQuantity(p) == quantity(p) IF quantity(p));
wrangQuantity (ActWriteOff w) = GROUP MIN ActWriteOffPosition p BY actWriteOff(p) IF wrangQuantity(p);
checkConditions(ActWriteOff w) += 'Количество кодов маркировки не соответствует количеству по позиции акта'
    IF wrangQuantity(w);

hideEdit(ActWriteOff a) += TRUE IF forbidEditSendDocument() AND notRejected(actWriteOffOutDoc(a)) AND id(actWriteOffOutDoc(a));
hideDelete(ActWriteOff a) += TRUE IF forbidEditSendDocument() AND notRejected(actWriteOffOutDoc(a)) AND id(actWriteOffOutDoc(a));

CONSTRAINT DROPPED(ActWriteOff a IS ActWriteOff) AND NOT disableEGAISDocumentConstraints()
    AND notRejected(actWriteOffOutDoc(a)) AND PREV(id(actWriteOffOutDoc(a)))
    MESSAGE 'Запрещено удалять акт списания с баланса после отправки в ЕГАИС';

CONSTRAINT (DROPCHANGED(number(ActWriteOff a)) OR DROPCHANGED(dateTime(a)) OR DROPCHANGED(regId(a))
    OR CHANGED(type(a)) OR DROPCHANGED(dataSaleDateTime(a)) OR DROPCHANGED(client(a)))
    AND notRejected(actWriteOffOutDoc(a)) AND PREV(id(actWriteOffOutDoc(a))) AND NOT disableEGAISDocumentConstraints()
    MESSAGE 'Запрещено изменять атрибуты акта списания с баланса после отправки в ЕГАИС';

notRejectedActWriteOff(ActWriteOffPosition p) = notRejected(actWriteOffOutDoc(actWriteOff(p)));

CONSTRAINT (SETCHANGED(product(ActWriteOffPosition p)) OR SETCHANGED(f2Reg(p)) OR SETCHANGED(overQuantity(p))
    OR SETCHANGED(sumSale(p)) OR DROPPED(product(p)) OR DROPPED(f2Reg(p)) OR DROPPED(overQuantity(p))
    OR DROPPED(sumSale(p)))
    AND notRejectedActWriteOff(p) AND PREV(id(actWriteOffOutDoc(actWriteOff(p)))) AND NOT disableEGAISDocumentConstraints()
    MESSAGE 'Запрещено изменять атрибуты строки акта списания с баланса после отправки в ЕГАИС';

CONSTRAINT DROPPED(p IS ActWriteOffPosition)
    AND PREV(notRejectedActWriteOff(p)) AND NOT disableEGAISDocumentConstraints()
    MESSAGE 'Запрещено удалять строки акта списания с баланса после отправки в ЕГАИС';

CONSTRAINT SET(p IS ActWriteOffPosition)
    AND notRejectedActWriteOff(p) AND PREV(id(actWriteOffOutDoc(actWriteOff[ActWriteOffPosition](p)))) AND NOT disableEGAISDocumentConstraints()
    MESSAGE 'Запрещено добавлять строки в акт списания с баланса после отправки в ЕГАИС';

CONSTRAINT (SETDROPPED(ActWriteOffMark m IS ActWriteOffMark) OR DROPCHANGED(markCode(m)))
    AND notRejected(actWriteOffOutDoc(actWriteOff(actWriteOffPosition(m)))) AND PREV(id(actWriteOffOutDoc(actWriteOff(actWriteOffPosition(m)))))
    AND NOT disableEGAISDocumentConstraints()
    MESSAGE 'Запрещено изменять марки акта списания с баланса после отправки в ЕГАИС';

hideAddPosition(ActWriteOff w) += ((notRejected(actWriteOffOutDoc(w)) AND id(actWriteOffOutDoc(w))) OR posted(w)) AND NOT disableEGAISDocumentConstraints();
hideDeletePosition(ActWriteOffPosition p) += ((notRejected(actWriteOffOutDoc(actWriteOff(p))) AND id(actWriteOffOutDoc(actWriteOff(p)))) OR posted(actWriteOff(p))) AND NOT disableEGAISDocumentConstraints();

// Блокировка редактирования проведённого или отправленного акта списания
hideEdit(ActWriteOff a) += ((notRejected(actWriteOffOutDoc(a)) AND id(actWriteOffOutDoc(a))) OR posted(a)) AND NOT disableEGAISDocumentConstraints();
hideDelete(ActWriteOff a) += ((notRejected(actWriteOffOutDoc(a)) AND id(actWriteOffOutDoc(a))) OR posted(a)) AND NOT disableEGAISDocumentConstraints();

CONSTRAINT DROPPED(ActWriteOff a IS ActWriteOff) AND PREV(posted(a)) AND NOT disableEGAISDocumentConstraints()
    MESSAGE 'Запрещено удалять проведённый акт списания с баланса';

CONSTRAINT (DROPCHANGED(number(ActWriteOff a)) OR DROPCHANGED(dateTime(a)) OR DROPCHANGED(regId(a))
    OR CHANGED(type(a)) OR DROPCHANGED(dataSaleDateTime(a)) OR DROPCHANGED(client(a)))
    AND posted(a) AND NOT disableEGAISDocumentConstraints()
    MESSAGE 'Запрещено изменять атрибуты проведённого акта списания с баланса';

CONSTRAINT (SETCHANGED(product(ActWriteOffPosition p)) OR SETCHANGED(f2Reg(p)) OR SETCHANGED(overQuantity(p))
    OR SETCHANGED(sumSale(p)) OR DROPPED(product(p)) OR DROPPED(f2Reg(p)) OR DROPPED(overQuantity(p))
    OR DROPPED(sumSale(p)))
    AND posted(actWriteOff(p)) AND NOT disableEGAISDocumentConstraints()
    MESSAGE 'Запрещено изменять атрибуты строки проведённого акта списания с баланса';

CONSTRAINT DROPPED(p IS ActWriteOffPosition)
    AND PREV(posted(actWriteOff[ActWriteOffPosition](p))) AND NOT disableEGAISDocumentConstraints()
    MESSAGE 'Запрещено удалять строки проведённого акта списания с баланса';

CONSTRAINT SET(p IS ActWriteOffPosition)
    AND posted(actWriteOff[ActWriteOffPosition](p)) AND NOT disableEGAISDocumentConstraints()
    MESSAGE 'Запрещено добавлять строки в проведённый акт списания с баланса';

CONSTRAINT (SETDROPPED(ActWriteOffMark m IS ActWriteOffMark) OR DROPCHANGED(markCode(m)))
    AND posted(actWriteOff(actWriteOffPosition(m)))
    AND NOT disableEGAISDocumentConstraints()
    MESSAGE 'Запрещено изменять марки проведённого акта списания с баланса';

blockedActWriteOff(ActWriteOff w) = posted(w) OR (notRejected(actWriteOffOutDoc(w)) AND id(actWriteOffOutDoc(w)));

edit(ActWriteOff o) + {
    IF blockedActWriteOff(o) THEN
        SHOW actWriteOff OBJECTS w = o DOCKED READONLY;
    ELSE
        SHOW actWriteOff OBJECTS w = o DOCKED;
}


DESIGN actWriteOff {
    PROPERTY(addMarkCodeInputIdMarkCode(w)) {
        showIf = NOT minActWriteOffPosition(w) AND NOT posted(w) AND NOT (notRejected(actWriteOffOutDoc(w)) AND id(actWriteOffOutDoc(w)));
    }
    PROPERTY(addMarkCodeInputIdMarkCode(p)) {
        showIf = minActWriteOffPosition(w) AND NOT posted(w) AND NOT (notRejected(actWriteOffOutDoc(w)) AND id(actWriteOffOutDoc(w)));
    }
}