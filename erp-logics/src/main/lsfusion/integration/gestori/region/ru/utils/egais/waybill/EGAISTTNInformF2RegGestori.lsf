MODULE EGAISTTNInformF2RegGestori;

REQUIRE EGAISTTNInformF2Reg, EGAISWayBillDocGestori;

NAMESPACE EGAIS;

overNumberBaseDocument(InDoc d) += WHEN docType(d) == DocType.TTNInformF2Reg THEN number(wayBill(d));
overDateBaseDocument(InDoc d) += WHEN docType(d) == DocType.TTNInformF2Reg THEN date(wayBill(d));

@defineInDocsFilterDocType(TTNInformF2Reg, 'Информация по справке 2');