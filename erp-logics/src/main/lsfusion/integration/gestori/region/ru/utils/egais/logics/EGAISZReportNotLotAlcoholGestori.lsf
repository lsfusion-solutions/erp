MODULE EGAISZReportNotLotAlcoholGestori;

REQUIRE EGAISZReportNotLotAlcohol, EGAISActWriteOffGestori;

NAMESPACE EGAIS;

createActWriteOff (Client c, DATE dFrom, DATE dTo, WriteOffType t) + {
    IF t == writeOffType('Реализация') THEN {
        FOR iterate(DATE d, dFrom, dTo) DO {
            IF own(c) AND NOT actWriteOffNotLot(c, d, t) THEN createActWriteOffNotLot(c, d);
        }
    }
}