MODULE EGAISSaleShipmentGestori;

REQUIRE EGAISSaleShipment, SkuLedgerLotGestori, EGAISWayBillGestory, SaleInvoiceTerminal;

PRIORITY Sale;

NAMESPACE EGAISSale;

CONSTRAINT CHANGED(quantity(UserShipmentDetail d, Lot l)) AND d IS UserShipmentDetail AND l IS Lot AND 
    availableQuantity(l, supplierStock(d)) < 0
    MESSAGE '–Э–µ–≤–µ—А–љ–Њ–µ –Ї–Њ–ї–Є—З–µ—Б—В–≤–Њ –і–Њ—Б—В—Г–њ–љ–Њ–≥–Њ –Њ—Б—В–∞—В–Ї–∞ –Љ–∞—А–Њ–Ї';

@defineOriginalLastDocumentWayBillAttributes(Sale, Invoice);
@defineOriginalLastDocumentWayBillAttributes(Sale, Invoice, supplierStock);

lastSaleInvoiceDetail (WayBillPosition wp) = GROUP LAST Sale.InvoiceDetail o IF wayBill(invoice(o)) == wayBill(wp) AND (in(sku(o), product(wp)) OR quantity(shipmentDetail(wp), wp)) ORDER o;
skuPositionOriginalDocument(WayBillPosition wp) += WHEN lastSaleInvoiceDetail(wp) THEN sku(lastSaleInvoiceDetail(wp));

@defineDenyEditDocumentEGAISCanceledInProcess(activeWayBillAct, wayBill, invoice, countWayBillActs);

editQuantity(UserInvoiceDetail d, F2Reg r) += NOT hideFillQuantity(userInvoice(d));
hideFillQuantity(UserInvoiceDetail d, F2Reg r) += hideFillQuantity(userInvoice(d));

@defineDocumentWayBillConstraint(invoice, '–Э–∞–Ї–ї–∞–і–љ–∞—П (–њ—А–Њ–і–∞–ґ–∞)');

DESIGN userInvoice {
    PROPERTY(addDetailDialogTerminalUserInvoiceDetail(i)) { showIf = disableEGAISDocumentConstraints() OR NOT activeWayBillAct(wayBill(invoice(d))); }
}

overCheckProcess(Shipment s) += '–Ъ–Њ–ї–Є—З–µ—Б—В–≤–Њ –≤ –њ–Њ–Ј–Є—Ж–Є–Є –і–Њ–Ї—Г–Љ–µ–љ—В–∞ –і–Њ–ї–ґ–љ–Њ —Б–Њ–Њ—В–≤–µ—В—Б—В–≤–Њ–≤–∞—В—М –Ї–Њ–ї–Є—З–µ—Б—В–≤—Г –њ—А–Є–≤—П–Ј–∞–љ–љ—Л—Е –Љ–∞—А–Њ–Ї' 
    IF [GROUP SUM 1 IF minProduct(sku(ShipmentDetail d)) AND lotType(sku(d)) AND NOT quantity(d) = quantityLot(d) BY shipment(d)](s);

notCorrect(ShipmentDetail d, F2Reg r) = minProduct(sku(d)) AND quantity(d, r) AND lotType(sku(d)) AND NOT quantity(d, r) == [GROUP SUM quantity(d, Lot l) BY f2Reg(markCode(id(l)))](r);
overCheckProcess(Shipment s) += '–Ъ–Њ–ї–Є—З–µ—Б—В–≤–Њ –≤ –њ–Њ–Ј–Є—Ж–Є–Є –њ–Њ —Б–њ—А–∞–≤–Ї–µ –С –і–Њ–ї–ґ–љ–Њ —Б–Њ–Њ—В–≤–µ—В—Б—В–≤–Њ–≤–∞—В—М –Ї–Њ–ї–Є—З–µ—Б—В–≤—Г –њ—А–Є–≤—П–Ј–∞–љ–љ—Л—Е –Љ–∞—А–Њ–Ї'
    IF [GROUP SUM 1 IF notCorrect(ShipmentDetail d, F2Reg r) BY shipment(d)](s);

overCheckProcess(Shipment s) += '–°—А–Њ–Ї –≥–Њ–і–љ–Њ—Б—В–Є —В–Њ–≤–∞—А–∞ –Є—Б—В–µ–Ї'
    IF [GROUP SUM 1 IF expiryDate(ShipmentDetail d) < currentDate() BY shipment(d)](s);

overCheckProcess(Shipment s) += '–Э–µ –Ј–∞–і–∞–љ –≤–Њ–і–Є—В–µ–ї—М –Ґ–°'
    IF s IS Shipment AND NOT nameDriverTrip(s);

overCheckProcess(Shipment s) += '–Э–µ –Ј–∞–і–∞–љ–∞ –Љ–∞—А–Ї–∞ –Ґ–°'
    IF s IS Shipment AND NOT nameTruckModelTrip(s);

overCheckProcess(Shipment s) += '–Э–µ –Ј–∞–і–∞–љ –љ–Њ–Љ–µ—А –Ґ–°'
    IF s IS Shipment AND NOT sid(truck(trip(s)));

overProcessFillWayBill(Shipment s) +{
    transportRegNumber(wayBill(s)) <- CONCAT ' ', nameTruckModel(truck(trip(s))), sid(truck(trip(s)));
    tranRedirect(wayBill(s)) <- OVERRIDE redirect(trip(s)), '–Э–µ—В' IF wayBill(s);
    tranForwarder(wayBill(s)) <- OVERRIDE forwarder(trip(s)), tranDriver(wayBill(s));
}

CONSTRAINT DROPPED(Sale.Shipment s IS Sale.Shipment) AND PREV(activeWayBillOutDoc(wayBill(s)))
    MESSAGE '–Ч–∞–њ—А–µ—Й–µ–љ–Њ —Г–і–∞–ї–µ–љ–Є–µ –њ–Њ—Б—В–∞–≤–Ї–Є, –њ–Њ –Ї–Њ—В–Њ—А–Њ–є –≤—Л–њ–Њ–ї–љ–µ–љ–∞ –Њ—В–њ—А–∞–≤–Ї–∞ –≤ –Х–У–Р–Ш–°';

DESIGN truck { 
    PROPERTY(sid(t)) { 
        regexp = '^[–Р–Т–Х–Ъ–Ь–Э–Ю–†–°–Ґ–£–•ABEKMHOPCTYX–∞–≤–µ–Ї–Љ–љ–Њ—А—Б—В—Г—Еabekmhopctyx][–Р–Т–Х–Ъ–Ь–Э–Ю–†–°–Ґ–£–•ABEKMHOPCTYX–∞–≤–µ–Ї–Љ–љ–Њ—А—Б—В—Г—Еabekmhopctyx]?\\d{3}\\d?[–Р–Т–Х–Ъ–Ь–Э–Ю–†–°–Ґ–£–•ABEKMHOPCTYX–∞–≤–µ–Ї–Љ–љ–Њ—А—Б—В—Г—Еabekmhopctyx][–Р–Т–Х–Ъ–Ь–Э–Ю–†–°–Ґ–£–•ABEKMHOPCTYX–∞–≤–µ–Ї–Љ–љ–Њ—А—Б—В—Г—Еabekmhopctyx]?\\d{2}\\d?$';
        regexpMessage = '–Э–µ–њ—А–∞–≤–Є–ї—М–љ—Л–є —Д–Њ—А–Љ–∞—В –љ–Њ–Љ–µ—А–∞';
    }

    PROPERTY(trailer(t)) {
        regexp = '^[–Р–Т–Х–Ъ–Ь–Э–Ю–†–°–Ґ–£–•ABEKMHOPCTYX–∞–≤–µ–Ї–Љ–љ–Њ—А—Б—В—Г—Еabekmhopctyx][–Р–Т–Х–Ъ–Ь–Э–Ю–†–°–Ґ–£–•ABEKMHOPCTYX–∞–≤–µ–Ї–Љ–љ–Њ—А—Б—В—Г—Еabekmhopctyx]?\\d{3}\\d?[–Р–Т–Х–Ъ–Ь–Э–Ю–†–°–Ґ–£–•ABEKMHOPCTYX–∞–≤–µ–Ї–Љ–љ–Њ—А—Б—В—Г—Еabekmhopctyx][–Р–Т–Х–Ъ–Ь–Э–Ю–†–°–Ґ–£–•ABEKMHOPCTYX–∞–≤–µ–Ї–Љ–љ–Њ—А—Б—В—Г—Еabekmhopctyx]?\\d{2}\\d?$';
        regexpMessage = '–Э–µ–њ—А–∞–≤–Є–ї—М–љ—Л–є —Д–Њ—А–Љ–∞—В –љ–Њ–Љ–µ—А–∞';
    }
}

DESIGN invoices {
    PROPERTY(cancelEGAIS) { caption = '–Ю—В–њ—А–∞–≤–Є—В—М –≤ –Х–У–Р–Ш–° –∞–Ї—В –Њ—В–Ї–∞–Ј–∞ –Њ—В –Ґ–Ґ–Э';}
}