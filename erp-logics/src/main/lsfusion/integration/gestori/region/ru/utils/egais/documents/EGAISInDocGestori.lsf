MODULE EGAISInDocGestori;

REQUIRE EGAISInDoc, EGAISOutDocGestori, EGAISQueryUtmDatabase, EGAISUTMGestori;

NAMESPACE EGAIS;

skipProcessInDocs (UTM utm) += inactive(utm);

overTypeBaseDocument 'Тип документа-основания' = ABSTRACT BPISTRING[100] (InDoc);
typeBaseDocumentOutDoc 'Тип документа-основания' (InDoc d) = OVERRIDE typeBaseDocument(outDoc(d)), overTypeBaseDocument(d);

overNumberBaseDocument 'Номер документа-основания' = ABSTRACT CASE STRING (InDoc);
numberBaseDocumentOutDoc 'Номер документа-основания' (InDoc d) = OVERRIDE numberBaseDocument(outDoc(d)), overNumberBaseDocument(d);

overDateBaseDocument 'Дата документа-основания' = ABSTRACT CASE DATE (InDoc);
dateBaseDocumentOutDoc 'Дата документа-основания' (InDoc d) = OVERRIDE dateBaseDocument(outDoc(d)), overDateBaseDocument(d);

typeOriginalDocumentOutDoc 'Тип документа системы' (InDoc d) = typeOriginalDocument(outDoc(d));
numberOriginalDocumentOutDoc 'Номер документа системы' (InDoc d) = numberOriginalDocument(outDoc(d));
dateOriginalDocumentOutDoc 'Дата документа системы' (InDoc d) = dateOriginalDocument(outDoc(d));

overTypeBaseDocument(InDoc d) += name(docType(d));

skipUrl(InDoc d) += dateTime(d) < utmDBDateTime(utm(d));

maxDocumentLength 'Порог отображения ответа для входящего документа, символов' = DATA INTEGER ();
largeDocument (InDoc d) = length(document(d)) > maxDocumentLength();
showFullDocument = DATA LOCAL BOOLEAN (InDoc);
documentToShow 'Ответ' (InDoc d) = document(d) IF (NOT largeDocument(d) OR showFullDocument(d));
showDocument 'Показать XML' (InDoc d) { showFullDocument(d) <- TRUE; }

EXTEND FORM inDocs
    PROPERTIES(d) READONLY AFTER idOutDoc(d) typeBaseDocumentOutDoc, numberBaseDocumentOutDoc, dateBaseDocumentOutDoc,
        typeOriginalDocumentOutDoc, numberOriginalDocumentOutDoc, dateOriginalDocumentOutDoc

    PROPERTIES(d) READONLY PANEL hldocument = documentToShow CUSTOM 'xmlHighlight'
    PROPERTIES(d) showDocument SHOWIF largeDocument(d) AND NOT showFullDocument(d)

    FILTERGROUP filterProcessed
        FILTER 'Необработанные' toProcess(d)
        FILTER 'Обработанные' processed(d)
    
    FILTERGROUP filterDocType
;

DESIGN inDocs {
    PROPERTY(idOutDoc(d)) { caption = 'Номер транспортного пакета исходящего документа'; }

    response {
        REMOVE PROPERTY(document(d));
        MOVE PROPERTY(showDocument(d));
        MOVE PROPERTY(hldocument) { caption = ''; autoSize = TRUE; panelCaptionVertical = TRUE; }
    }
}

META defineInDocsFilterDocType (type, caption)
    EXTEND FORM inDocs
        EXTEND FILTERGROUP filterDocType
            FILTER caption docType(d) == DocType.type
    ;
END;

DESIGN outDocs {
    BOX(i) { caption = CONCAT '', 'Входящие документы', ' (' + countInDocs(r) +  ')'; }
}

EXTEND FORM integrationData
    PROPERTIES() maxDocumentLength
;

DESIGN integrationData {
    EGAISParams {
        MOVE PROPERTY(maxDocumentLength());
    }
}

NAVIGATOR {
    inDocs 'Входящие документы УТМ';
}