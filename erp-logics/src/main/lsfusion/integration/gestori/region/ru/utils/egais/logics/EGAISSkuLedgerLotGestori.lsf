MODULE EGAISSkuLedgerLotGestori;

REQUIRE EGAISSkuLedgerLot, SkuLedgerLotGestori;

NAMESPACE EGAIS;

availableQuantity 'Доступный остаток' (MarkCode m) = availableQuantity(lot(m));

availableQuantityMarkCode 'Доступный остаток по маркам' (F2Reg r) = GROUP SUM availableQuantity(MarkCode m) BY f2Reg(m);

EXTEND FORM balanceReg
    PROPERTIES(r) READONLY availableQuantityMarkCode
    PROPERTIES(m) READONLY availableQuantity BACKGROUND NOT lot(m)
;

EXTEND FORM markCodes
    PROPERTIES(m) READONLY currentBalance
;