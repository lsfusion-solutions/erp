MODULE EGAISFRegReservationGestori;

REQUIRE EGAISActWriteOffExchangeGestori, EGAISFRegLedgerGestori,
        EGAISSaleShipment, EGAISPurchaseReturnShipment, EGAISWriteOff;

NAMESPACE EGAIS;

reservedActWriteOff (F2Reg r) = GROUP SUM overQuantity(ActWriteOffPosition p)
    IF f2Reg(p) = r
    AND NOT canceled(actWriteOff(p))
    AND NOT posted(actWriteOff(p));

reservedSale (F2Reg r) = GROUP SUM EGAISSale.quantity(Sale.ShipmentDetail d, r)
    IF NOT EGAISSale.wayBill(Sale.shipment(d));

reservedReturn (F2Reg r) = GROUP SUM EGAISPurchaseReturn.quantity(PurchaseReturn.ShipmentDetail d, r)
    IF NOT EGAISPurchaseReturn.wayBill(PurchaseReturn.shipment(d));

reservedWriteOff (F2Reg r) = GROUP SUM quantity(WriteOffDetail d, r)
    IF NOT actWriteOff(writeOff(d));

reservedF2Reg 'Текущий резерв' (F2Reg r) =
    reservedActWriteOff(r) (+) reservedSale(r) (+) reservedReturn(r) (+) reservedWriteOff(r);

availableF2Reg 'Доступно по справке Б' (F2Reg r) = currentBalance(r) (-) reservedF2Reg(r);

availableF2Reg 'Доступно по справке Б' (ActWriteOffMark m) =
    availableF2Reg(f2Reg(actWriteOffPosition(m)));

EXTEND FORM actWriteOff
    PROPERTIES(m) READONLY availableF2Reg BEFORE idMarkCode(m)
;

EXTEND FORM balanceReg
    PROPERTIES(r) READONLY reservedF2Reg AFTER currentBalance(r)
;

CONSTRAINT SET(availableF2Reg(F2Reg r) < 0) AND CHANGED(reservedF2Reg(r))
    AND NOT disableEGAISDocumentConstraints()
    MESSAGE 'Превышен доступный остаток по справке Б: количество уже зарезервировано другими документами';

activeDocCountByMark(MarkCode mc) = GROUP SUM 1
    BY markCode(ActWriteOffMark m)
    IF NOT canceled(actWriteOff(actWriteOffPosition(m)))
    AND NOT posted(actWriteOff(actWriteOffPosition(m)));

CONSTRAINT (SET(ActWriteOffMark m IS ActWriteOffMark) OR SETCHANGED(markCode(m)))
    AND activeDocCountByMark(markCode(m)) > 1
    MESSAGE 'Код маркировки уже присутствует в другом активном акте списания с баланса';
