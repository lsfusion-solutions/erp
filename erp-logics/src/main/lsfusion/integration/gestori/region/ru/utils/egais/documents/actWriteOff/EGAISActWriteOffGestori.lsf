MODULE EGAISActWriteOffGestori;

REQUIRE EGAISActWriteOff, EGAISActWriteOffTypeGestori, EGAISStock, EGAISItem, LotType, EGAISSkuLedgerLot;

NAMESPACE EGAIS;

typeOriginalDocument 'Тип документа системы' = ABSTRACT CASE BPISTRING[100] (ActWriteOff);
numberOriginalDocument 'Номер документа системы' = ABSTRACT CASE STRING (ActWriteOff);
dateOriginalDocument 'Дата документа системы' = ABSTRACT CASE DATE (ActWriteOff);

typeOriginalDocument 'Склад документа системы' (ActWriteOffPosition p) = typeOriginalDocument(actWriteOff(p));
numberOriginalDocument 'Склад документа системы' (ActWriteOffPosition p) = numberOriginalDocument(actWriteOff(p));
dateOriginalDocument 'Склад документа системы' (ActWriteOffPosition p) = dateOriginalDocument(actWriteOff(p));

dataSaleDateTime 'Дата и время продажи' = DATA DATETIME (ActWriteOff);
//dataSaleDateTime(ActWriteOff a) <- currentDateTime() WHEN SET(a IS ActWriteOff);
dataSaleDate 'Дата продажи' (ActWriteOff a) = DATE(dataSaleDateTime(a));

stockClientName 'Склад организации' (ActWriteOff w) = name(stock(client(w))) IN id;

META defineOriginalLastDocumentActWriteOffAttributes(object)
    last##object (ActWriteOff a) = GROUP LAST ##object o ORDER o BY actWriteOff(o);
    typeOriginalDocument(ActWriteOff a) += WHEN last##object(a) THEN objectClassName(last##object(a));
    numberOriginalDocument(ActWriteOff a) += WHEN last##object(a) THEN number(last##object(a));
    dateOriginalDocument(ActWriteOff a) += WHEN last##object(a) THEN date(last##object(a));
END;

stockOriginalDocument 'Склад документа системы' = ABSTRACT CASE Stock (ActWriteOff);
stockOriginalDocument 'Склад документа системы' (ActWriteOffPosition p) = stockOriginalDocument(actWriteOff(p));

META defineOriginalLastDocumentWayBillAttributes(object, prop)
    stockOriginalDocument(ActWriteOff b) += WHEN last##object(b) THEN prop(last##object(b));
END;

createActWriteOff 'Создать списание ЕГАИС на основе реализации' ABSTRACT LIST (Client, DATE, DATE, WriteOffType);

actWriteOffClient = DATA Client () NONULL ;
actWriteOffClientName 'Организация ЕГАИС' = shortName(actWriteOffClient());

actWriteOffType = DATA WriteOffType () NONULL ;
actWriteOffTypeName 'Тип списания ЕГАИС' = id(actWriteOffType());

createActWriteOff 'Создать списание ЕГАИС по кассовым отчетам' (DATE dFrom, DATE dTo) {
    createActWriteOff(actWriteOffClient(), dFrom, dTo, actWriteOffType());
}

post 'Провести' (ActWriteOff o)  {
    NEWSESSION { posted(o) <- TRUE; apply(); }
} TOOLBAR CONFIRM;

unpost 'Распровести' (ActWriteOff o)  {
    NEWSESSION { posted(o) <- NULL; apply(); }
} TOOLBAR CONFIRM;

editAdmin 'Редактировать (адм.доступ)' (ActWriteOff o)  {
    NEWSESSION {
        SHOW actWriteOff OBJECTS w = o DOCKED;
    }
} TOOLBAR CONFIRM IMAGE 'edit.png';

copy 'Копировать' (ActWriteOff a) {
    NEWSESSION {
        NEW na = ActWriteOff {
            client(na) <- client(a);
            dateTime(na) <- dateTime(a);
            type(na) <- type(a);

            FOR actWriteOff(ActWriteOffPosition ad) == a NEW d = ActWriteOffPosition DO {
                actWriteOff(d) <- na;
                f2Reg(d) <- f2Reg(d);
                product(d) <- product(ad);
                dataQuantity(d) <- dataQuantity(ad);

                FOR actWriteOffPosition(ActWriteOffMark am) == ad NEW m = ActWriteOffMark DO {
                    actWriteOffPosition(m) <- d;
                    markCode(m) <- markCode(am);
                }
            }

            SHOW actWriteOff OBJECTS w = na;
        }
    }
} TOOLBAR;

readonlyDescriptionClient() += TRUE;

in (ActWriteOff w, MarkCode c) = GROUP MIN TRUE BY actWriteOff(actWriteOffPosition(ActWriteOffMark m)), markCode(m);

processInputIdMarkCode(ActWriteOff w, ActWriteOffPosition p, STRING[200] s) {
    LOCAL markCode = MarkCode ();
    LOCAL position = ActWriteOffPosition ();
    
    markCode() <- markCode(s);
    position() <- p;
    
    IF NOT markCode() THEN {
        MESSAGE 'Код маркировки ЕГАИС "' + s + '" не найден' NOWAIT;
        RETURN;
    }

    IF NOT currentBalance(markCode()) THEN {
        MESSAGE 'Код маркировки ЕГАИС "' + s + '" отсутствует на балансе' NOWAIT;
        RETURN;
    }

    IF in(w, markCode()) THEN {
        MESSAGE 'Код маркировки ЕГАИС "' + s + '" уже присутствует в этом документе' NOWAIT;
        RETURN;
    }

    IF NOT f2Reg(position()) == f2Reg(markCode()) THEN {
        position() <- GROUP MIN ActWriteOffPosition ap IF f2Reg(ap) == f2Reg(markCode()) AND actWriteOff(ap) == w;
    }
    
    IF NOT position() IS ActWriteOffPosition THEN {
        NEW pos = ActWriteOffPosition {
            actWriteOff(pos) <- w;
            f2Reg(pos) <- f2Reg(markCode());
            product(pos) <- product(markCode());
            
            position() <- pos;
        }        
    }

    NEW m = ActWriteOffMark {
        actWriteOffPosition(m) <- position();
        markCode(m) <- markCode();
    }
    
    dataQuantity(position()) <- NULL;

    seek(position());
}

changeAddMarkCodeInputIdMarkCode(ActWriteOffPosition p)  {
    INPUT s = STRING[200] DO {
        processInputIdMarkCode(actWriteOff(p), p, s);
    }
};

changeAddMarkCodeInputIdMarkCode(ActWriteOff w)  {
    INPUT s = STRING[200] DO {
        processInputIdMarkCode(w, NULL, s);
    }
};

addMarkCodeInputIdMarkCode 'Ввод кода маркировки :' (ActWriteOffPosition position) = DATA LOCAL STRING[200] (ActWriteOffPosition) TOOLBAR CHARWIDTH 50 CHANGEKEY 'F4;editing=all' EVENTID 'SCANNER'
    ON CHANGE { changeAddMarkCodeInputIdMarkCode(position); }

addMarkCodeInputIdMarkCode 'Ввод кода маркировки :' (ActWriteOff w) = DATA LOCAL STRING[200] (ActWriteOff) TOOLBAR CHARWIDTH 50 CHANGEKEY 'F4;editing=all' EVENTID 'SCANNER'
    ON CHANGE { changeAddMarkCodeInputIdMarkCode(w); }

idEgais 'Код ЕГАИС' (ActWriteOffPosition p) = STRING(p) IF p IS ActWriteOffPosition; 

EXTEND FORM actWriteOffs
    OBJECTS dates = (dFrom = DATE, dTo = DATE) PANEL 
    PROPERTIES valFrom 'Дата с' = VALUE(dFrom), valTo 'Дата по' = VALUE(dTo)

    PROPERTIES () actWriteOffClientName, actWriteOffTypeName
    PROPERTIES (dFrom, dTo) createActWriteOff
    PROPERTIES (d) post SHOWIF NOT posted(d), unpost SHOWIF posted(d)

    PROPERTIES (d) editAdmin SHOWIF showToShow(d) AND hideEdit(d), copy
    PROPERTIES (d) READONLY dataSaleDate AFTER dateTime(d), stockClientName AFTER shortNameClient(d)
    
    PROPERTIES (p) READONLY idEgais
;

DESIGN actWriteOffs {
    OBJECTS {
        PROPERTY (descriptionClient(d)) {caption = 'Адрес'; alignment = STRETCH;};

        tabbedPane {
            NEW actions {
                caption = 'Действия';
                NEW createActWriteOff {
                    caption = 'Списание ЕГАИС по кассовым отчетам';

                    MOVE BOX(dates) {
                        caption = '';
                        horizontal = TRUE;
                    }
                    MOVE PROPERTY(actWriteOffClientName());
                    MOVE PROPERTY(actWriteOffTypeName());
                    MOVE PROPERTY(createActWriteOff(dFrom, dTo));
                }
            }
        }
    }
}

EXTEND FORM actWriteOff
    PROPERTIES (w) READONLY dataSaleDate
    PROPERTIES (p) READONLY idEgais
;

CONSTRAINT NOT own(actWriteOffClient())
    CHECKED BY actWriteOffClient[]
    MESSAGE 'Только собственные организации ЕГАИС';

CONSTRAINT actWriteOffType() AND (NOT actWriteOffType() == writeOffType('Розничная продажа') AND NOT  actWriteOffType() == writeOffType('Реализация'))
    CHECKED BY actWriteOffType[]
    MESSAGE 'Ограничение по типам списания ЕГАИС';

CONSTRAINT client(ActWriteOff a) AND NOT stock(client(a))
    CHECKED BY client[ActWriteOff]
    MESSAGE 'Доступны только организации, связанные со складами/отделами магазинов системы';

CONSTRAINT product(ActWriteOffPosition d) AND f2Reg(d) AND NOT product(f2Reg(d)) == product(d)
    CHECKED BY f2Reg[ActWriteOffPosition]
    MESSAGE 'Для строки акта списания с баланса ЕГАИС справка Б должна соответствовать продукции';

countPositionSameF2Reg (ActWriteOffPosition p) =
    GROUP SUM 1 IF f2Reg(ActWriteOffPosition pp) == f2Reg(p) AND actWriteOff(pp) == actWriteOff(p);
CONSTRAINT (SETCHANGED(f2Reg(ActWriteOffPosition p))) AND countPositionSameF2Reg(p) > 1
    MESSAGE 'Запрещено наличие несколько позиций с одной справкой Б в документе';

WHEN LOCAL FORMS actWriteOff CHANGED ( idF2Reg(ActWriteOffPosition d)) AND NOT (product(d)) DO {
    product(d) <- product(f2Reg(d));
}

EXTEND FORM actWriteOff
    PROPERTIES (w) DRAW m  addMarkCodeInputIdMarkCode SHOWIF NOT minActWriteOffPosition(w)
    PROPERTIES (p) DRAW m  addMarkCodeInputIdMarkCode SHOWIF minActWriteOffPosition(w)
    PROPERTIES(m) READONLY idF2Reg BEFORE idMarkCode(m)
    PROPERTIES(m) READONLY currentBalanceF2Reg BEFORE idMarkCode(m)
    PROPERTIES (m) DELETE GRID SHOWIF NOT posted(w)
;

DESIGN actWriteOff {
    OBJECTS {    
        NEW address BEFORE pane{
            align= STRETCH;
            MOVE PROPERTY (shortNameClient(w));
            MOVE PROPERTY (descriptionClient(w)) {caption = 'Адрес'; charWidth = 100;};
        }
    }
}

lotType (ActWriteOff w) = GROUP MIN TRUE IF lotType(minItem(product(ActWriteOffPosition p))) AND product(p) BY actWriteOff(p);
notLotType (ActWriteOff w) = GROUP MIN TRUE IF NOT lotType(minItem(product(ActWriteOffPosition p))) AND product(p) BY actWriteOff(p);

CONSTRAINT CHANGED(lotType(minItem(product(ActWriteOffPosition p)))) AND lotType(actWriteOff(p)) AND notLotType(actWriteOff(p)) 
    MESSAGE 'Запрещено добавлять в спецификацию документа маркированную и немаркированную продукцию';

CONSTRAINT SET(ActWriteOffPosition p IS ActWriteOffPosition) AND lotType(actWriteOff(p)) AND notLotType(actWriteOff(p))
    MESSAGE 'Запрещено добавлять в спецификацию документа маркированную и немаркированную продукцию';

CONSTRAINT SETCHANGED(dataQuantity(ActWriteOffPosition p)) AND dataQuantity(p) < 0
    MESSAGE 'Количество по позиции акта списания не может быть отрицательным';

CONSTRAINT (SETCHANGED(overQuantity(ActWriteOffPosition d)) OR SETCHANGED(f2Reg(d))) AND overQuantity(d) AND currentBalance(f2Reg(d)) < overQuantity(d)
    MESSAGE 'Количество не должно превышать остаток по справке Б';

CONSTRAINT CHANGED(quantity(ActWriteOffPosition p)) AND quantity(p) AND NOT overQuantity(p) == quantity(p)
    MESSAGE 'Количество кодов маркировки не соответствует количеству по позиции акта';

CONSTRAINT (SETCHANGED(posted(ActWriteOff d)) OR SETCHANGED(canceled(d))) AND posted(d) AND canceled(d)
    MESSAGE 'Документ не может быть проведен и отклонен одновременно';

NAVIGATOR {
    actWriteOffs 'Акты списания с баланса';
}