MODULE EGAISWayBillActExchangeGestori;

REQUIRE EGAISWayBillActExchange, EGAISWayBillGestory, EGAISTicketGestori;

NAMESPACE EGAIS;

@defineOutDocAbstractTypeNumberDate(wayBillAct, wayBillAct);

@defineOutDocAbstractOriginalDocumentTypeNumberDate(WayBillAct, wayBill);

EXTEND FORM inDocs
    EXTEND FILTERGROUP filterDocType
        FILTER 'Акт разногласий' docType(d) == DocType.WayBillAct_v3 OR docType(d) == DocType.WayBillAct_v4
;