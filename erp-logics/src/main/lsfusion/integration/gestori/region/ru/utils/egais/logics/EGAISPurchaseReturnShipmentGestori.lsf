MODULE EGAISPurchaseReturnShipmentGestori;

REQUIRE EGAISPurchaseReturnShipment, SkuLedgerLotGestori;

PRIORITY PurchaseReturn;

NAMESPACE EGAISPurchaseReturn;

CONSTRAINT CHANGED(quantity(UserShipmentDetail d, Lot l)) AND NOT (availableQuantity(l, customerStock(d)) == 1 OR NOT OVERRIDE availableQuantity(l, customerStock(d)), 0)
    MESSAGE 'Неверное количество доступного остатка марок';