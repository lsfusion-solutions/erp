MODULE EGAISPurchaseReturnShipmentGestori;

REQUIRE EGAISPurchaseReturnShipment, SkuLedgerLotGestori, EGAISWayBillGestory, PurchaseReturnInvoiceTerminal;

PRIORITY PurchaseReturn;

NAMESPACE EGAISPurchaseReturn;

CONSTRAINT SETCHANGED(quantity(UserShipmentDetail d, Lot l)) AND availableQuantity(l, customerStock(d)) < 0
    MESSAGE 'Неверное количество доступного остатка марок';

@defineOriginalLastDocumentWayBillAttributes(PurchaseReturn, Shipment);
@defineOriginalLastDocumentWayBillAttributes(PurchaseReturn, Shipment, customerStock);

@defineDenyEditDocumentEGAISCanceledInProcess(activeWayBillAct, wayBill, invoice, countWayBillActs);

editQuantity(UserInvoiceDetail d, F2Reg r) += NOT hideFillQuantity(userInvoice(d));
hideFillQuantity(UserInvoiceDetail d, F2Reg r) += hideFillQuantity(userInvoice(d));

@defineDocumentWayBillConstraint(invoice, 'Накладная (закупка-возврат)');

DESIGN userInvoice {
    importTSD { showIf = NOT disableEGAISDocumentConstraints() AND activeWayBillAct(wayBill(invoice(d))); }
}