MODULE EGAISGestori;

REQUIRE EGAIS;

NAMESPACE EGAIS;

fsrarId 'FSRAR_ID ' = DATA STRING (UTM) CHARWIDTH 12;

EXTEND FORM UTM
    PROPERTIES(o) fsrarId
;

EXTEND FORM dialogUTMs
    PROPERTIES(o) READONLY fsrarId
;

EXTEND FORM integrationData
    PROPERTIES() EGAISTestMode
    PROPERTIES(utm) READONLY fsrarId
;

DESIGN integrationData {
    EGAISParams {
        MOVE PROPERTY(EGAISTestMode());
    }
}