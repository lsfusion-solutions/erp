MODULE EGAISActChargeOnGestori;

REQUIRE EGAISActChargeOn, EGAISActChargeOnTypeGestori, EGAISStock, EGAISItem, LotType, EGAISF1RegImport;

NAMESPACE EGAIS;

dataSaleReturnDateTime 'Дата и время возврата' = DATA DATETIME (ActChargeOn);
//dataSaleReturnDateTime(ActChargeOn a) <- currentDateTime() WHEN SET(a IS ActChargeOn);
dataSaleReturnDate 'Дата возврата' (ActChargeOn a) = DATE(dataSaleReturnDateTime(a));

stockClientName 'Склад организации' (ActChargeOn a) = name(stock(client(a))) IN id;

overQuantityBatch(ActChargeOnPosition p) += quantityBatch(f1Reg(f2Reg(p)));
overBottlingDate(ActChargeOnPosition p) += bottlingDate(f1Reg(f2Reg(p)));
overOriginalDocNumber(ActChargeOnPosition p) += originalDocNumber(f1Reg(f2Reg(p)));
overOriginalDocDate(ActChargeOnPosition p) += originalDocDate(f1Reg(f2Reg(p)));
overEgaisFixNumber(ActChargeOnPosition p) += egaisFixNumber(f1Reg(f2Reg(p)));
overEgaisFixDate(ActChargeOnPosition p) += egaisFixDate(f1Reg(f2Reg(p)));

post 'Провести' (ActChargeOn o)  {
    NEWSESSION { posted(o) <- TRUE; apply(); }
} TOOLBAR CONFIRM;

unpost 'Распровести' (ActChargeOn o)  {
    NEWSESSION { posted(o) <- NULL; apply(); }
} TOOLBAR CONFIRM;

edit 'Редактировать (адм.доступ)' (ActChargeOn o)  {
    NEWSESSION {
        SHOW actChargeOn OBJECTS a = o DOCKED;
    }
} TOOLBAR CONFIRM IMAGE 'edit.png';

showToShow(ActChargeOn c) += canceled(c);

copy 'Копировать' (ActChargeOn a) {
    NEWSESSION {
        NEW na = ActChargeOn {
            client(na) <- client(a);
            dateTime(na) <- dateTime(a);            
            type(na) <- type(a);
            
            FOR actChargeOn(ActChargeOnPosition ad) == a NEW d = ActChargeOnPosition DO {
                actChargeOn(d) <- na;
                product(d) <- product(ad);
                f2Reg(d) <- f2Reg(ad);
                quantity(d) <- quantity(ad);
                dataQuantityBatch(d) <- dataQuantityBatch(ad);
                dataBottlingDate(d) <- dataBottlingDate(ad);
                dataOriginalDocNumber(d) <- dataOriginalDocNumber(ad);
                dataOriginalDocDate(d) <- dataOriginalDocDate(ad);
                dataEgaisFixNumber(d) <- dataEgaisFixNumber(ad);
                dataEgaisFixDate(d) <- dataEgaisFixDate(ad);

                FOR actChargeOnPosition(ActChargeOnMark am) == ad NEW m = ActChargeOnMark DO {
                    actChargeOnPosition(m) <- d;
                    markCode(m) <- markCode(am);
                }
            }

            SHOW actChargeOn OBJECTS a = na;
        }
    }
} TOOLBAR;

readonlyDescriptionClientActChargeOn() += TRUE;

skipQuantity(ActChargeOnPosition p) += TRUE IF markQuantity(p);

in (ActChargeOn w, MarkCode c) = GROUP MIN TRUE BY actChargeOn(actChargeOnPosition(ActChargeOnMark m)), markCode(m);

processInputIdMarkCode(ActChargeOn w, ActChargeOnPosition p, STRING[200] s) {
    LOCAL markCode = MarkCode ();
    LOCAL position = ActChargeOnPosition ();

    markCode() <- markCode(s);
    position() <- p;

    IF NOT markCode() THEN {
        MESSAGE 'Код маркировки ЕГАИС "' + s + '" не найден' NOWAIT;
        RETURN;
    }

    IF in(w, markCode()) THEN {
        MESSAGE 'Код маркировки ЕГАИС "' + s + '" уже присутствует в этом документе' NOWAIT;
        RETURN;
    }

    IF NOT f2Reg(position()) == f2Reg(markCode()) THEN {
        position() <- GROUP MIN ActChargeOnPosition ap IF f2Reg(ap) == f2Reg(markCode()) AND actChargeOn(ap) == w;
    }

    IF NOT position() IS ActChargeOnPosition THEN {
        NEW pos = ActChargeOnPosition {
            actChargeOn(pos) <- w;
            f2Reg(pos) <- f2Reg(markCode());
            product(pos) <- product(markCode());

            position() <- pos;
        }
    }

    NEW m = ActChargeOnMark {
        actChargeOnPosition(m) <- position();
        markCode(m) <- markCode();
    }

    quantity(position()) <- NULL;
    seek(position());
}

changeAddMarkCodeInputIdMarkCode(ActChargeOnPosition p)  {
    INPUT s = STRING[200] DO {
        processInputIdMarkCode(actChargeOn(p), p, s);
    }
};

changeAddMarkCodeInputIdMarkCode(ActChargeOn w)  {
    INPUT s = STRING[200] DO {
        processInputIdMarkCode(w, NULL, s);
    }
};

addMarkCodeInputIdMarkCode 'Ввод кода маркировки :' (ActChargeOnPosition position) = DATA LOCAL STRING[200] (ActChargeOnPosition) TOOLBAR CHARWIDTH 50 CHANGEKEY 'F4;editing=all' EVENTID 'SCANNER'
    ON CHANGE { changeAddMarkCodeInputIdMarkCode(position); }

addMarkCodeInputIdMarkCode 'Ввод кода маркировки :' (ActChargeOn w) = DATA LOCAL STRING[200] (ActChargeOn) TOOLBAR CHARWIDTH 50 CHANGEKEY 'F4;editing=all' EVENTID 'SCANNER'
    ON CHANGE { changeAddMarkCodeInputIdMarkCode(w); }

EXTEND FORM actChargeOns
    PROPERTIES (d) post SHOWIF NOT posted(d) AND NOT canceled(d), unpost SHOWIF posted(d)
    PROPERTIES (d) edit SHOWIF showToShow(d), copy
    PROPERTIES (d) READONLY dataSaleReturnDate AFTER dateTime(d), stockClientName AFTER shortNameClient(d)
;

DESIGN actChargeOns {
    OBJECTS {
        PROPERTY (descriptionClient(d)) {caption = 'Адрес'; alignment = STRETCH;};
    }
}

CONSTRAINT client(ActChargeOn a) AND NOT isCompany(stock(client(a)))
    CHECKED BY client[ActChargeOn]
    MESSAGE 'Для акта постановки на баланс ЕГАИС доступны только собственные организации, связанные со складами/отделами магазинов компании';

CONSTRAINT product(ActChargeOnPosition d) AND NOT product(f2Reg(d)) == product(d) AND f2Reg(d)
    CHECKED BY f2Reg[ActChargeOnPosition]
    MESSAGE 'Для строки акта постановки на баланс ЕГАИС справка Б должна соответствовать продукции';

WHEN LOCAL FORMS actChargeOn CHANGED ( idF2Reg(ActChargeOnPosition d)) AND NOT (product(d)) DO {
    product(d) <- product(f2Reg(d));
}

EXTEND FORM actChargeOn
    PROPERTIES (a) READONLY dataSaleReturnDate
    PROPERTIES (a) DRAW m  addMarkCodeInputIdMarkCode SHOWIF NOT minActChargeOnPosition(a)
    PROPERTIES (p) DRAW m  addMarkCodeInputIdMarkCode SHOWIF minActChargeOnPosition(a)
    PROPERTIES idF2Reg 'Справка Б' = idF2Reg(p) AFTER fullNameProduct(p) NOSELECT 
    PROPERTIES (m) DELETE GRID
;

DESIGN actChargeOn {
    OBJECTS {
        NEW address BEFORE pane{
            align= STRETCH;
            MOVE PROPERTY (shortNameClient(a));
            MOVE PROPERTY (descriptionClient(a)) {caption = 'Адрес'; charWidth = 100;};
        }
        PROPERTY (idF2Reg(p)) {hide = TRUE;}
    }
}

lotType (ActChargeOn w) = GROUP MIN TRUE IF lotType(minItem(product(ActChargeOnPosition p))) AND product(p) BY actChargeOn(p);
notLotType (ActChargeOn w) = GROUP MIN TRUE IF NOT lotType(minItem(product(ActChargeOnPosition p))) AND product(p) BY actChargeOn(p);

CONSTRAINT CHANGED(lotType(minItem(product(ActChargeOnPosition p)))) AND lotType(actChargeOn(p)) AND notLotType(actChargeOn(p))
    MESSAGE 'Запрещено добавлять в спецификацию документа маркированную и немаркированную продукцию';

CONSTRAINT SET(ActChargeOnPosition p IS ActChargeOnPosition) AND lotType(actChargeOn(p)) AND notLotType(actChargeOn(p))
    MESSAGE 'Запрещено добавлять в спецификацию документа маркированную и немаркированную продукцию';

CONSTRAINT (SETCHANGED(overQuantity(ActChargeOnPosition d)) OR SETCHANGED(f2Reg(d))) AND overQuantity(d) AND currentBalance(f2Reg(d)) < overQuantity(d)
    MESSAGE 'Количество не должно превышать остаток по справке Б';

CONSTRAINT (SETCHANGED(posted(ActChargeOn d)) OR SETCHANGED(canceled(d))) AND posted(d) AND canceled(d)
    MESSAGE 'Документ не может быть проведен и отклонен одновременно';

NAVIGATOR {
    actChargeOns 'Акты постановки на баланс';
}