MODULE EGAISStockGestori;

REQUIRE EGAISStock, LegalEntityRu;

NAMESPACE EGAIS;

existStock'Связан со складами' (Client c) = TRUE IF stock(c);

EXTEND FORM dialogClients
    OBJECTS s = Stock
    PROPERTIES (s) READONLY id, name
    FILTERS client(s) == o    
;

DESIGN dialogClients {
    size = (1024, 768);
    OBJECTS {
        NEW body {
            fill = 1;
            MOVE BOX(o);
            MOVE BOX(s);
        }
    }
}

EXTEND FORM clients
    PROPERTIES(o) READONLY existStock AFTER nameStock(o)    
;

in(LegalEntity le, Client o) = GROUP MIN TRUE BY legalEntity(Stock st), client(st);
innLegalEntity 'ИНН' (Stock st) = inn(legalEntity(st));
kppLegalEntity 'КПП' (Stock st) = kpp(legalEntity(st));

addStock 'Добавить' (Client c){
    DIALOG stocks OBJECTS s INPUT DO {
        client(s) <- c;
    }
} IMAGE 'add.png' CHANGEKEY 'INSERT';

delete 'Отключить' (Stock st) {
    client(st) <- NULL;
} IMAGE 'delete.png';

EXTEND FORM client
    OBJECTS st = Stock
    PROPERTIES (st) READONLY id, name, idLegalEntity, nameLegalEntity, innLegalEntity, kppLegalEntity
    PROPERTIES addStock(o) DRAW st TOOLBAR, delete(st) GRID
    FILTERS client(st) == o

    OBJECTS le = LegalEntity
    PROPERTIES (le) READONLY id, name, fullName, address 
    FILTERS in(le, o)
;

DESIGN client {
    OBJECTS {
        header {
            horizontal = FALSE ;
            alignment = STRETCH;
            MOVE PROPERTY(id(o));
            MOVE PROPERTY(tsNumber(o));
            MOVE PROPERTY(shortName(o));
            MOVE PROPERTY(fullName(o));
            MOVE PROPERTY(own(o));
            MOVE PROPERTY(nameUtm(o));
        }
        MOVE parameters AFTER header{
            horizontal = FALSE;
            alignment = STRETCH;
            caption = '';
            parametersRow1 {
                horizontal = FALSE;
                alignment = STRETCH;                
            }
            parametersRow2 {
                horizontal = FALSE;
                alignment = STRETCH;
            }            
        }
        tabbedPane {
            NEW stocks {
                caption = 'Связь со складами';
                MOVE BOX(st);
            }
            NEW legalEntities {
                caption = 'Связь с организациями';
                MOVE BOX(le);
            }            
        }
    }
}