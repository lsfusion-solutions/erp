MODULE EGAISStockGestori;

REQUIRE EGAISStock;

NAMESPACE EGAIS;

existStock'Связан со складами' (Client c) = TRUE IF stock(c);

EXTEND FORM dialogClients
    OBJECTS s = Stock
    PROPERTIES (s) READONLY id, name
    FILTERS client(s) == o    
;

DESIGN dialogClients {
    size = (1024, 768);
    OBJECTS {
        NEW body {
            fill = 1;
            MOVE BOX(o);
            MOVE BOX(s);
        }
    }
}

EXTEND FORM clients
    PROPERTIES(o) READONLY existStock AFTER nameStock(o)    
;

in(LegalEntity le, Client o) = GROUP MIN TRUE BY legalEntity(Stock st), client(st);

EXTEND FORM client 
    OBJECTS le = LegalEntity
    PROPERTIES (le) READONLY id, name, fullName, address 
    FILTERS in(le, o)
;

DESIGN client {
    OBJECTS {
        header {
            horizontal = FALSE ;
            alignment = STRETCH;
            MOVE PROPERTY(id(o));
            MOVE PROPERTY(tsNumber(o));
            MOVE PROPERTY(shortName(o));
            MOVE PROPERTY(fullName(o));
            MOVE PROPERTY(own(o));
            MOVE PROPERTY(nameUtm(o));
        }
        MOVE parameters AFTER header{
            horizontal = FALSE;
            alignment = STRETCH;
            caption = '';
            parametersRow1 {
                horizontal = FALSE;
                alignment = STRETCH;                
            }
            parametersRow2 {
                horizontal = FALSE;
                alignment = STRETCH;
            }            
        }
        tabbedPane {
            NEW products {
                caption = 'Связь с организациями';
                MOVE BOX(le);
            }
        }
    }
}