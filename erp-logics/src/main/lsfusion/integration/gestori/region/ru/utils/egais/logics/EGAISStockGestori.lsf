MODULE EGAISStockGestori;

REQUIRE EGAISStock;

NAMESPACE EGAIS;

existItem 'Связан со складами' (Client c) = TRUE IF stock(c);
nameLegalEntity 'Связанная организация' (Client c) = name(legalEntity(stock(c)));

EXTEND FORM dialogClients
    OBJECTS s = Stock
    PROPERTIES (s) READONLY id, name
    FILTERS client(s) == o    
;

DESIGN dialogClients {
    size = (1024, 768);
    OBJECTS {
        NEW body {
            fill = 1;
            MOVE BOX(o);
            MOVE BOX(s);
        }
    }
}

EXTEND FORM clients
    PROPERTIES(o) READONLY existItem AFTER nameStock(o)    
;

EXTEND FORM client 
    PROPERTIES (o) READONLY nameLegalEntity
;

DESIGN client {
    OBJECTS {
        header {
            horizontal = FALSE ;
            alignment = STRETCH;
            MOVE PROPERTY(id(o));
            MOVE PROPERTY(tsNumber(o));
            MOVE PROPERTY(shortName(o));
            MOVE PROPERTY(fullName(o));
            MOVE PROPERTY(own(o));
            MOVE PROPERTY(nameUtm(o));
        }
        MOVE parameters AFTER header{
            horizontal = FALSE;
            alignment = STRETCH;
            caption = '';
            parametersRow1 {
                horizontal = FALSE;
                alignment = STRETCH;                
            }
            parametersRow2 {
                horizontal = FALSE;
                alignment = STRETCH;
            }
            MOVE PROPERTY (nameLegalEntity(o));
        }
        
    }
}