MODULE EGAISPurchaseReturnInvoiceGestori;

REQUIRE EGAISPurchaseReturnInvoice, SkuLedgerLotGestori;

PRIORITY PurchaseReturn;

NAMESPACE EGAISPurchaseReturn;

CONSTRAINT CHANGED(quantity(UserInvoiceDetail d, Lot l)) AND NOT (availableQuantity(l, customerStock(d)) == 1 AND NOT OVERRIDE availableQuantity(l, customerStock(d)), 0)
    MESSAGE 'Неверное количество доступного остатка марок';