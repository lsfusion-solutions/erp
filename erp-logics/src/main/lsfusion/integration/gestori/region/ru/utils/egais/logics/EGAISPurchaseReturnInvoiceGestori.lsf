MODULE EGAISPurchaseReturnInvoiceGestori;

REQUIRE EGAISPurchaseReturnInvoice, SkuLedgerLotGestori, EGAISWayBillGestory;

PRIORITY PurchaseReturn;

NAMESPACE EGAISPurchaseReturn;

CONSTRAINT SETCHANGED(quantity(UserInvoiceDetail d, Lot l)) AND availableQuantity(l, customerStock(d)) < 0
    MESSAGE 'Неверное количество доступного остатка марок';