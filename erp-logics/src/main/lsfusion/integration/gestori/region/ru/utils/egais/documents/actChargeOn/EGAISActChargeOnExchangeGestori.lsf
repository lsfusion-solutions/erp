MODULE EGAISActChargeOnExchangeGestori;

REQUIRE EGAISActChargeOnExchange, EGAISActChargeOnStatus, EGAISActChargeOnGestori, EGAISTicketGestori, EGAISDocGestori;

NAMESPACE EGAIS;

@defineOutDocAbstractTypeNumberDate(actChargeOn);

DESIGN actChargeOns {
    PROPERTY(id(odd)) { caption = 'Номер транспортного пакета'; }
}

@defineInDocsFilterDocType(ActInventoryInformF2Reg, 'Уведомление постановки на баланс');

checkConditions(ActChargeOn a) += 'Дата/время акта должна быть не старше трех дней от текущей даты/времени'
    IF secondsBetweenDates(currentDateTime(), dateTime(a)) > 3*86400;

checkConditions(ActChargeOn a) += 'Дата/время акта должна быть не больше текущей даты/времени'
    IF dateTime(a) > currentDateTime();

minPosition(ActChargeOn a) = GROUP MIN ActChargeOnPosition p BY actChargeOn(p);
checkConditions(ActChargeOn a) += 'Отсутствуют записи в спецификации'
    IF a IS ActChargeOn AND NOT minPosition(a);

wrangQuantity (ActChargeOnPosition p) = NOT overQuantity(p) OR (NOT overQuantity(p) == markQuantity(p) IF markQuantity(p));
wrangQuantity (ActChargeOn a) = GROUP MIN ActChargeOnPosition p BY actChargeOn(p) IF wrangQuantity(p);
checkConditions(ActChargeOn a) += 'Количество кодов маркировки не соответствует количеству по позиции акта'
    IF wrangQuantity(a);

checkConditions(ActChargeOn a) += 'Для документа не задана организация'
    IF NOT client(a);

notFilledRequiredFieldsF1Reg(ActChargeOnPosition p) = p IS ActChargeOnPosition AND (NOT quantityBatch(p) OR NOT bottlingDate(p) OR NOT originalDocNumber(p) OR NOT originalDocDate(p));
notFilledRequiredFieldsF1Reg(ActChargeOn a) = GROUP MIN ActChargeOnPosition p IF notFilledRequiredFieldsF1Reg(p) BY actChargeOn(p) ;
checkConditions(ActChargeOn a) += 'Не заполнены обязательные данные справки А (количество партии, дата розлива, номер и дата ТТН)'
    IF notFilledRequiredFieldsF1Reg(a);

// Без номера пакета документ остаётся редактируемым для повторной отправки.
hideEdit(ActChargeOn a) += TRUE IF forbidEditSendDocument() AND notRejected(actChargeOnOutDoc(a)) AND id(actChargeOnOutDoc(a));
hideDelete(ActChargeOn a) += TRUE IF forbidEditSendDocument() AND notRejected(actChargeOnOutDoc(a)) AND id(actChargeOnOutDoc(a));

CONSTRAINT DROPPED(ActChargeOn a IS ActChargeOn) AND NOT disableEGAISDocumentConstraints()
    AND notRejected(actChargeOnOutDoc(a)) AND id(actChargeOnOutDoc(a))
    MESSAGE 'Запрещено удалять акт постановки на баланс после отправки в ЕГАИС';

CONSTRAINT (DROPCHANGED(number(ActChargeOn a)) OR DROPCHANGED(dateTime(a)) OR DROPCHANGED(regId(a))
    OR CHANGED(type(a)) OR DROPCHANGED(client(a)))
    AND notRejected(actChargeOnOutDoc(a)) AND id(actChargeOnOutDoc(a)) AND NOT disableEGAISDocumentConstraints()
    MESSAGE 'Запрещено изменять атрибуты акта постановки на баланс после отправки в ЕГАИС';

CONSTRAINT (SETCHANGED(product(ActChargeOnPosition p)) OR SETCHANGED(overQuantity(p)) // OR SETCHANGED(f2Reg(p)) меняется уведомлением
    OR SETCHANGED(sumSale(p)) OR SETCHANGED(quantityBatch(p)) OR SETCHANGED(bottlingDate(p)) OR SETCHANGED(originalDocNumber(p))
    OR SETCHANGED(originalDocDate(p)) OR SETCHANGED(egaisFixNumber(p)) OR SETCHANGED(egaisFixDate(p))
    OR DROPPED(product(p)) OR DROPPED(f2Reg(p)) OR DROPPED(overQuantity(p))
    OR DROPPED(sumSale(p)) OR DROPPED(quantityBatch(p)) OR DROPPED(bottlingDate(p))
    OR DROPPED(originalDocNumber(p)) OR DROPPED(originalDocDate(p)) OR DROPPED(egaisFixNumber(p))
    OR DROPPED(egaisFixDate(p)) OR DROPPED(p IS ActChargeOnPosition))
    AND notRejected(actChargeOnOutDoc(actChargeOn(p))) AND id(actChargeOnOutDoc(actChargeOn(p)))
    AND NOT disableEGAISDocumentConstraints()
    MESSAGE 'Запрещено изменять атрибуты строки акта постановки на баланс после отправки в ЕГАИС';

CONSTRAINT (SETDROPPED(ActChargeOnMark m IS ActChargeOnMark) OR DROPCHANGED(markCode(m)))
    AND notRejected(actChargeOnOutDoc(actChargeOn(actChargeOnPosition(m)))) AND id(actChargeOnOutDoc(actChargeOn(actChargeOnPosition(m))))
    AND NOT disableEGAISDocumentConstraints()
    MESSAGE 'Запрещено изменять марки акта постановки на баланс после отправки в ЕГАИС';

EXTEND CLASS ActChargeOnStatus { noTransportPackage 'Не подтверждён УТМ' }

status (ActChargeOn w) += WHEN actChargeOnOutDoc(w) AND NOT id(actChargeOnOutDoc(w))
    THEN ActChargeOnStatus.noTransportPackage;

EXTEND FORM actChargeOns
    EXTEND FILTERGROUP status
        FILTER 'Не подтверждён УТМ' status(d) = ActChargeOnStatus.noTransportPackage
;