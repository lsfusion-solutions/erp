MODULE EGAISActChargeOnExchangeGestori;

REQUIRE EGAISActChargeOnExchange, EGAISActChargeOnGestori, EGAISTicketGestori;

NAMESPACE EGAIS;

@defineOutDocAbstractTypeNumberDate(actChargeOn);

DESIGN actChargeOns {
    PROPERTY(id(odd)) { caption = 'Номер транспортного пакета'; }
}

@defineInDocsFilterDocType(ActInventoryInformF2Reg, 'Уведомление постановки на баланс');

checkConditions(ActChargeOn w) += 'Дата/время акта должна быть не старше трех дней от текущей даты/времени'
    IF secondsBetweenDates(currentDateTime(), dateTime(w)) > 3*86400;

checkConditions(ActChargeOn w) += 'Дата/время акта должна быть не больше текущей даты/времени'
    IF dateTime(w) > currentDateTime();

minPosition(ActChargeOn w) = GROUP MIN ActChargeOnPosition p BY actChargeOn(p);
checkConditions(ActChargeOn w) += 'Отсутствуют записи в спецификации'
    IF w IS ActChargeOn AND NOT minPosition(w);

wrangQuantity (ActChargeOnPosition p) = NOT overQuantity(p) == quantity(p) IF quantity(p);
wrangQuantity (ActChargeOn w) = GROUP MIN ActChargeOnPosition p BY actChargeOn(p) IF wrangQuantity(p);
checkConditions(ActChargeOn w) += 'Количество кодов маркировки не соответствует количеству по позиции акта'
    IF wrangQuantity(w);