MODULE EGAISSaleInvoiceGestori;

REQUIRE EGAISSaleInvoice, SkuLedgerLotGestori;

NAMESPACE EGAISSale;

CONSTRAINT CHANGED(quantity(UserInvoiceDetail d, Lot l)) AND NOT (availableQuantity(l, supplierStock(d)) == 1 OR NOT OVERRIDE availableQuantity(l, supplierStock(d)), 0)
    MESSAGE 'Неверное количество доступного остатка марок';