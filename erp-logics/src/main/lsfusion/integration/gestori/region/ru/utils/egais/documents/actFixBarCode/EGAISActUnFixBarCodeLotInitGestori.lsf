MODULE EGAISActUnFixBarCodeLotInitGestori;

REQUIRE EGAISActUnFixBarCodeExchangeGestori, EGAISLotInitGestori, EGAISItem;

NAMESPACE EGAIS;

actUnFixBarCode = DATA ActUnFixBarCode (LotInit);
countLotInits (ActUnFixBarCode a) = GROUP SUM 1 IF actUnFixBarCode(LotInit l) BY actUnFixBarCode(l);

overCreateActUnFixBarCodeLotInit ABSTRACT LIST (ActUnFixBarCode, LotInit);

createActUnFixBarCodeLotInit 'Сформировать документ ввода марок в оборот' (ActUnFixBarCode a) {
    IF NOT countLotInits(a) THEN {
        NEW l = LotInit {
            actUnFixBarCode(l) <- a;
            isPosted(l) <- TRUE;
            number(l) <- STRING[48](number(a));
            date(l) <- date(a);
            time(l) <- time(a);
            type(l) <- LotType.alcohol;
            stock(l) <- stock(client(a));
            note(l) <- STRING[500](note(a));

            overCreateActUnFixBarCodeLotInit(a, l);

            FOR actUnFixBarCode(ActUnFixBarCodePosition p) == a NEW d = LotInitDetail DO {
                lotInit(d) <- l;
                sku(d) <- minItem(product(p));
                quantity(d) <- countMarkCodes(p);
                FOR actUnFixBarCodePosition(ActUnFixBarCodeMark m) == p AND lot(markCode(m)) DO {
                    quantity(d, lot(markCode(m))) <- -1;
                }
            }
        }
    } ELSE {
        FOR actFixBarCode(LotInit i) DO {
            isPosted(i) <- TRUE;
        }
    }
}

afterProcessActUnFixBarCodeTicketAccepted(Ticket t) + {
    createActUnFixBarCodeLotInit(actUnFixBarCode(outDoc(t)));
}

afterPostActUnFixBarCode(ActUnFixBarCode a) + {
    createActUnFixBarCodeLotInit(a);
}

afterUnpostActUnFixBarCode(ActUnFixBarCode a) + {
    DELETE LotInit i WHERE i IS LotInit AND actUnFixBarCode(i) == a;
}