MODULE PriceLimitAlcoholGestori;

REQUIRE PriceList, EGAISProductType, EGAISItemGestori, ItemSize, MachineryPriceTransaction;

NAMESPACE PriceLimitAlcohol;

CLASS AlcoholLimit 'Минимальные цены на алкоголь';
CLASS AlcoholLimitDetail 'Строка минимальных цен на алкоголь';

@defineDocument(alcoholLimit);
@deriveDocumentHeaderTimePrefix(AlcoholLimit, );

@defineDocumentPosted(alcoholLimit);

fromDate 'Дата с'= DATA DATE (AlcoholLimit) NONULL; 
toDate 'Дата по'= DATA DATE (AlcoholLimit) NONULL;
fromDate 'Дата с' (AlcoholLimitDetail d) = fromDate(alcoholLimit(d));
toDate 'Дата по' (AlcoholLimitDetail d) = toDate(alcoholLimit(d));

volume 'Объем, л' = DATA NUMERIC[10,4] (AlcoholLimitDetail) NONULL;
in 'Вкл.' = DATA BOOLEAN (AlcoholLimit, ProductType);

idProductTypes 'Виды продукции' (AlcoholLimit a)= GROUP CONCAT id(ProductType p) IF in(a, p) ,', ' ORDER id(p) CHARWIDTH 150;
idProductTypes 'Виды продукции' (AlcoholLimitDetail d) = idProductTypes(alcoholLimit(d));

FORM changeProductTypes 'Выбор видов продукции'
    OBJECTS r = AlcoholLimit TOOLBAR
    OBJECTS p = ProductType
    PROPERTIES in(r, p)
    PROPERTIES(p) READONLY id, name
    FILTERGROUP in FILTER 'Отмеченные' in(r, p)
;

changeProductTypes(AlcoholLimit r) {
    DIALOG changeProductTypes;
}


productType = DATA ProductType(AlcoholLimitDetail) NONULL;
idProductType 'Код вида продукции' (AlcoholLimitDetail d) = id(productType(d));
nameProductType 'Наименование вида продукции' (AlcoholLimitDetail d) = name(productType(d));
fromValueAlcohol 'Содержание алкоголя c, %' = DATA NUMERIC[10,2] (AlcoholLimitDetail) NONULL;
toValueAlcohol 'Содержание алкоголя по, %' = DATA NUMERIC[10,2] (AlcoholLimitDetail) NONULL;

minPrice 'Цена за заданый объем' = DATA NUMERIC[16,5](AlcoholLimitDetail) NONULL;

FORM alcoholLimit 'Минимальные цены на алкоголь'

    OBJECTS r = AlcoholLimit PANEL
    PROPERTIES READONLY r 'Код' = STRING(r)
    PROPERTIES (r) isPosted, date, time, fromDate, toDate, note, idProductTypes ON CHANGE changeProductTypes(r)

    PROPERTIES (r) READONLY countAlcoholLimitDetail

    OBJECTS d = AlcoholLimitDetail
    PROPERTIES (d) index, idProductType, nameProductType, fromValueAlcohol, toValueAlcohol, volume, minPrice

    PROPERTIES (d) NEW, deleteid=DELETE GRID

    PROPERTIES(r) DRAW d deleteAlcoholLimitDetail

    FILTERS alcoholLimit(d) == r

    EVENTS
        ON OK prePost(r)

    EDIT AlcoholLimit OBJECT r
;

DESIGN alcoholLimit {
    BOX {
        size = (1024, 768);
        NEW headerBox {
            horizontal = TRUE;

            NEW headerParams {
                fill = 1;
                MOVE GROUP(documentHeader,r) {
                    lines = 1;
                    NEW first {
                        horizontal = TRUE;
                        MOVE PROPERTY (isPosted(r));
                        MOVE PROPERTY (r);
                        MOVE PROPERTY(date(r));
                        MOVE PROPERTY(time(r));
                        MOVE PROPERTY(fromDate(r));
                        MOVE PROPERTY(toDate(r));
                    }
                    NEW second {
                        horizontal = TRUE;
                        MOVE PROPERTY(idProductTypes(r));
                    }

                }
                MOVE GROUP(documentPrm,r);
            }
            MOVE GROUP(documentSum,r) {
                lines = 1;
            }
        }
        NEW specificationBox {
            fill = 1;
            MOVE BOX(d) {
                caption = 'Спецификация';
            }
        }
        PROPERTY(formOk()) {
            caption = 'Провести';
        }
        MOVE TOOLBARBOX;

    }
}

CONSTRAINT productType(AlcoholLimitDetail d) AND NOT in(alcoholLimit(d), productType(d)) AND idProductTypes(alcoholLimit(d)) CHECKED BY productType[AlcoholLimitDetail] MESSAGE 'Запрещено в строка минимальных цен вида продукции не разрешенный в шапке';

FORM alcoholLimits 'Минимальные цены на алкоголь'

    OBJECTS r = AlcoholLimit
    PROPERTIES READONLY r 'Код' = STRING(r)
    PROPERTIES (r) READONLY isPosted, date, time, fromDate, toDate, note, idProductTypes
    PROPERTIES (r) READONLY countAlcoholLimitDetail

    PROPERTIES (r) NEWSESSION NEW, EDIT, deleter=DELETE
//    PROPERTIES (r)            copy
    PROPERTIES (r) READONLY PANEL createdNameUser, createdTime, createdHostnameComputer,
        postedNameUser, postedTime, postedHostnameComputer

    OBJECTS d = AlcoholLimitDetail
    PROPERTIES (d) READONLY index, idProductType, nameProductType, fromValueAlcohol, toValueAlcohol, volume, minPrice

    FILTERS alcoholLimit(d) == r

    LIST AlcoholLimit OBJECT r
;
DESIGN alcoholLimits {
    BOX {
        size = (1024, 768);

        NEW documentContainer BEFORE TOOLBARBOX {
            fill = 1;
            MOVE BOX(r);

            NEW documentDetail {
                fill = 1;
                tabbed = TRUE;
                MOVE BOX(d) {
                    fill = 1;
                    caption = 'Спецификация';
                }
                NEW documentHistory {
                    caption = 'История';
                    MOVE GROUP(created,r);
                    MOVE GROUP(posted,r);
                }
                NEW printTab {
                    caption = 'Печатные формы';
                    NEW printContainer {
                        caption = 'Печать';
                    }
                }
                NEW actionContainer {
                    caption = 'Действия';
                    horizontal = TRUE;
                    NEW createdContainer {
                        caption = 'Создание на основе';
                    }
                }
            }
        }
    }
}

NAVIGATOR {
    priceListDocuments{
        NEW alcoholLimits;
    }
}
minAlcoholLimitPrice = ABSTRACT CASE NUMERIC[16,4](Item , DATETIME);
minAlcoholLimitPriceRB = ABSTRACT CASE NUMERIC[16,4](Item , DATETIME);
useCustomAlcoholLimitPrice = ABSTRACT BOOLEAN ();

skipAlcoholLimitPrice = ABSTRACT VALUE BOOLEAN (AlcoholLimitDetail);

alcoholLimitDetail (Item s, DATETIME dt) = GROUP
    LAST AlcoholLimitDetail ad ORDER dateTime(ad), ad
    WHERE isPosted(ad) AND productType(s) == productType(ad) AND toDate(dt) >= fromDate(alcoholLimit(ad)) AND
        toDate(dt) <= toDate(alcoholLimit(ad)) AND value(alcohol(s)) >= fromValueAlcohol(ad) AND value(alcohol(s)) < toValueAlcohol(ad);

minAlcoholLimitPriceCalc (Item s, DATETIME dt) = GROUP
    LAST NUMERIC[16,4](ceil(minPrice(AlcoholLimitDetail ad)*volume(s)*100/volume(ad))/100)
    ORDER dateTime(ad), ad
    WHERE isPosted(ad) AND productType(s) == productType(ad) AND toDate(dt) >= fromDate(alcoholLimit(ad)) AND
        toDate(dt) <= toDate(alcoholLimit(ad)) AND value(alcohol(s)) >= fromValueAlcohol(ad) AND value(alcohol(s)) < toValueAlcohol(ad);

//minAlcoholLimitPriceRBCalc (Item s, DATETIME dt) = GROUP
//    LAST minPrice(AlcoholLimitDetail ad, Alcohol a)
//    ORDER dateTime(ad), ad
//    WHERE isPosted(ad) AND dateTime(ad) <= dt AND volume(s) == volume(ad) AND alcohol(s) == a AND NOT value(a) < minAlcoholValue(ad) AND isRB(ad) AND NOT skipAlcoholLimitPrice(ad);
//
minAlcoholLimitPrice (Item s, DATETIME dt) += WHEN s IS Item AND dt IS DATETIME AND NOT useCustomAlcoholLimitPrice() THEN minAlcoholLimitPriceCalc(s,dt);
//minAlcoholLimitPriceRB (Item s, DATETIME dt) += WHEN s IS Item AND dt IS DATETIME AND NOT useCustomAlcoholLimitPrice() THEN minAlcoholLimitPriceRBCalc(s,dt);


CLASS SingleMinPrice 'ЕМЦ';

itemGroup '' = DATA ItemGroup(SingleMinPrice) AUTOSET;
date 'Дата начала' = DATA DATE (SingleMinPrice);
price 'ЕМЦ' = DATA NUMERIC[16,4](SingleMinPrice);

FORM singleMinPrice
    OBJECTS s = SingleMinPrice PANEL
    PROPERTIES(s) date, price
    EDIT SingleMinPrice OBJECT s
;

isSingleMinPrice 'ЕМЦ' = DATA BOOLEAN (ItemGroup) IN paramsItemGroup;
singleMinPrice 'ЕМЦ' (ItemGroup g, DATE dt) = GROUP LAST price(SingleMinPrice s) IF itemGroup(s) = g AND date(s) <= dt ORDER date(s);
singleMinPrice 'ЕМЦ' (ItemGroup g) = GROUP LAST price(SingleMinPrice s) IF itemGroup(s) = g AND date(s) <= currentDate() ORDER date(s);

singleMinPrice 'ЕМЦ' (Item i, DATE dt) = GROUP LAST singleMinPrice(ItemGroup g, dt) IF isParent(g, i) ORDER g;
singleMinPrice 'ЕМЦ' (Item i) = GROUP LAST singleMinPrice(ItemGroup g) IF isParent(g, i) ORDER g;

singleMinPrice(Item i, DATETIME dt) = GROUP LAST SingleMinPrice s ORDER date(s), s
    WHERE toDate(dt) >= date(s) AND isParent(itemGroup(s), i) AND singleMinPrice(i, toDate(dt));

EXTEND FORM itemGroup
    PROPERTIES (g) isSingleMinPrice
;

EXTEND FORM itemGroups
    PROPERTIES (g) isSingleMinPrice
;

FORM singleMinPrices 'ЕМЦ'
    OBJECTS g = ItemGroup
    PROPERTIES(g) READONLY id, name, singleMinPrice
    FILTERS isSingleMinPrice(g)

    OBJECTS s = SingleMinPrice
    PROPERTIES(s)  READONLY date, price
    PROPERTIES(s) NEWSESSION NEW, EDIT, DELETE
    FILTERS itemGroup(s) = g
    OBJECTS i = Item
    PROPERTIES (i) READONLY idBarcode, id, name
    PROPERTIES singleMinPrice(i)
    FILTERS isParent(g, i)

;

NAVIGATOR {
    priceListDocuments{
        NEW singleMinPrices;
    }
}

minAlcoholLimitPrice 'МРЦ/EMЦ' (UserPriceListDetail d) = OVERRIDE minAlcoholLimitPrice(sku(d), fromDateTime(d)), singleMinPrice(sku(d), fromDate(d));

EXTEND FORM userPriceList
    PROPERTIES (d) READONLY minAlcoholLimitPrice SHOWIF show(p, priceListType('retail'))
;

CONSTRAINT CHANGED(isPosted(UserPriceListDetail d)) AND isPosted(d) AND price(d, dataPriceListType('retail')) < minAlcoholLimitPrice(d) MESSAGE 'Цена меньше МРЦ/ЕМЦ';

EXTEND FORM alcoholLimits
    OBJECTS i = Item
    PROPERTIES (i) READONLY idBarcode, id, name, volume, nameProductType
    PROPERTIES 'Минимальная цена (дата начала)' = minAlcoholLimitPrice(i, toDateTime(fromDate(r))), 'Минимальная цена (текущая дата)' = minAlcoholLimitPrice(i, currentDateTime())
    FILTERS [GROUP SUM 1 IF productType(Item i1) == productType(AlcoholLimitDetail d1) AND value(alcohol(i1)) >= fromValueAlcohol(d1) AND value(alcohol(i1)) < toValueAlcohol(d1) BY alcoholLimit(d1), i1](r, i)
    ;

DESIGN alcoholLimits {
    documentDetail {
        MOVE BOX (i);
    }
}

CONSTRAINT (SET(isPosted(AlcoholLimitDetail d)) OR CHANGED(productType(d)) OR CHANGED(fromValueAlcohol(d)) OR CHANGED(toValueAlcohol(d))) AND isPosted(d) AND
    (GROUP SUM 1 IF productType(AlcoholLimitDetail d1) = productType(d) AND alcoholLimit(d) = alcoholLimit(d1) AND d != d1 AND
    toValueAlcohol(d) > fromValueAlcohol(d1) AND fromValueAlcohol(d) < toValueAlcohol(d1)) 
    MESSAGE ' Диапазоны содержания % алкоголя в рамках одного вида продукции не должны пересекаться' 
    PROPERTIES index(d), idProductType(d), fromValueAlcohol(d), toValueAlcohol(d);

CONSTRAINT (SET(isPosted(AlcoholLimitDetail d)) OR CHANGED(fromValueAlcohol(d)) OR CHANGED(toValueAlcohol(d))) AND isPosted(d) AND fromValueAlcohol(d) >= toValueAlcohol(d)
    MESSAGE ' Диапазон содержания % алкоголя задан некорректно.\n Начало диапазона должно быть меньше окончания диапазона.'
    PROPERTIES index(d), idProductType(d), fromValueAlcohol(d), toValueAlcohol(d);

inAllProductType (AlcoholLimit a) = TRUE IF NOT (GROUP SUM 1 IF  in(a, ProductType p));

idAlcoholLimits 'Код МРЦ' (AlcoholLimitDetail a) = GROUP CONCAT STRING (alcoholLimit(AlcoholLimitDetail a1)) IF a != a1 AND toDate(alcoholLimit(a)) >= fromDate(alcoholLimit(a1)) AND fromDate(alcoholLimit(a)) <= toDate(alcoholLimit(a1)) AND
    productType(a) = productType(a1) AND alcoholLimit(a)!=alcoholLimit(a1), ', ' ORDER a1;

CONSTRAINT (SET(isPosted(AlcoholLimitDetail a)) OR CHANGED(fromDate(alcoholLimit(a))) OR CHANGED(toDate(alcoholLimit(a)))) AND isPosted(alcoholLimit(a)) AND
    (GROUP SUM 1 IF a != AlcoholLimitDetail a1 AND isPosted(a1) AND toDate(alcoholLimit(a)) >= fromDate(alcoholLimit(a1)) AND fromDate(alcoholLimit(a)) <= toDate(alcoholLimit(a1)) AND 
    productType(a) = productType(a1) AND alcoholLimit(a)!=alcoholLimit(a1)) 
    MESSAGE 'Периоды действия документов МРЦ в рамках указанных видов продукции не должны пересекаться' 
    PROPERTIES dateTime(a), fromDate(a), toDate(a), idProductTypes(a), index(a), idProductType(a), fromValueAlcohol(a), toValueAlcohol(a), idAlcoholLimits(a);

//CONSTRAINT (SET(isPosted(AlcoholLimit a)) OR CHANGED(fromDate(a)) OR CHANGED(toDate(a))) AND isPosted(a) AND
//    (GROUP SUM 1 IF a != AlcoholLimit a1 AND toDate(a) >= fromDate(a1) AND fromDate(a) <= toDate(a1) AND in(a, ProductType p) AND in(a1, p))
//    MESSAGE ' Запрещено проводить 2 документа МРЦ с пересекающимися датами';

defaultMinPrice = ABSTRACT NUMERIC[16,4] (Barcode, Stock);
dataMinPrice(Barcode b, Stock st) += OVERRIDE minAlcoholLimitPrice(sku(b), currentDateTime()), singleMinPrice(sku(b), currentDate()), defaultMinPrice(b, st);

dateMinPrice (Sku s, DATETIME dt) = OVERRIDE fromDate(alcoholLimitDetail(s, dt)), date(singleMinPrice(s, dt));