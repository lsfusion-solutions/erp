MODULE SaleReportsGestory;

REQUIRE SaleReportsRu, Item, SaleShipment, PurchaseShipment, AccountDocument,
        ZReportReceiptTime, SaleReports, SkuList, ReceiptDetailReport, InventoryGestori, SalePurchaseInvoice;

NAMESPACE SaleReports;

CLASS QuantityFilterType 'Тип фильтра по количеству' {
    greater 'Больше',
    less 'Меньше',
    equal 'Равно'
}

CLASS SkuFilterType 'Тип фильтра по товарам'{
    sku 'Товары',
    skuGroups 'Товарные группы',
    skuLists 'Списки товаров'
}

intervalsCount 'Количество интервалов' = DATA LOCAL INTEGER ();

filterQuantityType = DATA LOCAL QuantityFilterType();
filterQuantityTypeName 'Сравнение' = staticCaption(filterQuantityType());

filterFrom 'Дата (с)' = DATA LOCAL DATE ();
filterTo 'Дата (по)' = DATA LOCAL DATE ();
in 'Отм.' = DATA LOCAL BOOLEAN (CashRegister);
inSaleReportCashRegs 'Кассы' () =
    GROUP CONCAT STRING(npp(CashRegister c)) IF in(c), ',' ORDER c CHARWIDTH 20;

in 'Отм.' = DATA LOCAL BOOLEAN (Employee);
inReportCashiers 'Кассиры' () =
    GROUP CONCAT STRING(name(Employee e)) IF in(e), ',' ORDER e CHARWIDTH 20;

addSkuLists 'Отметить по cписку Sku' () {
    in(Sku s) <- NULL;
    DIALOG dialogAddLists DO {
        FOR [GROUP SUM 1 IF in(list(ListDetail d)) IF Sku s = sku(d) BY s](Sku s) DO {
            in(s) <- TRUE;
        }
    }
    in(List l) <- NULL;
}

filterQuantity 'Фильтр по количеству' = DATA LOCAL NUMERIC[10,3]();

filterByDates(ZReport.Receipt r) = (NOT filterFrom() OR date(r) >= filterFrom()) AND
    (NOT filterTo() OR date(r) <= filterTo());

filterForPerformanceReport(ZReport.Receipt r) = filterByDates(r) AND inSaleReport(ZReport.departmentStore(r))
    AND ((NOT GROUP SUM 1 IF in(CashRegister cr)) OR in(ZReport.cashRegister(r)))
    AND ((NOT GROUP SUM 1 IF in(Employee e)) OR in(ZReport.employee(r)));

skuFilterType = DATA LOCAL SkuFilterType();
nameSkuFilterType 'Выбор товаров' = staticCaption(skuFilterType());

filterBySku(ZReport.ReceiptDetail rd) = CASE
    WHEN skuFilterType() = SkuFilterType.skuGroups THEN ((NOT GROUP SUM 1 IF inSession(SkuGroup g)) OR inSession(skuGroup(sku(rd))))
    WHEN skuFilterType() = SkuFilterType.sku OR skuFilterType() = SkuFilterType.skuLists THEN (NOT GROUP SUM 1 IF in(Sku s)) OR in(sku(rd))
    ELSE TRUE ;

filterByQuantity(ZReport.ReceiptDetail rd) = NOT filterQuantityType() OR NOT filterQuantity() OR
    (filterQuantityType() = QuantityFilterType.greater AND ZReport.signedQuantity(rd) > filterQuantity() ) OR
    (filterQuantityType() = QuantityFilterType.less AND ZReport.signedQuantity(rd) < filterQuantity() ) OR
    (filterQuantityType() = QuantityFilterType.equal AND ZReport.signedQuantity(rd) = filterQuantity() )
;

iterateDays(DATE d) = RECURSION d = DATE(filterFrom())
    AND filterTo() IS DATE STEP d = DATE (sumDay(DATETIME ($d), 1)) AND d <= DATE (filterTo()) CYCLES IMPOSSIBLE;

FORM dialogCashRegisters 'Выбор касс'
    OBJECTS c = CashRegister
    PROPERTIES(c) in
    PROPERTIES(c) READONLY npp, shortDescription, description, nameStock, nameGroupMachinery, nppGroupMachinery
    FILTERS inSaleReport(stock(c))
;

FORM dialogCashiers 'Выбор кассиров'
    OBJECTS e = Employee
    PROPERTIES(e) in
    PROPERTIES(e) READONLY name
    FILTERS GROUP SUM 1 IF ZReport.employee(ZReport.Receipt r) = e
;

FORM selectSku 'Выбор товара'
    TREE skuTree sg = SkuGroup PARENT parent(sg)
    PROPERTIES READONLY order(sg), skuGroupName = name(sg)
    FILTERGROUP inactive FILTER 'Активные' active(sg) 'F6' DEFAULT
    ORDERS order(sg), skuGroupName

    OBJECTS s = Sku
    PROPERTIES (s) in
    PROPERTIES(s) READONLY id SHOWIF showIDs()
    PROPERTIES(s) READONLY name, idBarcode, shortNameUOM
    FILTERS isParent(sg, s), name(s)
    ORDERS name(s)
;

FORM skuFilterType 'Тип фильтра по товарам'
    OBJECTS t = SkuFilterType
    PROPERTIES(t) READONLY '' = staticCaption
    LIST SkuFilterType OBJECT t;

askSkuFilterType 'Фильтр по товарам'() {
    DIALOG skuFilterType OBJECTS t INPUT DO {
        skuFilterType() <- t;
        IF t = SkuFilterType.sku THEN SHOW selectSku ;
        ELSE IF t = SkuFilterType.skuGroups THEN SHOW filterGroupType;
        ELSE IF t = SkuFilterType.skuLists THEN addSkuLists();
    }
}

selectStocksForReport(){
    DIALOG dialogStocksSaleReport FILTERS s IS DepartmentStore;
}

inReportStocks 'Склады' () =
    GROUP CONCAT name(Stock st) IF inSaleReport(st), ',' ORDER st CHARWIDTH 30;

selectCashRegisters() {DIALOG dialogCashRegisters;}
selectCashiers() {DIALOG dialogCashiers;}

selectedSkus = GROUP CONCAT STRING(name(Sku s)) IF in(s), ',' ORDER s CHARWIDTH 30;
//selectedSkuGroups = GROUP CONCAT STRING(name(SkuGroup g)) IF inSession(g), ',' ORDER g CHARWIDTH 30;
//selectedSkuGroups 'Товарные группы' = GROUP CONCAT name(SkuGroup o) IF inSession(o) AND NOT inSession(parent(o)), '; ' ORDER o CHARWIDTH 30;

//inSaleReportSkus 'Товары' () = CONCAT ',', selectedSkus(), selectedSkuGroups();

priceSku(Sku s, Stock st, DATE d) += OVERRIDE accountPrice(s, st, d), accountPriceB(s, st, dateTimeToDateTime(d, 23:59));
costPriceSku(Sku s, Stock st, DATE d) += OVERRIDE costPrice(s, st, d), NUMERIC[17,5](round5(priceSku(s, st, d) * 100 / (100 + valueVAT(s))));

linkedPurchaseInvoice = ABSTRACT Purchase.Invoice (SaleLedger);
linkedPurchaseInvoice(Sale.InvoiceDetail l) += purchaseInvoice(Sale.invoice(l));

numberLinkedPurchaseInvoice 'Номер приходной накладной' (SaleLedger l) = number(linkedPurchaseInvoice(l));
dateLinkedPurchaseInvoice 'Дата приходной накладной' (SaleLedger l) = date(linkedPurchaseInvoice(l));

retailPriceSku 'Розничная цена' (SaleLedger l) =
    NUMERIC[16,4](prevPriceB(retailPriceListType(stock(l)), sku(l), stock(l), dateTime(l)));

sumRetail 'Розничная сумма' (SaleLedger l) =
    NUMERIC[18,2](round2(retailPriceSku(l) * quantity(l)));

initShipmentDates() {
    filterFrom() <- currentDate();
    filterTo() <- currentDate();
}

inSalesReportInterval (SaleLedger l) = filterFrom() <= date(l) AND filterTo() >= date(l);

isRetailLedger (SaleLedger l) = l IS DateSaleSkuLedger OR l IS DateReturnSkuLedger;

passesReportStockFilterStock (Stock st) = NOT inSaleReportStocks() OR inSaleReport(st);
passesReportSkuFilterSku (Sku s) = (NOT anySkuList() AND NOT anySkuGroup()) OR in(s) OR inSessionParent(s);
passesReportSupplierFilterSku (Sku s) = NOT inSaleReportSupplier() OR inSupplier(supplierSku(s));

passesReportStockFilter (SaleLedger l) = passesReportStockFilterStock(stock(l));
passesReportCustomerFilter (SaleLedger l) = NOT inSaleReportCustomer() OR inCustomer(customer(l));
passesReportSkuFilter (SaleLedger l) = passesReportSkuFilterSku(sku(l));
passesReportSupplierFilter (SaleLedger l) = passesReportSupplierFilterSku(sku(l));

shipmentIsOwnTransfer (SaleLedger l) = isCompany(customer(l));
shipmentTransferKind 'Тип расхода' (SaleLedger l) = CASE
    WHEN NOT shipmentIsOwnTransfer(l) THEN 'Сторонний покупатель'
    WHEN legalEntity(stock(l)) == customer(l) THEN 'Перемещение внутри своей компании'
    ELSE 'Перемещение между своими компаниями';
shipmentOwnStockSuffix 'Склад покупателя (для своих)' (SaleLedger l) = IF shipmentIsOwnTransfer(l) THEN CONCAT ' - ', id(customerStock(l)), nameCustomerStock(l);

FORM shipmentStatementGestori 'Ведомость отгрузок'
    PROPERTIES() filterFrom, filterTo
    PROPERTIES nameStockList() READONLY SHOWIF stockList()
    PROPERTIES inShipmentStocks 'Подразделения' = inSaleReportStocks() ON CHANGE changeStocksInventory() READONLYIF stockList()
    PROPERTIES nameLegalEntityCustomerList() READONLY SHOWIF legalEntityCustomerList()
    PROPERTIES inShipmentCustomers 'Покупатели' = inSaleReportCustomer() ON CHANGE { DIALOG dialogLegalEntitiesSaleReport; } READONLYIF legalEntityCustomerList()
    PROPERTIES nameSkuLists() READONLY SHOWIF anySkuList()
    PROPERTIES shipmentSelectedSkuGroups 'Товарные группы' = selectedSkuGroups() READONLY SHOWIF anySkuGroup()
    PROPERTIES shipmentSkus 'Товары' = inSkus() ON CHANGE selectSkus() READONLYIF anySkuList() OR anySkuGroup()

    OBJECTS l = SaleLedger
    PROPERTIES(l) READONLY idStock, nameStock,
        date, numberDocument, nameOperation, shipmentTransferKind,
        nameCustomer,
        numberLinkedPurchaseInvoice, dateLinkedPurchaseInvoice,
        idSku, nameSku, quantity, sumRetail

    PROPERTIES READONLY idCustomer 'Код покупателя' = id(customer(l)),
        ownStockSuffix 'Склад покупателя (для своих)' = shipmentOwnStockSuffix(l),
        manufacturerSku 'Производитель' = nameManufacturer(sku(l)),
        volume 'Объём' = volume(sku(l)) * quantity(l),
        weight 'Вес' = netWeight(sku(l)) * quantity(l),
        sumWtVat 'Сумма без НДС' = sum(l) (-) sumVAT(l)
    PROPERTIES READONLY skuGroup2 'Отдел' = CONCAT ' ', idSkuGroup2(sku(l)), nameSkuGroup2(sku(l))
    PROPERTIES READONLY skuGroup3 'Группа' = CONCAT ' ', idSkuGroup3(sku(l)), nameSkuGroup3(sku(l))
    PROPERTIES READONLY skuGroup4 'Подгруппа' = CONCAT ' ', idSkuGroup4(sku(l)), nameSkuGroup4(sku(l))

    ORDERS idStock(l), date(l), nameCustomer(l), nameSku(l)
    FILTERS active(l),
        inSalesReportInterval(l),
        NOT isRetailLedger(l),
        passesReportStockFilter(l),
        passesReportCustomerFilter(l),
        passesReportSkuFilter(l),
        NOT skipSaleReport(sku(l), stock(l))

    EVENTS ON INIT initShipmentDates()
;

@definePrintReport(shipmentStatementGestori, 'Ведомость отгрузок');

EXTEND FORM shipmentStatementGestori
    PROPERTIES() DISABLEIF NOT filterFrom() OR NOT filterTo() shipmentStatementGestori
;

DESIGN shipmentStatementGestori {
    NEW filters FIRST {
        alignment = STRETCH;
        NEW topRow {
            horizontal = TRUE;
            MOVE PROPERTY(filterFrom());
            MOVE PROPERTY(filterTo());
            MOVE PROPERTY(shipmentStatementGestori()) { valueClass = 'btn-primary'; }
        }
        MOVE PROPERTY(nameStockList()) { alignment = STRETCH; }
        MOVE PROPERTY(inShipmentStocks) { alignment = STRETCH; }
        MOVE PROPERTY(nameLegalEntityCustomerList()) { alignment = STRETCH; }
        MOVE PROPERTY(inShipmentCustomers) { alignment = STRETCH; }
        MOVE PROPERTY(nameSkuLists()) { alignment = STRETCH; }
        MOVE PROPERTY(shipmentSelectedSkuGroups) { alignment = STRETCH; }
        MOVE PROPERTY(shipmentSkus) { alignment = STRETCH; }
    }
}

NAVIGATOR {
    saleNavigator {
        salesReports {
            NEW shipmentStatementGestori;
        }
    }
}

inSaleIntervalReport 'Вкл.' = DATA LOCAL BOOLEAN (Stock);

intervalInHoursInput 'Интервал (в часах)' = DATA LOCAL INTEGER ();

filterShiftFromIntervals 'Смена от' = DATA LOCAL TIME ();
filterShiftToIntervals 'Смена до' = DATA LOCAL TIME ();

intervalInHours = CASE
    WHEN intervalInHoursInput() THEN intervalInHoursInput();

iterateHours(DATETIME d) = RECURSION d = DATETIME(filterFrom()) AND filterFrom() IS DATE
    AND DATETIME(filterTo()) IS DATETIME STEP d = sumMinutes($d, intervalInHours() * 60) AND d < DATETIME(filterTo()) CYCLES IMPOSSIBLE;

endInterval(DATETIME d) = sumMinutes(d, intervalInHours() * 60);

unitCountI 'Продано единиц' (DATETIME d, DepartmentStore s) = GROUP SUM ZReport.signedQuantity(ZReport.ReceiptDetail rd)
    IF ZReport.dateTime(rd) >= d AND ZReport.dateTime(rd) <= endInterval(d) AND ZReport.departmentStore(rd) = s;

sumI 'Сумма продаж' (DATETIME d, DepartmentStore s) = GROUP SUM ZReport.signedSum(ZReport.ReceiptDetail rd)
    IF ZReport.dateTime(rd) >= d AND ZReport.dateTime(rd) <= endInterval(d) AND ZReport.departmentStore(rd) = s;

avgI 'Средняя стоимость' (DATETIME d, DepartmentStore s) = sumI(d, s) / unitCountI(d, s);

shortName(DOW d) = CASE
    WHEN d == DOW.sunday THEN 'Вс'
    WHEN d == DOW.monday THEN 'Пн'
    WHEN d == DOW.tuesday THEN 'Вт'
    WHEN d == DOW.wednesday THEN 'Ср'
    WHEN d == DOW.thursday THEN 'Чт'
    WHEN d == DOW.friday THEN 'Пт'
    WHEN d == DOW.saturday THEN 'Сб'
;

FORM salesByIntervalsReportPrint 'Продажи по временным интервалам'
    PROPERTIES filterFrom = filterFrom(), filterTo = filterTo(),
        inSaleReportStocks = inReportStocks(), intervalInHours = intervalInHours(),
        shiftFrom = filterShiftFromIntervals(), shiftTo = filterShiftToIntervals()

    OBJECTS s = DepartmentStore
    PROPERTIES name(s)
    FILTERS inSaleReport(s)

    OBJECTS d = DATETIME
    PROPERTIES READONLY date 'Дата' = STRING (toChar(d, 'dd.MM.yyyy')), dow 'День\nнедели' = shortName(extractDOW(DATE(d))),
        time 'Время' = STRING (toChar(d, 'HH24:MI')),
        unitCountI(d, s) COLUMNS 'склад' (s) HEADER name(s) + ': Продано\nединиц ',
        sumI(d, s) COLUMNS 'склад' (s) HEADER 'Сумма\nпродаж',
        avgI(d, s) COLUMNS 'склад' (s) HEADER 'Средняя\nстоимость'
    FILTERS iterateHours(d), TIME (d) >= filterShiftFromIntervals(), TIME (d) <= filterShiftToIntervals()
;

printSaleReportIntervals 'Печать' (DATE from, DATE to){
    filterFrom() <- from;
    filterTo() <- to;
    PRINT salesByIntervalsReportPrint XLS TO printReportFile;
    buildPrintReportFileName('salesByIntervalsReportPrint', 'Продажи по временным интервалам');
    open(printReportFile(), builtPrintReportFileName());
}

filterByDates(DATE d) = (NOT filterFrom() OR d >= filterFrom()) AND
    (NOT filterTo() OR d <= filterTo());

FORM salesByCashRegsReportPrint 'Продажи товара на кассах'
    PROPERTIES filterFrom = filterFrom(), filterTo = filterTo(),
        inSaleReportStocks = inSaleReportStocks()

    OBJECTS rd = ZReport.ReceiptDetail
    PROPERTIES (rd) READONLY date, time, idBarcode, nameSku, numberCashRegister, numberReceipt, ZReport.signedQuantity, price
    FILTERS filterByDates(date(rd)) AND filterByQuantity(rd)
        AND inSaleReport(ZReport.departmentStore(rd)) AND filterBySku(rd)
    ORDERS date(rd), time(rd)
;

printSaleByCashRegsReport 'Печать' (DATE from, DATE to){
    filterFrom() <- from;
    filterTo() <- to;
    PRINT salesByCashRegsReportPrint XLS TO printReportFile;
    buildPrintReportFileName('salesByCashRegsReportPrint', 'Продажи товара на кассах');
    open(printReportFile(), builtPrintReportFileName());
}

workWithReceipt 'Время работы с чеком, сек' (ZReport.Receipt r) = secondsBetweenDates(ZReport.dateTimeClosed(r), ZReport.dateTimeOpen(r));

workWithReceiptSubtotalByCashier(Employee e) = GROUP SUM workWithReceipt(ZReport.Receipt r) IF filterForPerformanceReport(r) AND ZReport.employee(r) = e;
countReceiptDetailSubtotalByCashier(Employee e) = GROUP SUM ZReport.countReceiptDetail(ZReport.Receipt r) IF filterForPerformanceReport(r) AND ZReport.employee(r) = e;
sumReceiptDetailSubtotalByCashier(Employee e) = GROUP SUM ZReport.sumReceiptDetail(ZReport.Receipt r) IF filterForPerformanceReport(r) AND ZReport.employee(r) = e;

FORM cashierPerformanceReportPrint 'СКОРОСТЬ РАБОТЫ КАССИРА (подробно)'
    PROPERTIES filterFrom = filterFrom(), filterTo = filterTo(),
        inSaleReportStocks = inSaleReportStocks()

    OBJECTS e = Employee
    PROPERTIES (e) shortName, workWithReceiptSubtotalByCashier, countReceiptDetailSubtotalByCashier, sumReceiptDetailSubtotalByCashier
    FILTERS countReceiptDetailSubtotalByCashier(e)

    OBJECTS r = ZReport.Receipt
    PROPERTIES (r) READONLY idDepartmentStore, numberCashRegister, nameEmployee, date, number,
        ZReport.dateTimeOpen, ZReport.dateTimeClosed, workWithReceipt, ZReport.countReceiptDetail, ZReport.sumReceiptDetail

    FILTERS nameEmployee(r) AND filterForPerformanceReport(r) AND ZReport.employee(r) = e
    ORDERS nameEmployee(r), numberCashRegister(r), date(r)
;

printCashierPerformanceReport 'Печать' (DATE from, DATE to){
    filterFrom() <- from;
    filterTo() <- to;
    PRINT cashierPerformanceReportPrint XLS TO printReportFile;
    buildPrintReportFileName('cashierPerformanceReportPrint', 'СКОРОСТЬ РАБОТЫ КАССИРА (подробно)');
    open(printReportFile(), builtPrintReportFileName());
}

receiptsCount 'Кол-во чеков за период' (Employee e, CashRegister c) = GROUP SUM 1 IF ZReport.employee(ZReport.Receipt r) = e AND filterByDates(date(r))
    AND inSaleReport(ZReport.departmentStore(r)) AND ZReport.cashRegister(r) = c;
receiptDetailsCount 'Кол-во товаров за период' (Employee e, CashRegister c) = GROUP SUM 1 IF ZReport.employee(ZReport.receipt(ZReport.ReceiptDetail rd)) = e
    AND filterByDates(date(rd)) AND inSaleReport(ZReport.departmentStore(rd)) AND ZReport.cashRegister(ZReport.receipt(rd)) = c;
workWithReceiptTotal 'Время работы с чеками, сек' (Employee e, CashRegister c) = GROUP SUM workWithReceipt(ZReport.Receipt r) IF ZReport.employee(r) = e AND filterByDates(date(r))
    AND inSaleReport(ZReport.departmentStore(r)) AND ZReport.cashRegister(r) = c;
workWithReceiptAvg 'Среднее время на чек, сек' (Employee e, CashRegister c) = workWithReceiptTotal(e, c) / receiptsCount(e, c);
workWithItemAvg 'Среднее время на товар, сек' (Employee e, CashRegister c) = workWithReceiptTotal(e, c) / receiptDetailsCount(e, c);

receiptsCountSubtotal (CashRegister c) = GROUP SUM 1 IF ZReport.cashRegister(ZReport.Receipt r) = c AND filterByDates(date(r))
    AND inSaleReport(ZReport.departmentStore(r)) AND ZReport.employee(r);
receiptDetailsCountSubtotal (CashRegister c) = GROUP SUM 1 IF ZReport.cashRegister(ZReport.receipt(ZReport.ReceiptDetail rd)) = c
    AND filterByDates(date(rd)) AND inSaleReport(ZReport.departmentStore(rd)) AND ZReport.employee(ZReport.receipt(rd));
workWithReceiptTotalSubtotal (CashRegister c) = GROUP SUM workWithReceipt(ZReport.Receipt r) IF ZReport.cashRegister(r) = c
    AND filterByDates(date(r)) AND inSaleReport(ZReport.departmentStore(r)) AND ZReport.employee(r);
workWithReceiptAvgSubtotal (CashRegister c) = NUMERIC[13,3] (workWithReceiptTotalSubtotal(c)) / receiptsCountSubtotal(c);
workWithItemAvgSubtotal (CashRegister c) = NUMERIC[13,3] (workWithReceiptTotalSubtotal(c)) / receiptDetailsCountSubtotal(c);

filterForPerformanceReport(Employee e, CashRegister c) = inSaleReport(stock(c))
    AND ((NOT GROUP SUM 1 IF in(CashRegister cr)) OR in(c))
    AND ((NOT GROUP SUM 1 IF in(Employee em)) OR in(e));

FORM cashierPerformanceTotalReportPrint 'СКОРОСТЬ РАБОТЫ КАССИРА (итоги)'
    PROPERTIES filterFrom = filterFrom(), filterTo = filterTo(),
        inSaleReportStocks = inSaleReportStocks()

    OBJECTS c = CashRegister
    PROPERTIES (c) nameStock, npp, receiptsCountSubtotal, receiptDetailsCountSubtotal, workWithReceiptTotalSubtotal,
        workWithReceiptAvgSubtotal, workWithItemAvgSubtotal
    FILTERS receiptsCountSubtotal(c)

    OBJECTS e = Employee
    PROPERTIES READONLY name(e), receiptsCount(e, c), receiptDetailsCount(e, c),
        workWithReceiptTotal(e, c), workWithReceiptAvg(e, c), workWithItemAvg(e, c)
    FILTERS filterForPerformanceReport(e, c) AND receiptsCount(e, c)
    ORDERS npp(c)
;

printCashierPerformanceTotalReport 'Печать' (DATE from, DATE to){
    filterFrom() <- from;
    filterTo() <- to;
    PRINT cashierPerformanceTotalReportPrint XLS TO printReportFile;
    buildPrintReportFileName('cashierPerformanceTotalReportPrint', 'СКОРОСТЬ РАБОТЫ КАССИРА (итоги)');
    open(printReportFile(), builtPrintReportFileName());
}

filterShiftFrom 'Смена от' = DATA LOCAL TIME ();
filterShiftTo 'Смена до' = DATA LOCAL TIME ();

filterShiftFromReceiptDiscount 'Смена от' = DATA LOCAL TIME ();
filterShiftToReceiptDiscount 'Смена до' = DATA LOCAL TIME ();

filterDiscountFrom 'Скидка с' = DATA LOCAL NUMERIC ();
filterDiscountTo 'Скидка по' = DATA LOCAL NUMERIC ();

filterByShift(ZReport.ReceiptDetail rd) = (NOT filterShiftFrom() OR time(rd) >= filterShiftFrom()) AND
    (NOT filterShiftTo() OR time(rd) <= filterShiftTo());

filterForItemsWithDiscount(ZReport.ReceiptDetail rd) = sku(rd) AND ZReport.discountSum(rd)
    AND filterByShift(rd)
    AND filterByDates(date(rd))
    AND inSaleReport(ZReport.departmentStore(rd))
    AND ((NOT GROUP SUM 1 IF in(CashRegister cr)) OR in(ZReport.cashRegister(ZReport.receipt(rd))))
    AND ((NOT GROUP SUM 1 IF in(Employee e)) OR in(ZReport.employee(ZReport.receipt(rd))));

priceWithDiscount(ZReport.ReceiptDetail rd) = round(ZReport.signedSum(rd) / ZReport.signedQuantity(rd), roundDiscountCondition(ZReport.departmentStore(rd)));
discountPercentCalc(ZReport.ReceiptDetail rd) = round(1 - ZReport.signedSum(rd) / ZReport.fullSum(rd), roundDiscountCondition(ZReport.departmentStore(rd))) * 100;

fullSumByDay(DATE d) = GROUP SUM ZReport.fullSum(ZReport.ReceiptDetail rd) IF rd IS ZReport.ReceiptSaleDetail
    AND date(rd) = d AND filterForItemsWithDiscount(rd);
signedSumByDay(DATE d) = GROUP SUM ZReport.signedSum(ZReport.ReceiptDetail rd) IF rd IS ZReport.ReceiptSaleDetail
    AND date(rd) = d AND filterForItemsWithDiscount(rd);
discountSumByDay(DATE d) = GROUP SUM ZReport.discountSum(ZReport.ReceiptDetail rd) IF rd IS ZReport.ReceiptSaleDetail
    AND date(rd) = d AND filterForItemsWithDiscount(rd);
discountAvgPercentByDay(DATE d) = (GROUP SUM discountPercentCalc(ZReport.ReceiptDetail rd)
    IF rd IS ZReport.ReceiptSaleDetail AND date(rd) = d AND filterForItemsWithDiscount(rd)) /
    (GROUP SUM 1 IF date(ZReport.ReceiptDetail rd2) = d AND rd2 IS ZReport.ReceiptSaleDetail AND filterForItemsWithDiscount(rd2));

FORM itemsWithDiscountReportPrint 'Товары со скидками по кассам'
    PROPERTIES filterFrom = filterFrom(), filterTo = filterTo(),
        shiftFrom = filterShiftFrom(), shiftTo = filterShiftTo(),
        inSaleReportStocks = inSaleReportStocks(),
        inSaleReportCashRegisters = inSaleReportCashRegs(),
        inSaleReportCashiers = inReportCashiers()

    OBJECTS d = DATE
    PROPERTIES (d) fullSumByDay, discountSumByDay, discountAvgPercentByDay, signedSumByDay
    FILTERS iterateDays(d)

    OBJECTS rd = ZReport.ReceiptDetail
    PROPERTIES (rd) READONLY date, numberCashRegister, nameEmployee, numberReceipt, idBarcode, nameSku, ZReport.signedQuantity,
        price, ZReport.fullSum, ZReport.discountSum, discountPercentCalc, priceWithDiscount, ZReport.signedSum
    FILTERS ZReport.signedQuantity(rd) > 0 AND filterForItemsWithDiscount(rd) AND date(rd) = d
;

printItemsWithDiscountReport 'Печать' (DATE from, DATE to){
    filterFrom() <- from;
    filterTo() <- to;
    PRINT itemsWithDiscountReportPrint XLS TO printReportFile;
    buildPrintReportFileName('itemsWithDiscountReportPrint', 'Товары со скидками по кассам');
    open(printReportFile(), builtPrintReportFileName());
}

quantity(Item i, Stock s, DATE d) = GROUP SUM ZReport.signedQuantity(ZReport.ReceiptDetail rd) IF rd IS ZReport.ReceiptSaleDetail
    AND date(rd) = d AND filterForItemsWithDiscount(rd) AND sku(rd) = i AND ZReport.departmentStore(rd) = s ;

bruttoSum(Item i, Stock s, DATE d) = GROUP SUM ZReport.fullSum(ZReport.ReceiptDetail rd) IF rd IS ZReport.ReceiptSaleDetail
    AND date(rd) = d AND filterForItemsWithDiscount(rd) AND sku(rd) = i AND ZReport.departmentStore(rd) = s ;

discountSum(Item i, Stock s, DATE d) = GROUP SUM ZReport.discountSum(ZReport.ReceiptDetail rd)
    IF rd IS ZReport.ReceiptSaleDetail AND date(rd) = d AND filterForItemsWithDiscount(rd)
        AND sku(rd) = i AND ZReport.departmentStore(rd) = s ;

discountPercent(Item i, Stock s, DATE d) = round( (GROUP SUM discountPercentCalc(ZReport.ReceiptDetail rd)
    IF rd IS ZReport.ReceiptSaleDetail AND date(rd) = d AND filterForItemsWithDiscount(rd)
        AND sku(rd) = i AND ZReport.departmentStore(rd) = s) /
    (GROUP SUM 1 IF filterForItemsWithDiscount(ZReport.ReceiptDetail rd2) AND rd2 IS ZReport.ReceiptSaleDetail AND date(rd2) = d
        AND sku(rd2) = i AND ZReport.departmentStore(rd2) = s), roundDiscountCondition(s));

nettoSum(Item i, Stock s, DATE d) = GROUP SUM ZReport.signedSum(ZReport.ReceiptDetail rd) IF rd IS ZReport.ReceiptSaleDetail
    AND date(rd) = d AND filterForItemsWithDiscount(rd) AND sku(rd) = i AND ZReport.departmentStore(rd) = s ;

fullSumByDayAndStock(DATE d, Stock s) = GROUP SUM ZReport.fullSum(ZReport.ReceiptSaleDetail rd) IF rd IS ZReport.ReceiptSaleDetail
    AND date(rd) = d AND filterForItemsWithDiscount(rd) AND ZReport.departmentStore(rd) = s;

signedSumByDayAndStock(DATE d, Stock s) = GROUP SUM ZReport.signedSum(ZReport.ReceiptDetail rd)
    IF rd IS ZReport.ReceiptSaleDetail AND date(rd) = d AND filterForItemsWithDiscount(rd) AND ZReport.departmentStore(rd) = s;

discountSumByDayAndStock(DATE d, Stock s) = GROUP SUM ZReport.discountSum(ZReport.ReceiptDetail rd)
    IF rd IS ZReport.ReceiptSaleDetail AND date(rd) = d AND filterForItemsWithDiscount(rd) AND ZReport.departmentStore(rd) = s;

FORM itemsWithDiscountTotalReportPrint 'Товары со скидками (итого)'
    PROPERTIES filterFrom = filterFrom(), filterTo = filterTo(),
        shiftFrom = filterShiftFrom(), shiftTo = filterShiftTo(),
        inSaleReportStocks = inSaleReportStocks()

    OBJECTS d = DATE
    PROPERTIES date = VALUE (d)
    FILTERS filterByDates(d) AND iterateDays(d)

    OBJECTS s = Stock
    PROPERTIES (s) name
    FILTERS inSaleReport(s)

    OBJECTS i = Item
    PROPERTIES READONLY idBarcode(i), name(i), quantity(i, s, d), bruttoSum(i, s, d), discountSum(i, s, d),
        discountPercent(i, s, d), nettoSum(i, s, d),
        fullSumByDayAndStock(d, s), discountSumByDayAndStock(d, s), signedSumByDayAndStock(d, s)
    FILTERS quantity(i, s, d) > 0 ;

printItemsWithDiscountTotalReport 'Печать' (DATE from, DATE to){
    filterFrom() <- from;
    filterTo() <- to;
    PRINT itemsWithDiscountTotalReportPrint XLS TO printReportFile;
    buildPrintReportFileName('itemsWithDiscountTotalReportPrint', 'Товары со скидками (итого)');
    open(printReportFile(), builtPrintReportFileName());
}

filterByDiscountSum(ZReport.ReceiptDetail rd) = (NOT filterDiscountFrom() OR ZReport.discountSum(rd) >= filterDiscountFrom()) AND
    (NOT filterDiscountTo() OR ZReport.discountSum(rd) <= filterDiscountTo());

filterForReceiptsWithDiscount(ZReport.ReceiptDetail rd) = sku(rd) AND ZReport.discountSum(rd)
    AND filterByDiscountSum(rd)
    AND filterByShift(rd)
    AND filterByDates(date(rd))
    AND inSaleReport(ZReport.departmentStore(rd))
    AND ((NOT GROUP SUM 1 IF in(CashRegister cr)) OR in(ZReport.cashRegister(ZReport.receipt(rd))))
    AND filterBySku(rd);

barcodeQuantity(ZReport.ReceiptDetail rd) = ZReport.signedQuantity(rd) * amountBarcode(sku(rd));
barcodePrice(ZReport.ReceiptDetail rd) = price(rd) * amountBarcode(sku(rd));
barcodePriceWithDiscount(ZReport.ReceiptDetail rd) = priceWithDiscount(rd) * amountBarcode(sku(rd));

fullSumByDayReceiptDiscount(DATE d) = GROUP SUM ZReport.fullSum(ZReport.ReceiptDetail rd) IF rd IS ZReport.ReceiptSaleDetail
    AND date(rd) = d AND filterForReceiptsWithDiscount(rd);
signedSumByDayReceiptDiscount(DATE d) = GROUP SUM ZReport.signedSum(ZReport.ReceiptDetail rd) IF rd IS ZReport.ReceiptSaleDetail
    AND date(rd) = d AND filterForReceiptsWithDiscount(rd);
discountSumByDayReceiptDiscount(DATE d) = GROUP SUM ZReport.discountSum(ZReport.ReceiptDetail rd) IF rd IS ZReport.ReceiptSaleDetail
    AND date(rd) = d AND filterForReceiptsWithDiscount(rd);

FORM receiptsWithDiscountReportPrint 'Товары со скидками по чекам'
    PROPERTIES filterFrom = filterFrom(), filterTo = filterTo(),
        shiftFrom = filterShiftFrom(), shiftTo = filterShiftTo(),
        discountFrom = filterDiscountFrom(), discountTo = filterDiscountTo(),
        inSaleReportStocks = inSaleReportStocks(),
        inSaleReportCashRegisters = inSaleReportCashRegs(),
        inSaleReportSkus = inSkus()

    OBJECTS d = DATE
    PROPERTIES (d) fullSumByDayReceiptDiscount, discountSumByDayReceiptDiscount, signedSumByDayReceiptDiscount
    FILTERS iterateDays(d)

    OBJECTS rd = ZReport.ReceiptDetail
    PROPERTIES (rd) READONLY nameDepartmentStore, date, numberCashRegister, time, nameEmployee, numberReceipt, id, nameSku, idBarcode, barcodeQuantity,
        barcodePrice, ZReport.fullSum, ZReport.discountSum, discountPercentCalc, barcodePriceWithDiscount, ZReport.signedSum
    FILTERS ZReport.signedQuantity(rd) > 0 AND filterForReceiptsWithDiscount(rd) AND date(rd) = d
;

printReceiptsWithDiscountReport 'Печать' (DATE from, DATE to){
    filterFrom() <- from;
    filterTo() <- to;
    PRINT receiptsWithDiscountReportPrint XLS TO printReportFile;
    buildPrintReportFileName('receiptsWithDiscountReportPrint', 'Товары со скидками по чекам');
    open(printReportFile(), builtPrintReportFileName());
}

FORM statisticalReports
    OBJECTS dateFromObj = DATE PANEL
    PROPERTIES dateFromIntervals 'Дата (с)' = VALUE(dateFromObj),
        dateFromCashReg 'Дата (с)' = VALUE(dateFromObj),
        dateFromPerformance 'Дата (с)' = VALUE(dateFromObj),
        dateFromDiscount 'Дата (с)' = VALUE(dateFromObj),
        dateFromReceiptDiscount 'Дата (с)' = VALUE(dateFromObj)

    OBJECTS dateToObj = DATE PANEL
    PROPERTIES dateToIntervals 'Дата (по)' = VALUE(dateToObj),
        dateToCashReg 'Дата (по)' = VALUE(dateToObj),
        dateToPerformance 'Дата (по)' = VALUE(dateToObj),
        dateToDiscount 'Дата (по)' = VALUE(dateToObj),
        dateToReceiptDiscount 'Дата (по)' = VALUE(dateToObj)

    PROPERTIES inReportStocksIntervals 'Подразделения' = inSaleReportStocks() ON CHANGE changeStocksInventory() READONLYIF stockList(),
        inReportStocksCashRegs 'Подразделения' = inSaleReportStocks() ON CHANGE changeStocksInventory() READONLYIF stockList(),
        inReportStocksPerformance 'Подразделения' = inSaleReportStocks() ON CHANGE changeStocksInventory() READONLYIF stockList(),
        inReportStocksDiscount 'Подразделения' = inSaleReportStocks() ON CHANGE changeStocksInventory() READONLYIF stockList(),
        inReportStocksReceiptDiscount 'Подразделения' = inSaleReportStocks() ON CHANGE changeStocksInventory() READONLYIF stockList()


    PROPERTIES inReportCashRegs 'Кассы' = inSaleReportCashRegs() ON CHANGE selectCashRegisters(),
        inReportCashRegsPerformance 'Кассы' = inSaleReportCashRegs() ON CHANGE selectCashRegisters(),
        inReportCashRegsDiscount 'Кассы' = inSaleReportCashRegs() ON CHANGE selectCashRegisters(),
        inReportCashRegsReceiptDiscount 'Кассы' = inSaleReportCashRegs() ON CHANGE selectCashRegisters()

    PROPERTIES intervalInHoursInput(), filterShiftFromIntervals(), filterShiftToIntervals(),
        printSaleReportIntervals(dateFromObj, dateToObj),
        inReportCashiers() ON CHANGE selectCashiers(),
        inReportCashiersDiscount 'Кассиры' = inReportCashiers() ON CHANGE selectCashiers()

    PROPERTIES nameSkuLists() READONLY SHOWIF anySkuList()
    PROPERTIES nameSkuLists2 = nameSkuLists() READONLY SHOWIF anySkuList()
    PROPERTIES inSelectedSkuGroups 'Товарные группы' = selectedSkuGroups() READONLY SHOWIF anySkuGroup()
    PROPERTIES inSelectedSkuGroups2 'Товарные группы' = selectedSkuGroups() READONLY SHOWIF anySkuGroup()
    PROPERTIES inSkus 'Товары' = inSkus() ON CHANGE selectSkus() READONLYIF anySkuList() OR anySkuGroup()
       PROPERTIES inSaleReportSkusReceiptDiscount 'Товары' = inSkus() ON CHANGE selectSkus() READONLYIF anySkuList() OR anySkuGroup()

    PROPERTIES filterQuantityTypeName(), filterQuantity(),
        filterShiftFrom(), filterShiftTo(),
        filterShiftFromReceiptDiscount(), filterShiftToReceiptDiscount(),
        filterDiscountFrom(), filterDiscountTo(),

        printSaleByCashRegsReport(dateFromObj, dateToObj),
        printCashierPerformanceReport(dateFromObj, dateToObj),
        printCashierPerformanceTotalReport(dateFromObj, dateToObj),
        printItemsWithDiscountReport(dateFromObj, dateToObj),
        printItemsWithDiscountTotalReport(dateFromObj, dateToObj),
        printReceiptsWithDiscountReport(dateFromObj, dateToObj)
;

DESIGN statisticalReports{
    REMOVE TOOLBARBOX ;
    caption = 'Статистические отчеты';
    NEW main{
        NEW saleReportIntervals{
            caption = 'Продажи по временным интервалам';
            NEW datesIntervals{
                horizontal = TRUE ;
                MOVE PROPERTY (dateFromIntervals);
                MOVE PROPERTY (dateToIntervals);
            }
            MOVE PROPERTY (inReportStocksIntervals);
            MOVE PROPERTY (intervalInHoursInput());
            MOVE PROPERTY (filterShiftFromIntervals());
            MOVE PROPERTY (filterShiftToIntervals());
            MOVE PROPERTY (printSaleReportIntervals(dateFromObj, dateToObj));
        }
        NEW saleReportByCashRegs {
            caption = 'Статистика продажи товара на кассах';
            NEW cashFilters{
                NEW dates{
                    horizontal = TRUE ;
                    MOVE PROPERTY (dateFromCashReg);
                    MOVE PROPERTY (dateToCashReg);
                }
                NEW skuStock{
                    MOVE PROPERTY (inReportStocksCashRegs);
                    MOVE PROPERTY (inReportCashRegs);
                    //MOVE PROPERTY (inSaleReportSkus());
                    MOVE PROPERTY(nameSkuLists()) { alignment = STRETCH; }
                    MOVE PROPERTY(inSelectedSkuGroups) { alignment = STRETCH; }
                    MOVE PROPERTY(inSkus) { alignment = STRETCH; }
                }
                NEW quantity{
                    caption = 'По количеству';
                    MOVE PROPERTY (filterQuantityTypeName());
                    MOVE PROPERTY (filterQuantity());
                }
            }
            MOVE PROPERTY (printSaleByCashRegsReport(dateFromObj, dateToObj)) LAST ;
        }

        NEW saleReportByCashSpeed {
            caption = 'Скорость работы кассира';
            NEW cashSpeedFilters{
                horizontal = TRUE ;
                MOVE PROPERTY (dateFromPerformance);
                MOVE PROPERTY (dateToPerformance);
            }
            MOVE PROPERTY (inReportStocksPerformance);
            MOVE PROPERTY (inReportCashRegsPerformance);
            MOVE PROPERTY (inReportCashiers());
            NEW buttons{
                horizontal = TRUE ;
                MOVE PROPERTY (printCashierPerformanceReport(dateFromObj, dateToObj)) LAST {caption = 'Печать (подробно)';}
                MOVE PROPERTY (printCashierPerformanceTotalReport(dateFromObj, dateToObj)) LAST {caption = 'Печать (итоги)';}
            }
        }

        NEW saleReportItemsWithDiscount {
            caption = 'Товары со скидками по кассам';
            NEW cashDiscountFilters{
                horizontal = TRUE ;
                MOVE PROPERTY (dateFromDiscount);
                MOVE PROPERTY (dateToDiscount);
                MOVE PROPERTY (filterShiftFrom());
                MOVE PROPERTY (filterShiftTo());
            }
            MOVE PROPERTY (inReportStocksDiscount);
            MOVE PROPERTY (inReportCashRegsDiscount);
            MOVE PROPERTY (inReportCashiersDiscount);

            NEW buttonsDiscount{
                horizontal = TRUE ;
                MOVE PROPERTY (printItemsWithDiscountReport(dateFromObj, dateToObj)) LAST {caption = 'Печать (по кассирам)';}
                MOVE PROPERTY (printItemsWithDiscountTotalReport(dateFromObj, dateToObj)) LAST {caption = 'Печать (итого)';}
            }
        }
        NEW saleReportReceiptWithDiscount {
            caption = 'Товары со скидками по чекам';
            NEW receiptDiscountFilters{
                horizontal = TRUE ;
                MOVE PROPERTY (dateFromReceiptDiscount);
                MOVE PROPERTY (dateToReceiptDiscount);
                MOVE PROPERTY (filterShiftFromReceiptDiscount());
                MOVE PROPERTY (filterShiftToReceiptDiscount()){ caption = 'до'; }
            }
            NEW discountSumFilters{
                horizontal = TRUE ;
                MOVE PROPERTY (filterDiscountFrom());
                MOVE PROPERTY (filterDiscountTo()){caption = 'до';};
            }
            MOVE PROPERTY (inReportStocksReceiptDiscount);
            MOVE PROPERTY (inReportCashRegsReceiptDiscount);
            MOVE PROPERTY(nameSkuLists2) { alignment = STRETCH; }
            MOVE PROPERTY(inSelectedSkuGroups2) { alignment = STRETCH; }
            MOVE PROPERTY (inSaleReportSkusReceiptDiscount);

            MOVE PROPERTY (printReceiptsWithDiscountReport(dateFromObj, dateToObj)) LAST {caption = 'Печать';}
        }
    }
}

dataSkip 'Аннулирован'(ZReport.ReceiptDetail d) = ZReport.dataSkip(ZReport.receipt(d));

EXTEND FORM receiptDetailReport
    PROPERTIES (rd) dataSkip
;

FORM canceledSalesByCashRegsReportPrint 'Аннулированные продажи'
    PROPERTIES filterFrom = filterFrom(), filterTo = filterTo(),
        inSaleReportStocks = inSaleReportStocks(), inSaleReportCashRegs(), inSkus()

    OBJECTS rd = ZReport.ReceiptDetail
    PROPERTIES (rd) READONLY date, time, idBarcode, idSku, nameSku, numberCashRegister, nameEmployee, numberReceipt, ZReport.signedQuantity, price, ZReport.signedSum
    FILTERS filterByDates(ZReport.receipt(rd)) AND filterByQuantity(rd)
        AND inSaleReport(ZReport.departmentStore(rd)) AND filterBySku(rd) AND dataSkip(rd)
    ORDERS date(rd), time(rd)
;

printCanceledSalesByCashRegsReportPrint 'Аннулированные продажи' (DATE from, DATE to){
    filterFrom() <- from;
    filterTo() <- to;
    PRINT canceledSalesByCashRegsReportPrint XLS TO printReportFile;
    buildPrintReportFileName('canceledSalesByCashRegsReportPrint', 'Аннулированные продажи');
    open(printReportFile(), builtPrintReportFileName());
}

filterForPerformanceReportSkip(ZReport.Receipt r) = filterByDates(r) AND inSaleReport(ZReport.departmentStore(r))
    AND ((NOT GROUP SUM 1 IF in(CashRegister cr)) OR in(ZReport.cashRegister(r)))
    AND ((NOT GROUP SUM 1 IF in(Employee e)) OR in(ZReport.employee(r))) AND ZReport.dataSkip(r);

countReceiptSubtotalByCashier(Employee e, DepartmentStore ds) = GROUP SUM 1 IF filterForPerformanceReport(ZReport.Receipt r) AND ZReport.employee(r) = e AND ZReport.departmentStore(r) = ds;
countReceiptDetailSubtotalByCashier(Employee e, DepartmentStore ds) = GROUP SUM ZReport.countReceiptDetail(ZReport.Receipt r) IF filterForPerformanceReport(r) AND ZReport.employee(r) = e AND ZReport.departmentStore(r) = ds;
countReceiptSubtotalByCashierSkip(Employee e, DepartmentStore ds) = GROUP SUM 1 IF filterForPerformanceReportSkip(ZReport.Receipt r) AND ZReport.employee(r) = e AND ZReport.departmentStore(r) = ds;
countQuantityReceiptDetailSubtotalByCashierSkip(Employee e, DepartmentStore ds) = GROUP SUM ZReport.quantityReceiptDetail(ZReport.Receipt r) IF filterForPerformanceReportSkip(r) AND ZReport.employee(r) = e AND ZReport.departmentStore(r) = ds;
sumReceiptDetailSubtotalByCashierSkip(Employee e, DepartmentStore ds) = GROUP SUM ZReport.sumReceiptDetail(ZReport.Receipt r) IF filterForPerformanceReportSkip(r) AND ZReport.employee(r) = e AND ZReport.departmentStore(r) = ds;

FORM cashierCanceledSalesReportPrint 'Аннулированные продажи (по кассирам)'
    PROPERTIES filterFrom = filterFrom(), filterTo = filterTo(),
        inSaleReportStocks = inSaleReportStocks(), inSaleReportCashRegs(), inSkus()

    OBJECTS ds = DepartmentStore
    PROPERTIES (ds) name

    OBJECTS e = Employee
    PROPERTIES shortName(e)
    PROPERTIES (e, ds) countReceiptSubtotalByCashier, countReceiptDetailSubtotalByCashier, countReceiptSubtotalByCashierSkip,
        countQuantityReceiptDetailSubtotalByCashierSkip, sumReceiptDetailSubtotalByCashierSkip
    FILTERS countReceiptSubtotalByCashierSkip(e, ds)
;

printCashierCanceledSalesReportPrint 'Аннулированные продажи (по кассирам)' (DATE from, DATE to){
    filterFrom() <- from;
    filterTo() <- to;
    PRINT cashierCanceledSalesReportPrint XLS TO printReportFile;
    buildPrintReportFileName('cashierCanceledSalesReportPrint', 'Аннулированные продажи (по кассирам)');
    open(printReportFile(), builtPrintReportFileName());
}

FORM canceledSalesByCashRegsTotalReportPrint 'Аннулированные продажи (ИТОГИ)'
    PROPERTIES filterFrom = filterFrom(), filterTo = filterTo(),
        inSaleReportStocks = inSaleReportStocks(), inSaleReportCashRegs(), inSkus()

    OBJECTS ds = DepartmentStore
    PROPERTIES (ds) name

    OBJECTS rd = ZReport.ReceiptDetail
    PROPERTIES (rd) READONLY date, ZReport.signedQuantity, ZReport.signedSum
    FILTERS filterByDates(ZReport.receipt(rd)) AND filterByQuantity(rd)
        AND inSaleReport(ZReport.departmentStore(rd)) AND filterBySku(rd) AND dataSkip(rd) AND ZReport.departmentStore(rd) == ds
    ORDERS date(rd)
;

printCanceledSalesByCashRegsTotalReportPrint 'Аннулированные продажи (ИТОГИ)' (DATE from, DATE to){
    filterFrom() <- from;
    filterTo() <- to;
    PRINT canceledSalesByCashRegsTotalReportPrint XLS TO printReportFile;
    buildPrintReportFileName('canceledSalesByCashRegsTotalReportPrint', 'Аннулированные продажи (ИТОГИ)');
    open(printReportFile(), builtPrintReportFileName());
}

skuInReport 'Отм.' = DATA LOCAL BOOLEAN (List);

FORM canceledSales

    OBJECTS dateFromObj = DATE PANEL
    PROPERTIES dateFromCashReg 'Дата (с)' = VALUE(dateFromObj)

    OBJECTS dateToObj = DATE PANEL
    PROPERTIES dateToCashReg 'Дата (по)' = VALUE(dateToObj)

    PROPERTIES inReportStocksCashRegs 'Склады' = inReportStocks() ON CHANGE selectStocksForReport()

    PROPERTIES inReportCashRegs 'Кассы' = inSaleReportCashRegs() ON CHANGE selectCashRegisters()

    PROPERTIES inSkus() ON CHANGE askSkuFilterType()

    PROPERTIES
    filterQuantityTypeName(), filterQuantity(),
        printCanceledSalesByCashRegsReportPrint(dateFromObj, dateToObj),
        printCashierCanceledSalesReportPrint(dateFromObj, dateToObj),
        printCanceledSalesByCashRegsTotalReportPrint(dateFromObj, dateToObj)
;

DESIGN canceledSales{
    REMOVE TOOLBARBOX ;
    caption = 'Аннулированные продажи';
    NEW main{

        NEW canceledSalesByCashRegsReportPrint {
            caption = 'Аннулированные продажи';
            NEW cashFilters{
                NEW dates{
                    horizontal = TRUE ;
                    MOVE PROPERTY (dateFromCashReg);
                    MOVE PROPERTY (dateToCashReg);
                }
                NEW skuStock{
                    MOVE PROPERTY (inReportStocksCashRegs);
                    MOVE PROPERTY (inReportCashRegs);
                    MOVE PROPERTY (inSkus());
                }
                NEW quantity{
                    caption = 'По количеству';
                    MOVE PROPERTY (filterQuantityTypeName());
                    MOVE PROPERTY (filterQuantity());
                }
            }
            MOVE PROPERTY (printCanceledSalesByCashRegsReportPrint(dateFromObj, dateToObj)) LAST ;
            MOVE PROPERTY (printCashierCanceledSalesReportPrint(dateFromObj, dateToObj)) LAST ;
            MOVE PROPERTY (printCanceledSalesByCashRegsTotalReportPrint(dateFromObj, dateToObj)) LAST ;
        }
    }
}

NAVIGATOR {
    salesReports {
        NEW statisticalReports;
        NEW canceledSales;
    }
}

CLASS SalesAndStocksMode 'Тип отбора продаж' {
    retail 'Розница',
    all 'Опт + розница'
}
name 'Тип отбора продаж' (SalesAndStocksMode o) = staticCaption(o) IF o IS SalesAndStocksMode CHARWIDTH 15;

salesAndStocksMode 'Тип отбора продаж' = DATA LOCAL SalesAndStocksMode();
salesAndStocksModeOrDefault = OVERRIDE salesAndStocksMode(), SalesAndStocksMode.all;
nameSalesAndStocksMode 'Тип отбора продаж' = name(salesAndStocksModeOrDefault());

isSalesAndStocksRetailMode () = salesAndStocksModeOrDefault() = SalesAndStocksMode.retail;

initSalesAndStocksReports () {
    filterFrom() <- currentDate();
    filterTo() <- currentDate();
    datePriceSupplier() <- currentDate();
    salesAndStocksMode() <- SalesAndStocksMode.all;
}

passesSalesAndStocksModeFilter (SaleLedger l) = IF isSalesAndStocksRetailMode() THEN isRetailLedger(l) ELSE active(l);

passesSalesAndStocksAll (SaleLedger l) =
    active(l)
    AND inSalesReportInterval(l)
    AND passesReportStockFilter(l)
    AND passesReportSupplierFilter(l)
    AND passesReportSkuFilter(l)
    AND passesSalesAndStocksModeFilter(l)
    AND NOT skipSaleReport(sku(l), stock(l));

sasQty 'Количество продаж' (Sku s, Stock st) =
    GROUP SUM quantity(SaleLedger l) IF sku(l) = s AND stock(l) = st AND passesSalesAndStocksAll(l);

sasFullSum 'Сумма продаж по отпускной' (Sku s, Stock st) =
    GROUP SUM (price(SaleLedger l) * quantity(l)) IF sku(l) = s AND stock(l) = st AND passesSalesAndStocksAll(l);

sasAccountSum 'Сумма продаж по учётной' (Sku s, Stock st) =
    GROUP SUM (priceSku(sku(SaleLedger l), stock(l), date(l)) * quantity(l))
        IF sku(l) = s AND stock(l) = st AND passesSalesAndStocksAll(l);

sasGross 'Валовый доход' (Sku s, Stock st) = sasAccountSum(s, st) (-) sasFullSum(s, st);

sasMarkup 'Маржа, %' (Sku s, Stock st) = sasGross(s, st) * 100 / sasAccountSum(s, st);

sasBalanceB 'Остаток' (Sku s, Stock st) = balanceB(s, st, datePriceSupplier());

sasBalanceSumSku 'Сумма остатка в учётных ценах' (Sku s, Stock st) =
    sasBalanceB(s, st) * priceSku(s, st, datePriceSupplier());

sasLastSaleLedger = GROUP LAST SaleLedger ledger
    ORDER date(ledger), ledger
    WHERE date(ledger) <= DATE date AND active(ledger)
    BY sku(ledger), stock(ledger), date;

sasLastSaleDate 'Дата последней продажи' (Sku s, Stock st) = date(sasLastSaleLedger(s, st, filterTo()));

sasLastPurchaseLedger = GROUP LAST PurchaseLedger ledger
    ORDER date(ledger), ledger
    WHERE date(ledger) <= DATE date
    BY sku(ledger), stock(ledger), date;

sasLastPurchaseDate 'Дата последнего прихода' (Sku s, Stock st) = date(sasLastPurchaseLedger(s, st, filterTo()));

sasOrderQty 'Количество заказа' (Sku s, Stock st) =
    GROUP SUM quantity(Purchase.OrderDetail d)
        IF date(d) >= filterFrom() AND date(d) <= filterTo()
            AND sku(d) = s AND customerStock(d) = st;

sasDaysInPeriod () = daysBetweenDates(filterFrom(), filterTo()) + 1;

sasTurnoverDaysSku 'Оборачиваемость (дни)' (Sku s, Stock st) =
    NUMERIC[30,2](sasBalanceB(s, st) * sasDaysInPeriod() / sasQty(s, st));

sasShowRow (Sku s, Stock st) = sasQty(s, st) > 0;

FORM salesAndStocksReports 'Продажи и остатки'
    PROPERTIES() filterFrom, filterTo
    PROPERTIES() nameSalesAndStocksMode
    PROPERTIES() datePriceSupplier
    PROPERTIES nameStockList() READONLY SHOWIF stockList()
    PROPERTIES inSalesAndStocksReportStocks 'Подразделения' = inSaleReportStocks() ON CHANGE changeStocksInventory() READONLYIF stockList()
    PROPERTIES nameLegalEntityList() READONLY SHOWIF legalEntityList()
    PROPERTIES inSalesAndStocksReportSuppliers 'Поставщики' = inSaleReportSupplier() ON CHANGE { DIALOG dialogLegalEntitiesSupplier; } READONLYIF legalEntityList()
    PROPERTIES nameSkuLists() READONLY SHOWIF anySkuList()
    PROPERTIES salesAndStocksSelectedSkuGroups 'Товарные группы' = selectedSkuGroups() READONLY SHOWIF anySkuGroup()
    PROPERTIES salesAndStocksSkus 'Товары' = inSkus() ON CHANGE selectSkus() READONLYIF anySkuList() OR anySkuGroup()

    OBJECTS (st = Stock, s = Sku)
    PROPERTIES READONLY stockColumn 'Подразделение' = CONCAT ' - ', id(st), name(st)
    PROPERTIES(s) READONLY idSkuGroup2, nameSkuGroup2, idSkuGroup3, nameSkuGroup3, idSkuGroup4, nameSkuGroup4
    PROPERTIES(s) READONLY idSupplierSku, nameSupplierSku
    PROPERTIES READONLY skuCode 'Код товара' = id(s)
    PROPERTIES READONLY skuName 'Наименование товара' = name(s)
    PROPERTIES(s) READONLY shortNameUOM, idBarcode
    PROPERTIES (s, st) READONLY sasBalanceB, sasBalanceSumSku
    PROPERTIES READONLY colAccountPrice 'Учётная цена' = priceSku(s, st, datePriceSupplier())
    PROPERTIES READONLY colRetailPrice 'Отп.цена на дату расчета остатков' = prevPriceB(retailPriceListType(st), s, st, DATETIME(datePriceSupplier()))
    PROPERTIES (s, st) READONLY sasQty, sasFullSum, sasAccountSum, sasGross, sasMarkup,
        sasTurnoverDaysSku, sasOrderQty, sasLastSaleDate, sasLastPurchaseDate

    ORDERS stockColumn, skuName
    FILTERS passesReportStockFilterStock(st),
        passesReportSkuFilterSku(s),
        passesReportSupplierFilterSku(s),
        sasShowRow(s, st),
        NOT skipSaleReport(s, st)

    EVENTS ON INIT initSalesAndStocksReports()
;

@definePrintReport(salesAndStocksReports, 'Продажи и остатки');

EXTEND FORM salesAndStocksReports
    PROPERTIES() DISABLEIF NOT filterFrom() OR NOT filterTo() salesAndStocksReports
;

DESIGN salesAndStocksReports {
    NEW filters FIRST {
        alignment = STRETCH;
        NEW topRow {
            horizontal = TRUE;
            MOVE PROPERTY(filterFrom());
            MOVE PROPERTY(filterTo());
            MOVE PROPERTY(nameSalesAndStocksMode()) { valueClass = 'btn-info'; charWidth = 22; }
            MOVE PROPERTY(datePriceSupplier());
            MOVE PROPERTY(salesAndStocksReports()) { valueClass = 'btn-primary'; }
        }
        MOVE PROPERTY(nameStockList()) { alignment = STRETCH; }
        MOVE PROPERTY(inSalesAndStocksReportStocks) { alignment = STRETCH; }
        MOVE PROPERTY(nameLegalEntityList()) { alignment = STRETCH; }
        MOVE PROPERTY(inSalesAndStocksReportSuppliers) { alignment = STRETCH; }
        MOVE PROPERTY(nameSkuLists()) { alignment = STRETCH; }
        MOVE PROPERTY(salesAndStocksSelectedSkuGroups) { alignment = STRETCH; }
        MOVE PROPERTY(salesAndStocksSkus) { alignment = STRETCH; }
    }
}

NAVIGATOR {
    saleNavigator {
        salesReports {
            NEW salesAndStocksReports;
        }
    }
}

DESIGN salesReport {
    salesContainer {
        supplierSalesReportContainer {
            showIf = NULL;
        }
    }
}