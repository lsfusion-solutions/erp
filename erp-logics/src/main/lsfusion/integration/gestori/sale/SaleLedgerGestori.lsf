MODULE SaleLedgerGestori;

REQUIRE InventoryGestori, PriceListContract;

NAMESPACE Sale;

CLASS ProductCriteria 'Критерий отбора товара' {
    quantity 'количество',
    amount 'суммы',
    profit 'валовый доход',
    stock 'запасы',
    stockAmount 'сумма запаса',
    stockDays 'запас в днях'
}
name 'Критерий отбора товара' (ProductCriteria o) = staticCaption(o) IF o IS ProductCriteria CHARWIDTH 10;

CLASS SalesFilterType 'Тип отбора продаж' {
    retail 'Розница',
    wholesale 'Продажа по документам (опт)',
    both 'Розница + опт'
}
name 'Тип отбора продаж' (SalesFilterType o) = staticCaption(o) IF o IS SalesFilterType CHARWIDTH 10;

FORM salesFilterTypes 'Тип отбора продаж'
    OBJECTS o = SalesFilterType
    PROPERTIES(o) READONLY staticCaption
    LIST SalesFilterType OBJECT o
;

criteria = DATA LOCAL ProductCriteria ();
criteriaDefault = OVERRIDE criteria(), ProductCriteria.quantity;
nameCriteria 'Критерий отбора товара' = name(criteriaDefault());

salesType = DATA LOCAL SalesFilterType ();
salesTypeDefault = OVERRIDE salesType(), SalesFilterType.both;
nameSalesType 'Тип отбора продаж' = name(salesTypeDefault()) NOSELECT;

productsLimit = DATA LOCAL INTEGER ();
productsLimitDefault 'Количество отобранных товаров' = OVERRIDE productsLimit(), 50;
withAssortment 'С учетом ассортмента' = DATA LOCAL BOOLEAN ();

CLASS SkuFilterType 'Тип фильтра по товарам' {
    sku 'Товары',
    skuGroups 'Товарные группы',
    skuLists 'Списки товаров'
}

FORM skuFilterType 'Типы фильтра по товарам'
    OBJECTS t = SkuFilterType
    PROPERTIES(t) READONLY '' = staticCaption
    LIST SkuFilterType OBJECT t
;

fInSku 'Отм.' = DATA LOCAL BOOLEAN (Sku);
fInSkuList 'Отм.' = DATA LOCAL BOOLEAN (List);
fInSkuGroup 'Отм.' = DATA LOCAL BOOLEAN (SkuGroup);

fAnySkuList() = GROUP MAX fInSkuList(List l);
fAnySkuGroup() = GROUP MAX fInSkuGroup(SkuGroup g);
fAnySku() = GROUP MAX fInSku(Sku s);
fAnySkuSelected() = fAnySku() OR fAnySkuGroup();

fNameSkuLists 'Списки товаров' () = GROUP CONCAT name(List l) IF fInSkuList(l), ', ' ORDER name(l), l CHARWIDTH 30;
fNameSkuGroups 'Товарные группы' () = GROUP CONCAT name(SkuGroup o) IF fInSkuGroup(o) AND NOT fInSkuGroup(parent(o)), '; ' ORDER o CHARWIDTH 30;

fInSkuByGroup(Sku s) = GROUP MAX fInSkuGroup(SkuGroup g) IF isParent(g, s);

fSelectedSkuNames = GROUP CONCAT name(Sku s) IF fInSku(s), '; ' ORDER name(s), s;
fSkuNamesFromGroups = GROUP CONCAT name(Sku s) IF fInSkuByGroup(s) AND name(s), '; ' ORDER name(s), s;
fInSkus 'Товары' = OVERRIDE fSelectedSkuNames(), fSkuNamesFromGroups();

fDeleteSkuLists 'Сбросить список'() {
    fInSkuList(List l) <- NULL;
    fInSku(Sku s) <- NULL;
} ASON CONTEXTMENU fNameSkuLists;

fDeleteSkuGroups 'Сбросить группы'() {
    fInSkuGroup(SkuGroup g) <- NULL;
} ASON CONTEXTMENU fNameSkuGroups;

FORM fSelectSku 'Выбор товаров'
    TREE skuTree sg = SkuGroup PARENT parent(sg)
    PROPERTIES READONLY order(sg), skuGroupName = name(sg)
    FILTERGROUP inactive FILTER 'Активные' active(sg) 'F6' DEFAULT
    ORDERS order(sg), skuGroupName

    OBJECTS s = Sku
    PROPERTIES(s) fIn = fInSku
    PROPERTIES(s) READONLY id SHOWIF showIDs()
    PROPERTIES(s) READONLY name, idBarcode, shortNameUOM
    FILTERS isParent(sg, s), name(s)
    ORDERS name(s)
;

FORM fDialogSkuGroups 'Выбор товарных групп'
    TREE skuGroupTree sg = SkuGroup PARENT parent(sg)
    PROPERTIES(sg) fInSkuGroup
    PROPERTIES READONLY order(sg), sgName = name(sg)
    FILTERGROUP inactive FILTER 'Активные' active(sg) 'F6' DEFAULT
    ORDERS order(sg), sgName
;

FORM fDialogSkuLists 'Выбор списков товаров'
    OBJECTS o = List
    PROPERTIES(o) fInSkuList
    PROPERTIES(o) READONLY name
    ORDERS name(o)
;

fSelectSkus 'Фильтр по товарам' () {
    DIALOG skuFilterType OBJECTS t INPUT DO {
        CASE
            WHEN t = SkuFilterType.sku THEN {
                fInSkuList(List l) <- NULL;
                fInSkuGroup(SkuGroup g) <- NULL;
                SHOW fSelectSku;
            }
            WHEN t = SkuFilterType.skuGroups THEN {
                fInSkuList(List l) <- NULL;
                fInSku(Sku s) <- NULL;
                SHOW fDialogSkuGroups;
            }
            WHEN t = SkuFilterType.skuLists THEN {
                fInSkuGroup(SkuGroup g) <- NULL;
                DIALOG fDialogSkuLists DO {
                    fInSku(Sku s) <- NULL;
                    FOR fInSkuList(list(ListDetail ld)) AND Sku s = sku(ld) DO
                        fInSku(s) <- TRUE;
                }
            };
    }
}

fSkuFilter(Sku s) = NOT fAnySkuSelected() OR fInSku(s) OR fInSkuByGroup(s);

fInSupplier 'Отм.' = DATA LOCAL BOOLEAN (LegalEntity);
fAnySupplier() = GROUP MAX fInSupplier(LegalEntity l);
fNameSuppliers 'Поставщики' () = OVERRIDE
    (GROUP CONCAT name(LegalEntity l) IF fInSupplier(l), ', ' ORDER name(l), l),
    'Все поставщики' CHARWIDTH 30;

fSupplierList = DATA LOCAL LegalEntityList();
fNameSupplierList 'Список поставщиков' () = name(fSupplierList());

fChangeSupplierList 'Список поставщиков'() {
    DIALOG legalEntityLists OBJECTS o INPUT DO {
        fSupplierList() <- o;
        fInSupplier(LegalEntity s) <- NULL;
        fInSupplier(LegalEntity s) <- TRUE WHERE in(s, o) AND isSupplier(s);
    }
}

fDeleteSupplierList 'Сбросить список'() {
    fSupplierList() <- NULL;
    fInSupplier(LegalEntity l) <- NULL;
} ASON CONTEXTMENU fNameSupplierList;

selectAllFSuppliers 'Выбрать всех' () {
    fSupplierList() <- NULL;
    fInSupplier(LegalEntity l) <- TRUE WHERE isSupplier(l) AND active(l);
} ASON CONTEXTMENU fNameSuppliers;

deselectAllFSuppliers 'Сбросить всех' () {
    fSupplierList() <- NULL;
    fInSupplier(LegalEntity l) <- NULL;
} ASON CONTEXTMENU fNameSuppliers;

FORM fDialogSuppliers 'Выбор поставщиков'
    TREE legalEntityGroupTree lg = LegalEntityGroup PARENT parent(lg)
    PROPERTIES READONLY lgTreeName = name(lg)

    OBJECTS o = LegalEntity
    PROPERTIES(o) fInSupplier READONLYIF fSupplierList()
    PROPERTIES(o) READONLY name, id SHOWIF showIDs(), fullName, shortNameOwnership,
        nameLegalEntityGroup, address, phone
    PROPERTIES fChangeSupplierList() TOOLBAR
    ORDERS name(o)
    FILTERGROUP inactiveSupplier FILTER 'Активные' active(o) 'shift F10' DEFAULT
    FILTERGROUP selectedSupplier FILTER 'Отмеченные' fInSupplier(o) 'F9'
    FILTERS isSupplier(o)
    FILTERS isParent(legalEntityGroup(o), lg) OR
        o IS LegalEntity AND NOT lg IS LegalEntityGroup OR
        o IS LegalEntity AND lg IS LegalEntityGroup AND NOT legalEntityGroup(o)
;

DESIGN fDialogSuppliers {
    BOX {
        NEW topContainer {
            horizontal = TRUE;
            fill = 1;
            MOVE BOX(TREE legalEntityGroupTree) {
                caption = 'Группы организаций';
            }
            MOVE BOX(o) {
                fill = 3;
                GRID(o) {
                    defaultComponent = TRUE;
                }
            }
        }
        MOVE TOOLBARBOX;
    }
}

inCustomer 'Отм.' = DATA LOCAL BOOLEAN (LegalEntity);
anyCustomer() = GROUP MAX inCustomer(LegalEntity l);
nameCustomers 'Покупатели' () = OVERRIDE
    (GROUP CONCAT name(LegalEntity l) IF inCustomer(l), ', ' ORDER name(l), l),
    'Все покупатели' CHARWIDTH 30;

inLegalEntityGroup 'Отм.' = DATA LOCAL BOOLEAN (LegalEntityGroup);

customerList = DATA LOCAL LegalEntityList();
nameCustomerList 'Список покупателей' () = name(customerList());

changeCustomerList 'Список покупателей'() {
    DIALOG legalEntityLists OBJECTS o INPUT DO {
        customerList() <- o;
        inCustomer(LegalEntity s) <- NULL;
        inCustomer(LegalEntity s) <- TRUE WHERE in(s, o) AND isCustomer(s);
        inLegalEntityGroup(LegalEntityGroup lg) <- NULL;
    }
}

deleteIncludeCustomerList 'Сбросить список'() {
    customerList() <- NULL;
    inCustomer(LegalEntity l) <- NULL;
    inLegalEntityGroup(LegalEntityGroup lg) <- NULL;
} ASON CONTEXTMENU nameCustomerList;

changeLegalEntityGroup(LegalEntityGroup lg) {
    inLegalEntityGroup(lg) <- NOT inLegalEntityGroup(lg);
    IF inLegalEntityGroup(lg) THEN
        inCustomer(LegalEntity o) <- TRUE WHERE isParent(legalEntityGroup(o), lg) AND isCustomer(o) AND active(o);
    ELSE
        inCustomer(LegalEntity o) <- NULL WHERE isParent(legalEntityGroup(o), lg);
}

FORM dialogCustomers 'Выбор покупателей'
    TREE legalEntityGroupTree lg = LegalEntityGroup PARENT parent(lg)
    PROPERTIES(lg) inLegalEntityGroup ON CHANGE changeLegalEntityGroup(lg) READONLYIF customerList()
    PROPERTIES READONLY lgTreeName = name(lg)

    OBJECTS o = LegalEntity
    PROPERTIES(o) inCustomer READONLYIF customerList()
    PROPERTIES(o) READONLY name, id SHOWIF showIDs(), fullName, shortNameOwnership,
        nameLegalEntityGroup, address, phone
    PROPERTIES changeCustomerList() TOOLBAR
    ORDERS name(o)
    FILTERGROUP inactiveCustomer FILTER 'Активные' active(o) 'shift F10' DEFAULT
    FILTERS isCustomer(o)
    FILTERS isParent(legalEntityGroup(o), lg) OR
        o IS LegalEntity AND NOT lg IS LegalEntityGroup OR
        o IS LegalEntity AND lg IS LegalEntityGroup AND NOT legalEntityGroup(o)
;

DESIGN dialogCustomers {
    BOX {
        NEW topContainer {
            horizontal = TRUE;
            fill = 1;
            MOVE BOX(TREE legalEntityGroupTree) {
                caption = 'Группы организаций';
            }
            MOVE BOX(o) {
                fill = 3;
                GRID(o) {
                    defaultComponent = TRUE;
                }
            }
        }
        MOVE TOOLBARBOX;
    }
}

selectAllCustomers 'Выбрать всех' () {
    customerList() <- NULL;
    inCustomer(LegalEntity l) <- TRUE WHERE isCustomer(l) AND active(l);
    inLegalEntityGroup(LegalEntityGroup lg) <- TRUE;
} ASON CONTEXTMENU nameCustomers;

deselectAllCustomers 'Сбросить всех' () {
    customerList() <- NULL;
    inCustomer(LegalEntity l) <- NULL;
    inLegalEntityGroup(LegalEntityGroup lg) <- NULL;
} ASON CONTEXTMENU nameCustomers;

dateFrom 'Дата (с)' = DATA LOCAL DATE();
dateTo 'Дата (по)' = DATA LOCAL DATE();

includeReturns 'Учитывать возвраты' = DATA LOCAL BOOLEAN();

inSaleOp 'Отм.' = DATA LOCAL BOOLEAN (Operation);
showSaleOperations() = salesTypeDefault() != SalesFilterType.retail;
nameSaleOperations 'Операции (продажа)' () = GROUP CONCAT name(Operation o) IF inSaleOp(o), ', ' ORDER name(o), o CHARWIDTH 30;

FORM dialogSaleOperations 'Выбор операций (продажа)'
    OBJECTS o = Operation
    PROPERTIES(o) inSaleOp
    PROPERTIES(o) READONLY name
    ORDERS name(o)
;

selectAllSaleOps 'Выбрать все' () {
    inSaleOp(Operation o) <- TRUE;
} ASON CONTEXTMENU nameSaleOperations;

deselectAllSaleOps 'Сбросить все' () {
    inSaleOp(Operation o) <- NULL;
} ASON CONTEXTMENU nameSaleOperations;

initDates() {
    dateFrom() <- sum(currentDate(), -6);
    dateTo() <- currentDate();
    includeReturns() <- TRUE;
    inSaleOp(Operation o) <- TRUE;
}

isRetailSale(SaleLedger sl) = sl IS DateSaleSkuLedger;
isRetailReturn(SaleLedger sl) = sl IS DateReturnSkuLedger;
isRetail(SaleLedger sl) = isRetailSale(sl) OR isRetailReturn(sl);

lastPurchaseDetailByDate(Sku s, Stock st, DATE d) = GROUP LAST Purchase.InvoiceDetail pd
ORDER date(pd), pd
WHERE isPosted(pd) AND date(pd) <= d
BY sku(pd), customerStock(pd);

skuGroup2Full 'Код и наименование Отдела' (Sku s) = CONCAT ' ', idSkuGroup2(s), nameSkuGroup2(s);
skuGroup3Full 'Код и наименование Группы' (Sku s) = CONCAT ' ', idSkuGroup3(s), nameSkuGroup3(s);
skuGroup4Full 'Код и наименование Подгруппы' (Sku s) = CONCAT ' ', idSkuGroup4(s), nameSkuGroup4(s);

stockFullName 'Подразделение' (Stock st) = CONCAT ' ', id(st), name(st);

changeStocksDialog() { DIALOG dialogStocksSaleReportRu; }

inDocTypeFilterCommon(SaleLedger sl, SalesFilterType sdt, BOOLEAN incRet) =
    (sdt = SalesFilterType.both AND (NOT isRetailReturn(sl) OR incRet))
        OR (sdt = SalesFilterType.retail AND (isRetailSale(sl) OR (isRetailReturn(sl) AND incRet)))
        OR (sdt = SalesFilterType.wholesale AND NOT isRetail(sl));

skuInRangeForStock(Sku s, Range.Range r, Stock st, DATE d) =
    (include(r, s, d) OR in(s, r, store(st), d)) AND NOT inactive(r);

countRangeAll(Sku s, Stock st, DATE d) = GROUP SUM 1 IF skuInRangeForStock(s, Range.Range r, st, d);

rangesAll 'Ассортиментные матрицы' (Sku s, Stock st, DATE d) =
    GROUP CONCAT name(Range.Range r) IF skuInRangeForStock(s, r, st, d), ', ' ORDER r CHARWIDTH 30;

dateInRange(SaleLedger o) = dateFrom() <= date(o) AND dateTo() >= date(o);

filterForSalesQty (SaleLedger o) = active(o) AND dateInRange(o) AND inSaleReport(stock(o))
    AND fSkuFilter(sku(o))
    AND (NOT withAssortment() OR countRangeAll(sku(o), stock(o), currentDate()))
    AND (NOT (o IS DateReturnSkuLedger) OR includeReturns())
    AND (
        (salesTypeDefault() != SalesFilterType.wholesale AND isRetail(o))
            OR
            (salesTypeDefault() != SalesFilterType.retail AND NOT isRetail(o) AND (inSaleOp(operation(o)) OR NOT operation(o)))
        )
    AND (NOT anyCustomer() OR isRetail(o) OR inCustomer(customer(o)));

salesQty 'Кол-во продаж' = GROUP SUM quantity(SaleLedger o)
    IF filterForSalesQty(o) BY sku(o), stock(o);

salesSum 'Сумма продаж' = GROUP SUM sum(SaleLedger o) IF filterForSalesQty(o) BY sku(o), stock(o);

daysInPeriod 'Дни' () = daysBetweenDates(dateTo(), dateFrom()) + 1;
daysInPeriod 'Дни' (Sku s, Stock st) = daysInPeriod() IF s IS Sku AND st IS Stock;

accountPriceAtEnd 'Учетная цена' (Sku s, Stock st) = accountPriceA(s, st, toDateTime(dateTo()));
retailPrice 'Розничная цена' (Sku s, Stock st) = retailPriceA(s, st, toDateTime(dateTo()));
salesPrice 'Цена продаж' (Sku s, Stock st) = round2(salesSum(s, st) / salesQty(s, st));

sumByAccPrice 'Сумма в учетных ценах' = GROUP SUM quantity(SaleLedger o) * accountPriceA(sku(o), stock(o), toDateTime(date(o)))
    IF filterForSalesQty(o) BY sku(o), stock(o);

sumByRetailPrice 'Сумма в розничных ценах' = GROUP SUM quantity(SaleLedger o) * retailPriceA(sku(o), stock(o), toDateTime(date(o)))
    IF filterForSalesQty(o) BY sku(o), stock(o);

profit 'Валовый доход' (Sku s, Stock st) = salesSum(s, st) - sumByAccPrice(s, st);

balanceAtEnd 'Остаток' (Sku s, Stock st) = balanceA(s, st, dateTo());
accountSumAtEnd 'Сумма остатка в учетных ценах' (Sku s, Stock st) = round2(balanceAtEnd(s, st) * accountPriceAtEnd(s, st));
retailSumAtEnd 'Сумма остатка в розничных ценах' (Sku s, Stock st) = round2(balanceAtEnd(s, st) * retailPrice(s, st));

daysOfSupply 'Запас в днях' (Sku s, Stock st) = round2(balanceAtEnd(s, st) * daysInPeriod() / salesQty(s, st));

expiryText 'Срок годности' (Sku s) = CONCAT ' / ',
    (STRING[10](expiryMonth(s)) + ' мес.') IF expiryMonth(s),
    (STRING[10](expiryDays(s)) + ' дн.') IF expiryDays(s),
    (STRING[10](hoursExpiryPack(s)) + ' ч.') IF hoursExpiryPack(s);

lastPurchaseDetail(Sku s, Stock st) = lastPurchaseDetailByDate(s, st, dateTo());

lastSupplierText 'Поставщик по последнему приходу' (Sku s, Stock st) =
    CONCAT ' - ', id(supplier(lastPurchaseDetail(s, st))), name(supplier(lastPurchaseDetail(s, st)));

lastPurchaseDate 'Дата последнего прихода' (Sku s, Stock st) = date(lastPurchaseDetail(s, st));
lastPurchaseQty 'Кол-во по последнему приходу' (Sku s, Stock st) = quantity(lastPurchaseDetail(s, st));
lastExpiryDate 'Срок годности до' (Sku s, Stock st) = expiryDate(lastPurchaseDetail(s, st));

order (Sku s, Stock st) = CASE
    WHEN criteriaDefault() = ProductCriteria.quantity THEN salesQty(s, st)
    WHEN criteriaDefault() = ProductCriteria.amount THEN salesSum(s, st)
    WHEN criteriaDefault() = ProductCriteria.profit THEN profit(s, st)
    WHEN criteriaDefault() = ProductCriteria.stock THEN balanceAtEnd(s, st)
    WHEN criteriaDefault() = ProductCriteria.stockAmount THEN accountSumAtEnd(s, st)
    WHEN criteriaDefault() = ProductCriteria.stockDays THEN daysOfSupply(s, st);

index(Sku s, Stock st) = PARTITION SUM 1 ORDER DESC order(s, st), s, st IF salesQty(s, st);
formFilter(Sku s, Stock st) = index(s, st) <= productsLimitDefault();

indexW(Sku s, Stock st) = PARTITION SUM 1 ORDER order(s, st), s, st IF salesQty(s, st);
formFilterW(Sku s, Stock st) = indexW(s, st) <= productsLimitDefault();

salesTotalQty 'Кол-во продаж (итог)' = GROUP SUM salesQty(Sku s, Stock st) IF formFilter(s, st);
totalSumByAccPrice 'Сумма в учетных ценах (итог)' = GROUP SUM sumByAccPrice(Sku s, Stock st) IF formFilter(s, st);
totalSumByRetailPrice 'Сумма в розничных ценах (итог)' = GROUP SUM sumByRetailPrice(Sku s, Stock st) IF formFilter(s, st);
salesTotalSum 'Сумма продаж (итог)' = GROUP SUM salesSum(Sku s, Stock st) IF formFilter(s, st);
totalProfit 'Валовый доход (итог)' = GROUP SUM profit(Sku s, Stock st) IF formFilter(s, st);

orderTotal() = GROUP SUM order(Sku s, Stock st) IF formFilter(s, st);
productContributionPct 'Вклад товара в %' (Sku s, Stock st) = round2(order(s, st) / orderTotal() * 100);

orderTotalW() = GROUP SUM order(Sku s, Stock st) IF formFilterW(s, st);
productContributionPctW 'Вклад товара в %' (Sku s, Stock st) = round2(order(s, st) / orderTotalW() * 100);

formatDate = FORMULA DATE 'to_char($1,$2)';

showIncludeReturnsBW() = salesTypeDefault() != SalesFilterType.wholesale;

includeReturnsCaptionBW() = (IF includeReturns() THEN 'Да' ELSE 'Нет') IF salesTypeDefault() != SalesFilterType.wholesale;

subtitleBW() = CONCAT '   |   ',
    formatDate(dateFrom(), 'DD.MM.YYYY') + ' — ' + formatDate(dateTo(), 'DD.MM.YYYY'),
    'Продажи: ' + nameSalesType(),
    'Критерий: ' + nameCriteria(),
    'Возвраты: ' + includeReturnsCaptionBW();

FORM bestProdPrint 'Лучшие товары по продажам'
    OBJECTS report = (sku = Sku, stock = Stock)
    PROPERTIES(stock) READONLY 'Подразделение (код)' = id, name
    PROPERTIES(sku) READONLY idSkuGroup2, nameSkuGroup2, idSkuGroup3, nameSkuGroup3, idSkuGroup4, nameSkuGroup4, id, idBarcode, name, shortNameUOM, expiryText
    PROPERTIES READONLY ranges 'Ассортиментные матрицы' = rangesAll(sku, stock, currentDate())
    PROPERTIES(sku) READONLY 'Ценовой сегмент' = namePriceSegment
    PROPERTIES(sku, stock) READONLY salesQty, accountPriceAtEnd, retailPrice, salesPrice, sumByAccPrice, sumByRetailPrice, salesSum, profit,
        balanceAtEnd, accountSumAtEnd, retailSumAtEnd,
        daysOfSupply, daysInPeriod, productContributionPct,
        lastSupplierText, lastPurchaseDate, lastPurchaseQty, lastExpiryDate,
        index SHOWIF 1 = 2
    PROPERTIES() salesTotalQty, totalSumByAccPrice, totalSumByRetailPrice, salesTotalSum, totalProfit
    PROPERTIES mainTitle = 'Лучшие товары по продажам'
    PROPERTIES subtitle = subtitleBW()
    FILTERS formFilter(sku, stock)
    ORDERS index(sku, stock)
    REPORT 'SaleBestWorstProducts.jrxml'
;

FORM worstProdPrint 'Худшие товары по продажам'
    OBJECTS report = (sku = Sku, stock = Stock)
    PROPERTIES(stock) READONLY 'Подразделение (код)' = id, name
    PROPERTIES(sku) READONLY idSkuGroup2, nameSkuGroup2, idSkuGroup3, nameSkuGroup3, idSkuGroup4, nameSkuGroup4, id, idBarcode, name, shortNameUOM, expiryText
    PROPERTIES READONLY ranges 'Ассортиментные матрицы' = rangesAll(sku, stock, currentDate())
    PROPERTIES(sku) READONLY 'Ценовой сегмент' = namePriceSegment
    PROPERTIES(sku, stock) READONLY salesQty, accountPriceAtEnd, retailPrice, salesPrice, sumByAccPrice, sumByRetailPrice, salesSum, profit,
        balanceAtEnd, accountSumAtEnd, retailSumAtEnd,
        daysOfSupply, daysInPeriod, productContributionPctW,
        lastSupplierText, lastPurchaseDate, lastPurchaseQty, lastExpiryDate,
        indexW SHOWIF 1 = 2
    PROPERTIES() salesTotalQty, totalSumByAccPrice, totalSumByRetailPrice, salesTotalSum, totalProfit
    PROPERTIES mainTitle = 'Худшие товары по продажам'
    PROPERTIES subtitle = subtitleBW()
    FILTERS formFilterW(sku, stock)
    ORDERS indexW(sku, stock)
    REPORT 'SaleBestWorstProducts.jrxml'
;

bestProdPrint 'Лучшие товары по продажам' () {
    PRINT bestProdPrint XLSX TO printReportFile;
    buildPrintReportFileName('bestProdPrint', 'Лучшие товары по продажам');
    open(printReportFile(), builtPrintReportFileName());
} IMAGE 'print.png';
worstProdPrint 'Худшие товары по продажам' () {
    PRINT worstProdPrint XLSX TO printReportFile;
    buildPrintReportFileName('worstProdPrint', 'Худшие товары по продажам');
    open(printReportFile(), builtPrintReportFileName());
} IMAGE 'print.png';

FORM bestWorstProducts 'Лучшие и худшие товары по продажам'
    PROPERTIES() dateFrom, dateTo, nameSalesType, nameCriteria, productsLimitDefault, withAssortment
    PROPERTIES() includeReturns SHOWIF showIncludeReturnsBW()
    PROPERTIES nameStockList() READONLY SHOWIF stockList()
    PROPERTIES inSaleReportStocks 'Подразделения' = inSaleReportStocks() ON CHANGE changeStocksInventory() READONLYIF stockList()
    PROPERTIES inSaleReportOperations 'Операции (продажа)' = nameSaleOperations() ON CHANGE { DIALOG dialogSaleOperations; } SHOWIF showSaleOperations()
    PROPERTIES nameCustomerList() READONLY SHOWIF customerList()
    PROPERTIES inCustomers 'Покупатели' = nameCustomers() ON CHANGE { DIALOG dialogCustomers; } SHOWIF showSaleOperations() READONLYIF customerList()
    PROPERTIES fNameSkuLists() READONLY SHOWIF fAnySkuList()
    PROPERTIES bwSkuGroups 'Товарные группы' = fNameSkuGroups() READONLY SHOWIF fAnySkuGroup()
    PROPERTIES bwSkus 'Товары' = fInSkus() ON CHANGE fSelectSkus() READONLYIF fAnySkuList() OR fAnySkuGroup()

    OBJECTS bestProducts = (sku = Sku, stock = Stock)
    PROPERTIES(stock) READONLY 'Подразделение (код)' = id, 'Подразделение' = name
    PROPERTIES(sku) READONLY idSkuGroup2, nameSkuGroup2, idSkuGroup3, nameSkuGroup3, idSkuGroup4, nameSkuGroup4, id, idBarcode, name, shortNameUOM, expiryText
    PROPERTIES READONLY 'Ассортиментные матрицы' = rangesAll(sku, stock, currentDate())
    PROPERTIES(sku) READONLY 'Ценовой сегмент' = namePriceSegment
    PROPERTIES(sku, stock) READONLY salesQty, accountPriceAtEnd, retailPrice, salesPrice, sumByAccPrice, sumByRetailPrice, salesSum, profit,
        balanceAtEnd, accountSumAtEnd, retailSumAtEnd,
        daysOfSupply, daysInPeriod, productContributionPct,
        lastSupplierText, lastPurchaseDate, lastPurchaseQty, lastExpiryDate,
        index SHOWIF NULL
    FILTERS formFilter(sku, stock)
    ORDERS index(sku, stock)

    OBJECTS worstProducts = (skuW = Sku, stockW = Stock)
    PROPERTIES(stockW) READONLY 'Подразделение (код)' = id, 'Подразделение' = name
    PROPERTIES(skuW) READONLY idSkuGroup2, nameSkuGroup2, idSkuGroup3, nameSkuGroup3, idSkuGroup4, nameSkuGroup4, id, idBarcode, name, shortNameUOM, expiryText
    PROPERTIES READONLY 'Ассортиментные матрицы' = rangesAll(skuW, stockW, currentDate())
    PROPERTIES(skuW) READONLY 'Ценовой сегмент' = namePriceSegment
    PROPERTIES(skuW, stockW) READONLY salesQty, accountPriceAtEnd, retailPrice, salesPrice, sumByAccPrice, sumByRetailPrice, salesSum, profit,
        balanceAtEnd, accountSumAtEnd, retailSumAtEnd,
        daysOfSupply, daysInPeriod, productContributionPctW,
        lastSupplierText, lastPurchaseDate, lastPurchaseQty, lastExpiryDate,
        indexW SHOWIF NULL
    FILTERS formFilterW(skuW, stockW)
    ORDERS indexW(skuW, stockW)

    PROPERTIES() DISABLEIF NOT dateFrom() OR NOT dateTo() bestProdPrint, worstProdPrint

    EVENTS ON INIT initDates()
;

DESIGN bestWorstProducts {
    NEW filters FIRST {
        alignment = STRETCH;
        NEW topRow {
            horizontal = TRUE;
            alignment = STRETCH;
            MOVE PROPERTY(dateFrom());
            MOVE PROPERTY(dateTo());
            MOVE PROPERTY(nameSalesType());
            MOVE PROPERTY(nameCriteria());
            MOVE PROPERTY(productsLimitDefault());
            MOVE PROPERTY(withAssortment());
            MOVE PROPERTY(includeReturns());
        }
        MOVE PROPERTY(nameStockList()) { alignment = STRETCH; }
        MOVE PROPERTY(inSaleReportStocks) { alignment = STRETCH; }
        MOVE PROPERTY(inSaleReportOperations) { alignment = STRETCH; }
        MOVE PROPERTY(nameCustomerList()) { alignment = STRETCH; }
        MOVE PROPERTY(inCustomers) { alignment = STRETCH; }
        MOVE PROPERTY(fNameSkuLists()) { alignment = STRETCH; }
        MOVE PROPERTY(bwSkuGroups) { alignment = STRETCH; }
        MOVE PROPERTY(bwSkus) { alignment = STRETCH; }
        NEW actionGroup {
            horizontal = TRUE;
            alignment = CENTER;
            MOVE PROPERTY(bestProdPrint()) { valueClass = 'btn-success'; }
            MOVE PROPERTY(worstProdPrint()) { valueClass = 'btn-warning'; }
        }
    }
    OBJECTS {
        tabbed = TRUE;
        MOVE BOX(bestProducts) { caption = 'Лучшие товары по продажам'; };
        MOVE BOX(worstProducts) { caption = 'Худшие товары по продажам'; };
    }
}

selectAllInStockGroup 'Выбрать все в группе' (StockGroup sg) {
    inSaleReportDialog(Stock s) <- TRUE WHERE isParent(sg, s) AND isCompany(s) AND active(s);
}

deselectAllInStockGroup 'Сбросить все в группе' (StockGroup sg) {
    inSaleReportDialog(Stock s) <- NULL WHERE isParent(sg, s);
}

EXTEND FORM dialogStocksSaleReportRu
    PROPERTIES(sg) selectAllInStockGroup TOOLBAR SHOWIF NOT stockList()
    PROPERTIES(sg) deselectAllInStockGroup TOOLBAR SHOWIF NOT stockList()
;

CLASS PeriodType 'Детализация' {
    week 'Неделя',
    month 'Месяц',
    quarter 'Квартал',
    year 'Год'
}

FORM periodTypes 'Детализация'
    OBJECTS pt = PeriodType
    PROPERTIES(pt) READONLY staticCaption
    LIST PeriodType OBJECT pt
;

showIncludeReturns(SalesFilterType sdt) = sdt != SalesFilterType.wholesale;

inDocTypeFilter(SaleLedger sl, SalesFilterType sdt) = inDocTypeFilterCommon(sl, sdt, includeReturns());

isoDOW(DATE d) = FORMULA INTEGER PG '(EXTRACT(ISODOW FROM ($1))::integer)';
mondayOfWeek(DATE d) = sum(d, 1 - isoDOW(d));

monthsIntoQuarter(DATE d) = (extractMonthNumber(d) - 1) - (extractMonthNumber(d) - 1) / 3 * 3;
firstOfQuarter(DATE d) = sumMonth(firstDayOfMonth(d), -monthsIntoQuarter(d));
firstOfYear(DATE d) = sumMonth(firstDayOfMonth(d), 1 - extractMonthNumber(d));

periodsCount(PeriodType pt) = CASE
    WHEN pt = PeriodType.week THEN
    daysBetweenDates(mondayOfWeek(dateTo()), mondayOfWeek(dateFrom())) / 7 + 1
    WHEN pt = PeriodType.month THEN
    (extractYear(dateTo()) - extractYear(dateFrom())) * 12
        + extractMonthNumber(dateTo()) - extractMonthNumber(dateFrom()) + 1
    WHEN pt = PeriodType.quarter THEN
    (extractYear(dateTo()) * 4 + (extractMonthNumber(dateTo()) - 1) / 3)
        - (extractYear(dateFrom()) * 4 + (extractMonthNumber(dateFrom()) - 1) / 3) + 1
    WHEN pt = PeriodType.year THEN
    extractYear(dateTo()) - extractYear(dateFrom()) + 1;

dateFromPeriodRaw(PeriodType pt, INTEGER n) = CASE
    WHEN pt = PeriodType.week THEN sum(mondayOfWeek(dateFrom()), (n - 1) * 7)
    WHEN pt = PeriodType.month THEN sumMonth(firstDayOfMonth(dateFrom()), n - 1)
    WHEN pt = PeriodType.quarter THEN sumMonth(firstOfQuarter(dateFrom()), (n - 1) * 3)
    WHEN pt = PeriodType.year THEN sumMonth(firstOfYear(dateFrom()), (n - 1) * 12);

dateToPeriodRaw(PeriodType pt, INTEGER n) = CASE
    WHEN pt = PeriodType.week THEN sum(mondayOfWeek(dateFrom()), n * 7 - 1)
    WHEN pt = PeriodType.month THEN sum(sumMonth(firstDayOfMonth(dateFrom()), n), -1)
    WHEN pt = PeriodType.quarter THEN sum(sumMonth(firstOfQuarter(dateFrom()), n * 3), -1)
    WHEN pt = PeriodType.year THEN sum(sumMonth(firstOfYear(dateFrom()), n * 12), -1);

dateFromPeriod(PeriodType pt, INTEGER n) =
    IF dateFromPeriodRaw(pt, n) < dateFrom() THEN dateFrom() ELSE dateFromPeriodRaw(pt, n);

dateToPeriod(PeriodType pt, INTEGER n) =
    IF dateToPeriodRaw(pt, n) > dateTo() THEN dateTo() ELSE dateToPeriodRaw(pt, n);

isPartial(PeriodType pt, INTEGER n) =
    dateFromPeriod(pt, n) != dateFromPeriodRaw(pt, n) OR dateToPeriod(pt, n) != dateToPeriodRaw(pt, n);

periodCaption(PeriodType pt, INTEGER n) =
    toDateDDMMYYYY(dateFromPeriod(pt, n)) + ' - ' + toDateDDMMYYYY(dateToPeriod(pt, n));

quantitySoldPeriod(Stock st, PeriodType pt, INTEGER n, SalesFilterType sdt) =
    GROUP SUM quantity(SaleLedger sl) IF
        isPosted(sl) AND stock(sl) = st AND
            date(sl) >= dateFromPeriod(pt, n) AND date(sl) <= dateToPeriod(pt, n) AND
            inDocTypeFilter(sl, sdt);

sumRetailPeriod(Stock st, PeriodType pt, INTEGER n, SalesFilterType sdt) =
    GROUP SUM sum(SaleLedger sl) IF
        isPosted(sl) AND stock(sl) = st AND
            date(sl) >= dateFromPeriod(pt, n) AND date(sl) <= dateToPeriod(pt, n) AND
            inDocTypeFilter(sl, sdt);

sumCostPeriod(Stock st, PeriodType pt, INTEGER n, SalesFilterType sdt) =
    GROUP SUM costSum(SaleLedger sl) IF
        isPosted(sl) AND stock(sl) = st AND
            date(sl) >= dateFromPeriod(pt, n) AND date(sl) <= dateToPeriod(pt, n) AND
            inDocTypeFilter(sl, sdt);

quantitySoldResult 'Кол-во продаж' = DATA LOCAL NUMERIC[16,3] (DepartmentStore, INTEGER);
sumRetailResult 'Сумма (отпускные)' = DATA LOCAL NUMERIC[18,4] (DepartmentStore, INTEGER);
sumCostResult 'Сумма (учётные)' = DATA LOCAL NUMERIC[18,4] (DepartmentStore, INTEGER);
grossIncomeResult 'Валовый доход' = DATA LOCAL NUMERIC[18,4] (DepartmentStore, INTEGER);
marginResult 'Маржа, %' = DATA LOCAL NUMERIC[5,2] (DepartmentStore, INTEGER);
periodCaptionResult 'Период' = DATA LOCAL STRING[30] (INTEGER);
isPartialResult = DATA LOCAL BOOLEAN (INTEGER);
periodsCountResult = DATA LOCAL INTEGER ();

selectedPeriodTypeCaption 'Детализация' = DATA LOCAL STRING[30] ();
selectedSaleDocTypeCaption 'Тип документов' = DATA LOCAL STRING[50] ();
selectedIncludeReturns 'Возвраты' = DATA LOCAL STRING[10] ();

totalQuantityResult 'Всего кол-во' = DATA LOCAL NUMERIC[16,3] ();
totalRetailResult 'Всего (отпускные)' = DATA LOCAL NUMERIC[18,4] ();
totalCostResult 'Всего (учётные)' = DATA LOCAL NUMERIC[18,4] ();
totalGrossIncomeResult 'Всего валовый доход' = DATA LOCAL NUMERIC[18,4] ();
totalMarginResult 'Всего маржа, %' = DATA LOCAL NUMERIC[5,2] ();

backgroundGrossIncome(DepartmentStore ds, INTEGER n) =
    IF grossIncomeResult(ds, n) > 0 THEN RGB(212, 237, 218)
    ELSE IF grossIncomeResult(ds, n) < 0 THEN RGB(248, 215, 218);

backgroundMargin(DepartmentStore ds, INTEGER n) =
    IF marginResult(ds, n) >= 0 THEN RGB(255, 243, 205)
    ELSE IF marginResult(ds, n) < 0 THEN RGB(248, 215, 218);

backgroundPeriod(INTEGER n) =
    IF isPartialResult(n) THEN RGB(220, 235, 250);

titleReport = 'Динамика продаж за ' + toDateDDMMYYYY(dateFrom()) + ' - ' + toDateDDMMYYYY(dateTo());

fill 'Сформировать' (PeriodType pt, SalesFilterType sdt) {
    selectedPeriodTypeCaption() <- staticCaption(pt);
    selectedSaleDocTypeCaption() <- staticCaption(sdt);
    selectedIncludeReturns() <- (IF includeReturns() THEN 'Да' ELSE 'Нет') IF sdt != SalesFilterType.wholesale;

    quantitySoldResult(DepartmentStore ds, INTEGER n) <- NULL;
    sumRetailResult(DepartmentStore ds, INTEGER n) <- NULL;
    sumCostResult(DepartmentStore ds, INTEGER n) <- NULL;
    grossIncomeResult(DepartmentStore ds, INTEGER n) <- NULL;
    marginResult(DepartmentStore ds, INTEGER n) <- NULL;
    periodCaptionResult(INTEGER n) <- NULL;
    isPartialResult(INTEGER n) <- NULL;

    periodsCountResult() <- periodsCount(pt);

    FOR iterate(INTEGER n, 1, periodsCount(pt)) DO {
        periodCaptionResult(n) <- periodCaption(pt, n);
        isPartialResult(n) <- isPartial(pt, n);
    }

    FOR inSaleReport(DepartmentStore ds) AND iterate(INTEGER n, 1, periodsCount(pt)) DO {
        quantitySoldResult(ds, n) <- quantitySoldPeriod(ds, pt, n, sdt);
        sumRetailResult(ds, n) <- sumRetailPeriod(ds, pt, n, sdt);
        sumCostResult(ds, n) <- sumCostPeriod(ds, pt, n, sdt);
        grossIncomeResult(ds, n) <- sumRetailResult(ds, n) (-) sumCostResult(ds, n);
        marginResult(ds, n) <- NUMERIC[5,2](round2(grossIncomeResult(ds, n) * 100.0 / sumRetailResult(ds, n)))
            IF sumRetailResult(ds, n) != 0;
    }

    totalQuantityResult() <- GROUP SUM quantitySoldResult(DepartmentStore ds, INTEGER n);
    totalRetailResult() <- GROUP SUM sumRetailResult(DepartmentStore ds, INTEGER n);
    totalCostResult() <- GROUP SUM sumCostResult(DepartmentStore ds, INTEGER n);
    totalGrossIncomeResult() <- totalRetailResult() (-) totalCostResult();
    totalMarginResult() <- NUMERIC[5,2](round2(totalGrossIncomeResult() * 100.0 / totalRetailResult()))
        IF totalRetailResult() != 0;
}

FORM salesDynamicsReport 'Динамика продаж'
    PROPERTIES() titleReport, selectedPeriodTypeCaption, selectedSaleDocTypeCaption, selectedIncludeReturns
    PROPERTIES() dateFrom, dateTo
    PROPERTIES nameStockList() READONLY SHOWIF stockList()
    PROPERTIES changeStocks 'Подразделения' = inSaleReportStocks() ON CHANGE changeStocksDialog() READONLYIF stockList()

    OBJECTS pt = PeriodType PANEL
    PROPERTIES(pt) staticCaption SELECTOR

    OBJECTS sdt = SalesFilterType PANEL
    PROPERTIES(sdt) staticCaption SELECTOR

    PROPERTIES() includeReturns SHOWIF showIncludeReturns(sdt)

    PROPERTIES(pt, sdt) fill

    OBJECTS (ds = DepartmentStore, n = INTEGER)
    PROPERTIES READONLY
    idDs 'Код объекта учёта' = id(ds),
        nameDs 'Наименование объекта учёта' = name(ds),
        periodNumber '№ периода' = VALUE(n),
        periodCaptionResult(n) BACKGROUND backgroundPeriod(n)
    PROPERTIES(ds, n) READONLY
    quantitySoldResult,
        sumRetailResult,
        sumCostResult,
        grossIncomeResult BACKGROUND backgroundGrossIncome(ds, n),
        marginResult BACKGROUND backgroundMargin(ds, n)
    FILTERS inSaleReport(ds),
        iterate(n, 1, periodsCountResult())
    FILTERS quantitySoldResult(ds, n) OR sumRetailResult(ds, n)
    ORDERS nameDs, periodNumber

    PROPERTIES() READONLY PANEL
    totalQuantityResult, totalRetailResult, totalCostResult, totalGrossIncomeResult, totalMarginResult

    EVENTS ON INIT initDates()
;

FORM printSalesDynamicsReport 'Динамика продаж (печать)'
    PROPERTIES() titleReport, selectedPeriodTypeCaption, selectedSaleDocTypeCaption, selectedIncludeReturns
    PROPERTIES() totalQuantityResult, totalRetailResult, totalCostResult, totalGrossIncomeResult, totalMarginResult

    OBJECTS (ds = DepartmentStore, n = INTEGER)
    PROPERTIES READONLY
    idDs 'Код' = id(ds),
        nameDs 'Наименование' = name(ds),
        periodNumber '№' = VALUE(n),
        periodCaption 'Период' = periodCaptionResult(n) BACKGROUND backgroundPeriod(n),
        quantity 'Количество' = quantitySoldResult(ds, n),
        sumRetail 'Сумма отпускная' = sumRetailResult(ds, n),
        sumCost 'Сумма учётная' = sumCostResult(ds, n),
        grossIncome 'Валовой доход' = grossIncomeResult(ds, n) BACKGROUND backgroundGrossIncome(ds, n),
        margin 'Маржа, %' = marginResult(ds, n) BACKGROUND backgroundMargin(ds, n)
    FILTERS inSaleReport(ds),
        iterate(n, 1, periodsCountResult())
    FILTERS quantitySoldResult(ds, n) OR sumRetailResult(ds, n)
    ORDERS nameDs, periodNumber
;

print 'Печать' (PeriodType pt, SalesFilterType sdt) {
    fill(pt, sdt);
    PRINT printSalesDynamicsReport XLSX TO printReportFile;
    buildPrintReportFileName('printSalesDynamicsReport', 'Динамика продаж');
    open(printReportFile(), builtPrintReportFileName());
}

EXTEND FORM salesDynamicsReport
    PROPERTIES(pt, sdt) print
;

DESIGN salesDynamicsReport {
    OBJECTS {
        NEW params FIRST {
            alignment = STRETCH;
            NEW row1 {
                horizontal = TRUE;
                alignment = STRETCH;
                MOVE PROPERTY(dateFrom()) { valueClass = 'btn-outline-primary'; }
                MOVE PROPERTY(dateTo()) { valueClass = 'btn-outline-primary'; }
                MOVE PROPERTY(fill(pt, sdt)) { valueClass = 'btn-success'; }
                MOVE PROPERTY(print(pt, sdt)) { valueClass = 'btn-warning'; }
                NEW row1right {
                    horizontal = TRUE;
                    fill = 1;
                    childrenAlignment = END;
                    MOVE PROPERTY(includeReturns());
                }
            }
            NEW row2 {
                horizontal = TRUE;
                caption = 'Параметры';
                alignment = STRETCH;
                MOVE PROPERTY(staticCaption(pt)) { caption = 'Детализация'; valueClass = 'btn-primary'; }
                MOVE PROPERTY(staticCaption(sdt)) { caption = 'Документы'; valueClass = 'btn-info'; }
            }
            NEW row3 {
                horizontal = TRUE;
                alignment = STRETCH;
                MOVE PROPERTY(nameStockList()) { fill = 1; }
                MOVE PROPERTY(changeStocks) { fill = 1; }
            }
        }
        NEW totals LAST {
            horizontal = TRUE;
            caption = 'Итого за весь период';
            alignment = STRETCH;
            MOVE PROPERTY(totalQuantityResult());
            MOVE PROPERTY(totalRetailResult());
            MOVE PROPERTY(totalCostResult());
            MOVE PROPERTY(totalGrossIncomeResult()) { valueClass = 'btn-success'; }
            MOVE PROPERTY(totalMarginResult()) { valueClass = 'btn-warning'; }
        }
    }
    REMOVE PROPERTY(titleReport());
    REMOVE PROPERTY(selectedPeriodTypeCaption());
    REMOVE PROPERTY(selectedSaleDocTypeCaption());
    REMOVE PROPERTY(selectedIncludeReturns());
}

CLASS AMFilterMode 'Фильтр ассортимента' {
    all 'Все товары подразделения',
    matrix 'Только товары в ассортиментных матрицах'
}
name 'Фильтр ассортимента' (AMFilterMode o) = staticCaption(o) IF o IS AMFilterMode CHARWIDTH 15;

FORM amFilterModes 'Фильтр ассортимента'
    OBJECTS o = AMFilterMode
    PROPERTIES(o) READONLY staticCaption
    LIST AMFilterMode OBJECT o
;

amFilterMode = DATA LOCAL AMFilterMode ();
amFilterModeDefault = OVERRIDE amFilterMode(), AMFilterMode.all;
nameAMFilterMode 'Фильтр ассортимента' = name(amFilterModeDefault());

amSkuInRange(Sku s, Range.Range r, Stock st) =
    skuInRangeForStock(s, r, st, dateTo());

amInMatrix(Sku s, Stock st) = GROUP SUM 1 IF amSkuInRange(s, Range.Range r, st);

amRanges 'Ассортиментные матрицы' (Sku s, Stock st) =
    GROUP CONCAT name(Range.Range r) IF amSkuInRange(s, r, st), ', ' ORDER name(r), r CHARWIDTH 30;

amFilter(Sku s, Stock st) = inSaleReport(st) AND fSkuFilter(s)
    AND (amFilterModeDefault() = AMFilterMode.all OR amInMatrix(s, st));

amSupplierID 'Код поставщика' (Sku s, Stock st) = id(supplier(lastPurchaseDetail(s, st)));
amSupplierName 'Наименование поставщика' (Sku s, Stock st) = name(supplier(lastPurchaseDetail(s, st)));

amPackQuantity 'Количество в упаковке' (Sku s) = amountPack(s);

amSkuSupplierID 'Код поставщика' (Sku s) = GROUP MAX amSupplierID(s, Stock st) IF inSaleReport(st);
amSkuSupplierName 'Наименование поставщика' (Sku s) = GROUP MAX amSupplierName(s, Stock st) IF inSaleReport(st);

amHasData(Sku s) = GROUP MAX amFilter(s, Stock st);

FORM assortmentMatrixReport 'Отчёт по ассортиментным матрицам'
    PROPERTIES() dateTo, nameAMFilterMode
    PROPERTIES nameStockList() READONLY SHOWIF stockList()
    PROPERTIES amStocks 'Подразделения' = inSaleReportStocks() ON CHANGE changeStocksDialog() READONLYIF stockList()
    PROPERTIES amSkuListsCaption 'Списки товаров' = fNameSkuLists() READONLY SHOWIF fAnySkuList()
    PROPERTIES amSkuGroups 'Товарные группы' = fNameSkuGroups() READONLY SHOWIF fAnySkuGroup()
    PROPERTIES amSkus 'Товары' = fInSkus() ON CHANGE fSelectSkus() READONLYIF fAnySkuList() OR fAnySkuGroup()

    OBJECTS st = Stock
    FILTERS inSaleReport(st)

    OBJECTS s = Sku
    PROPERTIES(s) READONLY 'Код товара' = id, 'Наименование товара' = name, idBarcode, shortNameUOM, amPackQuantity,
        amSkuSupplierID, amSkuSupplierName
    PROPERTIES READONLY amRanges(s, st) COLUMNS 'stock' (st) HEADER stockFullName(st)
    FILTERS amHasData(s)
    ORDERS name(s)

    EVENTS ON INIT initDates()
;

FORM assortmentMatrixReportPrint 'Отчёт по ассортиментным матрицам'
    PROPERTIES() dateTo

    OBJECTS st = Stock
    FILTERS inSaleReport(st)

    OBJECTS s = Sku
    PROPERTIES(s) READONLY 'Код товара' = id, 'Наименование товара' = name, 'Штрихкод' = idBarcode,
        'Единица измерения' = shortNameUOM, 'Количество в упаковке' = amPackQuantity, 'Код поставщика' = amSkuSupplierID,
        'Наименование поставщика' = amSkuSupplierName
    PROPERTIES READONLY amRanges(s, st) COLUMNS 'stock' (st) HEADER stockFullName(st)
    FILTERS amHasData(s)
    ORDERS name(s)
;

@definePrintReport(assortmentMatrixReportPrint, 'Отчёт по ассортиментным матрицам');

EXTEND FORM assortmentMatrixReport
    PROPERTIES() DISABLEIF NOT (GROUP SUM 1 IF inSaleReport(Stock sst)) assortmentMatrixReportPrint
;

DESIGN assortmentMatrixReport {
    REMOVE BOX(st);
    NEW filters FIRST {
        alignment = STRETCH;
        NEW topRow {
            horizontal = TRUE;
            alignment = STRETCH;
            MOVE PROPERTY(dateTo());
            MOVE PROPERTY(assortmentMatrixReportPrint()) { valueClass = 'btn-primary'; }
            MOVE PROPERTY(nameAMFilterMode());
        }
        MOVE PROPERTY(nameStockList()) { alignment = STRETCH; }
        MOVE PROPERTY(amStocks) { alignment = STRETCH; }
        MOVE PROPERTY(amSkuListsCaption) { alignment = STRETCH; }
        MOVE PROPERTY(amSkuGroups) { alignment = STRETCH; }
        MOVE PROPERTY(amSkus) { alignment = STRETCH; }
    }
    BOX(s) {
        caption = 'Товары';
    }
}

ahInRangeAtStart(Sku s, Range.Range r, Store st) = in(s, r, st, dateFrom());
ahInRangeAtEnd(Sku s, Range.Range r, Store st) = in(s, r, st, dateTo());

ahDateIncludedByRev(Sku s, Range.Range r, Store st) = GROUP LAST date(RangeRev v)
ORDER date(v), v
WHERE range(v) = r AND date(v) >= dateFrom() AND date(v) <= dateTo()
    AND in(s, r, st, date(v))
    AND NOT in(s, r, st, sum(date(v), -1));

ahDateIncludedByStore(Sku s, Range.Range r, Store st) = GROUP LAST DATE d
ORDER d
WHERE hasLevel(r, st, d) AND d >= dateFrom() AND d <= dateTo()
    AND in(s, r, st, d)
    AND NOT in(s, r, st, sum(d, -1));

ahDateIncludedByStoreType(Sku s, Range.Range r, Store st) = GROUP LAST DATE d
ORDER d
WHERE hasLevel(r, storeType(st), d) AND d >= dateFrom() AND d <= dateTo()
    AND NOT skipStoreType(r, st)
    AND in(s, r, st, d)
    AND NOT in(s, r, st, sum(d, -1));

ahDateIncluded(Sku s, Range.Range r, Store st) =
    MAX ahDateIncludedByRev(s, r, st), ahDateIncludedByStore(s, r, st), ahDateIncludedByStoreType(s, r, st);

ahDateIncludedDisplay 'Дата включения в ассортимент' (Sku s, Range.Range r, Store st) =
    OVERRIDE ahDateIncluded(s, r, st), (dateFrom() IF ahInRangeAtStart(s, r, st));

ahDateExcludedByRev(Sku s, Range.Range r, Store st) = GROUP LAST date(RangeRev v)
ORDER date(v), v
WHERE range(v) = r AND date(v) >= dateFrom() AND date(v) <= dateTo()
    AND NOT in(s, r, st, date(v))
    AND in(s, r, st, sum(date(v), -1));

ahDateExcludedByStore(Sku s, Range.Range r, Store st) = GROUP LAST DATE d
ORDER d
WHERE hasLevel(r, st, d) AND d >= dateFrom() AND d <= dateTo()
    AND NOT in(s, r, st, d)
    AND in(s, r, st, sum(d, -1));

ahDateExcludedByStoreType(Sku s, Range.Range r, Store st) = GROUP LAST DATE d
ORDER d
WHERE hasLevel(r, storeType(st), d) AND d >= dateFrom() AND d <= dateTo()
    AND NOT skipStoreType(r, st)
    AND NOT in(s, r, st, d)
    AND in(s, r, st, sum(d, -1));

ahDateExcluded 'Дата удаления из ассортимента' (Sku s, Range.Range r, Store st) =
    MAX ahDateExcludedByRev(s, r, st), ahDateExcludedByStore(s, r, st), ahDateExcludedByStoreType(s, r, st);

ahIsExcluding 'Выводим из ассортимента' (Sku s, Range.Range r, Store st) =
    'Да' IF NOT ahInRangeAtEnd(s, r, st) AND (ahInRangeAtStart(s, r, st) OR ahDateExcluded(s, r, st));

ahChanged(Sku s, Range.Range r, Store st) =
    ahDateIncluded(s, r, st) OR ahDateExcluded(s, r, st)
        OR (ahInRangeAtStart(s, r, st) AND NOT ahInRangeAtEnd(s, r, st))
        OR (NOT ahInRangeAtStart(s, r, st) AND ahInRangeAtEnd(s, r, st));

ahHasData(Sku s, Range.Range r, DepartmentStore ds) =
    inSaleReport(ds) AND fSkuFilter(s) AND inChild(r, s)
        AND NOT inactive(r)
        AND ahChanged(s, r, store(ds));

FORM assortmentHistoryReport 'История изменения ассортимента'
    PROPERTIES() dateFrom, dateTo
    PROPERTIES nameStockList() READONLY SHOWIF stockList()
    PROPERTIES ahStocks 'Подразделения' = inSaleReportStocks() ON CHANGE changeStocksDialog() READONLYIF stockList()
    PROPERTIES ahSkuListsCaption 'Списки товаров' = fNameSkuLists() READONLY SHOWIF fAnySkuList()
    PROPERTIES ahSkuGroups 'Товарные группы' = fNameSkuGroups() READONLY SHOWIF fAnySkuGroup()
    PROPERTIES ahSkus 'Товары' = fInSkus() ON CHANGE fSelectSkus() READONLYIF fAnySkuList() OR fAnySkuGroup()

    OBJECTS report = (s = Sku, r = Range.Range, ds = DepartmentStore)
    PROPERTIES(ds) READONLY 'Код подразделения' = id, 'Наименование подразделения' = name
    PROPERTIES(s) READONLY skuGroup2Full, skuGroup3Full, skuGroup4Full
    PROPERTIES(s) READONLY 'Код товара' = id, 'Наименование товара' = name
    PROPERTIES READONLY ahDateIncludedDisplay 'Дата включения в ассортимент' = ahDateIncludedDisplay(s, r, store(ds)),
        ahDateExcluded 'Дата удаления из ассортимента' = ahDateExcluded(s, r, store(ds)),
        ahIsExcluding 'Выводим из ассортимента' = ahIsExcluding(s, r, store(ds))
    FILTERS ahHasData(s, r, ds)
    ORDERS name(ds), skuGroup2Full(s), skuGroup3Full(s), skuGroup4Full(s), name(s)

    EVENTS ON INIT initDates()
;

@definePrintReport(assortmentHistoryReport, 'История изменения ассортимента');

EXTEND FORM assortmentHistoryReport
    PROPERTIES() DISABLEIF NOT dateFrom() OR NOT dateTo() OR NOT (GROUP SUM 1 IF inSaleReport(Stock sst)) assortmentHistoryReport
;

DESIGN assortmentHistoryReport {
    NEW filters FIRST {
        alignment = STRETCH;
        NEW topRow {
            horizontal = TRUE;
            alignment = STRETCH;
            MOVE PROPERTY(dateFrom());
            MOVE PROPERTY(dateTo());
            MOVE PROPERTY(assortmentHistoryReport()) { valueClass = 'btn-primary'; }
        }
        MOVE PROPERTY(nameStockList()) { alignment = STRETCH; }
        MOVE PROPERTY(ahStocks) { alignment = STRETCH; }
        MOVE PROPERTY(ahSkuListsCaption) { alignment = STRETCH; }
        MOVE PROPERTY(ahSkuGroups) { alignment = STRETCH; }
        MOVE PROPERTY(ahSkus) { alignment = STRETCH; }
    }
    BOX(report) {
        caption = 'История изменения ассортимента';
    }
}

CLASS CmpTurnoverCriterion 'Критерий для расчета оборачиваемости' {
    retail 'Отпускные цены',
    account 'Учетные цены',
    quantity 'Количество'
}
name 'Критерий для расчета оборачиваемости' (CmpTurnoverCriterion o) = staticCaption(o) IF o IS CmpTurnoverCriterion CHARWIDTH 20;

FORM cmpTurnoverCriteria 'Критерий для расчета оборачиваемости'
    OBJECTS o = CmpTurnoverCriterion
    PROPERTIES(o) READONLY staticCaption
    LIST CmpTurnoverCriterion OBJECT o
;

cmpCriterion = DATA LOCAL CmpTurnoverCriterion();
cmpCriterionDefault = OVERRIDE cmpCriterion(), CmpTurnoverCriterion.account;
nameCmpCriterion 'Критерий для расчета оборачиваемости' = name(cmpCriterionDefault());

cmpSalesType = DATA LOCAL SalesFilterType();
cmpSalesTypeDefault = OVERRIDE cmpSalesType(), SalesFilterType.both;
nameCmpSalesType 'Тип отбора продаж' = name(cmpSalesTypeDefault());

cmpDateFrom 'Основной период (с)' = DATA LOCAL DATE ();
cmpDateTo 'Основной период (по)' = DATA LOCAL DATE ();
prevDateFrom 'Предыдущий период (с)' = DATA LOCAL DATE ();
prevDateTo 'Предыдущий период (по)' = DATA LOCAL DATE ();

cmpIncludeReturns 'Учитывать возвраты' = DATA LOCAL BOOLEAN();

cmpDateFromRun = DATA LOCAL DATE();
cmpDateToRun = DATA LOCAL DATE();
prevDateFromRun = DATA LOCAL DATE();
prevDateToRun = DATA LOCAL DATE();
cmpSalesTypeRun = DATA LOCAL SalesFilterType();
cmpCriterionRun = DATA LOCAL CmpTurnoverCriterion();
cmpIncludeReturnsRun = DATA LOCAL BOOLEAN();

cmpSalesTypeRunDefault = OVERRIDE cmpSalesTypeRun(), SalesFilterType.both;
cmpCriterionRunDefault = OVERRIDE cmpCriterionRun(), CmpTurnoverCriterion.account;

initCmpDates() {
    cmpDateTo() <- currentDate();
    cmpDateFrom() <- firstDayOfMonth(cmpDateTo());
    prevDateTo() <- sumYear(cmpDateTo(), -1);
    prevDateFrom() <- sumYear(cmpDateFrom(), -1);
    cmpSalesType() <- SalesFilterType.both;
    cmpCriterion() <- CmpTurnoverCriterion.account;
    cmpIncludeReturns() <- TRUE;
}

daysBetween(DATE d1, DATE d2) = daysBetweenDates(d2, d1) + 1;

cmpDays () = daysBetween(cmpDateFromRun(), cmpDateToRun());
prevDays () = daysBetween(prevDateFromRun(), prevDateToRun());

cmpSkuFilter(Sku s) = fSkuFilter(s);

cmpLastPurchaseDetail(Sku s, Stock st) = lastPurchaseDetailByDate(s, st, cmpDateToRun());

cmpSupplier(Sku s, Stock st) = OVERRIDE supplier(cmpLastPurchaseDetail(s, st)), supplierSku(s);

cmpSupplierFilter(Sku s, Stock st) = NOT fAnySupplier() OR fInSupplier(cmpSupplier(s, st));

cmpRowFilter(Sku s, Stock st) = inSaleReport(st) AND cmpSkuFilter(s) AND cmpSupplierFilter(s, st);

cmpShowIncludeReturns() = cmpSalesTypeDefault() != SalesFilterType.wholesale;

cmpInDocTypeFilter(SaleLedger sl, SalesFilterType sdt) = inDocTypeFilterCommon(sl, sdt, cmpIncludeReturnsRun());

cmpSaleFilter (SaleLedger o) = active(o) AND inSaleReport(stock(o))
    AND cmpSkuFilter(sku(o))
    AND cmpSupplierFilter(sku(o), stock(o))
    AND cmpInDocTypeFilter(o, cmpSalesTypeRunDefault());

cSumRestQty (Sku s, Stock st) =
    GROUP SUM balanceA(s, st, DATE d) IF iterate(d, cmpDateFromRun(), cmpDateToRun());

cSumRestCost (Sku s, Stock st) =
    GROUP SUM round2(balanceA(s, st, DATE d) * accountPriceA(s, st, toDateTime(d))) IF iterate(d, cmpDateFromRun(), cmpDateToRun());

cSumRestRetail (Sku s, Stock st) =
    GROUP SUM round2(balanceA(s, st, DATE d) * prevPriceA(retailPriceListType(st), s, st, toDateTime(d))) IF iterate(d, cmpDateFromRun(), cmpDateToRun());

cAvgRestQty 'Средний остаток количество' (Sku s, Stock st) =
    NUMERIC[18,2](round2(cSumRestQty(s, st) / cmpDays())) IF cmpDays();

cAvgStockSum 'Средняя сумма остатка (учетные)' (Sku s, Stock st) =
    NUMERIC[18,2](round2(cSumRestCost(s, st) / cmpDays())) IF cmpDays();

cAvgRestRetail 'Средний остаток отпускные' (Sku s, Stock st) =
    NUMERIC[18,2](round2(cSumRestRetail(s, st) / cmpDays())) IF cmpDays();

cSalesQty 'Продажи (количество)' (Sku s, Stock st) =
    GROUP SUM quantity(SaleLedger sl)
        IF cmpSaleFilter(sl) AND date(sl) >= cmpDateFromRun() AND date(sl) <= cmpDateToRun()
    BY sku(sl), stock(sl);

cSalesSum 'Сумма продаж (продажные)' (Sku s, Stock st) =
    GROUP SUM sum(SaleLedger sl)
        IF cmpSaleFilter(sl) AND date(sl) >= cmpDateFromRun() AND date(sl) <= cmpDateToRun()
    BY sku(sl), stock(sl);

cSalesCost 'Сумма продаж (учетные)' (Sku s, Stock st) =
    GROUP SUM costSum(SaleLedger sl)
        IF cmpSaleFilter(sl) AND date(sl) >= cmpDateFromRun() AND date(sl) <= cmpDateToRun()
    BY sku(sl), stock(sl);

cMargin 'Маржинальный доход' (Sku s, Stock st) = cSalesSum(s, st) (-) cSalesCost(s, st);

cProfitability 'Рентабельность %' (Sku s, Stock st) =
    NUMERIC[18,2](round2(cMargin(s, st) * 100.0 / cSalesSum(s, st))) IF cSalesSum(s, st) != 0;

cTurnoverBaseSales (Sku s, Stock st) = CASE
    WHEN cmpCriterionRunDefault() = CmpTurnoverCriterion.quantity THEN cSalesQty(s, st)
    WHEN cmpCriterionRunDefault() = CmpTurnoverCriterion.account THEN cSalesCost(s, st)
    WHEN cmpCriterionRunDefault() = CmpTurnoverCriterion.retail THEN cSalesSum(s, st);

cTurnoverBaseRest (Sku s, Stock st) = CASE
    WHEN cmpCriterionRunDefault() = CmpTurnoverCriterion.quantity THEN cAvgRestQty(s, st)
    WHEN cmpCriterionRunDefault() = CmpTurnoverCriterion.account THEN cAvgStockSum(s, st)
    WHEN cmpCriterionRunDefault() = CmpTurnoverCriterion.retail THEN cAvgRestRetail(s, st);

cTurnoverDays 'Оборачиваемость товарных остатков' (Sku s, Stock st) =
    NUMERIC[18,3](round3(cTurnoverBaseRest(s, st) * cmpDays() / cTurnoverBaseSales(s, st)))
        IF cTurnoverBaseSales(s, st) > 0 AND cTurnoverBaseRest(s, st) > 0;

pSumRestQty (Sku s, Stock st) =
    GROUP SUM balanceA(s, st, DATE d) IF iterate(d, prevDateFromRun(), prevDateToRun());

pSumRestCost (Sku s, Stock st) =
    GROUP SUM round2(balanceA(s, st, DATE d) * accountPriceA(s, st, toDateTime(d))) IF iterate(d, prevDateFromRun(), prevDateToRun());

pSumRestRetail (Sku s, Stock st) =
    GROUP SUM round2(balanceA(s, st, DATE d) * prevPriceA(retailPriceListType(st), s, st, toDateTime(d))) IF iterate(d, prevDateFromRun(), prevDateToRun());

pAvgRestQty 'Средний остаток пред. количество' (Sku s, Stock st) =
    NUMERIC[18,2](round2(pSumRestQty(s, st) / prevDays())) IF prevDays();

pAvgStockSum 'Средняя сумма остатка пред. (учетные)' (Sku s, Stock st) =
    NUMERIC[18,2](round2(pSumRestCost(s, st) / prevDays())) IF prevDays();

pAvgRestRetail 'Средний остаток пред. отпускные' (Sku s, Stock st) =
    NUMERIC[18,2](round2(pSumRestRetail(s, st) / prevDays())) IF prevDays();

pSalesQty 'Продажи пред. (количество)' (Sku s, Stock st) =
    GROUP SUM quantity(SaleLedger sl)
        IF cmpSaleFilter(sl) AND date(sl) >= prevDateFromRun() AND date(sl) <= prevDateToRun()
    BY sku(sl), stock(sl);

pSalesSum 'Сумма продаж пред. (продажные)' (Sku s, Stock st) =
    GROUP SUM sum(SaleLedger sl)
        IF cmpSaleFilter(sl) AND date(sl) >= prevDateFromRun() AND date(sl) <= prevDateToRun()
    BY sku(sl), stock(sl);

pSalesCost 'Сумма продаж пред. (учетные)' (Sku s, Stock st) =
    GROUP SUM costSum(SaleLedger sl)
        IF cmpSaleFilter(sl) AND date(sl) >= prevDateFromRun() AND date(sl) <= prevDateToRun()
    BY sku(sl), stock(sl);

pMargin 'Маржинальный доход пред.' (Sku s, Stock st) = pSalesSum(s, st) (-) pSalesCost(s, st);

pProfitability 'Рентабельность пред. %' (Sku s, Stock st) =
    NUMERIC[18,2](round2(pMargin(s, st) * 100.0 / pSalesSum(s, st))) IF pSalesSum(s, st) != 0;

pTurnoverBaseSales (Sku s, Stock st) = CASE
    WHEN cmpCriterionRunDefault() = CmpTurnoverCriterion.quantity THEN pSalesQty(s, st)
    WHEN cmpCriterionRunDefault() = CmpTurnoverCriterion.account THEN pSalesCost(s, st)
    WHEN cmpCriterionRunDefault() = CmpTurnoverCriterion.retail THEN pSalesSum(s, st);

pTurnoverBaseRest (Sku s, Stock st) = CASE
    WHEN cmpCriterionRunDefault() = CmpTurnoverCriterion.quantity THEN pAvgRestQty(s, st)
    WHEN cmpCriterionRunDefault() = CmpTurnoverCriterion.account THEN pAvgStockSum(s, st)
    WHEN cmpCriterionRunDefault() = CmpTurnoverCriterion.retail THEN pAvgRestRetail(s, st);

pTurnoverDays 'Оборачиваемость товарных остатков пред.' (Sku s, Stock st) =
    NUMERIC[18,3](round3(pTurnoverBaseRest(s, st) * prevDays() / pTurnoverBaseSales(s, st)))
        IF pTurnoverBaseSales(s, st) > 0 AND pTurnoverBaseRest(s, st) > 0;

cmpDiffPercent(NUMERIC a, NUMERIC b) =
    CASE
        WHEN b != 0.0 THEN NUMERIC[18,2](round2(((OVERRIDE a, 0.0) - b) * 100.0 / abs(b)))
        WHEN a != 0.0 THEN 100.0
        ELSE 0.0;

diffTurnover 'Оборачиваемость %' (Sku s, Stock st) = cmpDiffPercent(cTurnoverDays(s, st), pTurnoverDays(s, st));
diffSalesSum 'Продажи (прод.ц.) %' (Sku s, Stock st) = cmpDiffPercent(cSalesSum(s, st), pSalesSum(s, st));
diffSalesCost 'Продажи (учет.ц.) %' (Sku s, Stock st) = cmpDiffPercent(cSalesCost(s, st), pSalesCost(s, st));
diffAvgStock 'Сред. остаток %' (Sku s, Stock st) = cmpDiffPercent(cAvgStockSum(s, st), pAvgStockSum(s, st));
diffMargin 'Марж. доход %' (Sku s, Stock st) = cmpDiffPercent(cMargin(s, st), pMargin(s, st));
diffProfitability 'Рентабельность (+/- %)' (Sku s, Stock st) = cProfitability(s, st) (-) pProfitability(s, st);

cmpHasData(Sku s, Stock st) = cmpRowFilter(s, st) AND (
    cSalesSum(s, st) OR cSalesCost(s, st) OR cSalesQty(s, st) OR
        pSalesSum(s, st) OR pSalesCost(s, st) OR pSalesQty(s, st) OR
        cAvgRestQty(s, st) OR cAvgStockSum(s, st) OR cAvgRestRetail(s, st) OR
        pAvgRestQty(s, st) OR pAvgStockSum(s, st) OR pAvgRestRetail(s, st));

cmpSupplierName 'Наименование поставщика' (Sku s, Stock st) = name(cmpSupplier(s, st));

cmpReportJasper = DATA LOCAL STRING();

runCmpReport 'Сформировать отчет' () {
    cmpDateFromRun() <- cmpDateFrom();
    cmpDateToRun() <- cmpDateTo();
    prevDateFromRun() <- prevDateFrom();
    prevDateToRun() <- prevDateTo();
    cmpSalesTypeRun() <- cmpSalesType();
    cmpCriterionRun() <- cmpCriterion();
    cmpIncludeReturnsRun() <- cmpIncludeReturns();
}

FORM comparativeTurnoverReport 'Сравнительный анализ оборачиваемости'
    PROPERTIES() cmpDateFrom, cmpDateTo, prevDateFrom, prevDateTo
    PROPERTIES() nameCmpSalesType, nameCmpCriterion
    PROPERTIES() cmpIncludeReturns SHOWIF cmpShowIncludeReturns()

    PROPERTIES nameStockList() READONLY SHOWIF stockList()
    PROPERTIES cmpStocks 'Подразделения' = inSaleReportStocks() ON CHANGE changeStocksDialog() READONLYIF stockList()

    PROPERTIES cmpSkuListsCaption 'Списки товаров' = fNameSkuLists() READONLY SHOWIF fAnySkuList()
    PROPERTIES cmpSkuGroups 'Товарные группы' = fNameSkuGroups() READONLY SHOWIF fAnySkuGroup()
    PROPERTIES cmpSkus 'Товары' = fInSkus() ON CHANGE fSelectSkus() READONLYIF fAnySkuList() OR fAnySkuGroup()

    PROPERTIES fNameSupplierList() READONLY SHOWIF fSupplierList()
    PROPERTIES cmpSuppliers 'Поставщики' = fNameSuppliers() ON CHANGE { DIALOG fDialogSuppliers; } READONLYIF fSupplierList()

    OBJECTS report = (st = Stock, s = Sku)
    PROPERTIES(st) READONLY 'Код объекта учета' = id, 'Наименование объекта учета' = name
    PROPERTIES(s) READONLY
    'Код отдела' = idSkuGroup2, 'Наименование отдела' = nameSkuGroup2,
        'Код группы' = idSkuGroup3, 'Наименование группы' = nameSkuGroup3,
        'Код подгруппы' = idSkuGroup4, 'Наименование подгруппы' = nameSkuGroup4
    PROPERTIES(s, st) READONLY cmpSupplierName
    PROPERTIES(s) READONLY 'Код товара' = id, 'Наименование товара' = name

    PROPERTIES(s, st) READONLY BACKGROUND RGB(240, 248, 255)
    cTurnoverDays, cSalesSum, cSalesCost, cAvgStockSum, cMargin, cProfitability

    PROPERTIES(s, st) READONLY BACKGROUND RGB(255, 245, 238)
    pTurnoverDays, pSalesSum, pSalesCost, pAvgStockSum, pMargin, pProfitability

    PROPERTIES(s, st) READONLY BACKGROUND RGB(245, 255, 245)
    diffTurnover, diffSalesSum, diffSalesCost, diffAvgStock, diffMargin, diffProfitability

    FILTERS cmpHasData(s, st)
    ORDERS name(st), idSkuGroup2(s), idSkuGroup3(s), idSkuGroup4(s), name(s)

    REPORT cmpReportJasper()

    EVENTS ON INIT initCmpDates()
;

printSalesDynamicsReport 'Отчет по товарам' () {
    cmpReportJasper() <- 'ComparativeTurnoverReportSku.jrxml';
    PRINT comparativeTurnoverReport XLSX TO printReportFile;
    buildPrintReportFileName('comparativeTurnoverReportSku', 'Сравнительный анализ оборачиваемости (по товарам)');
    open(printReportFile(), builtPrintReportFileName());
} IMAGE 'print.png';

printCmpTurnoverReportGroup 'Отчет по товарным группам' () {
    cmpReportJasper() <- 'ComparativeTurnoverReportGroup.jrxml';
    PRINT comparativeTurnoverReport XLSX TO printReportFile;
    buildPrintReportFileName('comparativeTurnoverReportGroup', 'Сравнительный анализ оборачиваемости (по группам)');
    open(printReportFile(), builtPrintReportFileName());
} IMAGE 'print.png';

EXTEND FORM comparativeTurnoverReport
    PROPERTIES() runCmpReport
    PROPERTIES() DISABLEIF NOT cmpDateFromRun() OR NOT cmpDateToRun() OR NOT prevDateFromRun() OR NOT prevDateToRun()
    /*printCmpTurnoverReportSku,*/ printCmpTurnoverReportGroup
;

DESIGN comparativeTurnoverReport {
    NEW filters FIRST {
        alignment = STRETCH;
        NEW periods {
            horizontal = TRUE;
            alignment = STRETCH;
            MOVE PROPERTY(cmpDateFrom());
            MOVE PROPERTY(cmpDateTo());
            MOVE PROPERTY(prevDateFrom());
            MOVE PROPERTY(prevDateTo());
        }
        NEW criteria {
            horizontal = TRUE;
            alignment = STRETCH;
            MOVE PROPERTY(nameCmpSalesType());
            MOVE PROPERTY(nameCmpCriterion());
            MOVE PROPERTY(cmpIncludeReturns());
        }
        MOVE PROPERTY(nameStockList()) { alignment = STRETCH; }
        MOVE PROPERTY(cmpStocks) { alignment = STRETCH; }
        MOVE PROPERTY(cmpSkuListsCaption) { alignment = STRETCH; }
        MOVE PROPERTY(cmpSkuGroups) { alignment = STRETCH; }
        MOVE PROPERTY(cmpSkus) { alignment = STRETCH; }
        MOVE PROPERTY(fNameSupplierList()) { alignment = STRETCH; }
        MOVE PROPERTY(cmpSuppliers) { alignment = STRETCH; }
        NEW buttons {
            horizontal = TRUE;
            alignment = STRETCH;
            MOVE PROPERTY(runCmpReport()) { valueClass = 'btn-primary'; fontSize = 16; }
//            MOVE PROPERTY(printCmpTurnoverReportSku()) { valueClass = 'btn-primary'; }
            MOVE PROPERTY(printCmpTurnoverReportGroup()) { valueClass = 'btn-primary'; }
        }
    }
    BOX(report) {
        caption = 'Данные сравнительного анализа';
    }
}

opDateFrom 'Отчетный период (с)' = DATA LOCAL DATE ();
opDateTo 'Отчетный период (по)' = DATA LOCAL DATE ();
cmpOpDateFrom 'Сравнительный период (с)' = DATA LOCAL DATE ();
cmpOpDateTo 'Сравнительный период (по)' = DATA LOCAL DATE ();
opReportDate 'Отчетная дата' = DATA LOCAL DATE ();
cmpOpReportDate 'Сравнительная дата' = DATA LOCAL DATE ();

inOpStock 'Отм.' = DATA LOCAL BOOLEAN (Stock);
opStockCount() = GROUP SUM 1 IF inOpStock(Stock s);
opStockNames 'Подразделения' () = GROUP CONCAT (CONCAT ' ', id(Stock s), name(s)) IF inOpStock(s), ', ' ORDER id(s), s CHARWIDTH 40;

inOpStockDialog 'Отм.' = DATA LOCAL BOOLEAN (Stock);

opStockList = DATA LOCAL StockList();
nameOpStockList 'Список подразделений' () = name(opStockList());

changeOpStockList 'Список подразделений'() {
    DIALOG stockLists OBJECTS o INPUT DO {
        opStockList() <- o;
        inOpStockDialog(Stock s) <- in(o, s);
    }
}

deleteIncludeOpStockList 'Сбросить список'() {
    opStockList() <- NULL;
    inOpStockDialog(Stock s) <- NULL;
} ASON CONTEXTMENU nameOpStockList;

FORM dialogOpStocks 'Выбор подразделений'
    TREE stockTree a = BPSTRING[3], sg = StockGroup PARENT parent(sg)
    PROPERTIES READONLY VALUE(a), name(sg)
    ORDERS name(sg)
    FILTERS stringEqualsAll(a)

    OBJECTS s = Stock
    PROPERTIES(s) READONLY id, name, address, nameRegion
    PROPERTIES(s) inOpStockDialog READONLYIF opStockList()
    PROPERTIES changeOpStockList() TOOLBAR
    ORDERS name(s)
    FILTERS isParent(sg, s) OR (s IS Stock AND NOT sg),
        isCompany(s),
        countCompanyStock(sg)
    FILTERGROUP inactiveStock FILTER 'Активный' active(s) 'ctrl F10' DEFAULT
    FILTERGROUP select FILTER 'Отм.' inOpStockDialog(s) 'F9'

    EVENTS
        ON INIT {
            inOpStockDialog(Stock st) <- inOpStock(st);
        },
        ON OK {
            inOpStock(Stock st) <- inOpStockDialog(st);
        }
;

DESIGN dialogOpStocks {
    BOX {
        size = (1024, 768);
        NEW topContainer {
            horizontal = TRUE;
            fill = 1;
            MOVE BOX(TREE stockTree) { caption = 'Подразделения'; }
            MOVE BOX(s) {
                fill = 3;
                GRID(s) { defaultComponent = TRUE; }
                PROPERTY(name(s)) { charWidth = 35; }
            }
        }
        MOVE TOOLBARBOX;
    }
}

changeOpStocks() {
    DIALOG dialogOpStocks;
}

opRetailSalesSum (DepartmentStore ds, DATE d1, DATE d2) =
    GROUP SUM sum(SaleLedger sl)
        IF isPosted(sl)
            AND stock(sl) = ds
            AND sl IS DateSaleSkuLedger
            AND date(sl) >= d1
            AND date(sl) <= d2;

opRetailCostSum (DepartmentStore ds, DATE d1, DATE d2) =
    GROUP SUM costSum(SaleLedger sl)
        IF isPosted(sl)
            AND stock(sl) = ds
            AND sl IS DateSaleSkuLedger
            AND date(sl) >= d1
            AND date(sl) <= d2;

opRetailChecks (DepartmentStore ds, DATE d) =
    GROUP SUM 1
        IF isPosted(Receipt r)
            AND departmentStore(r) = ds
            AND date(r) = d
            AND NOT skip(r);

opPeriodChecks (DepartmentStore ds, DATE d1, DATE d2) =
    GROUP SUM 1
        IF isPosted(Receipt r)
            AND departmentStore(r) = ds
            AND date(r) >= d1
            AND date(r) <= d2
            AND NOT skip(r);

opPeriodSalesSum 'Сумма продаж (отчетный период)' (DepartmentStore ds) =
    opRetailSalesSum(ds, opDateFrom(), opDateTo());

cmpOpPeriodSalesSum 'Сумма продаж (сравнительный период)' (DepartmentStore ds) =
    opRetailSalesSum(ds, cmpOpDateFrom(), cmpOpDateTo());

opDaySalesSum 'Сумма продаж (отчетная дата)' (DepartmentStore ds) =
    opRetailSalesSum(ds, opReportDate(), opReportDate());

cmpOpDaySalesSum 'Сумма продаж (сравнительная дата)' (DepartmentStore ds) =
    opRetailSalesSum(ds, cmpOpReportDate(), cmpOpReportDate());

opDaySalesCostSum 'Сумма в учетных ценах (отчетная дата)' (DepartmentStore ds) =
    opRetailCostSum(ds, opReportDate(), opReportDate());

cmpOpDaySalesCostSum 'Сумма в учетных ценах (сравнительная дата)' (DepartmentStore ds) =
    opRetailCostSum(ds, cmpOpReportDate(), cmpOpReportDate());

opDaySalesDiff 'Разница (сумма продаж)' (DepartmentStore ds) =
    opDaySalesSum(ds) (-) cmpOpDaySalesSum(ds);

opDaySalesDiffPct 'Процент расхождения (сумма продаж)' (DepartmentStore ds) =
    NUMERIC[18,2](round2(opDaySalesDiff(ds) * 100.0 / cmpOpDaySalesSum(ds)))
        IF cmpOpDaySalesSum(ds) != 0 AND cmpOpDaySalesSum(ds);

opDayChecks 'Число чеков (отчетная дата)' (DepartmentStore ds) =
    opRetailChecks(ds, opReportDate());

cmpOpDayChecks 'Число чеков (сравнительная дата)' (DepartmentStore ds) =
    opRetailChecks(ds, cmpOpReportDate());

opPeriodChecksCount 'Число чеков (отчетный период)' (DepartmentStore ds) =
    opPeriodChecks(ds, opDateFrom(), opDateTo());

cmpOpPeriodChecksCount 'Число чеков (сравнительный период)' (DepartmentStore ds) =
    opPeriodChecks(ds, cmpOpDateFrom(), cmpOpDateTo());

opDayChecksDiffPct 'Процент расхождения (число чеков)' (DepartmentStore ds) =
    NUMERIC[18,2](round2(
            (NUMERIC[18,2](opDayChecks(ds)) - NUMERIC[18,2](cmpOpDayChecks(ds))) * 100.0
                / NUMERIC[18,2](cmpOpDayChecks(ds))))
        IF cmpOpDayChecks(ds) != 0 AND cmpOpDayChecks(ds);

opDayAvgCheck 'Средний чек (отчетная дата)' (DepartmentStore ds) =
    NUMERIC[18,2](round2(opDaySalesSum(ds) / NUMERIC[18,2](opDayChecks(ds))))
        IF opDayChecks(ds) != 0 AND opDayChecks(ds);

cmpOpDayAvgCheck 'Средний чек (сравнительная дата)' (DepartmentStore ds) =
    NUMERIC[18,2](round2(cmpOpDaySalesSum(ds) / NUMERIC[18,2](cmpOpDayChecks(ds))))
        IF cmpOpDayChecks(ds) != 0 AND cmpOpDayChecks(ds);

opPeriodAvgCheck 'Средний чек (отчетный период)' (DepartmentStore ds) =
    NUMERIC[18,2](round2(opPeriodSalesSum(ds) / NUMERIC[18,2](opPeriodChecksCount(ds))))
        IF opPeriodChecksCount(ds) != 0 AND opPeriodChecksCount(ds);

cmpOpPeriodAvgCheck 'Средний чек (сравнительный период)' (DepartmentStore ds) =
    NUMERIC[18,2](round2(cmpOpPeriodSalesSum(ds) / NUMERIC[18,2](cmpOpPeriodChecksCount(ds))))
        IF cmpOpPeriodChecksCount(ds) != 0 AND cmpOpPeriodChecksCount(ds);

opDayMarkup 'Наценка (отчетная дата), %' (DepartmentStore ds) =
    NUMERIC[18,2](round2(
            (opDaySalesSum(ds) (-) opDaySalesCostSum(ds)) * 100.0 / opDaySalesCostSum(ds)))
        IF opDaySalesCostSum(ds) != 0 AND opDaySalesCostSum(ds);

cmpOpDayMarkup 'Наценка (сравнительная дата), %' (DepartmentStore ds) =
    NUMERIC[18,2](round2(
            (cmpOpDaySalesSum(ds) (-) cmpOpDaySalesCostSum(ds)) * 100.0 / cmpOpDaySalesCostSum(ds)))
        IF cmpOpDaySalesCostSum(ds) != 0 AND cmpOpDaySalesCostSum(ds);

opHasData(DepartmentStore ds) = inOpStock(ds) AND (
    opPeriodSalesSum(ds) OR cmpOpPeriodSalesSum(ds) OR
        opDaySalesSum(ds) OR cmpOpDaySalesSum(ds));

initOpDates() {
    opDateTo() <- currentDate();
    opDateFrom() <- firstDayOfMonth(currentDate());
    opReportDate() <- currentDate();
    cmpOpDateTo() <- sumYear(currentDate(), -1);
    cmpOpDateFrom() <- firstDayOfMonth(sumYear(currentDate(), -1));
    cmpOpReportDate() <- sumYear(currentDate(), -1);
}

FORM operativeReport 'Оперативный отчет'
    PROPERTIES() opDateFrom, opDateTo, opReportDate
    PROPERTIES() cmpOpDateFrom, cmpOpDateTo, cmpOpReportDate
    PROPERTIES() nameOpStockList READONLY SHOWIF opStockList()
    PROPERTIES() opStockNames ON CHANGE changeOpStocks() READONLYIF opStockList()

    OBJECTS ds = DepartmentStore
    PROPERTIES(ds) READONLY
    'Код подразделения' = id,
        'Наименование подразделения' = name
    PROPERTIES(ds) READONLY
    opPeriodSalesSum,
        cmpOpPeriodSalesSum,
        opPeriodChecksCount,
        cmpOpPeriodChecksCount,
        opPeriodAvgCheck,
        cmpOpPeriodAvgCheck,
        opDaySalesSum,
        cmpOpDaySalesSum,
        opDaySalesDiff,
        opDaySalesDiffPct,
        opDayAvgCheck,
        cmpOpDayAvgCheck,
        opDayChecks,
        cmpOpDayChecks,
        opDayChecksDiffPct,
        opDayMarkup,
        cmpOpDayMarkup
    FILTERS opHasData(ds)
    ORDERS id(ds)

    EVENTS ON INIT initOpDates()
;

@definePrintReport(operativeReport, 'Оперативный отчет');

EXTEND FORM operativeReport
    PROPERTIES() DISABLEIF NOT opDateFrom() OR NOT opDateTo() OR NOT opReportDate()
        OR NOT cmpOpDateFrom() OR NOT cmpOpDateTo() OR NOT cmpOpReportDate()
    operativeReport
;

DESIGN operativeReport {
    NEW filters FIRST {
        alignment = STRETCH;
        NEW topRow {
            horizontal = TRUE;
            alignment = STRETCH;
            MOVE PROPERTY(operativeReport()) { valueClass = 'btn-primary'; }
        }
        MOVE PROPERTY(nameOpStockList()) { alignment = STRETCH; }
        MOVE PROPERTY(opStockNames()) { alignment = STRETCH; }
        NEW periodsBlock {
            alignment = STRETCH;
            NEW reportPeriod {
                horizontal = TRUE;
                alignment = STRETCH;
                MOVE PROPERTY(opDateFrom());
                MOVE PROPERTY(opDateTo());
                MOVE PROPERTY(opReportDate());
            }
            NEW cmpPeriod {
                horizontal = TRUE;
                alignment = STRETCH;
                MOVE PROPERTY(cmpOpDateFrom());
                MOVE PROPERTY(cmpOpDateTo());
                MOVE PROPERTY(cmpOpReportDate());
            }
        }
    }
    BOX(ds) {
        caption = 'Данные по подразделениям';
    }
}

avgDaysInPeriod() = daysBetween(dateFrom(), dateTo());

avgSaleFilter(SaleLedger sl, Sku s, DepartmentStore st) =
    sku(sl) = s AND stock(sl) = st AND active(sl)
        AND isRetail(sl)
        AND date(sl) >= dateFrom() AND date(sl) <= dateTo();

avgRetailSalesQty 'Количество продаж через кассу' (Sku s, DepartmentStore st) =
    (GROUP SUM quantity(SaleLedger sl) IF avgSaleFilter(sl, s, st) AND isRetailSale(sl))
        (-)
        (GROUP SUM quantity(SaleLedger sl) IF avgSaleFilter(sl, s, st) AND isRetailReturn(sl));

avgDailySales 'Средняя реализация в день' (Sku s, DepartmentStore st) =
    NUMERIC[18,3](round3(avgRetailSalesQty(s, st) / avgDaysInPeriod())) IF avgDaysInPeriod() > 0;

avgRetailPrice 'Текущая отпускная цена в подразделении' (Sku s, DepartmentStore st) =
    retailPriceA(s, st, toDateTime(dateTo()));

avgAccountPrice 'Учетная цена' (Sku s, DepartmentStore st) =
    accountPriceA(s, st, toDateTime(dateTo()));

avgSalesRetailSum (Sku s, DepartmentStore st) =
    (GROUP SUM sum(SaleLedger sl) IF avgSaleFilter(sl, s, st) AND isRetailSale(sl))
        (-)
        (GROUP SUM sum(SaleLedger sl) IF avgSaleFilter(sl, s, st) AND isRetailReturn(sl));

avgSalesAccountSum (Sku s, DepartmentStore st) =
    (GROUP SUM round2(quantity(SaleLedger sl) * accountPriceA(sku(sl), stock(sl), toDateTime(date(sl))))
        IF avgSaleFilter(sl, s, st) AND isRetailSale(sl))
        (-)
        (GROUP SUM round2(quantity(SaleLedger sl) * accountPriceA(sku(sl), stock(sl), toDateTime(date(sl))))
            IF avgSaleFilter(sl, s, st) AND isRetailReturn(sl));

avgMarginPct 'Маржа %' (Sku s, DepartmentStore st) =
    NUMERIC[18,2](round2((avgSalesRetailSum(s, st) (-) avgSalesAccountSum(s, st)) * 100.0 / avgSalesRetailSum(s, st)))
        IF avgSalesRetailSum(s, st) > 0;

avgBalance 'Текущий остаток в подразделении' (Sku s, DepartmentStore st) =
    balanceA(s, st, dateTo());

avgDaysOfSupply 'Запас в днях' (Sku s, DepartmentStore st) =
    NUMERIC[18,2](round2(avgBalance(s, st) / avgDailySales(s, st)))
        IF avgDailySales(s, st) > 0;

avgLastSupplier 'Последний поставщик в компании' (Sku s, DepartmentStore st) =
    CONCAT ' - ', id(supplier(lastPurchaseDetail(s, st))), name(supplier(lastPurchaseDetail(s, st)));

avgLastPurchaseDate 'Дата последней поставки' (Sku s, DepartmentStore st) = date(lastPurchaseDetail(s, st));

avgLastPurchasePrice 'Цена в последней поставке' (Sku s, DepartmentStore st) = price(lastPurchaseDetail(s, st));

avgSkuGroupPath 'Категория' (Sku s) = CONCAT '/',
    nameSkuGroup2(s), nameSkuGroup3(s), nameSkuGroup4(s);

avgHasData(Sku s, DepartmentStore st) = inSaleReport(st) AND fSkuFilter(s) AND
    (avgRetailSalesQty(s, st) OR avgBalance(s, st) OR avgLastPurchaseDate(s, st));

avgHeaderLastSupplier 'Последний поставщик в компании' (DepartmentStore st) = stockFullName(st) + ' | Последний поставщик в компании' IF st IS DepartmentStore;
avgHeaderLastPurchaseDate 'Дата последней поставки' (DepartmentStore st) = stockFullName(st) + ' | Дата последней поставки' IF st IS DepartmentStore;
avgHeaderLastPurchasePrice 'Цена в последней поставке' (DepartmentStore st) = stockFullName(st) + ' | Цена в последней поставке' IF st IS DepartmentStore;
avgHeaderRetailPrice 'Текущая отпускная цена' (DepartmentStore st) = stockFullName(st) + ' | Текущая отпускная цена в подразделении' IF st IS DepartmentStore;
avgHeaderSalesQty 'Количество продаж' (DepartmentStore st) = stockFullName(st) + ' | Количество продаж через кассу' IF st IS DepartmentStore;
avgHeaderDailySales 'Средняя реализация в день' (DepartmentStore st) = stockFullName(st) + ' | Средняя реализация в день' IF st IS DepartmentStore;
avgHeaderMarginPct 'Маржа %' (DepartmentStore st) = stockFullName(st) + ' | Маржа %' IF st IS DepartmentStore;
avgHeaderBalance 'Текущий остаток' (DepartmentStore st) = stockFullName(st) + ' | Текущий остаток в подразделении' IF st IS DepartmentStore;
avgHeaderDaysOfSupply 'Запас в днях' (DepartmentStore st) = stockFullName(st) + ' | Запас в днях' IF st IS DepartmentStore;

initAvgDates() {
    dateFrom() <- firstDayOfMonth(currentDate());
    dateTo() <- currentDate();
}

FORM avgDailySalesReport 'Средняя реализация в день'
    PROPERTIES() dateFrom, dateTo
    PROPERTIES nameStockList() READONLY SHOWIF stockList()
    PROPERTIES avgStocks 'Подразделения' = inSaleReportStocks() ON CHANGE changeStocksDialog() READONLYIF stockList()
    PROPERTIES avgSkuListsCaption 'Списки товаров' = fNameSkuLists() READONLY SHOWIF fAnySkuList()
    PROPERTIES avgSkuGroups 'Товарные группы' = fNameSkuGroups() READONLY SHOWIF fAnySkuGroup()
    PROPERTIES avgSkus 'Товары' = fInSkus() ON CHANGE fSelectSkus() READONLYIF fAnySkuList() OR fAnySkuGroup()

    OBJECTS st = DepartmentStore
    FILTERS inSaleReport(st)

    OBJECTS s = Sku
    PROPERTIES(s) READONLY 'Код товара' = id, 'Баркод' = idBarcode, 'Наименование рабочее(полное)' = name
    PROPERTIES READONLY 'Категория' = avgSkuGroupPath(s)
    PROPERTIES READONLY COLUMNS 'st' (st)
    avgLastSupplier(s, st) HEADER avgHeaderLastSupplier(st),
        avgLastPurchaseDate(s, st) HEADER avgHeaderLastPurchaseDate(st),
        avgLastPurchasePrice(s, st) HEADER avgHeaderLastPurchasePrice(st),
        avgRetailPrice(s, st) HEADER avgHeaderRetailPrice(st),
        avgRetailSalesQty(s, st) HEADER avgHeaderSalesQty(st),
        avgDailySales(s, st) HEADER avgHeaderDailySales(st),
        avgMarginPct(s, st) HEADER avgHeaderMarginPct(st),
        avgBalance(s, st) HEADER avgHeaderBalance(st),
        avgDaysOfSupply(s, st) HEADER avgHeaderDaysOfSupply(st)
    FILTERS (GROUP MAX avgHasData(s, DepartmentStore dst) IF inSaleReport(dst))
    ORDERS avgSkuGroupPath(s), name(s)

    EVENTS ON INIT initAvgDates()
;

FORM avgDailySalesReportPrint 'Средняя реализация в день'
    PROPERTIES() dateFrom, dateTo
    PROPERTIES nameStockList() READONLY SHOWIF stockList()
    PROPERTIES avgStocksP 'Подразделения' = inSaleReportStocks() READONLYIF stockList()
    PROPERTIES avgSkuListsCaptionP 'Списки товаров' = fNameSkuLists() READONLY SHOWIF fAnySkuList()
    PROPERTIES avgSkuGroupsP 'Товарные группы' = fNameSkuGroups() READONLY SHOWIF fAnySkuGroup()
    PROPERTIES avgSkusP 'Товары' = fInSkus() READONLYIF fAnySkuList() OR fAnySkuGroup()

    OBJECTS st = DepartmentStore
    PROPERTIES(st) READONLY id, name, stockFullName
    FILTERS inSaleReport(st)
    ORDERS stockFullName(st)

    OBJECTS s = Sku
    PROPERTIES(s) READONLY id, idBarcode, name
    PROPERTIES READONLY avgSkuGroupPath(s)
    PROPERTIES(s, st) READONLY
    avgLastSupplier,
        avgLastPurchaseDate,
        avgLastPurchasePrice,
        avgRetailPrice,
        avgRetailSalesQty,
        avgDailySales,
        avgMarginPct,
        avgBalance,
        avgDaysOfSupply
    FILTERS avgHasData(s, st)
    ORDERS stockFullName(st), avgSkuGroupPath(s), id(s)
;

@definePrintReport(avgDailySalesReportPrint, 'Средняя реализация в день');

EXTEND FORM avgDailySalesReport
    PROPERTIES() DISABLEIF NOT dateFrom() OR NOT dateTo() avgDailySalesReportPrint
;

DESIGN avgDailySalesReport {
    NEW filters FIRST {
        alignment = STRETCH;
        NEW topRow {
            horizontal = TRUE;
            alignment = STRETCH;
            MOVE PROPERTY(dateFrom());
            MOVE PROPERTY(dateTo());
            MOVE PROPERTY(avgDailySalesReportPrint()) { valueClass = 'btn-primary'; }
        }
        MOVE PROPERTY(nameStockList()) { alignment = STRETCH; }
        MOVE PROPERTY(avgStocks) { alignment = STRETCH; }
        MOVE PROPERTY(avgSkuListsCaption) { alignment = STRETCH; }
        MOVE PROPERTY(avgSkuGroups) { alignment = STRETCH; }
        MOVE PROPERTY(avgSkus) { alignment = STRETCH; }
    }
    REMOVE BOX(st);
    MOVE BOX(s) {
        fill = 1;
        caption = 'Средняя реализация в день';
    }
    MOVE TOOLBARBOX;
}

mcReportDate 'На дату' = DATA LOCAL DATE ();
mcMarkupLessThan 'Наценка на товар менее, %' = DATA LOCAL NUMERIC[10,2] ();

mcIsRetailIdPLT(PriceListType plt) = isSubstring(lower(id(plt)), 'retail');

inMcPriceListType 'Отм.' = DATA LOCAL BOOLEAN (PriceListType);
nameMcPriceListTypes 'Виды цен продажи' () = GROUP CONCAT name(PriceListType plt) IF inMcPriceListType(plt), ', ' ORDER name(plt), plt CHARWIDTH 30;

FORM dialogMcPriceListTypes 'Выбор видов цен продажи'
    OBJECTS plt = PriceListType
    PROPERTIES(plt) inMcPriceListType
    PROPERTIES(plt) READONLY name
    FILTERS mcIsRetailIdPLT(plt)
    ORDERS name(plt)
;

selectAllMcPriceListTypes 'Выбрать все' () {
    inMcPriceListType(PriceListType plt) <- TRUE WHERE mcIsRetailIdPLT(plt);
} ASON CONTEXTMENU nameMcPriceListTypes;

deselectAllMcPriceListTypes 'Сбросить все' () {
    inMcPriceListType(PriceListType plt) <- NULL;
} ASON CONTEXTMENU nameMcPriceListTypes;

anyMcCustomer() = GROUP MAX inCustomer(LegalEntity l);

mcAccountPrice 'Средняя закуп. цена' (Sku s, Stock st) =
    accountPriceA(s, st, toDateTime(mcReportDate()));

mcInvoiceDetail(Sku s, Stock st, PriceListType plt) =
    GROUP LAST Sale.InvoiceDetail d
    ORDER dateTime(d), d
    WHERE active(d)
        AND sku(d) == s
        AND Sale.supplierStock(d) == st
        AND Sale.priceListType(d) == plt
        AND date(d) <= mcReportDate()
        AND (NOT anyMcCustomer() OR inCustomer(Sale.customer(d)));

mcInvoicePrice(Sku s, Stock st, PriceListType plt) =
    invoicePrice(mcInvoiceDetail(s, st, plt));

mcSalePrice 'Цена продажи' (Sku s, Stock st, PriceListType plt) =
    OVERRIDE mcInvoicePrice(s, st, plt),
        prevPriceA(plt, s, st, toDateTime(mcReportDate()));

mcMarkupPct 'Наценка %' (Sku s, Stock st, PriceListType plt) =
    NUMERIC[10,2](round2((mcSalePrice(s, st, plt) (-) mcAccountPrice(s, st)) * 100.0 / mcAccountPrice(s, st)))
        IF mcAccountPrice(s, st) > 0;

mcSaleExists(Sku s, Stock st) =
    GROUP MAX 1 IF active(SaleLedger sl)
        AND sku(sl) == s
        AND stock(sl) == st
        AND date(sl) <= mcReportDate()
        AND (NOT anyMcCustomer() OR inCustomer(customer(sl)));

mcRowFilter(Sku s, Stock st, PriceListType plt) =
    inSaleReport(st)
        AND fSkuFilter(s)
        AND inMcPriceListType(plt)
        AND mcSalePrice(s, st, plt)
        AND mcSaleExists(s, st)
        AND (NOT mcMarkupLessThan() OR mcMarkupPct(s, st, plt) < mcMarkupLessThan());

initMcDates() {
    mcReportDate() <- currentDate();
    mcMarkupLessThan() <- 100.0;
    inMcPriceListType(PriceListType plt) <- TRUE WHERE mcIsRetailIdPLT(plt);
}

FORM markupControlReport 'Контроль наценки товара'
    PROPERTIES() mcReportDate, mcMarkupLessThan
    PROPERTIES nameStockList() READONLY SHOWIF stockList()
    PROPERTIES mcStocks 'Подразделения' = inSaleReportStocks() ON CHANGE changeStocksDialog() READONLYIF stockList()
    PROPERTIES mcSkuListsCaption 'Списки товаров' = fNameSkuLists() READONLY SHOWIF fAnySkuList()
    PROPERTIES mcSkuGroupsCaption 'Товарные группы' = fNameSkuGroups() READONLY SHOWIF fAnySkuGroup()
    PROPERTIES mcSkusCaption 'Товары' = fInSkus() ON CHANGE fSelectSkus() READONLYIF fAnySkuList() OR fAnySkuGroup()
    PROPERTIES nameCustomerList() READONLY SHOWIF customerList()
    PROPERTIES mcCustomersCaption 'Покупатели' = nameCustomers() ON CHANGE { DIALOG dialogCustomers; } READONLYIF customerList()
    PROPERTIES mcPriceTypesCaption 'Виды цен продажи' = nameMcPriceListTypes() ON CHANGE { DIALOG dialogMcPriceListTypes; }

    OBJECTS report = (st = Stock, s = Sku, plt = PriceListType)
    PROPERTIES(st) READONLY stockFullName
    PROPERTIES(s) READONLY skuGroup2Full, skuGroup3Full, skuGroup4Full
    PROPERTIES(s) READONLY 'Код товара' = id, 'Наименование товара' = name, 'Баркод' = idBarcode
    PROPERTIES(s, st) READONLY mcAccountPrice
    PROPERTIES(s, st, plt) READONLY mcSalePrice, mcMarkupPct
    PROPERTIES(plt) READONLY 'Название вида цены продажи' = name
    FILTERS mcRowFilter(s, st, plt)
    ORDERS stockFullName(st), skuGroup2Full(s), skuGroup3Full(s), skuGroup4Full(s), id(s), name(plt)

    EVENTS ON INIT initMcDates()
;

FORM markupControlReportPrint 'Контроль наценки товара'
    PROPERTIES() mcReportDate

    OBJECTS report = (st = Stock, s = Sku, plt = PriceListType)
    PROPERTIES(st) READONLY stockFullName
    PROPERTIES(s) READONLY skuGroup2Full, skuGroup3Full, skuGroup4Full
    PROPERTIES(s) READONLY id, name, idBarcode
    PROPERTIES READONLY mcAccountPrice(s, st)
    PROPERTIES(plt) READONLY name
    PROPERTIES READONLY mcSalePrice(s, st, plt), mcMarkupPct(s, st, plt)
    FILTERS mcRowFilter(s, st, plt)
    ORDERS stockFullName(st), skuGroup2Full(s), skuGroup3Full(s), skuGroup4Full(s), id(s), name(plt)
;

printMcReport 'Печать' () {
    PRINT markupControlReportPrint XLSX TO printReportFile;
    buildPrintReportFileName('markupControlReportPrint', 'Контроль наценки товара');
    open(printReportFile(), builtPrintReportFileName());
} IMAGE 'print.png';

EXTEND FORM markupControlReport
    PROPERTIES() printMcReport
;

DESIGN markupControlReport {
    NEW filters FIRST {
        alignment = STRETCH;
        NEW topRow {
            horizontal = TRUE;
            MOVE PROPERTY(mcReportDate());
            MOVE PROPERTY(mcMarkupLessThan());
            MOVE PROPERTY(printMcReport()) { valueClass = 'btn-warning'; }
        }
        MOVE PROPERTY(nameStockList()) { alignment = STRETCH; }
        MOVE PROPERTY(mcStocks) { alignment = STRETCH; }
        MOVE PROPERTY(mcSkuListsCaption) { alignment = STRETCH; }
        MOVE PROPERTY(mcSkuGroupsCaption) { alignment = STRETCH; }
        MOVE PROPERTY(mcSkusCaption) { alignment = STRETCH; }
        MOVE PROPERTY(nameCustomerList()) { alignment = STRETCH; }
        MOVE PROPERTY(mcCustomersCaption) { alignment = STRETCH; }
        MOVE PROPERTY(mcPriceTypesCaption) { alignment = STRETCH; }
    }
    BOX(report) {
        caption = 'Контроль наценки товара';
    }
}

amxReportDate 'На дату' = DATA LOCAL DATE ();
amxOnlyInContract 'Только товары в действующих спецификациях договоров' = DATA LOCAL BOOLEAN ();

amxContractSku = DATA LOCAL ContractSku ();
amxNameContractSku 'Договор (спецификация)' () = OVERRIDE description(amxContractSku()), 'Все договоры' CHARWIDTH 30;

amxPriceList = DATA LOCAL PriceList ();
amxNamePriceList 'Прайс-лист' () = OVERRIDE description(amxPriceList()), 'Все прайс-листы' CHARWIDTH 30;

amxCalculated = DATA LOCAL BOOLEAN ();

deleteAmxContractSku 'Сбросить выбранный договор' () {
    amxContractSku() <- NULL;
    amxPriceList() <- NULL;
    amxCalculated() <- NULL;
} ASON CONTEXTMENU amxNameContractSku;

deleteAmxPriceList 'Сбросить выбранный прайс-лист' () {
    amxPriceList() <- NULL;
    amxCalculated() <- NULL;
} ASON CONTEXTMENU amxNamePriceList;

amxIsSupplierPriceList(PriceList pl) =
    operation(pl) = PriceList.operation('supplier');

amxActiveContract(ContractSku c) =
    dateFrom(c) <= amxReportDate()
        AND NOT (dateTo(c) < amxReportDate());

amxActivePriceList(PriceList pl) =
    isPosted(pl) AND isActive(pl, toDateTime(amxReportDate()));

amxValidPriceList(PriceList pl) =
    amxActivePriceList(pl)
        AND amxIsSupplierPriceList(pl)
        AND contractSku(pl)
        AND amxActiveContract(contractSku(pl));

amxSupplierMatch(PriceList pl) =
    NOT fAnySupplier() OR fInSupplier(company(pl));

amxContractMatch(PriceList pl) =
    NOT amxContractSku() OR contractSku(pl) = amxContractSku();

amxPriceListMatch(PriceList pl) =
    NOT amxPriceList() OR pl = amxPriceList();

amxPriceListSuitable(PriceList pl) =
    amxValidPriceList(pl)
        AND amxSupplierMatch(pl)
        AND amxContractMatch(pl)
        AND amxPriceListMatch(pl);

amxContractSupplierMatch(ContractSku c) =
    NOT fAnySupplier() OR fInSupplier(partyA(c));

amxContractSuitable(ContractSku c) =
    amxActiveContract(c)
        AND amxContractSupplierMatch(c);

amxPriceListForDialogSuitable(PriceList pl) =
    amxValidPriceList(pl)
        AND amxSupplierMatch(pl)
        AND amxContractMatch(pl);

amxInActivePriceList(Sku s) =
    GROUP MAX 1 IF active(PriceListDetail pld)
        AND sku(pld) = s
        AND amxPriceListSuitable(priceList(pld));

amxContractSupplierName 'Поставщик по договору' (Sku s) =
    GROUP CONCAT name(company(PriceList pl)) IF active(PriceListDetail pld)
        AND sku(pld) = s
        AND priceList(pld) = pl
        AND amxPriceListSuitable(pl), ',' ORDER id(company(pl)), pl CHARWIDTH 30;

amxLastPriceListDetail(Sku s) = GROUP LAST PriceListDetail pld
ORDER date(priceList(pld)), pld
WHERE active(pld)
    AND sku(pld) = s
    AND amxPriceListSuitable(priceList(pld));

amxContractPrice 'Цена по спецификации договора' (Sku s) = price(amxLastPriceListDetail(s));

amxSkuFilter(Sku s) =
    fSkuFilter(s) AND (NOT amxOnlyInContract() OR amxInActivePriceList(s));

amxRangeActive(Range.Range r) = NOT inactive(r) AND r IS Range.Range;

amxSkuInAnyStock(Sku s, Range.Range r) =
    GROUP MAX 1 IF skuInRangeForStock(s, r, Stock st, amxReportDate()) AND st IS Stock;

amxRangeMarker 'Признак вхождения' (Sku s, Range.Range r) =
    ('+' IF amxRangeActive(r) AND amxSkuInAnyStock(s, r)) CHARWIDTH 20;

amxSkuHasData(Sku s) =
    amxCalculated() AND amxSkuFilter(s);

initAmxDates() {
    amxReportDate() <- currentDate();
    amxCalculated() <- NULL;
}

calculateContractAssortmentMatrixReport '🔄 Расчет' () {
    amxCalculated() <- TRUE;
}

resetAmxCalculated() {
    amxCalculated() <- NULL;
}

FORM contractAssortmentMatrixContractsDialog 'Выбор договора'
    OBJECTS c = ContractSku
    PROPERTIES(c) READONLY seriesNumber, dateFrom, dateTo, namePartyA, namePartyB
    FILTERS amxContractSuitable(c)
;

FORM contractAssortmentMatrixPriceListsDialog 'Выбор прайс-листа'
    OBJECTS p = PriceList
    PROPERTIES(p) READONLY number, series, date, fromDate, toDate, nameCompany, nameCompanyStock
    FILTERS amxPriceListForDialogSuitable(p)
;

FORM contractAssortmentMatrixReport 'Ассортимент товаров по матрицам и спецификациям договоров'
    PROPERTIES() amxReportDate ON CHANGE { INPUT d = DATE DO { amxReportDate() <- d; resetAmxCalculated(); } }
    PROPERTIES() amxOnlyInContract ON CHANGE { INPUT b = BOOLEAN DO { amxOnlyInContract() <- b; resetAmxCalculated(); } }
    PROPERTIES amxSkuListsCaption 'Списки товаров' = fNameSkuLists() READONLY SHOWIF fAnySkuList()
    PROPERTIES amxSkuGroupsCaption 'Товарные группы' = fNameSkuGroups() READONLY SHOWIF fAnySkuGroup()
    PROPERTIES amxSkusCaption 'Товары' = fInSkus() ON CHANGE { fSelectSkus(); resetAmxCalculated(); } READONLYIF fAnySkuList() OR fAnySkuGroup()
    PROPERTIES fNameSupplierList() READONLY SHOWIF fSupplierList() AND amxOnlyInContract()
    PROPERTIES amxSuppliersCaption 'Поставщики' = fNameSuppliers() ON CHANGE { DIALOG fDialogSuppliers; resetAmxCalculated(); } SHOWIF amxOnlyInContract() READONLYIF fSupplierList()
    PROPERTIES amxContractCaption 'Договор (спецификация)' = amxNameContractSku() ON CHANGE { DIALOG contractAssortmentMatrixContractsDialog OBJECTS c INPUT DO { amxContractSku() <- c; resetAmxCalculated(); } } SHOWIF amxOnlyInContract()
    PROPERTIES amxPriceListCaption 'Прайс-лист' = amxNamePriceList() ON CHANGE { DIALOG contractAssortmentMatrixPriceListsDialog OBJECTS p INPUT DO { amxPriceList() <- p; resetAmxCalculated(); } } SHOWIF amxOnlyInContract()
    PROPERTIES() calculateContractAssortmentMatrixReport

    OBJECTS s = Sku
    PROPERTIES READONLY
    skuGroupCaption 'Товарная группа' = skuGroup3Full(s),
        barcode 'Штрихкод' = idBarcode(s),
        skuId 'Код товара' = id(s),
        skuName 'Наименование товара' = name(s)
    PROPERTIES READONLY supplierFromContract 'Поставщик по договору' = amxContractSupplierName(s)
    PROPERTIES READONLY contractPrice 'Цена по спецификации договора' = amxContractPrice(s)
    PROPERTIES(s) READONLY priceSegmentCaption 'Ценовой сегмент' = namePriceSegment

    OBJECTS r = Range.Range
    FILTERS amxRangeActive(r)

    PROPERTIES READONLY amxRangeMarker(s, r) COLUMNS 'range' (r) HEADER name(r)

    FILTERS amxSkuHasData(s)

    EVENTS ON INIT initAmxDates()
;

FORM contractAssortmentMatrixReportPrint 'Ассортимент товаров по матрицам и спецификациям договоров'
    PROPERTIES() amxReportDate

    OBJECTS s = Sku
    PROPERTIES READONLY
    skuGroupCaption 'Товарная группа' = skuGroup3Full(s),
        barcode 'Штрихкод' = idBarcode(s),
        skuId 'Код товара' = id(s),
        skuName 'Наименование товара' = name(s)
    PROPERTIES READONLY supplierFromContract 'Поставщик по договору' = amxContractSupplierName(s)
    PROPERTIES READONLY contractPrice 'Цена по спецификации договора' = amxContractPrice(s)
    PROPERTIES(s) READONLY priceSegmentCaption 'Ценовой сегмент' = namePriceSegment

    OBJECTS r = Range.Range
    FILTERS amxRangeActive(r)

    PROPERTIES READONLY amxRangeMarker(s, r) COLUMNS 'range' (r) HEADER name(r)

    FILTERS amxSkuHasData(s)
;

printContractAssortmentMatrixReport '🖨️ Печать' () {
    PRINT contractAssortmentMatrixReportPrint XLSX TO printReportFile;
    buildPrintReportFileName('contractAssortmentMatrixReportPrint', 'Ассортимент товаров по матрицам и спецификациям договоров');
    open(printReportFile(), builtPrintReportFileName());
};

EXTEND FORM contractAssortmentMatrixReport
    PROPERTIES() DISABLEIF NOT amxReportDate() OR NOT amxCalculated() printContractAssortmentMatrixReport
;

DESIGN contractAssortmentMatrixReport {
    NEW filters FIRST {
        alignment = STRETCH;
        NEW topRow {
            horizontal = TRUE;
            alignment = STRETCH;
            MOVE PROPERTY(amxReportDate());
            MOVE PROPERTY(calculateContractAssortmentMatrixReport()) { valueClass = 'btn-primary'; }
            MOVE PROPERTY(printContractAssortmentMatrixReport()) { valueClass = 'btn-primary'; }
            NEW row1right {
                horizontal = TRUE;
                fill = 1;
                childrenAlignment = END;
                MOVE PROPERTY(amxOnlyInContract());
            }
        }
        MOVE PROPERTY(amxSkuListsCaption);
        MOVE PROPERTY(amxSkuGroupsCaption);
        MOVE PROPERTY(amxSkusCaption);
        MOVE PROPERTY(fNameSupplierList());
        MOVE PROPERTY(amxSuppliersCaption);
        NEW contractRow {
            horizontal = TRUE;
            alignment = STRETCH;
            MOVE PROPERTY(amxContractCaption);
            MOVE PROPERTY(amxPriceListCaption);
        }
    }
    BOX(s) {
        caption = 'Товары и их вхождение в ассортиментные матрицы';
    }
}

NAVIGATOR {
    salesReports {
        NEW bestWorstProducts;
        NEW salesDynamicsReport;
        NEW assortmentMatrixReport;
        NEW assortmentHistoryReport;
        NEW comparativeTurnoverReport;
        NEW operativeReport;
        NEW avgDailySalesReport;
        NEW markupControlReport;
        NEW contractAssortmentMatrixReport;
    }
}