MODULE YandexDeliveryDefault;

REQUIRE SaleInternetPickingTerminalOrder, Store, ItemInternet;

NAMESPACE YandexDelivery;

@defineLogRotate(yandexDelivery, 5, weekly);

//настройки Яндекс.Доставка
tokenYandexDelivery 'Токен Яндекс.Доставка' = DATA STRING ();
skipClientNotify 'Не отправлять отправителю / получателю смс-нотификации, когда к нему направится курьер' = DATA BOOLEAN ();
skipDoorToDoor 'Отказ от доставки до двери (курьер доставит заказ только на улицу, до подъезда)' = DATA BOOLEAN ();
optionalReturnDelivery 'Не требуется возврат товаров в случае отмены заказа' = DATA BOOLEAN ();
bufferWeightDiff 'Буфер веса для выбора тарифа (в кг)' = DATA NUMERIC[5,3] ();
skipEmergencyNotify 'Не отправлять нотификации emergency контакту' = DATA BOOLEAN ();
skipConfirmationClient 'Не требовать подтверждения клиента' = DATA BOOLEAN ();
commentTextDelivery 'Текст комментария для курьера' = DATA STRING ();
defaultTaxiClass 'Тариф по умолчанию' = DATA STRING[20] ();
weightChangeTaxiClass 'Пограничный вес' = DATA INTEGER ();
enableLogYandexDelivery 'Логировать все запросы ЯндексДоставки' = DATA BOOLEAN ();
sendSflatDetail 'Отправлять квартиру в sflat' = DATA BOOLEAN ();

logToFileYD(STRING s, STRING t){
    IF enableLogYandexDelivery() THEN logToFile(s, t);
}

EXTEND FORM integrationData
    PROPERTIES () tokenYandexDelivery, skipClientNotify, skipDoorToDoor, skipConfirmationClient, optionalReturnDelivery, sendSflatDetail,
        bufferWeightDiff, skipEmergencyNotify, commentTextDelivery, defaultTaxiClass, weightChangeTaxiClass, enableLogYandexDelivery
;

DESIGN integrationData{
    delivery{
        NEW yandexDelivery{
            caption = 'Яндекс.Доставка';
            MOVE PROPERTY (tokenYandexDelivery());
            MOVE PROPERTY (skipClientNotify());
            MOVE PROPERTY (skipDoorToDoor());
            MOVE PROPERTY (skipConfirmationClient());
            MOVE PROPERTY (optionalReturnDelivery());
            MOVE PROPERTY (bufferWeightDiff());
            MOVE PROPERTY (sendSflatDetail());
            MOVE PROPERTY (skipEmergencyNotify());
            MOVE PROPERTY (commentTextDelivery());
            MOVE PROPERTY (defaultTaxiClass());
            MOVE PROPERTY (weightChangeTaxiClass());
            MOVE PROPERTY (enableLogYandexDelivery());
        }
    }
}

//телефон для уведомлений
phoneNotification 'Телефон для уведовлений(доставка)' = DATA STRING[30] (DepartmentStore);

EXTEND FORM departmentStore
    PROPERTIES (d) phoneNotification
;
DESIGN departmentStore{
    headerExtraParams{
        MOVE PROPERTY (phoneNotification(d));
    }
}

latitude '{geo.latitude.poi}' = DATA NUMERIC[11,6] (InternetOrder);
longitude '{geo.longitude.poi}' = DATA NUMERIC[11,6] (InternetOrder);
delivery 'Доставка' = DATA BOOLEAN (InternetOrder);
slotDelivery 'Слотовая доставка' = DATA BOOLEAN (InternetOrder);
detailAddress 'Квартира, подъезд' = DATA STRING (InternetOrder);
sflat 'Квартира'= DATA STRING (InternetOrder);
porch 'Подъезд' = DATA STRING (InternetOrder);
sfloor 'Этаж' = DATA STRING (InternetOrder);

CLASS DeliveryRequest 'Заявка на доставку' ;
TABLE deliveryRequest (DeliveryRequest);

@defineExternalizable(deliveryRequest, STRING[100]);
@defineDocumentHeaderTimePrefix(DeliveryRequest, , ' заявки');
@deriveDocumentHeaderTimePrefix(DeliveryRequest, );

internetOrder = DATA InternetOrder (DeliveryRequest);
numberInternetOrder 'Интернет-заказ'  (DeliveryRequest r) = number(internetOrder(r));

CLASS StatusDeliveryRequest{
    new 'Создана',
    estimating 'Оценка',
    estimating_failed 'Не удалось оценить',
    ready_for_approval 'Готова к одобрению',
    accepted 'Принята',
    performer_lookup 'Взята в обработку',
    performer_draft 'Поиск исполнителя',
    performer_found 'Исполнитель найден',
    performer_not_found 'Не удалось найти исполнителя',
    pickup_arrived 'Исполнитель приехал в ПВЗ',
    ready_for_pickup_confirmation '(ПВЗ)Ожидание кода подтвеждения',
    pickuped 'Исполнитель успешно забрал груз',
    delivery_arrived 'Исполнитель приехал в точку назначения',
    ready_for_delivery_confirmation '(КЛИЕНТ)Ожидание кода подтвеждения',
    pay_waiting 'оплата_ожидание',
    delivered 'Успешная доставка',
    delivered_finish 'Заказ завершен',
    returning 'Исполнителю пришлось вернуть груз и он едет в точку возврата',
    return_arrived '(ВОЗВРАТ)Исполнитель приехал в ПВЗ',
    ready_for_return_confirmation '(ВОЗВРАТ)Ожидание кода подтвеждения',
    returned 'Груз вернули в ПВЗ',
    returned_finish '(ВОЗВРАТ)Заказ завершён',
    failed 'При выполнение заказа произошла ошибка, дальнейшее выполнение невозможно',
    cancelled 'ОТМЕНА (Бесплатно)',
    cancelled_with_payment 'Платная отмена',
    cancelled_by_taxi 'Заказ завершен', //'Исполнитель отменил заказ (до получения груза)',
    cancelled_with_items_on_hands 'Платная отмена(БЕЗ ВОЗВРАТА)'
}
status = DATA StatusDeliveryRequest (DeliveryRequest);
nameStatus 'Статус' (DeliveryRequest r) = staticCaption(status(r));
nameStatusName (DeliveryRequest r) = staticName(status(r));
statusDelivery (STRING id) = GROUP MAX StatusDeliveryRequest s
    IF staticName(s) == id;

usePerformerLookupRecalculate 'Пересчитывть вес когда заявка в обработке' = DATA BOOLEAN ();

allowRecalculate(DeliveryRequest r) = status(r) = StatusDeliveryRequest.new OR
    status(r) = StatusDeliveryRequest.ready_for_approval OR
    status(r) = StatusDeliveryRequest.accepted OR
    status(r) = StatusDeliveryRequest.performer_draft OR
    (status(r) = StatusDeliveryRequest.performer_lookup AND usePerformerLookupRecalculate())OR
    status(r) = StatusDeliveryRequest.cancelled OR
    status(r) = StatusDeliveryRequest.performer_not_found
;

//интернет-заказы
weightPosition (InternetOrderDetail d) = IF pickingQuantity(d) THEN
    (OVERRIDE grossWeight(sku(d)), 0.5) * pickingQuantity(d)
    ELSE
    (OVERRIDE grossWeight(sku(d)), 0.5) * quantity(d)
;

sumGrossWeight 'Вес заказа' = GROUP SUM weightPosition(InternetOrderDetail d) BY internetOrder(d);
sumGrossWeight 'Вес заявки' = DATA NUMERIC (DeliveryRequest);

carrierDeliveryWebSite () = GROUP MAX Carrier c IF id(c) = 'yandexDelivery';

classTaxi 'Тариф' (DeliveryRequest d) = IF sumGrossWeight(internetOrder(d)) (-) bufferWeightDiff() >
    OVERRIDE weightChangeTaxiClass(), 20
    THEN 'express' ELSE 'courier';
overTaxiClass (DeliveryRequest r) = OVERRIDE defaultTaxiClass(), classTaxi(r);
classTaxiName 'Тариф'(DeliveryRequest r) = IF overTaxiClass(r) = 'express' THEN 'Экспресс' ELSE 'Стандарт';
timeFormat(DATETIME dt) = toChar(dt,'YYYY-MM-DD"T"HH24:MI:SS+03:00');
due 'Время доставки' (DeliveryRequest r)= dateTimeToDateTime(deliveryDate(internetOrder(r)),
    deliveryTimeFromInternetOrder(internetOrder(r)));
confirmationCode 'Код подтверждения' = DATA STRING[50] (DeliveryRequest);

//точки маршрута и курьера
CLASS ABSTRACT Point 'Точка';

latitude '{geo.latitude.poi}' = DATA NUMERIC[11,6] (Point);
longitude '{geo.longitude.poi}' = DATA NUMERIC[11,6] (Point);

deliveryRequest = DATA DeliveryRequest (Point) NONULL DELETE;
name = ABSTRACT STRING (Point);

CLASS Perfomer 'Исполнитель': Point;

performer(DeliveryRequest r) = GROUP MAX Perfomer p IF deliveryRequest(p) = r AND p IS Perfomer;

CLASS RoutePoint 'Точка маршрута' : Point;
TABLE routePoint (RoutePoint);

comment 'Коментарий' = DATA STRING[100] (RoutePoint);
fitBounds = DATA BOOLEAN (RoutePoint);
coordinates 'Координаты' = DATA STRING[100] (RoutePoint);
fullname 'Адрес' = DATA STRING[400] (RoutePoint);
sflat 'Квартира' = DATA STRING[100] (RoutePoint);
porch 'Подъезд' = DATA STRING[100] (RoutePoint);
sfloor 'Этаж' = DATA STRING[10] (RoutePoint);
nameContact 'Контакт' = DATA STRING[255] (RoutePoint);
phone 'Телефон' = DATA STRING[100] (RoutePoint);
source 'Точка А' = DATA BOOLEAN (RoutePoint);
type (RoutePoint r) = IF source(r) THEN 'source' ELSE 'destination';
dataPointId 'Изменить порядок' = DATA INTEGER (RoutePoint);
pointId (RoutePoint r) = IF source(r) THEN 1 ELSE OVERRIDE dataPointId(r), 2;
name (RoutePoint r) += CONCAT ' : ', pointId(r) + ' - ', nameContact(r), fullname(r);
externalOrderId (RoutePoint r) = IF NOT source(r) THEN number(internetOrder(deliveryRequest(r)));
skipConfirmation(RoutePoint r) = CASE
    WHEN source(r) THEN TFALSE
    WHEN NOT source(r) AND skipConfirmationClient() THEN TTRUE
    WHEN NOT source(r) AND NOT skipConfirmationClient() THEN TFALSE
;

calculateCoordinates '{geo.calculate.coordinates}'(RoutePoint r) {
    getCoordinates (CONCAT ',', 'Беларусь', fullname(r));
    coordinates(r) <- CONCAT '', '[', readLatitude(), ', ', readLongitude(), ']';
}

createdTime 'Создана' = DATA DATETIME (DeliveryRequest);
updatedTime 'Обновлена' = DATA DATETIME (DeliveryRequest);

verifyCodeA 'Код подтверждения курьера' = DATA STRING[20] (DeliveryRequest);
preCost 'Оценка' = DATA NUMERIC[18,4] (DeliveryRequest);
cost 'Стоимость' = DATA NUMERIC[18,4] (DeliveryRequest);

commentDeliveryRequest (DeliveryRequest r) = replace(commentTextDelivery(), '[phone]',
    OVERRIDE phoneNotification(supplierStock(internetOrder(r))), '');

isRequest (DeliveryRequest r) = IF r IS DeliveryRequest THEN TRUE;

GROUP address;
GROUP contact;
GROUP external_order_cost;
GROUP client_requirements;
GROUP size;
GROUP emergency_contact;

FORM claimsCreate FORMEXTID 'null'
    OBJECTS c = DeliveryRequest PANEL

    PROPERTIES commentDeliveryRequest(c) EXTID 'comment', = IF isRequest(c) THEN TFALSE EXTID 'skip_act',
        = IF skipClientNotify() AND isRequest(c) THEN TTRUE ELSE TFALSE EXTID 'skip_client_notify',
        = IF skipDoorToDoor() AND isRequest(c) THEN TTRUE ELSE TFALSE EXTID 'skip_door_to_door',
        = IF skipEmergencyNotify() AND isRequest(c) THEN TTRUE ELSE TFALSE EXTID 'skip_emergency_notify',
        = IF optionalReturnDelivery() AND isRequest(c) THEN TTRUE ELSE TFALSE EXTID 'optional_return',
        = IF isRequest(c) THEN 'lsFusion ERP' EXTID 'referral_source', = timeFormat(due(c)) EXTID 'due'
    PROPERTIES IN client_requirements = IF isRequest(c) THEN TFALSE EXTID 'assign_robot',
        = IF isRequest(c) THEN TFALSE EXTID 'pro_courier', overTaxiClass(c) EXTID 'taxi_class'

    OBJECTS r = RoutePoint EXTID 'route_points'
    PROPERTIES IN contact nameContact(r) EXTID 'name', phone(r)
    PROPERTIES IN address fullname(r), coordinates(r), comment(r), = IF r IS RoutePoint AND sflat(r) THEN sflat(r) EXTID 'sflat',
        porch(r) EXTID 'porch', sfloor(r) EXTID 'sfloor'
    PROPERTIES IN external_order_cost = IF isRequest(deliveryRequest(r)) THEN 'BYN' EXTID 'currency',
        = IF isRequest(deliveryRequest(r)) THEN 'BYN' EXTID 'currency_sign',
        = STRING (round2(sumInternetOrderDetail(internetOrder(deliveryRequest(r))))) EXTID 'value'
    PROPERTIES type(r), pointId(r) EXTID 'point_id', = OVERRIDE pointId(r) EXTID 'visit_order',
        skipConfirmation(r) EXTID 'skip_confirmation', externalOrderId(r) EXTID 'external_order_id'
    FILTERS deliveryRequest(r) = c

    OBJECTS id = InternetOrderDetail EXTID 'items'
    PROPERTIES nameSku(id) EXTID 'title', = IF id IS InternetOrderDetail THEN 1 EXTID 'quantity', = IF id IS InternetOrderDetail THEN 2 EXTID 'droppof_point',
        = OVERRIDE STRING(round2(sum(id))) EXTID 'cost_value',
        = IF id IS InternetOrderDetail THEN 'BYN' EXTID 'cost_currency', = IF id IS InternetOrderDetail THEN 1 EXTID 'pickup_point',
        //        = (OVERRIDE grossWeight(sku(id)) * quantity(id), 0.5) EXTID 'weight',  
        = weightPosition(id) EXTID 'weight',
        = number(internetOrder(id)) + '_' +  index(id) EXTID 'extra_id'

    FILTERS (internetOrder(id) = internetOrder(c) AND weightPosition(id) > 0) OR NOT internetOrder(c)
;

//импорт заявки
