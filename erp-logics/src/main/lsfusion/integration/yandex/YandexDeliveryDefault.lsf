comment1 = DATA LOCAL STRING();
corp_client_id = DATA LOCAL STRING();
cargo_type_int = DATA LOCAL STRING(INTEGER);
door_to_door = DATA LOCAL STRING(INTEGER);
taxi_class1 = DATA LOCAL STRING(INTEGER);
cargo_loaders1 = DATA LOCAL STRING(INTEGER);
cargo_type1 = DATA LOCAL STRING(INTEGER);
pro_courier1 = DATA LOCAL STRING(INTEGER);
client_taxi_class = DATA LOCAL STRING(INTEGER);
