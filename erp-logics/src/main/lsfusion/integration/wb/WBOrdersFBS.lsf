MODULE WBOrdersFBS;

REQUIRE WBStockMapping, WBItemMapping, SaleInternetOrder, WBPriceTransaction, SaleInternetPicking;

NAMESPACE WB;

isWBOrder 'WB' = DATA BOOLEAN (InternetOrder);
orderUID 'Группировочный номер товара по заказам (в корзине)' = DATA STRING (InternetOrder);
groupId 'ID транзакции заказа' = DATA STRING (InternetOrder);
orderRidID 'ID сборочного задания WB' = DATA STRING (InternetOrder);
supplierStockWB 'Склад поставщика' = ABSTRACT CASE Stock.Stock (InternetOrder);

isSelected 'Отм.' = DATA LOCAL NESTED BOOLEAN (InternetOrder);

