MODULE WBOrdersFBS;

REQUIRE WBOrders, SaleInternetOrderLot, LotAggregate, SaleShipmentLot;

NAMESPACE WB;

fbsCarrier = ABSTRACT CASE Carrier();
customFbsCarrier = ABSTRACT BOOLEAN ();
fbsCarrier () += WHEN carrier('WB') AND NOT customFbsCarrier() THEN carrier('WB');

onStarted() + {
    IF NOT customFbsCarrier() THEN {
        IF NOT carrier('WB') THEN NEW c = Carrier{
            id(c) <- 'WB';
            name(c) <- 'FBS(WB)';
        }
    }
}

isWBOrderFBS 'FBS' = DATA BOOLEAN (InternetOrder);
isWBOrder(InternetOrder o) += WHEN o IS InternetOrder AND isWBOrderFBS(o) THEN isWBOrderFBS(o);

wbIsCancellable 'WB: доступна отмена' = DATA BOOLEAN (InternetOrder);

offices = DATA LOCAL STRING(INTEGER);
ordersOffices = DATA LOCAL INTEGER(INTEGER);
ddate = DATA LOCAL DATE(INTEGER); // планируемая дата доставки
optionalMeta = DATA LOCAL STRING(INTEGER);
ordersOptionalMeta = DATA LOCAL INTEGER(INTEGER);

// Симметрично afterGetOrdersDBSNew в WBOrdersDBS.lsf.
afterGetOrdersFBSNew ABSTRACT LIST;

FORM importNewOrdersFBS

    OBJECTS orders = INTEGER

    PROPERTIES(orders) cargoType, nmId, rid, createdAt, isZeroOrder, officeId, price, convertedCurrencyCode, id, ddate,
        salePrice, article, convertedPrice, orderUid, warehouseId, comment, colorCode, chrtId,
        currencyCode

    OBJECTS skus = INTEGER
    PROPERTIES(skus) skus EXTID 'value'
    FILTERS imported(skus)
    FILTERS ordersSkus(skus) == orders

    OBJECTS offices = INTEGER
    PROPERTIES(offices) offices EXTID 'value'
    FILTERS imported(offices)
    FILTERS ordersOffices(offices) == orders
    PROPERTIES(orders) IN options isB2b
    FILTERS imported(orders)
    PROPERTIES(orders) IN address latitude, fullAddress, longitude

    OBJECTS requiredMeta = INTEGER
    PROPERTIES(requiredMeta) requiredMeta EXTID 'value'
    FILTERS imported(requiredMeta)
    FILTERS ordersRequiredMeta(requiredMeta) == orders

    OBJECTS optionalMeta = INTEGER
    PROPERTIES(optionalMeta) optionalMeta EXTID 'value'
    FILTERS imported(optionalMeta)
    FILTERS ordersOptionalMeta(optionalMeta) == orders;

dataGetOrdersLimit = DATA INTEGER ();
getOrdersLimit 'Лимит запросов для сборочных заданий' = OVERRIDE dataGetOrdersLimit(), 1000;

// https://marketplace-api.wildberries.ru/api/v3/orders/new
getOrdersFBSNew 'Получить список новых сборочных заданий (FBS)' () {
    NEWSESSION {
        setHttpHeadersIS();
        LOCAL messageOrder = STRING ();
        LOCAL response = FILE();

        logToFile('WB', 'GET: ' + url(CategoryRequest.marketplace) + '/api/v3/orders/new');

        TRY {
            EXTERNAL HTTP GET url(CategoryRequest.marketplace) + '/api/v3/orders/new' HEADERS httpHeaders TO response;
            fileToString(response());
            logToFile('WB', resultString());
            IMPORT importNewOrdersFBS JSON FROM response();

            FOR INTEGER i = [GROUP MAX INTEGER i1 BY id(i1)](STRING number)
                AND NOT (GROUP MAX InternetOrder o IF number(o) == number AND isWBOrderFBS(o))
                AND NOT (GROUP MAX InternetOrder o IF orderRidID(o) == rid(i) AND isWBOrderFBS(o))
                INLINE DO NEW order = InternetOrder {
                number(order) <- number;
                orderRidID(order) <- rid(i);
                orderUID(order) <- orderUid(i);
                date(order) <- currentDate();
                isWBOrderFBS(order) <- TRUE;
                carrier(order) <- fbsCarrier();
                status(order) <- IF autoAggreed() THEN StatusInternetOrder.agreed ELSE StatusInternetOrder.new;
                isPosted(order) <- TRUE WHERE autoAggreed();
                warehouseId(order) <- warehouseId(i);
                supplierStock(order) <- supplierStockWB(order);
                wbStatus(order) <- WbStatus.new;
                wbSystemStatus(order) <- WbSystemStatus.waiting;
                wbIsCancellable(order) <- TRUE;
                addressInternetCustomer(order) <- fullAddress(i);
                deliveryDate(order) <- ddate(i);
                note(order) <- comment(i);

                currency(order) <- GROUP MAX Currency c IF sid(c) == currencyCode(i);

                FOR INTEGER ii = [GROUP MAX INTEGER j BY rid(j)](STRING rid)
                    AND Size size == size(chrtId(ii))
                    AND Item item == itemNM(nmId(ii))
                    AND itemWB(size) == item
                    AND orderRidID(order) == rid
                    INLINE DO NEW detail = InternetOrderDetail {
                    internetOrder(detail) <- order;
                    sku(detail) <- item(size);
                    quantity(detail) <- 1;
                    price(detail) <- salePrice(ii) / 100.0;
                    discountPrice(detail) <- salePrice(ii) / 100.0;
                    sum(detail) <- salePrice(ii) / 100.0;
                    discountSum(detail) <- salePrice(ii) / 100.0;
                }

                FOR INTEGER rm AND ordersRequiredMeta(rm) == i AND OrderMeta meta == orderMetaByName(requiredMeta(rm)) DO {
                    FOR InternetOrderDetail detail AND internetOrder(detail) == order DO {
                        requiredMeta(detail, meta) <- TRUE;
                    }
                }
                FOR INTEGER om AND ordersOptionalMeta(om) == i AND OrderMeta meta == orderMetaByName(optionalMeta(om)) DO {
                    FOR InternetOrderDetail detail AND internetOrder(detail) == order DO {
                        optionalMeta(detail, meta) <- TRUE;
                    }
                }
            }
            afterGetOrdersFBSNew();
            messageOrder() <- (OVERRIDE messageOrder() + '\n', '') + messageStatusHTTP(STRING(statusHttp()));
        } CATCH {
            logToFile('WB', messageCaughtException());
            IF statusHttp() == 403 THEN {
                IMPORT importError JSON FROM response();
                extraDescriptionStatusHTTP() <- 'Список новых сборочных заданий (FBS) не получен: ' + message();
            }
            messageOrder() <- CONCAT '\n', messageStatusHTTP(STRING(statusHttp())), messageCaughtException();
        } FINALLY {
            afterSendRequestIS();
            MESSAGE messageOrder() NOWAIT;
            APPLY;
        }
    }
}

supplyId = DATA LOCAL STRING(INTEGER);

nextIndex = DATA LOCAL INTEGER ();

FORM importOrdersFBS
    PROPERTIES() nextIndex EXTID 'next'

    OBJECTS orders = INTEGER

    PROPERTIES(orders) cargoType, nmId, rid, article, createdAt, convertedPrice, orderUid, isZeroOrder,
        warehouseId, officeId, supplyId, price, colorCode, convertedCurrencyCode, comment, id, chrtId, currencyCode
    FILTERS imported(orders)
    PROPERTIES(orders) IN address latitude, fullAddress, longitude

    OBJECTS skus = INTEGER
    PROPERTIES(skus) skus EXTID 'value'
    FILTERS imported(skus)
    FILTERS ordersSkus(skus) == orders

    OBJECTS offices = INTEGER
    PROPERTIES(offices) offices EXTID 'value'
    FILTERS imported(offices)
    FILTERS ordersOffices(offices) == orders
    PROPERTIES(orders) IN options isB2b
;

// https://marketplace-api.wildberries.ru/api/v3/orders
getOrdersFBS 'Получить информацию о сборочных заданиях (FBS)' (DATE from, DATE to) {
    NEWSESSION {
        setHttpHeadersIS();
        LOCAL messageOrder = STRING ();
        LOCAL response = FILE();

        LOCAL limit = INTEGER ();
        limit() <- getOrdersLimit();
        IF limit() > 1000 THEN limit() <- 1000;

        LOCAL NESTED nextWB = INTEGER ();
        nextWB() <- 0;

        LOCAL dFrom = LONG ();
        LOCAL dTo = LONG ();

        IF to THEN
            dTo() <- LONG(getSeconds(toZDateTime(to)));
        ELSE
            dTo() <- LONG(getSeconds(currentZDateTime()));

        IF from THEN
            dFrom() <- LONG(getSeconds(toZDateTime(from)));
        ELSE
            dFrom() <- dTo() - 2592000L;

        LOCAL stop = BOOLEAN ();

        logToFile('WB', 'GET: ' + url(CategoryRequest.marketplace) + '/api/v3/orders');

        WHILE NOT stop() AND nextWB() >= 0 DO {
            TRY {
                EXTERNAL HTTP GET url(CategoryRequest.marketplace) + '/api/v3/orders?limit=$1&next=$2&dateFrom=$3&dateTo=$4'
                    HEADERS httpHeaders
                    PARAMS
                    limit(),
                    nextWB(),
                    dFrom(),
                    dTo()
                    TO response;

                fileToString(response());
                logToFile('WB', resultString());
                IMPORT importOrdersFBS JSON FROM response();

                LOCAL currentNext = INTEGER();
                currentNext() <- nextIndex();

                FOR INTEGER i = [GROUP MAX INTEGER i1 BY id(i1)](STRING number)
                    AND InternetOrder order == (GROUP MAX InternetOrder o IF (number(o) == number OR orderRidID(o) == rid(i)) AND isWBOrderFBS(o))
                    INLINE DO {

                    IF NOT warehouse(warehouseId(i)) THEN
                        messageOrder() <- (OVERRIDE messageOrder() + '\n', '') + 'В справочнике системы не найден warehouseId: ' + warehouseId(i);

                    addressInternetCustomer(order) <- fullAddress(i);
                    note(order) <- comment(i);

                    currency(order) <- GROUP MAX Currency c IF sid(c) == currencyCode(i);

                    FOR INTEGER ii = [GROUP MAX INTEGER j BY rid(j)](STRING rid)
                        AND Size size == size(chrtId(ii))
                        AND Item item == itemNM(nmId(ii))
                        AND itemWB(size) == item
                        AND orderRidID(order) == rid
                        INLINE DO {
                        IF NOT (GROUP MAX InternetOrderDetail d IF internetOrder(d) == order AND sku(d) == item(size)) THEN NEW detail = InternetOrderDetail {
                            internetOrder(detail) <- order;
                            sku(detail) <- item(size);
                            price(detail) <- price(ii) / 100.0;
                        }
                    }
                }

                IF currentNext() > 0 AND currentNext() != nextWB() THEN {
                    nextWB() <- currentNext();
                } ELSE {
                    stop() <- TRUE;
                }

                messageOrder() <- (OVERRIDE messageOrder() + '\n', '') + messageStatusHTTP(STRING(statusHttp()));

            } CATCH {
                logToFile('WB', messageCaughtException());
                IF statusHttp() == 400 OR statusHttp() == 403 OR statusHttp() == 404 OR statusHttp() == 409 THEN {
                    IMPORT importError JSON FROM response();
                    extraDescriptionStatusHTTP() <- 'Список сборочных заданий не получен: ' + message();
                }
                messageOrder() <- CONCAT '\n', messageStatusHTTP(STRING(statusHttp())), messageCaughtException();
                stop() <- TRUE;
            } FINALLY {
                afterSendRequestIS();
                MESSAGE messageOrder() NOWAIT;

                IF NOT (statusHttp() >= 200 AND statusHttp() < 300) THEN {
                    stop() <- TRUE;
                }
                APPLY NESTED LOCAL;
                IF NOT stop() THEN sleep(200);
            }
        }
    }
}

getOrdersFBS 'Получить информацию о сборочных заданиях (FBS)' () {
    getOrdersFBS(NULL, NULL);
    isSelected(InternetOrder o) <- NULL;
}

// POST /api/v3/orders/status — ответ:
// {"orders":[{"id":..., "isCancellable":..., "supplierStatus":..., "wbStatus":...}]}
// supplierStatus ∈ {new, confirm, complete, cancel, cancel_carrier} — действие продавца;
// wbStatus — статус системы Wildberries.
// В ответе НЕТ errors-блока (в отличие от DBS /status/info), его в форме нет.
isCancellable = DATA LOCAL BOOLEAN(INTEGER);

FORM statusInfoResponse
    OBJECTS orders = INTEGER
    PROPERTIES(orders) id, isCancellable, supplierStatus, wbStatus
;

// По умолчанию после синка статусов от WB локальный status(InternetOrder) автоматически
// обновляется по WB-маппингу. Если проект ведёт переходы вручную и не хочет
// перетирания — пусть переопределит customSetFbsStatus в TRUE.
customSetFbsStatus = ABSTRACT BOOLEAN ();

//https://marketplace-api-sandbox.wildberries.ru/api/v3/orders/status
getWbFbsStatuses 'Получить статусы заказов FBS' () {
    NEWSESSION NESTED LOCAL {
        IF NOT (GROUP SUM 1 IF isSelected(InternetOrder order) AND isWBOrderFBS(order)) THEN {
            MESSAGE 'Заказ FBS не выбран.';
            RETURN ;
        }

        setHttpHeadersIS();
        LOCAL messageOrder = STRING ();
        LOCAL response = FILE();

        logToFile('WB', 'POST: ' + url(CategoryRequest.marketplace) + '/api/v3/orders/status');

        EXPORT JSON FROM 'value' = INTEGER(number(InternetOrder order)) WHERE isSelected(order) AND isWBOrderFBS(order);
        fileToString(exportFile(), 'UTF-8');
        stringToFile('\{"orders":' + replace(resultString(), '\n', '') + '\}', 'UTF-8', 'json');
        fileToString(resultFile(), 'UTF-8');
        logToFile('WB', 'orders: ' + resultString());

        TRY {
            EXTERNAL HTTP POST url(CategoryRequest.marketplace) + '/api/v3/orders/status' HEADERS httpHeaders PARAMS resultFile() TO response;
            fileToString(response());
            logToFile('WB', resultString());
            messageOrder() <- messageStatusHTTP(STRING(statusHttp()));
            IF statusHttp() == 200 THEN {
                IMPORT statusInfoResponse JSON FROM response();
                FOR id(INTEGER i) AND InternetOrder o == orderByNumber(id(i))
                    AND WbStatus ws = wbStatus(supplierStatus(i)) AND WbSystemStatus wss = wbSystemStatus(wbStatus(i)) DO {
                    IF wss = WbSystemStatus.declined_by_client AND status(o) = StatusInternetOrder.new AND subtractSeconds(currentDateTime(), dateTime(o)) <= 3600 THEN {
                        IF customCancelOrder() THEN {
                            overCancelOrder(o);
                        } ELSE {
                            status(o) <- OVERRIDE customCancelOrderStatus(), StatusInternetOrder.closed;
                        }
                    } ELSE IF NOT customSetFbsStatus() THEN {
                        status(o) <- statusInternetOrder(ws);
                    }
                    wbStatus(o) <- ws;
                    wbSystemStatus(o) <- wss;
                    wbIsCancellable(o) <- isCancellable(i);
                }
                APPLY NESTED LOCAL ;
            }
        } CATCH {
            logToFile('WB', messageCaughtException());
            IF statusHttp() == 400 OR statusHttp() == 403 OR statusHttp() == 404 OR statusHttp() == 409 THEN {
                IMPORT importError JSON FROM response();
                extraDescriptionStatusHTTP() <- 'Статус сборочного задания не получен: ' + message();
            }
            messageOrder() <- CONCAT '\n', messageStatusHTTP(STRING(statusHttp())), messageCaughtException();
        } FINALLY {
            afterSendRequestIS();
            MESSAGE messageOrder() NOWAIT;
        }
    }
}

getWbFbsStatus 'Получить статус заказа FBS' (InternetOrder order) {
    IF NOT GROUP SUM 1 IF isSelected(InternetOrder order1) THEN {
        isSelected(order) <- TRUE ;
    }
    getWbFbsStatuses();
    isSelected(InternetOrder o) <- NULL;
}

// POST /api/v3/orders/stickers?type=svg&width=58&height=40
// Стикеры доступны только для заказов в статусах confirm и complete. Макс. 100 за запрос.
getStickers 'Получить стикеры' () {
    NEWSESSION NESTED LOCAL {
        IF NOT (GROUP SUM 1 IF isSelected(InternetOrder order) AND isWBOrderFBS(order)) THEN {
            MESSAGE 'Заказ FBS не выбран.';
            RETURN ;
        }

        setHttpHeadersIS();
        LOCAL messageOrder = STRING ();
        LOCAL response = FILE();

        LOCAL postUrl = STRING ();
        postUrl() <- '/api/v3/orders/stickers?' + stickerParams();

        logToFile('WB', 'POST: ' + url(CategoryRequest.marketplace) + postUrl());

        EXPORT JSON FROM 'value' = INTEGER(number(InternetOrder order)) WHERE isSelected(order) AND isWBOrderFBS(order);
        fileToString(exportFile(), 'UTF-8');
        stringToFile('\{"orders":' + replace(resultString(), '\n', '') + '\}', 'UTF-8', 'json');
        fileToString(resultFile(), 'UTF-8');
        logToFile('WB', 'orders: ' + resultString());

        TRY {
            EXTERNAL HTTP POST url(CategoryRequest.marketplace) + postUrl() HEADERS httpHeaders PARAMS resultFile() TO response;
            fileToString(response());
            logToFile('WB', resultString());
            messageOrder() <- messageStatusHTTP(STRING(statusHttp()));
            IF statusHttp() == 200 THEN {
                IMPORT stickersResponse JSON FROM response();
                FOR orderId(INTEGER i) DO {
                    sticker(orderByNumber(orderId(i))) <- RAWFILE(file(decode(file(i), 'base64'), 'svg'));
                }
                APPLY NESTED LOCAL ;
            }
        } CATCH {
            logToFile('WB', messageCaughtException());
            IF statusHttp() == 400 OR statusHttp() == 403 OR statusHttp() == 404 OR statusHttp() == 409 THEN {
                IMPORT importError JSON FROM response();
                extraDescriptionStatusHTTP() <- 'Стикеры не получены: ' + message();
            }
            messageOrder() <- CONCAT '\n', messageStatusHTTP(STRING(statusHttp())), messageCaughtException();
        } FINALLY {
            afterSendRequestIS();
            MESSAGE messageOrder() NOWAIT;
        }
    }
}

getSticker 'Получить стикер' (InternetOrder order) {
    IF NOT GROUP SUM 1 IF isSelected(InternetOrder order1) THEN {
        isSelected(order) <- TRUE ;
    }
    getStickers();
    isSelected(InternetOrder o) <- NULL;
}

// PATCH /api/v3/orders/{orderId}/cancel
// Доступно только до передачи в доставку (wbStatus = new/confirm). WB отвечает 204 без тела.
// Опт-аут авто-отмены — через customFilterChangeOrdersFBSStatus(WbStatus.cancel, o).
afterCancelOrderFBS ABSTRACT LIST (InternetOrder);

cancelOrderFBS 'Отменить сборочное задание (FBS)' (InternetOrder o) {
    NEWSESSION NESTED LOCAL {
        IF NOT number(o) THEN {
            MESSAGE 'У заказа отсутствует номер.';
            RETURN;
        }
        IF NOT isWBOrderFBS(o) THEN {
            MESSAGE 'Заказ не является FBS-заказом WB.';
            RETURN;
        }

        setHttpHeadersIS();
        LOCAL messageOrder = STRING ();
        LOCAL response = FILE();

        LOCAL patchUrl = STRING ();
        patchUrl() <- '/api/v3/orders/' + number(o) + '/cancel';

        logToFile('WB', 'PATCH: ' + url(CategoryRequest.marketplace) + patchUrl());

        TRY {
            EXTERNAL HTTP PATCH url(CategoryRequest.marketplace) + patchUrl() HEADERS httpHeaders TO response;
            fileToString(response());
            logToFile('WB', resultString());
            messageOrder() <- messageStatusHTTP(STRING(statusHttp()));
            IF statusHttp() == 204 THEN {
                wbStatus(o) <- WbStatus.cancel;
                wbSystemStatus(o) <- WbSystemStatus.canceled;
                status(o) <- OVERRIDE customCancelOrderStatus(), StatusInternetOrder.cancel;
                afterCancelOrderFBS(o);
                APPLY NESTED LOCAL ;
            }
        } CATCH {
            logToFile('WB', messageCaughtException());
            IF statusHttp() == 400 OR statusHttp() == 403 OR statusHttp() == 404 OR statusHttp() == 409 THEN {
                IMPORT importError JSON FROM response();
                extraDescriptionStatusHTTP() <- 'Заказ не отменён: ' + message();
            }
            messageOrder() <- CONCAT '\n', messageStatusHTTP(STRING(statusHttp())), messageCaughtException();
        } FINALLY {
            afterSendRequestIS();
            MESSAGE '<h3>Отмена сборочного задания</h3>' NOWAIT;
            MESSAGE messageOrder() NOWAIT;
        }
    }
}

cancelOrdersFBS 'Отменить выбранные сборочные задания (FBS)' () {
    IF NOT (GROUP SUM 1 IF isSelected(InternetOrder order) AND isWBOrderFBS(order)) THEN {
        MESSAGE 'Заказ FBS не выбран.';
        RETURN;
    }
    FOR isSelected(InternetOrder o) AND isWBOrderFBS(o) DO {
        cancelOrderFBS(o);
    }
}

// Аналог DBS-ветки (changeOrdersDBSStatusCondition/changeOrdersDBSStatus).
// FBS-API не имеет единого endpoint смены статуса: confirm/deliver/receive идут
// через поставку (addOrdersToSupply → sendSupplyToDeliver), а cancel — отдельный
// PATCH /orders/{id}/cancel. Поэтому changeOrdersFBSStatus — диспетчер по wbStatus.
customFilterChangeOrdersFBSStatus = ABSTRACT BOOLEAN (WbStatus, InternetOrder);
afterChangeOrdersFBSStatus ABSTRACT LIST (WbStatus);
changeOrdersFBSStatusCondition (WbStatus ws, InternetOrder o) =
    CASE WHEN ws = WbStatus.cancel AND wbIsCancellable(o) AND NOT customFilterChangeOrdersFBSStatus(ws, o) THEN TRUE
;

changeOrdersFBSStatus (WbStatus wbStatus) {
    IF NOT (GROUP SUM 1 IF isSelected(InternetOrder order) AND isWBOrderFBS(order)) THEN {
        MESSAGE 'Заказ FBS не выбран.';
        RETURN;
    }
    IF GROUP SUM 1 IF isSelected(InternetOrder order) AND isWBOrderFBS(order) AND NOT changeOrdersFBSStatusCondition(wbStatus, order) THEN {
        MESSAGE 'Для одного из выбранных заказов не соблюдены условия перевода.';
        RETURN;
    }
    IF wbStatus = WbStatus.cancel THEN cancelOrdersFBS();
    afterChangeOrdersFBSStatus(wbStatus);
}

wbSupplyId = DATA STRING[100](Picking);

createSupply(Picking picking){
    NEWSESSION NESTED LOCAL {
        IF NOT number(picking) THEN {
            MESSAGE 'Отсутствует номер поставки.';
            RETURN;
        }
        setHttpHeadersIS();
        LOCAL messageOrder = STRING ();
        LOCAL response = FILE();
        LOCAL supplyId = STRING[100] ();

        logToFile('WB', 'POST: ' + url(CategoryRequest.marketplace) + '/api/v3/supplies');

        stringToFile('\{"name": "' + number(picking) + '" \}', 'UTF-8', 'json');
        fileToString(resultFile(), 'UTF-8');
        logToFile('WB', 'orders: ' + resultString());

        TRY {
            EXTERNAL HTTP POST url(CategoryRequest.marketplace) + '/api/v3/supplies' HEADERS httpHeaders PARAMS resultFile() TO response;
            fileToString(response());
            logToFile('WB', resultString());
            messageOrder() <- messageStatusHTTP(STRING(statusHttp()));
            IF statusHttp() == 201 THEN {
                IMPORT JSON FROM response() TO() supplyId = id;
                wbSupplyId(picking) <- supplyId();
                APPLY NESTED LOCAL ;
            }
        } CATCH {
            logToFile('WB', messageCaughtException());
            IF statusHttp() == 400 OR statusHttp() == 403 OR statusHttp() == 404 OR statusHttp() == 409 THEN {
                IMPORT importError JSON FROM response();
                extraDescriptionStatusHTTP() <- 'Поставка не создана: ' + messageCaughtException();
            }
            messageOrder() <- CONCAT '\n', messageStatusHTTP(STRING(statusHttp())), messageCaughtException();
        } FINALLY {
            afterSendRequestIS();
            MESSAGE '<h3>Создание поставки</h3>' NOWAIT;
            MESSAGE messageOrder() NOWAIT;
        }
    }
}

FORM inputSupplyName 'Введите название сборки'
    OBJECTS n = STRING[50] PANEL
    PROPERTIES 'Название' = VALUE(n)
;

afterAddOrdersToSupply ABSTRACT LIST (Picking);

addOrdersToSupply 'Добавить сборочные задания к поставке' (Picking p) {
    IF hasUnvalidatedRequiredMetaPicking(p) THEN {
        MESSAGE 'Не все обязательные метаданные валидированы. Перевод заказа в статус «Собран» запрещён.';
        RETURN;
    }
    // createSupply открывает свою NEWSESSION NESTED LOCAL с HTTP-вызовом.
    // Вкладывать её в другую NEWSESSION NESTED LOCAL нельзя — после выхода
    // из внутренней HTTP-state наружной портится ("connectionString not specified"
    // при последующем PATCH).
    IF NOT wbSupplyId(p) THEN createSupply(p);
    IF NOT wbSupplyId(p) THEN {
        MESSAGE 'Не удалось создать поставку на WB.';
        RETURN;
    }
    NEWSESSION NESTED LOCAL {
        setHttpHeadersIS();
        LOCAL messageOrder = STRING ();
        LOCAL response = FILE();

        LOCAL patchUrl = STRING ();
        patchUrl() <- '/api/marketplace/v3/supplies/' + wbSupplyId(p) + '/orders';

        logToFile('WB', 'PATCH: ' + url(CategoryRequest.marketplace) + patchUrl());
        isSelected(InternetOrder order) <- TRUE WHERE (GROUP SUM 1 IF internetOrder(InternetOrderDetail detail) = order AND picking(detail) = p);

        EXPORT JSON FROM 'value' = INTEGER(number(InternetOrder order)) WHERE isSelected(order);
        fileToString(exportFile(), 'UTF-8');
        stringToFile('\{"orders":' + replace(resultString(), '\n', '') + '\}', 'UTF-8', 'json');
        fileToString(resultFile(), 'UTF-8');
        logToFile('WB', 'orders: ' + resultString());

        TRY {
            EXTERNAL HTTP PATCH url(CategoryRequest.marketplace) + patchUrl() HEADERS httpHeaders PARAMS resultFile() TO response;
            fileToString(response());
            logToFile('WB', resultString());
            messageOrder() <- messageStatusHTTP(STRING(statusHttp()));
            IF statusHttp() == 204 THEN {
                // На WB заказы переходят new → confirm. isSelected уже выставлен выше,
                // переиспользуем его и сразу подтягиваем актуальные wbStatus/wbIsCancellable.
                getWbFbsStatuses();
                afterAddOrdersToSupply(p);
            }
        } CATCH {
            logToFile('WB', messageCaughtException());
            IF statusHttp() == 400 OR statusHttp() == 403 OR statusHttp() == 404 OR statusHttp() == 409 THEN {
                IMPORT importError JSON FROM response();
                extraDescriptionStatusHTTP() <- 'Сборочные задания не добавлены в поставку: ' + message();
            }
            messageOrder() <- CONCAT '\n', messageStatusHTTP(STRING(statusHttp())), messageCaughtException();
        } FINALLY {
            afterSendRequestIS();
            MESSAGE '<h3>Добавление заказов к поставке</h3>' NOWAIT;
            MESSAGE messageOrder() NOWAIT;
            isSelected(InternetOrder o) <- NULL;
        }
    }
}

EXTEND CLASS StatusPicking {
    deliver 'В доставке',
    closed 'Закрыта'
}

addToPicking 'Отм.' = DATA LOCAL BOOLEAN (InternetOrderDetail);

orderNumber(InternetOrderDetail d) = number(internetOrder(d));

//https://marketplace-api.wildberries.ru/api/v3/supplies/{supplyId}/deliver
sendSupplyToDeliver 'Передать поставку в доставку'(Picking p){
    NEWSESSION NESTED LOCAL {

        IF NOT wbSupplyId(p) THEN {
            MESSAGE 'У поставки отсутствует wbSupplyId.';
            RETURN;
        }

        setHttpHeadersIS();
        LOCAL messageOrder = STRING ();
        LOCAL response = FILE();

        LOCAL patchUrl = STRING ();

        patchUrl() <- '/api/v3/supplies/' + wbSupplyId(p) + '/deliver';

        logToFile('WB', 'PATCH: ' + url(CategoryRequest.marketplace) + patchUrl());

        TRY {
            EXTERNAL HTTP PATCH url(CategoryRequest.marketplace) + patchUrl() HEADERS httpHeaders TO response;
            fileToString(response());
            logToFile('WB', resultString());
            messageOrder() <- messageStatusHTTP(STRING(statusHttp()));
            IF statusHttp() == 204 THEN {
                status(p) <- StatusPicking.deliver;
                APPLY NESTED LOCAL ;
                // На WB заказы поставки переходят confirm → complete. Подтягиваем
                // актуальные wbStatus/wbIsCancellable по заказам этой комплектации.
                isSelected(InternetOrder order) <- TRUE WHERE (GROUP SUM 1 IF internetOrder(InternetOrderDetail detail) = order AND picking(detail) = p);
                getWbFbsStatuses();
            }
        } CATCH {
            logToFile('WB', messageCaughtException());
            IF statusHttp() == 400 OR statusHttp() == 403 OR statusHttp() == 404 OR statusHttp() == 409 THEN {
                IMPORT importError JSON FROM response();
                extraDescriptionStatusHTTP() <- 'Статус поставки не изменен: ' + message();
            }
            messageOrder() <- CONCAT '\n', messageStatusHTTP(STRING(statusHttp())), messageCaughtException();
        } FINALLY {
            afterSendRequestIS();
            MESSAGE '<h3>Передать поставку в доставку</h3>' NOWAIT;
            MESSAGE messageOrder() NOWAIT;
            isSelected(InternetOrder o) <- NULL;
        }
    }
}

cargoType = DATA LOCAL NUMERIC();
createdAt = DATA LOCAL DATETIME ();
closedAt = DATA LOCAL DATETIME ();
scanDt = DATA LOCAL DATETIME ();
isB2b = DATA LOCAL BOOLEAN();

destinationOfficeId = DATA LOCAL NUMERIC();
crossBorderType = DATA LOCAL NUMERIC();
supplyId = DATA LOCAL STRING();
done = DATA LOCAL BOOLEAN ();
isPickupPointShipmentAllowed = DATA LOCAL BOOLEAN();
recommendedWhId = DATA LOCAL INTEGER();

FORM supplyInfoResponse
    PROPERTIES() cargoType, createdAt, scanDt, isB2b, name, destinationOfficeId, crossBorderType, supplyId EXTID 'id', closedAt, done,
        isPickupPointShipmentAllowed, recommendedWhId;

wbCreatedAt = DATA DATETIME(Picking);
wbClosedAt = DATA DATETIME(Picking);
wbScanDt = DATA DATETIME(Picking);
wbDestinationOfficeId = DATA INTEGER (Picking);
wbIsB2b 'WB: B2B' = DATA BOOLEAN (Picking);
wbIsPickupPointShipmentAllowed 'WB: можно отгрузить на ПВЗ' = DATA BOOLEAN (Picking);
wbCrossBorderType 'WB: тип поставки' = DATA INTEGER (Picking); // 0 — внутр., 1 — трансгран.
wbRecommendedWhId 'WB: рекомендуемый склад приёмки' = DATA INTEGER (Picking);

//https://marketplace-api.wildberries.ru/api/v3/supplies/{supplyId}
getSupplyInfo 'Получить информацию о поставке'(Picking p){
    NEWSESSION NESTED LOCAL {

        IF NOT wbSupplyId(p) THEN {
            MESSAGE 'У поставки отсутствует wbSupplyId.';
            RETURN;
        }

        setHttpHeadersIS();
        LOCAL messageOrder = STRING ();
        LOCAL response = FILE();

        LOCAL patchUrl = STRING ();

        patchUrl() <- '/api/v3/supplies/' + wbSupplyId(p);

        logToFile('WB', 'GET: ' + url(CategoryRequest.marketplace) + patchUrl());

        TRY {
            EXTERNAL HTTP GET url(CategoryRequest.marketplace) + patchUrl() HEADERS httpHeaders TO response;
            fileToString(response());
            logToFile('WB', resultString());
            messageOrder() <- messageStatusHTTP(STRING(statusHttp()));

            IF statusHttp() == 200 THEN {
                IMPORT supplyInfoResponse JSON FROM response();

                wbCreatedAt(p) <- createdAt();
                wbClosedAt(p) <- closedAt();
                wbScanDt(p) <- scanDt();
                wbDestinationOfficeId(p) <- destinationOfficeId();
                wbIsB2b(p) <- isB2b();
                wbIsPickupPointShipmentAllowed(p) <- isPickupPointShipmentAllowed();
                wbCrossBorderType(p) <- crossBorderType();
                wbRecommendedWhId(p) <- recommendedWhId();

                IF done() THEN status(p) <- StatusPicking.closed;

                APPLY NESTED LOCAL ;
            }
        } CATCH {
            logToFile('WB', messageCaughtException());
            IF statusHttp() == 400 OR statusHttp() == 403 OR statusHttp() == 404 OR statusHttp() == 409 THEN {
                IMPORT importError JSON FROM response();
                extraDescriptionStatusHTTP() <- 'Информация о поставке не получена: ' + message();
            }
            messageOrder() <- CONCAT '\n', messageStatusHTTP(STRING(statusHttp())), messageCaughtException();
        } FINALLY {
            afterSendRequestIS();
            MESSAGE messageOrder() NOWAIT;
        }
    }
}
afterAddOrdersToSupply(Picking p) + {
    IF wbSupplyId(p) THEN getSupplyInfo(p);
}

wbSupplyBarcode 'Штрихкод поставки WB' = DATA STRING (Picking);
wbSupplyBarcodeFile 'QR поставки WB' = DATA RAWFILE (Picking);
openWBSupplyBarcodeFile 'QR поставки WB' (Picking p){
    open(wbSupplyBarcodeFile(p), (OVERRIDE wbSupplyId(p), 'qr') + '.svg');
}
// Локальные поля для импорта ответа /barcode (избегаем конфликта с
// barcode = DATA LOCAL STRING(INTEGER) из WBOrders.lsf).
supplyBarcodeStr = DATA LOCAL STRING();
supplyBarcodeImgFile = DATA LOCAL STRING();

FORM supplyBarcodeResponse
    PROPERTIES() supplyBarcodeStr EXTID 'barcode', supplyBarcodeImgFile EXTID 'file'
;

// GET /api/v3/supplies/{supplyId}/barcode?type={svg|png|zplv|zplh}
// Ответ 200: {"barcode":"WB-GI-...", "file":"<base64>"}.
// Доступно только после передачи поставки в доставку (sendSupplyToDeliver) —
// до этого WB вернёт 400. Используем svg.
getSupplyBarcode 'Получить QR поставки' (Picking p) {
    NEWSESSION NESTED LOCAL {
        IF NOT wbSupplyId(p) THEN {
            MESSAGE 'У поставки отсутствует wbSupplyId.';
            RETURN;
        }

        setHttpHeadersIS();
        LOCAL messageOrder = STRING ();
        LOCAL response = FILE();

        LOCAL getUrl = STRING ();
        getUrl() <- '/api/v3/supplies/' + wbSupplyId(p) + '/barcode?type=svg';

        logToFile('WB', 'GET: ' + url(CategoryRequest.marketplace) + getUrl());

        TRY {
            EXTERNAL HTTP GET url(CategoryRequest.marketplace) + getUrl() HEADERS httpHeaders TO response;
            fileToString(response());
            logToFile('WB', resultString());
            messageOrder() <- messageStatusHTTP(STRING(statusHttp()));

            IF statusHttp() == 200 THEN {
                IMPORT supplyBarcodeResponse JSON FROM response();
                wbSupplyBarcode(p) <- supplyBarcodeStr();
                wbSupplyBarcodeFile(p) <- RAWFILE(file(decode(supplyBarcodeImgFile(), 'base64'), 'svg'));
                APPLY NESTED LOCAL ;
            }
        } CATCH {
            logToFile('WB', messageCaughtException());
            IF statusHttp() == 400 OR statusHttp() == 403 OR statusHttp() == 404 OR statusHttp() == 409 THEN {
                IMPORT importError JSON FROM response();
                extraDescriptionStatusHTTP() <- 'QR поставки не получен: ' + message();
            }
            messageOrder() <- CONCAT '\n', messageStatusHTTP(STRING(statusHttp())), messageCaughtException();
        } FINALLY {
            afterSendRequestIS();
            MESSAGE '<h3>Получение QR поставки</h3>' NOWAIT;
            MESSAGE messageOrder() NOWAIT;
        }
    }
}

CLASS WbBox 'Короб FBS';
TABLE wbBox (WbBox);

wbBoxId 'ID грузоместа' = DATA STRING (WbBox) INDEXED;
wbBoxByCode = GROUP AGGR WbBox b BY wbBoxId(b);
picking 'Поставка' = DATA Picking (WbBox) INDEXED NONULL;
numberPicking 'Поставка' (WbBox b) = number(picking(b));
boxSticker 'Стикер короба' = DATA RAWFILE (WbBox);

// Локальный маппинг «заказ → короб». На стороне WB такой связи нет — короба
// привязаны только к поставке, — но в ЕРП мы держим её для планирования
// раскладки и для просмотра «какие заказы в каком коробе».
wbBox 'Короб' = DATA WbBox (InternetOrder);
nameWbBox 'ID короба' (InternetOrder o) = wbBoxId(wbBox(o));

isSelectedBox 'Отм.' = DATA LOCAL NESTED BOOLEAN (WbBox);

// Локальные поля для импорта /trbx (GET): {"trbxes":[{"id":"WB-TRBX-..."}]}.
trbxId = DATA LOCAL STRING(INTEGER);

FORM importSupplyTrbx
    OBJECTS trbxes = INTEGER
    PROPERTIES(trbxes) trbxId EXTID 'id'
    FILTERS imported(trbxes)
;

// Локальные поля для импорта /trbx (POST): {"trbxIds":["WB-TRBX-..."]}.
addedTrbxId = DATA LOCAL STRING(INTEGER);

FORM importAddedTrbx
    OBJECTS trbxIds = INTEGER
    PROPERTIES(trbxIds) addedTrbxId EXTID 'value'
    FILTERS imported(trbxIds)
;

// GET /api/v3/supplies/{supplyId}/trbx
// Ответ: {"trbxes":[{"id":"WB-TRBX-..."}]}. Поле в trbx-объекте — только id.
// Синхронизирует локальные WbBox: создаёт недостающие, удаляет отсутствующие на WB.
getSupplyBoxes 'Подтянуть короба поставки' (Picking p) {
    NEWSESSION NESTED LOCAL {
        IF NOT wbSupplyId(p) THEN {
            MESSAGE 'У поставки отсутствует wbSupplyId.';
            RETURN;
        }
        setHttpHeadersIS();
        LOCAL messageOrder = STRING();
        LOCAL response = FILE();

        LOCAL getUrl = STRING();
        getUrl() <- '/api/v3/supplies/' + wbSupplyId(p) + '/trbx';
        logToFile('WB', 'GET: ' + url(CategoryRequest.marketplace) + getUrl());

        TRY {
            EXTERNAL HTTP GET url(CategoryRequest.marketplace) + getUrl() HEADERS httpHeaders TO response;
            fileToString(response());
            logToFile('WB', resultString());
            IF statusHttp() == 200 THEN {
                IMPORT importSupplyTrbx JSON FROM response();

                FOR INTEGER i AND trbxId(i) AND NOT wbBoxByCode(trbxId(i)) INLINE DO NEW b = WbBox {
                    wbBoxId(b) <- trbxId(i);
                    picking(b) <- p;
                }
                FOR INTEGER i AND trbxId(i) AND WbBox b == wbBoxByCode(trbxId(i)) DO {
                    picking(b) <- p;
                }

                LOCAL hasOnWb = BOOLEAN (WbBox);
                hasOnWb(WbBox b) <- TRUE WHERE picking(b) == p
                    AND (GROUP MAX INTEGER i IF trbxId(i) == wbBoxId(b));
                DELETE WbBox b WHERE picking(b) == p AND NOT hasOnWb(b);

                APPLY NESTED LOCAL;
            }
            messageOrder() <- messageStatusHTTP(STRING(statusHttp()));
        } CATCH {
            logToFile('WB', messageCaughtException());
            IF statusHttp() == 400 OR statusHttp() == 403 OR statusHttp() == 404 THEN {
                IMPORT importError JSON FROM response();
                extraDescriptionStatusHTTP() <- 'Короба не получены: ' + message();
            }
            messageOrder() <- CONCAT '\n', messageStatusHTTP(STRING(statusHttp())), messageCaughtException();
        } FINALLY {
            afterSendRequestIS();
            MESSAGE messageOrder() NOWAIT;
        }
    }
}

// POST /api/v3/supplies/{supplyId}/trbx body: {"amount":N}
// Ответ: {"trbxIds":["WB-TRBX-...", ...]}. Макс 1000 за запрос; поставка должна быть на сборке.
addSupplyBoxes 'Добавить короба в поставку' (Picking p, INTEGER amount) {
    NEWSESSION NESTED LOCAL {
        IF NOT wbSupplyId(p) THEN {
            MESSAGE 'У поставки отсутствует wbSupplyId.';
            RETURN;
        }
        IF NOT (amount > 0) THEN {
            MESSAGE 'Укажите положительное количество коробов.';
            RETURN;
        }
        IF amount > 1000 THEN {
            MESSAGE 'Максимум 1000 коробов за запрос.';
            RETURN;
        }

        setHttpHeadersIS();
        LOCAL messageOrder = STRING();
        LOCAL response = FILE();

        LOCAL postUrl = STRING();
        postUrl() <- '/api/v3/supplies/' + wbSupplyId(p) + '/trbx';

        stringToFile('\{"amount":' + amount + '\}', 'UTF-8', 'json');
        fileToString(resultFile(), 'UTF-8');
        logToFile('WB', 'POST: ' + url(CategoryRequest.marketplace) + postUrl() + ' body: ' + resultString());

        TRY {
            EXTERNAL HTTP POST url(CategoryRequest.marketplace) + postUrl() HEADERS httpHeaders PARAMS resultFile() TO response;
            fileToString(response());
            logToFile('WB', resultString());
            messageOrder() <- messageStatusHTTP(STRING(statusHttp()));
            IF statusHttp() == 201 OR statusHttp() == 200 THEN {
                IMPORT importAddedTrbx JSON FROM response();
                FOR INTEGER i AND addedTrbxId(i) INLINE DO NEW b = WbBox {
                    wbBoxId(b) <- addedTrbxId(i);
                    picking(b) <- p;
                }
                APPLY NESTED LOCAL;
            }
        } CATCH {
            logToFile('WB', messageCaughtException());
            IF statusHttp() == 400 OR statusHttp() == 403 OR statusHttp() == 404 OR statusHttp() == 409 THEN {
                IMPORT importError JSON FROM response();
                extraDescriptionStatusHTTP() <- 'Короба не добавлены: ' + message();
            }
            messageOrder() <- CONCAT '\n', messageStatusHTTP(STRING(statusHttp())), messageCaughtException();
        } FINALLY {
            afterSendRequestIS();
            MESSAGE '<h3>Добавление коробов</h3>' NOWAIT;
            MESSAGE messageOrder() NOWAIT;
        }
    }
}

FORM inputBoxAmount 'Количество коробов'
    OBJECTS n = INTEGER PANEL
    PROPERTIES 'Количество' = VALUE(n)
;

addSupplyBoxesDialog 'Добавить короба' (Picking p) {
    DIALOG inputBoxAmount OBJECTS n INPUT DO {
        addSupplyBoxes(p, n);
    }
}

// DELETE /api/v3/supplies/{supplyId}/trbx body: {"trbxIds":["WB-TRBX-..."]}
// Удаляет отмеченные короба; заказы, которые в них были, на стороне WB
// автоматически выходят из коробов (но остаются в поставке).
deleteSupplyBoxes 'Удалить отмеченные короба' (Picking p) {
    NEWSESSION NESTED LOCAL {
        IF NOT wbSupplyId(p) THEN {
            MESSAGE 'У поставки отсутствует wbSupplyId.';
            RETURN;
        }
        IF NOT (GROUP SUM 1 IF isSelectedBox(WbBox b) AND picking(b) == p) THEN {
            MESSAGE 'Нет отмеченных коробов.';
            RETURN;
        }

        setHttpHeadersIS();
        LOCAL messageOrder = STRING();
        LOCAL response = FILE();

        LOCAL deleteUrl = STRING();
        deleteUrl() <- '/api/v3/supplies/' + wbSupplyId(p) + '/trbx';

        EXPORT JSON FROM 'value' = wbBoxId(WbBox b) WHERE isSelectedBox(b) AND picking(b) == p;
        fileToString(exportFile(), 'UTF-8');
        stringToFile('\{"trbxIds":' + replace(resultString(), '\n', '') + '\}', 'UTF-8', 'json');
        fileToString(resultFile(), 'UTF-8');
        logToFile('WB', 'DELETE: ' + url(CategoryRequest.marketplace) + deleteUrl() + ' body: ' + resultString());

        TRY {
            EXTERNAL HTTP DELETE url(CategoryRequest.marketplace) + deleteUrl() HEADERS httpHeaders PARAMS resultFile() TO response;
            fileToString(response());
            logToFile('WB', resultString());
            messageOrder() <- messageStatusHTTP(STRING(statusHttp()));
            IF statusHttp() == 204 THEN {
                DELETE WbBox b WHERE isSelectedBox(b) AND picking(b) == p;
                APPLY NESTED LOCAL;
            }
        } CATCH {
            logToFile('WB', messageCaughtException());
            IF statusHttp() == 400 OR statusHttp() == 403 OR statusHttp() == 404 OR statusHttp() == 409 THEN {
                IMPORT importError JSON FROM response();
                extraDescriptionStatusHTTP() <- 'Короба не удалены: ' + message();
            }
            messageOrder() <- CONCAT '\n', messageStatusHTTP(STRING(statusHttp())), messageCaughtException();
        } FINALLY {
            afterSendRequestIS();
            MESSAGE messageOrder() NOWAIT;
        }
    }
}

// POST /api/v3/supplies/{supplyId}/trbx/stickers?type={svg|zplv|zplh|png} body: {"trbxIds":[...]}
boxStickerFile = DATA LOCAL STRING(INTEGER);
boxStickerTrbxId = DATA LOCAL STRING(INTEGER);

FORM boxStickersResponse
    OBJECTS stickers = INTEGER
    PROPERTIES(stickers) boxStickerFile EXTID 'file', boxStickerTrbxId EXTID 'trbxId'
    FILTERS imported(stickers)
;

getSupplyBoxStickers 'Получить стикеры коробов' (Picking p) {
    NEWSESSION NESTED LOCAL {
        IF NOT wbSupplyId(p) THEN {
            MESSAGE 'У поставки отсутствует wbSupplyId.';
            RETURN;
        }
        IF NOT (GROUP SUM 1 IF picking(WbBox b) == p) THEN {
            MESSAGE 'В поставке нет коробов.';
            RETURN;
        }

        setHttpHeadersIS();
        LOCAL messageOrder = STRING();
        LOCAL response = FILE();

        LOCAL postUrl = STRING();
        postUrl() <- '/api/v3/supplies/' + wbSupplyId(p) + '/trbx/stickers?type=svg';

        EXPORT JSON FROM 'value' = wbBoxId(WbBox b) WHERE picking(b) == p AND wbBoxId(b);
        fileToString(exportFile(), 'UTF-8');
        stringToFile('\{"trbxIds":' + replace(resultString(), '\n', '') + '\}', 'UTF-8', 'json');
        fileToString(resultFile(), 'UTF-8');
        logToFile('WB', 'POST: ' + url(CategoryRequest.marketplace) + postUrl() + ' body: ' + resultString());

        TRY {
            EXTERNAL HTTP POST url(CategoryRequest.marketplace) + postUrl() HEADERS httpHeaders PARAMS resultFile() TO response;
            fileToString(response());
            logToFile('WB', resultString());
            messageOrder() <- messageStatusHTTP(STRING(statusHttp()));
            IF statusHttp() == 200 THEN {
                IMPORT boxStickersResponse JSON FROM response();
                FOR INTEGER i AND boxStickerTrbxId(i) AND WbBox b == wbBoxByCode(boxStickerTrbxId(i)) DO {
                    boxSticker(b) <- RAWFILE(file(decode(boxStickerFile(i), 'base64'), 'svg'));
                }
                APPLY NESTED LOCAL;
            }
        } CATCH {
            logToFile('WB', messageCaughtException());
            IF statusHttp() == 400 OR statusHttp() == 403 OR statusHttp() == 404 OR statusHttp() == 409 THEN {
                IMPORT importError JSON FROM response();
                extraDescriptionStatusHTTP() <- 'Стикеры коробов не получены: ' + message();
            }
            messageOrder() <- CONCAT '\n', messageStatusHTTP(STRING(statusHttp())), messageCaughtException();
        } FINALLY {
            afterSendRequestIS();
            MESSAGE messageOrder() NOWAIT;
        }
    }
}

FORM wbSupplyBoxes 'Короба поставки'
    OBJECTS p = Picking PANEL
    PROPERTIES (p) READONLY number, wbSupplyId
    PROPERTIES (p) addSupplyBoxesDialog, getSupplyBoxes, getSupplyBoxStickers, deleteSupplyBoxes

    OBJECTS b = WbBox
    PROPERTIES (b) isSelectedBox, wbBoxId READONLY, boxSticker READONLY
    FILTERS picking(b) == p
    ORDERS wbBoxId(b)
;

manageSupplyBoxes 'Короба поставки' (Picking p) {
    SHOW wbSupplyBoxes OBJECTS p = p;
}

// Только в ЕРП: WB этой связи не знает. Используется для планирования и
// печати на стикере короба списка заказов внутри.
FORM wbBoxTargetDialog 'Выбор короба'
    OBJECTS b = WbBox
    PROPERTIES (b) READONLY wbBoxId, numberPicking
    LIST WbBox OBJECT b
;

setWbBox 'Положить в короб' (InternetOrder o) {
    LOCAL targetP = Picking();
    targetP() <- GROUP MAX Picking pic IF (GROUP MAX InternetOrderDetail d IF internetOrder(d) == o AND picking(d) == pic);
    IF NOT targetP() THEN {
        MESSAGE 'Заказ не привязан к поставке.';
        RETURN;
    }
    DIALOG wbBoxTargetDialog OBJECTS b INPUT FILTERS picking(b) == targetP() DO {
        wbBox(o) <- b;
        APPLY;
    }
}

clearWbBox 'Убрать из короба' (InternetOrder o) {
    wbBox(o) <- NULL;
    APPLY;
}

setWbBox 'Положить в короб' (InternetOrderDetail d) {
    setWbBox(internetOrder(d));
}

clearWbBox 'Убрать из короба' (InternetOrderDetail d) {
    clearWbBox(internetOrder(d));
}

// Префикс supplies* — чтобы не конфликтовать с одноимёнными LOCAL'ами getSupplyInfo.
suppliesId = DATA LOCAL STRING(INTEGER);
suppliesDone = DATA LOCAL BOOLEAN(INTEGER);
suppliesCreatedAt = DATA LOCAL DATETIME(INTEGER);
suppliesClosedAt = DATA LOCAL DATETIME(INTEGER);
suppliesScanDt = DATA LOCAL DATETIME(INTEGER);
suppliesName = DATA LOCAL STRING(INTEGER);
suppliesCargoType = DATA LOCAL INTEGER(INTEGER);
suppliesDestinationOfficeId = DATA LOCAL INTEGER(INTEGER);
suppliesIsB2b = DATA LOCAL BOOLEAN(INTEGER);
suppliesIsPickupPointShipmentAllowed = DATA LOCAL BOOLEAN(INTEGER);
suppliesCrossBorderType = DATA LOCAL INTEGER(INTEGER);
suppliesRecommendedWhId = DATA LOCAL INTEGER(INTEGER);
nextSuppliesIndex = DATA LOCAL INTEGER();

FORM importSuppliesList
    PROPERTIES() nextSuppliesIndex EXTID 'next'

    OBJECTS supplies = INTEGER
    PROPERTIES(supplies)
    suppliesId EXTID 'id',
        suppliesDone EXTID 'done',
        suppliesCreatedAt EXTID 'createdAt',
        suppliesClosedAt EXTID 'closedAt',
        suppliesScanDt EXTID 'scanDt',
        suppliesName EXTID 'name',
        suppliesCargoType EXTID 'cargoType',
        suppliesDestinationOfficeId EXTID 'destinationOfficeId',
        suppliesIsB2b EXTID 'isB2b',
        suppliesIsPickupPointShipmentAllowed EXTID 'isPickupPointShipmentAllowed',
        suppliesCrossBorderType EXTID 'crossBorderType',
        suppliesRecommendedWhId EXTID 'recommendedWhId'
    FILTERS imported(supplies)
;

dataGetSuppliesLimit = DATA INTEGER();
getSuppliesLimit 'Лимит запросов списка поставок' = OVERRIDE dataGetSuppliesLimit(), 1000;

// GET /api/v3/supplies?limit&next
// Список поставок продавца с пагинацией. Синхронизирует wbCreatedAt/wbClosedAt/wbScanDt/
// wbDestinationOfficeId на существующих Picking по wbSupplyId; завершённые помечает StatusPicking.closed.
// Поставки без локального Picking сообщаются как «orphan» (созданы вне ERP).
listSuppliesFBS 'Синхронизировать список поставок (FBS)' () {
    NEWSESSION NESTED LOCAL {
        setHttpHeadersIS();
        LOCAL messageOrder = STRING();
        LOCAL response = FILE();

        LOCAL limit = INTEGER();
        limit() <- getSuppliesLimit();
        IF limit() > 1000 THEN limit() <- 1000;

        LOCAL NESTED nextWB = INTEGER();
        nextWB() <- 0;

        LOCAL stop = BOOLEAN();
        LOCAL orphanCount = INTEGER();
        orphanCount() <- 0;
        LOCAL pickingFor = Picking (INTEGER);
        LOCAL pageOrphans = INTEGER();

        WHILE NOT stop() AND nextWB() >= 0 DO {
            logToFile('WB', 'GET: ' + url(CategoryRequest.marketplace) + '/api/v3/supplies?limit=' + limit() + '&next=' + nextWB());

            TRY {
                EXTERNAL HTTP GET url(CategoryRequest.marketplace) + '/api/v3/supplies?limit=$1&next=$2'
                    HEADERS httpHeaders PARAMS limit(), nextWB() TO response;
                fileToString(response());
                logToFile('WB', resultString());
                IMPORT importSuppliesList JSON FROM response();

                pickingFor(INTEGER i) <- GROUP MAX Picking p1 IF imported(i) AND suppliesId(i) AND wbSupplyId(p1) == suppliesId(i);

                FOR INTEGER i AND suppliesId(i) AND Picking p == pickingFor(i) DO {
                    wbCreatedAt(p) <- suppliesCreatedAt(i);
                    wbClosedAt(p) <- suppliesClosedAt(i);
                    wbScanDt(p) <- suppliesScanDt(i);
                    wbDestinationOfficeId(p) <- suppliesDestinationOfficeId(i);
                    wbIsB2b(p) <- suppliesIsB2b(i);
                    wbIsPickupPointShipmentAllowed(p) <- suppliesIsPickupPointShipmentAllowed(i);
                    wbCrossBorderType(p) <- suppliesCrossBorderType(i);
                    wbRecommendedWhId(p) <- suppliesRecommendedWhId(i);
                    IF suppliesDone(i) THEN status(p) <- StatusPicking.closed;
                }

                pageOrphans() <- GROUP SUM 1 IF imported(INTEGER i) AND suppliesId(i) AND NOT pickingFor(i);
                IF pageOrphans() THEN orphanCount() <- orphanCount() + pageOrphans();

                LOCAL currentNext = INTEGER();
                currentNext() <- nextSuppliesIndex();
                IF currentNext() > 0 AND currentNext() != nextWB() THEN {
                    nextWB() <- currentNext();
                } ELSE {
                    stop() <- TRUE;
                }
                messageOrder() <- (OVERRIDE messageOrder() + '\n', '') + messageStatusHTTP(STRING(statusHttp()));
            } CATCH {
                logToFile('WB', messageCaughtException());
                IF statusHttp() == 400 OR statusHttp() == 401 OR statusHttp() == 403 THEN {
                    IMPORT importError JSON FROM response();
                    extraDescriptionStatusHTTP() <- 'Список поставок не получен: ' + message();
                }
                messageOrder() <- CONCAT '\n', messageStatusHTTP(STRING(statusHttp())), messageCaughtException();
                stop() <- TRUE;
            } FINALLY {
                afterSendRequestIS();
                IF NOT (statusHttp() >= 200 AND statusHttp() < 300) THEN stop() <- TRUE;
                APPLY NESTED LOCAL;
                IF NOT stop() THEN sleep(200);
            }
        }

        IF orphanCount() > 0 THEN
            messageOrder() <- (OVERRIDE messageOrder() + '\n', '') + 'Поставок на WB без локального Picking: ' + STRING(orphanCount());
        MESSAGE messageOrder() NOWAIT;
    }
}

// GET /api/v3/supplies/{supplyId}/orders
// Возвращает заказы указанной поставки. Используется для восстановления связи
// InternetOrderDetail.picking, если заказы попали в поставку вне ERP или связь потеряна.
// Локальные поля переиспользуем из FORM importOrdersFBS — обёртка ответа {"orders":[...]} совместима.
getOrdersInSupply 'Подтянуть заказы поставки' (Picking p) {
    NEWSESSION NESTED LOCAL {
        IF NOT wbSupplyId(p) THEN {
            MESSAGE 'У поставки отсутствует wbSupplyId.';
            RETURN;
        }

        setHttpHeadersIS();
        LOCAL messageOrder = STRING();
        LOCAL response = FILE();

        LOCAL getUrl = STRING();
        getUrl() <- '/api/v3/supplies/' + wbSupplyId(p) + '/orders';

        logToFile('WB', 'GET: ' + url(CategoryRequest.marketplace) + getUrl());

        TRY {
            EXTERNAL HTTP GET url(CategoryRequest.marketplace) + getUrl() HEADERS httpHeaders TO response;
            fileToString(response());
            logToFile('WB', resultString());
            IF statusHttp() == 200 THEN {
                IMPORT importOrdersFBS JSON FROM response();

                FOR INTEGER i = [GROUP MAX INTEGER i1 BY id(i1)](STRING number)
                    AND InternetOrder o == orderByNumber(number)
                    AND isWBOrderFBS(o) INLINE DO {
                    FOR InternetOrderDetail d AND internetOrder(d) == o AND NOT picking(d) DO {
                        picking(d) <- p;
                    }
                }
                APPLY NESTED LOCAL;
            }
            messageOrder() <- messageStatusHTTP(STRING(statusHttp()));
        } CATCH {
            logToFile('WB', messageCaughtException());
            IF statusHttp() == 400 OR statusHttp() == 403 OR statusHttp() == 404 THEN {
                IMPORT importError JSON FROM response();
                extraDescriptionStatusHTTP() <- 'Заказы поставки не получены: ' + message();
            }
            messageOrder() <- CONCAT '\n', messageStatusHTTP(STRING(statusHttp())), messageCaughtException();
        } FINALLY {
            afterSendRequestIS();
            MESSAGE messageOrder() NOWAIT;
        }
    }
}

// DELETE /api/v3/supplies/{supplyId}
// Удаляет пустую поставку (без заказов, не переданную в доставку).
deleteSupplyOnWBOk = DATA LOCAL NESTED BOOLEAN ();

deleteSupplyOnWB (STRING supplyId) {
    NEWSESSION NESTED LOCAL {
        setHttpHeadersIS();
        LOCAL messageOrder = STRING();
        LOCAL response = FILE();

        LOCAL deleteUrl = STRING();
        deleteUrl() <- '/api/v3/supplies/' + supplyId;

        logToFile('WB', 'DELETE: ' + url(CategoryRequest.marketplace) + deleteUrl());

        TRY {
            EXTERNAL HTTP DELETE url(CategoryRequest.marketplace) + deleteUrl() HEADERS httpHeaders TO response;
            fileToString(response());
            logToFile('WB', resultString());
            messageOrder() <- messageStatusHTTP(STRING(statusHttp()));
            IF statusHttp() == 204 THEN deleteSupplyOnWBOk() <- TRUE;
        } CATCH {
            logToFile('WB', messageCaughtException());
            IF statusHttp() == 400 OR statusHttp() == 403 OR statusHttp() == 404 OR statusHttp() == 409 THEN {
                IMPORT importError JSON FROM response();
                extraDescriptionStatusHTTP() <- 'Поставка не удалена: ' + message();
            }
            messageOrder() <- CONCAT '\n', messageStatusHTTP(STRING(statusHttp())), messageCaughtException();
        } FINALLY {
            afterSendRequestIS();
            MESSAGE '<h3>Удаление поставки</h3>' NOWAIT;
            MESSAGE messageOrder() NOWAIT;
        }
    }
}

deleteSupplyFBS 'Удалить поставку WB' (Picking p) {
    IF NOT wbSupplyId(p) THEN {
        MESSAGE 'У поставки отсутствует wbSupplyId.';
        RETURN;
    }
    ASK 'Удалить поставку ' + wbSupplyId(p) + ' на WB? Должна быть пустой и не переданной в доставку.' DO {
        deleteSupplyOnWBOk() <- NULL;
        deleteSupplyOnWB(wbSupplyId(p));
        IF deleteSupplyOnWBOk() THEN {
            wbSupplyId(p) <- NULL;
            APPLY;
        }
    }
}

// При удалении локального Picking сначала пытаемся снести поставку на WB.
// Если в комплектации остались строки — на WB поставка точно непуста (DELETE
// вернёт 409 SupplyHasOrders), HTTP лишний раз не дёргаем, сразу CANCEL.
// Иначе пробуем DELETE на WB; любая ошибка → тоже CANCEL, чтобы не оставлять
// orphan-поставку. Чтобы Picking удалить, разгребите заказы заранее:
// cancelOrderFBS / moveOrderFBSDialog.
WHEN DROPPED(Picking p IS Picking) AND PREV(wbSupplyId(p)) DO {
    IF PREV(countInternetOrderDetail(p)) THEN {
        MESSAGE 'Нельзя удалить FBS-комплектацию: остались заказы. Сначала отмените их или перенесите в другую поставку.' NOWAIT;
        CANCEL;
    } ELSE {
        deleteSupplyOnWBOk() <- NULL;
        deleteSupplyOnWB(PREV(wbSupplyId(p)));
        IF NOT deleteSupplyOnWBOk() THEN CANCEL;
    }
}

// PATCH /api/v3/supplies/{supplyId}/orders/{orderId}
// В WB FBS-API нет отдельного DELETE для удаления заказа из поставки — перенос
// делается тем же PATCH с другим supplyId, заказ автоматически уходит из старой.
// Используется и для «убрать из поставки» (создать пустую и перенести), и для перекомпоновки.
moveOrderToSupplyFBS 'Переместить заказ в поставку' (InternetOrder o, Picking targetP) {
    NEWSESSION NESTED LOCAL {
        IF NOT isWBOrderFBS(o) THEN {
            MESSAGE 'Заказ не является FBS-заказом WB.';
            RETURN;
        }
        IF NOT number(o) THEN {
            MESSAGE 'У заказа отсутствует номер.';
            RETURN;
        }
        IF NOT wbSupplyId(targetP) THEN createSupply(targetP);
        IF NOT wbSupplyId(targetP) THEN {
            MESSAGE 'Не удалось получить wbSupplyId для целевой поставки.';
            RETURN;
        }

        setHttpHeadersIS();
        LOCAL messageOrder = STRING();
        LOCAL response = FILE();

        LOCAL patchUrl = STRING();
        patchUrl() <- '/api/v3/supplies/' + wbSupplyId(targetP) + '/orders/' + number(o);

        logToFile('WB', 'PATCH: ' + url(CategoryRequest.marketplace) + patchUrl());

        TRY {
            EXTERNAL HTTP PATCH url(CategoryRequest.marketplace) + patchUrl() HEADERS httpHeaders TO response;
            fileToString(response());
            logToFile('WB', resultString());
            messageOrder() <- messageStatusHTTP(STRING(statusHttp()));
            IF statusHttp() == 204 THEN {
                FOR InternetOrderDetail d AND internetOrder(d) == o DO {
                    picking(d) <- targetP;
                }
                APPLY NESTED LOCAL;
            }
        } CATCH {
            logToFile('WB', messageCaughtException());
            IF statusHttp() == 400 OR statusHttp() == 403 OR statusHttp() == 404 OR statusHttp() == 409 THEN {
                IMPORT importError JSON FROM response();
                extraDescriptionStatusHTTP() <- 'Заказ не перенесён: ' + message();
            }
            messageOrder() <- CONCAT '\n', messageStatusHTTP(STRING(statusHttp())), messageCaughtException();
        } FINALLY {
            afterSendRequestIS();
            MESSAGE '<h3>Перенос заказа в поставку</h3>' NOWAIT;
            MESSAGE messageOrder() NOWAIT;
        }
    }
}

FORM pickingTargetDialog 'Выбор целевой поставки'
    OBJECTS p = Picking
    PROPERTIES (p) READONLY number, status
    FILTERS NOT (status(p) == StatusPicking.deliver OR status(p) == StatusPicking.closed)
    LIST Picking OBJECT p
;

moveOrderFBSDialog 'Перенести в другую поставку' (InternetOrder o) {
    DIALOG pickingTargetDialog OBJECTS p INPUT DO {
        moveOrderToSupplyFBS(o, p);
    }
}

moveOrderFBSDialog 'Перенести в другую поставку' (InternetOrderDetail d) {
    moveOrderFBSDialog(internetOrder(d));
}

acceptanceDate 'Дата' = DATA LOCAL DATETIME(INTEGER);
acceptanceCoefficient 'Коэффициент' = DATA LOCAL NUMERIC(INTEGER);
acceptanceWarehouseID 'ID склада' = DATA LOCAL INTEGER(INTEGER);
acceptanceWarehouseName 'Склад' = DATA LOCAL STRING(INTEGER);
acceptanceAllowUnload 'Приёмка доступна' = DATA LOCAL BOOLEAN(INTEGER);
acceptanceBoxTypeName 'Тип упаковки' = DATA LOCAL STRING(INTEGER);
acceptanceBoxTypeID 'ID типа упаковки' = DATA LOCAL INTEGER(INTEGER);
acceptanceIsSortingCenter 'Сорт. центр' = DATA LOCAL BOOLEAN(INTEGER);

FORM importAcceptanceCoefficients
    OBJECTS value = INTEGER
    PROPERTIES(value)
    acceptanceDate EXTID 'date',
        acceptanceCoefficient EXTID 'coefficient',
        acceptanceWarehouseID EXTID 'warehouseID',
        acceptanceWarehouseName EXTID 'warehouseName',
        acceptanceAllowUnload EXTID 'allowUnload',
        acceptanceBoxTypeName EXTID 'boxTypeName',
        acceptanceBoxTypeID EXTID 'boxTypeID',
        acceptanceIsSortingCenter EXTID 'isSortingCenter'
    FILTERS imported(value)
;

FORM wbAcceptanceCoefficients 'Коэффициенты приёмки WB'
    OBJECTS v = INTEGER
    PROPERTIES(v) READONLY
    acceptanceWarehouseName, acceptanceWarehouseID, acceptanceDate, acceptanceCoefficient,
        acceptanceAllowUnload, acceptanceBoxTypeName, acceptanceIsSortingCenter
    FILTERS imported(v)
    ORDERS acceptanceWarehouseName(v), acceptanceDate(v)
;

// GET https://supplies-api.wildberries.ru/api/v1/acceptance/coefficients
// Коэффициенты приёмки на ближайшие 14 дней по складам WB. Лимит 6 запросов/мин.
// Категория токена: «Поставки» (CategoryRequest.shipment). Ответ — массив без обёртки.
getAcceptanceCoefficients 'Получить коэффициенты приёмки' () {
    NEWSESSION NESTED LOCAL {
        setHttpHeadersIS();
        LOCAL messageOrder = STRING();
        LOCAL response = FILE();

        logToFile('WB', 'GET: ' + url(CategoryRequest.shipment) + '/api/v1/acceptance/coefficients');

        TRY {
            EXTERNAL HTTP GET url(CategoryRequest.shipment) + '/api/v1/acceptance/coefficients' HEADERS httpHeaders TO response;
            fileToString(response());
            logToFile('WB', resultString());
            messageOrder() <- messageStatusHTTP(STRING(statusHttp()));
            IF statusHttp() == 200 THEN {
                IMPORT importAcceptanceCoefficients JSON FROM response();
                SHOW wbAcceptanceCoefficients;
            }
        } CATCH {
            logToFile('WB', messageCaughtException());
            IF statusHttp() == 400 OR statusHttp() == 401 OR statusHttp() == 403 OR statusHttp() == 429 THEN {
                IMPORT importError JSON FROM response();
                extraDescriptionStatusHTTP() <- 'Коэффициенты приёмки не получены: ' + message();
            }
            messageOrder() <- CONCAT '\n', messageStatusHTTP(STRING(statusHttp())), messageCaughtException();
        } FINALLY {
            afterSendRequestIS();
            MESSAGE messageOrder() NOWAIT;
        }
    }
}

// PUT /api/v3/orders/{orderId}/meta/{key}
// PUT /api/marketplace/v3/orders/{orderId}/meta/customs-declaration
sendOrderMeta 'Передать метаданные сборочного задания' (InternetOrder o, OrderMeta m) {
    NEWSESSION NESTED LOCAL {
        IF NOT number(o) THEN {
            MESSAGE 'У заказа отсутствует номер.';
            RETURN;
        }
        IF NOT apiMetaPath(m) THEN {
            MESSAGE 'Неизвестный тип метаданных.';
            RETURN;
        }

        setHttpHeadersIS();
        LOCAL messageOrder = STRING ();
        LOCAL response = FILE();

        LOCAL putUrl = STRING ();
        putUrl() <- (CASE WHEN m == OrderMeta.customsDeclaration THEN '/api/marketplace/v3/orders/' ELSE '/api/v3/orders/')
            + number(o) + '/meta/' + apiMetaPath(m);

        EXPORT JSON FROM 'value' = valueMeta(InternetOrderDetail d, m)
            WHERE internetOrder(d) == o AND valueMeta(d, m);
        fileToString(exportFile(), 'UTF-8');
        stringToFile('\{"' + apiMetaBodyKey(m) + '":' + replace(resultString(), '\n', '') + '\}', 'UTF-8', 'json');
        fileToString(resultFile(), 'UTF-8');

        logToFile('WB', 'PUT: ' + url(CategoryRequest.marketplace) + putUrl() + ' body: ' + resultString());

        TRY {
            EXTERNAL HTTP PUT url(CategoryRequest.marketplace) + putUrl() HEADERS httpHeaders PARAMS resultFile() TO response;
            fileToString(response());
            logToFile('WB', resultString());
            messageOrder() <- messageStatusHTTP(STRING(statusHttp()));
        } CATCH {
            logToFile('WB', messageCaughtException());
            IF statusHttp() == 400 OR statusHttp() == 403 OR statusHttp() == 404 OR statusHttp() == 409 THEN {
                IMPORT importError JSON FROM response();
                extraDescriptionStatusHTTP() <- 'Метаданные не переданы: ' + message();
            }
            messageOrder() <- CONCAT '\n', messageStatusHTTP(STRING(statusHttp())), messageCaughtException();
        } FINALLY {
            afterSendRequestIS();
            MESSAGE messageOrder() NOWAIT;
        }
    }
}

// DELETE /api/v3/orders/{orderId}/meta?key=...
deleteOrderMeta 'Удалить метаданные сборочного задания' (InternetOrder o, OrderMeta m) {
    NEWSESSION NESTED LOCAL {
        IF NOT number(o) THEN {
            MESSAGE 'У заказа отсутствует номер.';
            RETURN;
        }
        IF NOT apiMetaPath(m) THEN {
            MESSAGE 'Неизвестный тип метаданных.';
            RETURN;
        }

        setHttpHeadersIS();
        LOCAL messageOrder = STRING ();
        LOCAL response = FILE();

        LOCAL deleteUrl = STRING ();
        deleteUrl() <- '/api/v3/orders/' + number(o) + '/meta?key=' + apiMetaPath(m);

        logToFile('WB', 'DELETE: ' + url(CategoryRequest.marketplace) + deleteUrl());

        TRY {
            EXTERNAL HTTP DELETE url(CategoryRequest.marketplace) + deleteUrl() HEADERS httpHeaders TO response;
            fileToString(response());
            logToFile('WB', resultString());
            messageOrder() <- messageStatusHTTP(STRING(statusHttp()));

            IF statusHttp() == 204 THEN {
                FOR InternetOrderDetail d AND internetOrder(d) == o DO {
                    orderMetaStatus(d, m) <- NULL;
                }
                APPLY NESTED LOCAL ;
            }
        } CATCH {
            logToFile('WB', messageCaughtException());
            IF statusHttp() == 400 OR statusHttp() == 403 OR statusHttp() == 404 OR statusHttp() == 409 THEN {
                IMPORT importError JSON FROM response();
                extraDescriptionStatusHTTP() <- 'Метаданные не удалены: ' + message();
            }
            messageOrder() <- CONCAT '\n', messageStatusHTTP(STRING(statusHttp())), messageCaughtException();
        } FINALLY {
            afterSendRequestIS();
            MESSAGE messageOrder() NOWAIT;
        }
    }
}

// POST /api/marketplace/v3/orders/meta body: {"orders":[<номера заказов>]}
actualizeOrdersMeta 'Актуализировать статусы метаданных (FBS)' () {
    NEWSESSION NESTED LOCAL {
        IF NOT (GROUP SUM 1 IF isSelected(InternetOrder order) AND isWBOrderFBS(order)) THEN {
            MESSAGE 'Заказ FBS не выбран.';
            RETURN;
        }

        setHttpHeadersIS();
        LOCAL messageOrder = STRING ();
        LOCAL response = FILE();
        LOCAL index = INTEGER (InternetOrder);
        LOCAL exported = INTEGER ();
        LOCAL bodyIds = STRING ();

        index(InternetOrder o) <- PARTITION SUM 1 IF isSelected(o) AND isWBOrderFBS(o) ORDER o;
        exported() <- 0;

        WHILE exported() < (GROUP MAX index(InternetOrder i)) DO {
            bodyIds() <- (GROUP CONCAT number(InternetOrder o), ',' ORDER o
            WHERE index(o) > exported() AND index(o) <= exported() + getOrdersMetaLimit());

            stringToFile('\{"orders":[' + bodyIds() + ']\}', 'UTF-8', 'json');
            fileToString(resultFile(), 'UTF-8');
            logToFile('WB', 'POST: ' + url(CategoryRequest.marketplace) + '/api/marketplace/v3/orders/meta body: ' + resultString());

            TRY {
                EXTERNAL HTTP POST url(CategoryRequest.marketplace) + '/api/marketplace/v3/orders/meta'
                    HEADERS httpHeaders PARAMS resultFile() TO response;
                fileToString(response());
                logToFile('WB', resultString());

                IF statusHttp() == 200 THEN {
                    IMPORT ordersMetaResponse JSON FROM response();

                    FOR INTEGER d AND imported(d)
                        AND OrderMeta meta == orderMetaByName(metaDetailKey(d))
                        AND InternetOrder ord == orderByNumber(metaOrderId(ordersMetaDetails(d)))
                        DO {

                        LOCAL status = OrderMetaStatus ();
                        status() <- orderMetaStatusById(meta, metaDetailDecision(d));
                        IF NOT status() THEN NEW s = OrderMetaStatus {
                            id(s) <- metaDetailDecision(d);
                            orderMeta(s) <- meta;
                            status() <- s;
                        }
                        name(status()) <- metaDetailDecision(d);
                        validated(status()) <- validatedDecision(metaDetailDecision(d));

                        FOR InternetOrderDetail detail AND internetOrder(detail) == ord DO {
                            orderMetaStatus(detail, meta) <- status();
                            wbValueMeta(detail, meta) <- metaDetailValue(d);
                        }
                    }
                }
                messageOrder() <- messageStatusHTTP(STRING(statusHttp()));
            } CATCH {
                logToFile('WB', messageCaughtException());
                IF statusHttp() == 400 OR statusHttp() == 403 OR statusHttp() == 404 OR statusHttp() == 409 THEN {
                    IMPORT importError JSON FROM response();
                    extraDescriptionStatusHTTP() <- 'Статусы метаданных не получены: ' + message();
                }
                messageOrder() <- CONCAT '\n', messageStatusHTTP(STRING(statusHttp())), messageCaughtException();
            } FINALLY {
                afterSendRequestIS();
                APPLY NESTED LOCAL ;
            }

            exported() <- exported() + getOrdersMetaLimit();
        }

        MESSAGE messageOrder() NOWAIT;
    }
}

EXTEND FORM internetOrder
    PROPERTIES SHOWIF isWBOrderFBS(o) sendOrderMeta(o, mm)
;

FORM wbInternetDetailsDialog 'WB заказы'
    OBJECTS d = InternetOrderDetail
    PROPERTIES (d) addToPicking, orderNumber, nameSku
    // В поставку можно добавить только заказы в supplierStatus=new (ещё не приписаны
    // ни к какой поставке); после addOrdersToSupply WB переводит их в confirm.
    FILTERS isWBOrderFBS(internetOrder(d)) AND wbStatus(internetOrder(d)) == WbStatus.new;

addDetailsFromWbOrder 'Добавить заказы WB' (Picking p){
    LOCAL added = BOOLEAN();
    DIALOG wbInternetDetailsDialog OBJECTS d INPUT DO {
        FOR addToPicking(InternetOrderDetail dd) DO {
            picking(dd) <- p;
            added() <- TRUE;
        }
    }
    IF NOT added() THEN RETURN;
    APPLY ;
    addOrdersToSupply(p);
}

// На стороне WB короба (TRBX) формируются только при доставке поставки на ПВЗ;
// для прямой доставки на склад/курьерской модели короба не нужны. Признак
// делаем абстрактным — проект может подставить свою логику (например, по
// wbDestinationOfficeId или флагу склада). Дефолтная реализация — ручная
// отметка dataPvzDelivery на форме комплектации.
isPvzDelivery 'Доставка на ПВЗ' = ABSTRACT CASE BOOLEAN (Picking);
dataPvzDelivery 'Доставка на ПВЗ' = DATA BOOLEAN (Picking);
isPvzDelivery(Picking p) += WHEN p IS Picking AND wbIsPickupPointShipmentAllowed(p) THEN dataPvzDelivery(p);

// Заказ «идёт на ПВЗ», если хотя бы одна его строка лежит в Picking с isPvzDelivery=TRUE.
// Используется для SHOWIF box-actions на форме заказа.
isPvzDeliveryOrder 'Доставка на ПВЗ' (InternetOrder o) =
    GROUP MAX isPvzDelivery(picking(InternetOrderDetail d)) IF internetOrder(d) == o;

// Поставка «FBS-комплектация», если хотя бы одна её строка — заказ WB FBS.
// По этому признаку гейтятся FBS-действия на форме комплектации и дашборде.
isWBOrderPicking 'Содержит заказы FBS WB' (Picking p) =
    GROUP MAX isWBOrderFBS(internetOrder(InternetOrderDetail d)) IF picking(d) == p;

openSticker 'Печать стикеров WB' (InternetOrder o) { open(sticker(o)); } IMAGE 'print.png' IN print;

EXTEND FORM picking
    PROPERTIES (p) SHOWIF isWBOrderPicking(p) addDetailsFromWbOrder DRAW d TOOLBAR
    PROPERTIES (p) SHOWIF isWBOrderPicking(p) dataPvzDelivery READONLYIF NOT wbIsPickupPointShipmentAllowed(p)
    PROPERTIES (d) SHOWIF isWBOrderPicking(p) moveOrderFBSDialog,
        setWbBox SHOWIF isWBOrderFBS(internetOrder(d)) AND isPvzDeliveryOrder(internetOrder(d)),
        clearWbBox SHOWIF isWBOrderFBS(internetOrder(d)) AND wbBox(internetOrder(d))
;

EXTEND FORM internetOrders
    PROPERTIES(o) READONLY isWBOrderFBS AFTER isClosed(o)
    PROPERTIES(o) SHOWIF isWBOrderFBS(o) openSticker
    PROPERTIES(o) READONLY SHOWIF isWBOrderFBS(o) orderRidID, orderUID, nameWbBox, getSticker CHANGEABLE
    PROPERTIES (o) getWbFbsStatus,
        cancelOrderFBS SHOWIF isWBOrderFBS(o) AND wbIsCancellable(o)
    PROPERTIES() getOrdersFBSNew, getOrdersFBS, actualizeOrdersMeta,
        listSuppliesFBS, getAcceptanceCoefficients
;

EXTEND FORM pickingDashboard
    PROPERTIES (p) TOOLBAR SHOWIF isWBOrderPicking(p) AND wbSupplyId(p) sendSupplyToDeliver, getSupplyInfo, getOrdersInSupply, deleteSupplyFBS,
        manageSupplyBoxes SHOWIF isWBOrderPicking(p) AND wbSupplyId(p) AND isPvzDelivery(p),
        getSupplyBarcode SHOWIF isWBOrderPicking(p) AND wbSupplyId(p) AND (status(p) == StatusPicking.deliver OR 
            status(p) == StatusPicking.closed) AND NOT wbSupplyBarcodeFile(p),
        openWBSupplyBarcodeFile SHOWIF wbSupplyBarcodeFile(p)
    PROPERTIES (p) READONLY SHOWIF isWBOrderPicking(p) AND wbSupplyId(p) wbSupplyBarcode, wbSupplyBarcodeFile

    PROPERTIES(o) SHOWIF isWBOrderFBS(o) openSticker DRAW o TOOLBAR
;

DESIGN internetOrders {
    documentDetail {
        wbContainer {
            caption = 'WB';
            NEW FBS {
                caption = 'FBS';
                MOVE PROPERTY (getOrdersFBSNew());
                MOVE PROPERTY (getSticker(o));
                MOVE PROPERTY (getOrdersFBS());
                MOVE PROPERTY (getWbFbsStatus(o));
                MOVE PROPERTY (actualizeOrdersMeta());
                MOVE PROPERTY (cancelOrderFBS(o));
                MOVE PROPERTY (listSuppliesFBS());
                MOVE PROPERTY (getAcceptanceCoefficients());

            }
        }
        printContainer {
            MOVE PROPERTY(openSticker(o));
        }
    }
}

// Автотрансляция изменения локального статуса InternetOrder → соответствующий
// статус на WB. По аналогии с DBS-веткой: маппинг ws через statusInternetOrder и
// проверка перехода в changeOrdersFBSStatusCondition. Текущая реализация
// changeOrdersFBSStatus покрывает только cancel — этого достаточно, потому что
// confirm/deliver/receive на FBS идут через поставку (addOrdersToSupply →
// sendSupplyToDeliver), а не через смену статуса заказа. Перехват кастомных
// правил — через customFilterChangeOrdersFBSStatus.
WHEN SETCHANGED(status(InternetOrder o)) AND statusInternetOrder(WbStatus ws) = status(o) AND changeOrdersFBSStatusCondition(ws, o) AND isWBOrderFBS(o) DO {
    NEWSESSION {
        isSelected(o) <- TRUE;
        changeOrdersFBSStatus(ws);
    }
}

// customCreatePicking полностью повторяет дефолтную DIALOG-ветку createPicking
// (см. SaleInternetPicking.lsf): select/filterDashboard, группировка по
// (stock, carrier), per-detail batch-блок, DIALOG, итоговый status(o) <- isPicking.
// Это нужно потому, что useCustomCreatePicking() += TRUE здесь форсится, и без
// полного дубля дефолта не-FBS заказы остались бы без обработки в проектах,
// где customCreatePicking не переопределён иначе (например, mothercare).
// Для пикингов с FBS-заказами (isWBOrderPicking(p)) после успешного DIALOG'а
// дополнительно: проставляем number(p) по первому FBS-заказу (иначе createSupply
// упадёт в 'Отсутствует номер поставки') и вызываем addOrdersToSupply(p).
// WHEN-триггер на SET(isWBOrderPicking) пробовали — HTTP проходит, но
// APPLY NESTED LOCAL из createSupply не коммитит wbSupplyId в apply-event сессию,
// поставки плодились пустыми.
useCustomCreatePicking() += TRUE;
customCreatePicking(InternetOrder o) + {
    IF NOT countInternetOrders() THEN {
        select(o) <- TRUE;
    }
    IF countInternetOrders() THEN {
        LOCAL NESTED ok = BOOLEAN ();
        ok() <- NULL;
        FOR [GROUP SUM 1 IF select(internetOrder(InternetOrderDetail d)) AND NOT picking(d) AND filterDashboard(d) BY Sale.supplierStock[InternetOrderDetail](d), carrier(internetOrder(d))](Stock.Stock stock, Carrier carrier) DO {
            NEWSESSION {
                NEW p = Picking{
                    stock(p) <- stock;
                    carrier(p) <- carrier;
                    FOR Sale.supplierStock[InternetOrderDetail](InternetOrderDetail detail) == stock AND carrier(internetOrder(detail)) == carrier AND filterDashboard(detail) DO {
                        picking(detail) <- p;
                        IF isItem(sku(detail)) AND NOT batch(detail) THEN {
                            batch(detail) <- prevFirstOrderBatchBalance(sku(detail), stock, quantity(detail));
                            overFillBatchPicking(detail);
                        }
                    }
                    DIALOG picking OBJECTS p = p DOCKED NOCANCEL DO {
                        ok() <- TRUE;
                    }
                    IF ok() AND isWBOrderPicking(p) THEN {
                        IF NOT number(p) THEN {
                            FOR isWBOrderFBS(InternetOrder ord)
                                AND (GROUP SUM 1 IF internetOrder(InternetOrderDetail dd) = ord AND picking(dd) = p)
                                AND NOT number(p) DO {
                                number(p) <- CONCAT '_', number(ord), GROUP SUM 1 IF relation(Picking pp, ord) + 1;
                            }
                        }
                        APPLY;
                        addOrdersToSupply(p);
                    }
                }
            }
        }
        IF ok() THEN {
            status(InternetOrder ord) <- StatusInternetOrder.isPicking WHERE select(ord);
            apply();
        }
        select(InternetOrder ord) <- NULL;
        ok() <- NULL;
    } ELSE {
        MESSAGE 'Вначале необходимо отметить интернет заказы.';
    }
}

saleOperationWB = DATA Sale.Operation();
nameSaleOperationWB 'Операция для накладных по комплектациям' () = name(saleOperationWB());
saleCustomerWB = DATA LegalEntity ();
nameSaleCustomerWB 'Контрагент для накладных по комплектациям' () = name(saleCustomerWB());

EXTEND FORM options
    PROPERTIES nameSaleOperationWB(), nameSaleCustomerWB()
;

DESIGN options {
    WB {
        internetOrders {
            MOVE PROPERTY (nameSaleOperationWB());
            MOVE PROPERTY (nameSaleCustomerWB());
        }
    }
}

createInvoice 'Создать накладную продажа' (Picking p) {
    IF saleOperationWB() AND saleCustomerWB() THEN NEWSESSION NEW si = Sale.UserInvoice {
        date(si) <- currentDate();
        time(si) <- currentTime();

        supplierStock(si) <- stock(p);
        supplier(si) <- legalEntity(supplierStock(si));
        customer(si) <- saleCustomerWB();
        customerStock(si) <- GROUP MAX Stock.Stock st IF active(st) AND legalEntity(st) == customer(si);
        
        operation(si) <- saleOperationWB();
        // isPosted(si) <- TRUE;

        FOR picking(InternetOrderDetail d) == p AND pickingQuantity(d) > 0 DO NEW sd = Sale.UserInvoiceDetail {
            userInvoice(sd) <- si;
            sku(sd) <- sku(d);
            batch(sd) <- batch(d);
            quantity(sd) <- pickingQuantity(d);
            price(sd) <- price(d);
            shipmentPrice(sd) <- price(d);

            FOR InternetOrderDetailLot ld == [GROUP MAX InternetOrderDetailLot ll IF internetOrderDetail(ll) = d BY id(ll)](STRING  str)
                AND id(ld) == str AND NOT lot(str) DO NEW l = Lot {
                id(l) <- id(ld);
                tail(l) <- tail(ld);
                sku(l) <- sku(d);
                dataCount(l) <- quantity(ld) IF quantity(ld) != 1;
            }
            quantity(sd, Lot l) <- GROUP SUM 1 IF l = lot(id(InternetOrderDetailLot ld)) AND internetOrderDetail(ld) = d;
        }

        executeLocalEvents('Sale.userInvoice');
        
        SHOW Sale.userInvoice OBJECTS i = si DOCKED;
    } ELSE {
        MESSAGE 'Необходимо заполнить операцию и контрагента WB';
    }
}

EXTEND FORM pickingDashboard
    PROPERTIES(p) SHOWIF isWBOrderPicking(p) createInvoice DRAW p TOOLBAR 
;