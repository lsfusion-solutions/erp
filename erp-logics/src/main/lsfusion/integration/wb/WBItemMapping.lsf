MODULE WBItemMapping;

REQUIRE WBItem, ItemArticle;

NAMESPACE WB;

CLASS MappingType 'Тип связи' {
    item 'Товар'
}

mappingType = DATA MappingType (Item);
nameMappingType 'Тип связи с ERP' (Item i) = caption(mappingType(i));

item = DATA Item.Item (Size);
nameItem 'Товар ERP' (Size s) = nameAttribute(item(s));

// После импорта карточек WB пробуем сматчить размеры с товарами ERP по их штрихкодам.
onAfterPostItems () + {
    FOR Size s == size(Barcode b) AND id(b) AND NOT item(s) AND skuBarcode(STRING[15](id(b))) DO
        item(s) <- skuBarcode(STRING[15](id(b)));
}
nameItems 'Товары ERP'  = GROUP CONCAT nameItem(Size s), '; ' ORDER nameItem(s), s BY itemWB(s) CHARWIDTH 40;

urlImageItem 'Url изображения товара ERP' = ABSTRACT STRING (Item.Item);

urlHttpAccessItem 'Ссылка изображения товара ERP' (MediaFile mf) =
    GROUP MAX urlImageItem(item(Size s)) IF itemWB(s) == item(mf);

fillUrlImage 'Заполнить ссылку из товара ERP' (MediaFile mf) {
    url(mf) <- urlHttpAccessItem(mf);
}

EXTEND FORM masterData
    PROPERTIES READONLY nameItems(item)
;   
EXTEND FORM moveConnItems
    PROPERTIES(i) READONLY nameItems
    PROPERTIES(i2) READONLY nameItems
;
EXTEND FORM moveDisConnItems
    PROPERTIES(i) READONLY nameItems
    PROPERTIES(i2) READONLY nameItems
;

changeItem (Size s) {
    DIALOG items OBJECTS i INPUT DO {
        ASK 'Выбран новый товар, размеры и штрихкоды будут обновлены. Продолжить?' DO {
            item(s) <- i;
            techSize(s) <- OVERRIDE nameOriginal(size(i)), 'A';
            wbSize(s) <- OVERRIDE nameSize(i), '1';
            FOR size(Barcode b) == s DO delete(b);
            FOR sku(Barcode.Barcode b) == i AND active(b) AND id(b) DO NEW bc = Barcode {
                size(bc) <- s;
                id(bc) <- id(b);
            }
        }
    }
}

EXTEND FORM item
    PROPERTIES(i) nameMappingType
    PROPERTIES nameItem(size) BEFORE skus(size) ON CHANGE changeItem(size)
    PROPERTIES(mf) fillUrlImage
;

DESIGN item {
    itemHeader {
        MOVE PROPERTY(nameMappingType(i));
    }
}