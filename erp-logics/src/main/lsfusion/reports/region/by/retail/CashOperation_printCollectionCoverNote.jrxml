					<reportElement style="GroupCellStyle0" x="0" y="30" width="280" height="22" uuid="301d91d4-a053-4ccc-8e0c-081a543b38d7"/>
					<box>
						<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
						<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
						<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
						<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					</box>
					<textElement textAlignment="Left" verticalAlignment="Bottom">
						<font fontName="lsf.TimesNewRoman"/>
					</textElement>
					<textFieldExpression><![CDATA["   Денежная выручка вкладывается в сумку (мешок) для сдачи в банк."]]></textFieldExpression>
				</textField>
				<textField textAdjust="StretchHeight" isBlankWhenNull="true">
					<reportElement style="GroupCellStyle0" x="0" y="52" width="280" height="22" uuid="792279cd-4a5a-4b8b-9929-214c8ec7aaac">
						<property name="com.jaspersoft.studio.unit.height" value="px"/>
					</reportElement>
					<box>
						<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
						<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
						<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
						<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					</box>
					<textElement textAlignment="Left" verticalAlignment="Bottom">
						<font fontName="lsf.TimesNewRoman"/>
					</textElement>
					<textFieldExpression><![CDATA["   Денежная выручка подбирается по достоинствам. Оттиск пломбира должен быть четким."]]></textFieldExpression>
				</textField>
				<textField textAdjust="StretchHeight" isBlankWhenNull="true">
					<reportElement style="GroupCellStyle0" x="0" y="74" width="280" height="22" uuid="93ea8bfc-e2f2-4898-843c-ad4bc2ef69ba">
						<property name="com.jaspersoft.studio.unit.height" value="px"/>
					</reportElement>
					<box>
						<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
						<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
						<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
						<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					</box>
					<textElement textAlignment="Left" verticalAlignment="Bottom">
						<font fontName="lsf.TimesNewRoman"/>
					</textElement>
					<textFieldExpression><![CDATA["    При сдаче сумки с денежной выручкой инкассатору требуйте от него:"]]></textFieldExpression>
				</textField>
				<textField textAdjust="StretchHeight" isBlankWhenNull="true">
					<reportElement style="GroupCellStyle0" x="0" y="96" width="280" height="33" uuid="bd1835f1-f9d8-485c-8a90-08ce688cf0dd">
						<property name="com.jaspersoft.studio.unit.height" value="px"/>
					</reportElement>
