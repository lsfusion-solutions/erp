MODULE ZReportShiftTime;

REQUIRE ZReport;

NAMESPACE ZReport;

shiftStart 'Дата/время открытия смены' = DATA DATETIME (ZReport);
shiftEnd 'Дата/время закрытия смены' = DATA DATETIME (ZReport);

EXTEND FORM zReports
    PROPERTIES READONLY shiftStart(z) AFTER time(z), shiftEnd(z) BEFORE nameDepartmentStore(z)
;
