MODULE TerminalPreferences;

REQUIRE System, Terminal;

usernameLotStatus = ABSTRACT STRING (STRING);
passwordLotStatus = ABSTRACT STRING (STRING);

CLASS Preference '–Ě–į—Ā—ā—Ä–ĺ–Ļ–ļ–ł' {
// nameGroup|order|jsonName|name|type
    GENERAL_OPTIONS                     'GENERAL|000|Options|–ě–Ņ—Ü–ł–ł –Ņ—Ä–ł–Ľ–ĺ–∂–Ķ–Ĺ–ł—Ź|3',
    GENERAL_FONT_SCALE                  'GENERAL|001|FontScale|–†–į–∑–ľ–Ķ—Ä —ą—Ä–ł—Ą—ā–į|2|1',
