    ONLINE_PORT	                        'ONLINE|203|OnlinePort|–ü–ĺ—Ä—ā|2|2004',
    ONLINE_SEND_ORDER_STATUS            'ONLINE|204|OnlineSendOrderStatus|–ě–Ī–ľ–Ķ–Ĺ —Ā—ā–į—ā—É—Ā–į–ľ–ł –∑–į–ļ–į–∑–ĺ–≤|1',
    ONLINE_REQ_STOCK                    'ONLINE|205|OnlineReqStock|–ó–į–Ņ—Ä–į—ą–ł–≤–į—ā—Ć —Ā–ļ–Ľ–į–ī –Ņ—Ä–ł –į–≤—ā–ĺ—Ä–ł–∑–į—Ü–ł–ł|1',
    ONLINE_TEST_CONNECT                 'ONLINE|206|OnlineTestConnect|–ú–ĺ–Ĺ–ł—ā–ĺ—Ä–ł–Ĺ–≥ –Ņ–ĺ–ī–ļ–Ľ—é—á–Ķ–Ĺ–ł—Ź –ļ —Ā–Ķ—Ä–≤–Ķ—Ä—É|1',
    ONLINE_SAVE_LAST_PASS               'ONLINE|207|OnlineSaveLastPass|–°–ĺ—Ö—Ä–į–Ĺ—Ź—ā—Ć –Ņ–ĺ—Ā–Ľ–Ķ–ī–Ĺ–ł–Ļ –Ņ–į—Ä–ĺ–Ľ—Ć|1',
    ONLINE_LOAD_BATCHES                 'ONLINE|208|OnlineLoadBatches|–ü—Ä–ł–Ĺ–ł–ľ–į—ā—Ć –Ņ–į—Ä—ā–ł–ł –Ņ—Ä–ł –∑–į–≥—Ä—É–∑–ļ–Ķ –ī–į–Ĺ–Ĺ—č—Ö|1',
    ONLINE_LOGIN_ON_STARTUP             'ONLINE|209|OnlineLoginOnStartup|–ó–į–Ņ—Ä–ĺ—Ā –į–≤—ā–ĺ—Ä–ł–∑–į—Ü–ł–ł –Ņ—Ä–ł —Ā—ā–į—Ä—ā–Ķ –Ņ—Ä–ł–Ľ–ĺ–∂–Ķ–Ĺ–ł—Ź|1',
    
    OBMEN_TYPE                          'OBMEN|301|ObmenType|–§–ĺ—Ä–ľ–į—ā —Ą–į–Ļ–Ľ–ĺ–≤–ĺ–≥–ĺ –ĺ–Ī–ľ–Ķ–Ĺ–į|0|XML',
    OBMEN_DIR                           'OBMEN|302|ObmenDir|–ö–į—ā–į–Ľ–ĺ–≥ –ĺ–Ī–ľ–Ķ–Ĺ–į|0|smb://192.168.1.1/obmen',
    OBMEN_USER                          'OBMEN|303|ObmenUserName|–ü–ĺ–Ľ—Ć–∑–ĺ–≤–į—ā–Ķ–Ľ—Ć',
    OBMEN_PASS                          'OBMEN|304|ObmenPass|–ü–į—Ä–ĺ–Ľ—Ć',
    OBMEN_DOMAIN                        'OBMEN|305|ObmenDomain|–Ē–ĺ–ľ–Ķ–Ĺ',
    OBMEN_FTP                           'OBMEN|306|ObmenFtp|–í–ļ–Ľ—é—á–ł—ā—Ć FTP-–ĺ–Ī–ľ–Ķ–Ĺ|1',
    OBMEN_FTP_SERVER                    'OBMEN|307|ObmenFtpServer|FTP-—Ā–Ķ—Ä–≤–Ķ—Ä',
    OBMEN_FTP_USER                      'OBMEN|308|ObmenFtpUserName|FTP-–Ľ–ĺ–≥–ł–Ĺ',
    OBMEN_FTP_PASS                      'OBMEN|309|ObmenFtpPass|FTP-–Ņ–į—Ä–ĺ–Ľ—Ć',
    OBMEN_FTP_DIR                       'OBMEN|310|ObmenFtpDir|FTP-–ļ–į—ā–į–Ľ–ĺ–≥ –ĺ–Ī–ľ–Ķ–Ĺ–į',
    
    UPDATEAPP_STARTUP                   'UPD|401|UpdateAppBackground|–§–ĺ–Ĺ–ĺ–≤–į—Ź –Ņ—Ä–ĺ–≤–Ķ—Ä–ļ–į –ĺ–Ī–Ĺ–ĺ–≤–Ľ–Ķ–Ĺ–ł—Ź|1',
    UPDATEAPP_SUGGEST_INSTALL           'UPD|402|UpdateAppSuggestInstall|–ü—Ä–Ķ–ī–Ľ–į–≥–į—ā—Ć —É—Ā—ā–į–Ĺ–ĺ–≤–ļ—É –ĺ–Ī–Ĺ–ĺ–≤–Ľ–Ķ–Ĺ–ł—Ź|1',
    UPDATEAPP_SERVER                    'UPD|403|UpdateAppServer|FTP-—Ā–Ķ—Ä–≤–Ķ—Ä|0|office.luxsoft.by',
    UPDATEAPP_USER                      'UPD|404|UpdateAppUser|–õ–ĺ–≥–ł–Ĺ|0|tsd',
    UPDATEAPP_PASS                      'UPD|405|UpdateAppPassword|–ü–į—Ä–ĺ–Ľ—Ć|0|tsd',
    UPDATEAPP_DIR                       'UPD|406|UpdateAppDir|–ö–į—ā–į–Ľ–ĺ–≥',
    UPDATEAPP_APK_FILE                  'UPD|407|UpdateAppApkFile|APK-—Ą–į–Ļ–Ľ',

    TICKET_PRINT_ENABLE                 'TICKET|500|MobCennikEnable|–í–ļ–Ľ—é—á–ł—ā—Ć –ľ–ĺ–Ī–ł–Ľ—Ć–Ĺ—É—é –Ņ–Ķ—á–į—ā—Ć|1',
    TICKET_VOP                          'TICKET|501|MobCennikVop|–ö–ĺ–ī –ĺ–Ņ–Ķ—Ä–į—Ü–ł–ł –ī–Ľ—Ź —Ü–Ķ–Ĺ–Ĺ–ł–ļ–į',
    TICKET_BOUQUET_ANA                  'TICKET|502|MobCennikBouquetAna|–ö–ĺ–ī –į–Ĺ–į–Ľ–ł—ā–ł–ļ–ł –ī–Ľ—Ź —Ü–Ķ–Ĺ–Ĺ–ł–ļ–į –Ī—É–ļ–Ķ—ā–į',
    TICKET_QUANTITY_REQUEST             'TICKET|503|MobCennikQuantityRequest|–ó–į–Ņ—Ä–ĺ—Ā –ļ–ĺ–Ľ–ł—á–Ķ—Ā—ā–≤–į —Ü–Ķ–Ĺ–Ĺ–ł–ļ–ĺ–≤ –ī–Ľ—Ź –Ņ–Ķ—á–į—ā–ł|1',
    TICKET_DIRECT_PRINT                 'TICKET|504|MobCennikDirectPrint|–ü—Ä—Ź–ľ–į—Ź –Ņ–Ķ—á–į—ā—Ć –Ĺ–į –ľ–ĺ–Ī–ł–Ľ—Ć–Ĺ—č–Ļ –Ņ—Ä–ł–Ĺ—ā–Ķ—Ä|1',
    TICKET_TCP_ADDRESS                  'TICKET|505|MobCennikTCPPrinterAddress|IP –į–ī—Ä–Ķ—Ā –Ņ—Ä–ł–Ĺ—ā–Ķ—Ä–į',
    TICKET_USE_BLUETOOTH_PRINTER        'TICKET|506|MobCennikBluetoothPrinterEnable|–ü–Ķ—á–į—ā—Ć –Ĺ–į Bluetooth –Ņ—Ä–ł–Ĺ—ā–Ķ—Ä|1',

    MARKING_A1_ENABLE                 'MARKING|610|MarkingOnlineEnable|A1. –ě–Ĺ–Ľ–į–Ļ–Ĺ –Ņ—Ä–ĺ–≤–Ķ—Ä–ļ–į –ľ–į—Ä–ĺ–ļ|1',
    MARKING_A1_URL                    'MARKING|611|MarkingOnlineURL|A1. URL',
    MARKING_A1_LOGIN                  'MARKING|612|MarkingOnlineLogin|A1. –ė–ľ—Ź –Ņ–ĺ–Ľ—Ć–∑–ĺ–≤–į—ā–Ķ–Ľ—Ź',
    MARKING_A1_PASSWORD               'MARKING|613|MarkingOnlinePassword|A1. –ü–į—Ä–ĺ–Ľ—Ć',
    MARKING_A1_UID                    'MARKING|614|MarkingOnlineUID|A1. ID —É—Ā—ā—Ä–ĺ–Ļ—Ā—ā–≤–į',

    MARKING_EZ_ENABLE                 'MARKING|620|MarkingEzEnable|–≠–ó. –ě–Ĺ–Ľ–į–Ļ–Ĺ –Ņ—Ä–ĺ–≤–Ķ—Ä–ļ–į –ľ–į—Ä–ĺ–ļ|1',
    MARKING_EZ_URL                    'MARKING|621|MarkingEzURL|–≠–ó. URL',
    MARKING_EZ_LOGIN                  'MARKING|622|MarkingEzLogin|–≠–ó. –ė–ľ—Ź –Ņ–ĺ–Ľ—Ć–∑–ĺ–≤–į—ā–Ķ–Ľ—Ź',
    MARKING_EZ_PASSWORD               'MARKING|623|MarkingEzPassword|–≠–ó. –ü–į—Ä–ĺ–Ľ—Ć'
}

CLASS Obmen '–§–ĺ—Ä–ľ–į—ā –ĺ–Ī–ľ–Ķ–Ĺ–į' {
    Obmen_SQLite '0|SQLite',
    Obmen_CSV '1|CSV',
    Obmen_XML '2|XML'
}

value (Obmen o) = STRING(getWord(staticCaption(o), '|',1));
name '–§–ĺ—Ä–ľ–į—ā' (Obmen o) = STRING(getWord(staticCaption(o), '|',2));
obmen (STRING s) = CASE 
    WHEN s == 'SQLite' THEN Obmen.Obmen_SQLite
    WHEN s == 'CSV' THEN Obmen.Obmen_CSV
    WHEN s == 'XML' THEN Obmen.Obmen_XML
;
        
FORM dialogObmen '–§–ĺ—Ä–ľ–į—ā –ĺ–Ī–ľ–Ķ–Ĺ–į'
    OBJECTS o = Obmen
    PROPERTIES(o) READONLY name
    LIST Obmen OBJECT o
    ORDERS name(o);

CLASS PreferenceType {
    TYPE_STRING,
    TYPE_INTEGER,
    TYPE_YESNO,
    TYPE_TEXT
}

CLASS YesNo {
    true 'true|Yes',
    false 'false|No'
}
value (YesNo y) = STRING(getWord(staticCaption(y), '|',1));
name (YesNo y) = STRING(getWord(staticCaption(y), '|',2));

nameYesNo(STRING s) = CASE 
    WHEN s = 'true' THEN name(YesNo.true)
    WHEN s = 'false' THEN name(YesNo.false) MATERIALIZED;

stringToYesNo(STRING s) = CASE 
    WHEN s = 'Yes' THEN YesNo.true
    WHEN s = 'No' THEN YesNo.false MATERIALIZED;

FORM dialogYesNo '–ó–Ĺ–į—á–Ķ–Ĺ–ł–Ķ'
    OBJECTS y = YesNo
    PROPERTIES name(y) READONLY
;

getType(STRING s) = CASE 
    WHEN s = '0' THEN PreferenceType.TYPE_STRING
    WHEN s = '1' THEN PreferenceType.TYPE_YESNO
    WHEN s = '2' THEN PreferenceType.TYPE_INTEGER
    WHEN s = '3' THEN PreferenceType.TYPE_TEXT
    ELSE PreferenceType.TYPE_STRING;

enable '–í–ļ–Ľ' (Preference p) = DATA BOOLEAN;
nameGroup (Preference p) = STRING(getWord(staticCaption(p),'|', 1));
order (Preference p) = STRING(getWord(staticCaption(p),'|', 2));
namePreference (Preference p) = STRING(getWord(staticCaption(p),'|', 3));
name '–ü–į—Ä–į–ľ–Ķ—ā—Ä' (Preference p) = STRING(getWord(staticCaption(p),'|', 4));
defaultValue (Preference p) = STRING(getWord(staticCaption(p),'|', 6));
value = DATA STRING (Preference);
type (Preference p) = getType(getWord(staticCaption(p),'|', 5));
overValue '–ó–Ĺ–į—á–Ķ–Ĺ–ł–Ķ' (Preference p) =
        OVERRIDE 'No' IF type(p) = PreferenceType.TYPE_YESNO AND NOT value(p),
        OVERRIDE defaultValue(p) IF NOT value(p), value(p);
foregroundLine (Preference p) = IF NOT enable(p) THEN RGB(169,169,169);

overNameGroup '–ď—Ä—É–Ņ–Ņ–į' (Preference p) = CASE
    WHEN nameGroup(p) = 'GENERAL' THEN '–ě—Ā–Ĺ–ĺ–≤–Ĺ—č–Ķ –Ĺ–į—Ā—ā—Ä–ĺ–Ļ–ļ–ł'
    WHEN nameGroup(p) = 'ONLINE' THEN 'On-line –Ĺ–į—Ā—ā—Ä–ĺ–Ļ–ļ–ł'
    WHEN nameGroup(p) = 'OBMEN' THEN '–ě–Ī–ľ–Ķ–Ĺ –ī–į–Ĺ–Ĺ—č–ľ–ł'
    WHEN nameGroup(p) = 'UPD' THEN '–ě–Ī–Ĺ–ĺ–≤–Ľ–Ķ–Ĺ–ł–Ķ'
    WHEN nameGroup(p) = 'TICKET' THEN '–ü–Ķ—á–į—ā—Ć —Ü–Ķ–Ĺ–Ĺ–ł–ļ–ĺ–≤'
    WHEN nameGroup(p) = 'MARKING' THEN '–ú–į—Ä–ļ–ł—Ä–ĺ–≤–ļ–į —ā–ĺ–≤–į—Ä–į'
    ELSE nameGroup(p);  

TABLE preferences (Preference);

FORM dialogText '–Ę–Ķ–ļ—Ā—ā'
    OBJECTS s = TEXT PANEL
    PROPERTIES(s) objValue = VALUE
;

DESIGN dialogText {
    BOX {
        size = (300, 150); 
        MOVE PROPERTY(objValue) { fill = 1; caption = ''; focusable = FALSE; font = 'bold 16'; }
    }
    MOVE TOOLBARBOX; 
}

changePreferenceValue(Preference p)  {
    CASE
        WHEN p == Preference.OBMEN_TYPE THEN {
            DIALOG dialogObmen OBJECTS o = obmen(value(p)) INPUT DO {
                value(p) <- name(o);
            }
        }
        WHEN type(p) == PreferenceType.TYPE_TEXT THEN {
            DIALOG dialogText OBJECTS s = value(p) INPUT DO {
                value(p) <- s;
            }
        }
        WHEN type(p) == PreferenceType.TYPE_STRING THEN {
            INPUT s = STRING DO {
                value(p) <- s;
            }
        }
        WHEN type(p) == PreferenceType.TYPE_INTEGER THEN {
            INPUT s = INTEGER DO {
                value(p) <- trim(TEXT(s));
                IF p == Preference.GENERAL_FONT_SCALE AND value(p) != '1' AND value(p) != '2' AND value(p) != '3' AND value(p) != '4' AND value(p) != '5' THEN {
                    value(p) <- '1';
                }
            }
        }
        WHEN type(p) == PreferenceType.TYPE_YESNO THEN {           
            DIALOG dialogYesNo OBJECTS y = stringToYesNo(overValue(p)) INPUT DO {
                value(p) <- name(y);
            }
        }
}

FORM preferences '–ö–ĺ–Ĺ—Ą–ł–≥—É—Ä–į—Ü–ł—Ź –Ę–°–Ē'
    OBJECTS p = Preference    
    PROPERTIES(p) FOREGROUND foregroundLine(p) enable, overNameGroup, name, overValue ON CHANGE changePreferenceValue(p), order SHOWIF NULL
    ORDERS order(p)
;

jsonValue(Preference p) = CASE
    WHEN p = Preference.OBMEN_TYPE THEN value(obmen(overValue(p))) 
    WHEN type(p) = PreferenceType.TYPE_YESNO THEN value(stringToYesNo(overValue(p)))
    WHEN type(p) = PreferenceType.TYPE_INTEGER THEN overValue(p)
    ELSE '"' + overValue(p) + '"'
;

terminalPreferencesJSON = DATA LOCAL STRING();

getTerminalPreferences(terminalID, CustomUser user) {

    LOCAL json = STRING();
    json() <- '';

    LOCAL userLogin = STRING();
    userLogin() <- login(user);
    
    FOR Preference p IS Preference AND enable(p) DO {
        IF length(json()) > 0 THEN json() <- json() + ',';

        LOCAL name = STRING();
        LOCAL value = STRING();
        name() <- namePreference(p);
        value() <- jsonValue(p);

        CASE
            WHEN p = Preference.MARKING_A1_LOGIN THEN
                value() <- OVERRIDE usernameLotStatus(userLogin()), jsonValue(p);
            WHEN p = Preference.MARKING_A1_PASSWORD THEN
                value() <- OVERRIDE passwordLotStatus(userLogin()), jsonValue(p);
        
        json() <- json() + '"' + name() + '":' + (OVERRIDE value(), 'null');
    }
    IF length(json()) > 0 THEN json() <- '[\{' + json() + '\}]'; ELSE json() <- NULL;
    
    terminalPreferencesJSON() <- json();
}

NAVIGATOR {
    terminalNavigator {
        NEW preferences;
    }
}
