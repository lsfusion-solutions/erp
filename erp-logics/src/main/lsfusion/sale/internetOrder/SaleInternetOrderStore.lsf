MODULE SaleInternetOrderStore;

REQUIRE SaleInternetOrder, Store;

NAMESPACE Sale;

departmentStore = DATA DepartmentStore (Carrier);
nameDepartmentStore 'Интернет магазин(отдел магазина)' (Carrier c) = name(departmentStore(c));

carrier = GROUP AGGR (Carrier carrier) BY departmentStore(carrier);

EXTEND FORM carrier
    PROPERTIES nameDepartmentStore(c) AFTER name(c)
;

EXTEND FORM carriers
    PROPERTIES READONLY nameDepartmentStore(c) AFTER name(c)
;

EXTEND FORM internetCatalogs
    PROPERTIES READONLY nameDepartmentStore(carrier) AFTER name(carrier)
;