MODULE SaleInvoiceTracking;

REQUIRE SaleInvoice, ItemTracking, TrackingLedger, 
        PurchaseInvoiceTracking, BatchInventoryTracking; // для миграции

NAMESPACE Sale;

TABLE trackingInvoiceDetail(InvoiceDetail);

dateStartSPT 'Дата начала прослеживания' (UserInvoiceDetail d)=dateStartSPT(sku(d));
isTracking 'Подлежит прослеживанию' (UserInvoiceDetail d) = TRUE IF isTrackingOver(sku(d)) AND date(d) >= dateStartSPT(d);
isTracking (Invoice i) = GROUP SUM 1 IF isTracking(UserInvoiceDetail d) AND invoice(d)==i;
showSPT (Invoice i)= TRUE IF isTracking(i);

trackingInvoiceDetail = DATA Purchase.InvoiceDetail (UserInvoiceDetail) INDEXED TABLE trackingInvoiceDetail;

inTrackingLedger = DATA InTrackingLedger (UserInvoiceDetail) INDEXED TABLE trackingInvoiceDetail;
descriptionTracking 'Основание СПТ' (UserInvoiceDetail d) = description(inTrackingLedger(d));

saleInvoiceTrackingMigrate(){
    FOR isTracking(UserInvoiceDetail d) DO {
        inTrackingLedger(d) <- OVERRIDE inTrackingLedger(trackingInvoiceDetail(d)), 
                inTrackingLedger(batch(d), supplierStock(d)),
                (GROUP MAX InTrackingLedger l IF TrackingLedger.batch(l) == batch(d));
    }
    setNoCancelInTransaction();
}
@defOnStartMigrate(saleInvoiceTrackingMigrate);


itemCustomCode 'Код ТНВЭД' (UserInvoiceDetail d) = codeCustomsGroupDefaultCountry(sku(d));
itemCustomCodeOther 'Дополнительный таможенный код'(UserInvoiceDetail d) = idExtraCode(sku(d));
deliveryTypePrev 'Тип приходного документа'(UserInvoiceDetail d) = deliveryTypePrev(inTrackingLedger(d));
deliveryNotePrev 'Номер приходного документа' (UserInvoiceDetail d) = deliveryNotePrev(inTrackingLedger(d));
deliveryNoteDate 'Дата создания приходного документа' (UserInvoiceDetail d) = deliveryNoteDate(inTrackingLedger(d));
deliveryNotePrevLineID 'Номер строки в приходном документе' (UserInvoiceDetail d) = deliveryNotePrevLineID(inTrackingLedger(d));
lineItemQuantitySPT 'Ед. изм.СПТ' (UserInvoiceDetail d) = trackingUOMCustomsGroup(sku(d));
quantityDespatchedSPT 'Кол-во в ед.СПТ ' (UserInvoiceDetail d) =  NUMERIC[16,5](quantity(d) * 1.0 IF inTrackingLedger(d)); // на данный момент прослеживаемые только шт
lineItemPriceSPT'Цена за единицу товара для прослеживаемости' (UserInvoiceDetail d) = price(d) * 1.0 IF inTrackingLedger(d); // на данный момент прослеживаемые только шт

EXTEND CLASS UserInvoiceDetail : OutTrackingLedger;

TrackingLedger.inTrackingLedger(UserInvoiceDetail l) += inTrackingLedger(l);
TrackingLedger.quantity(UserInvoiceDetail l) += quantityDespatchedSPT(l);
TrackingLedger.description(UserInvoiceDetail l) += descriptionIndex(l) IF inTrackingLedger(l);

WHEN LOCAL (CHANGED(sku(UserInvoiceDetail d)) OR CHANGED(supplierStock(d)) OR CHANGED(date(d)) OR CHANGED(batch(d))) AND NOT batch(d) DO {
    inTrackingLedger(d) <- prevLastInTrackingLedgerB(sku(d), supplierStock(d), date(d));
}

WHEN LOCAL (CHANGED(sku(UserInvoiceDetail d)) OR CHANGED(supplierStock(d)) OR CHANGED(date(d)) OR CHANGED(batch(d))) AND batch(d) DO {
    inTrackingLedger(d) <- prevLastInTrackingLedgerB(batch(d), supplierStock(d), date(d));
}

changeInTrackingLedger 'Выбрать приход' (UserInvoiceDetail out) {
    DIALOG changeInTrackingLedger OBJECTS s = sku(out), b = batch(out), st = supplierStock(out), l INPUT DO
        inTrackingLedger(out) <- l;
}

EXTEND FORM userInvoice
    OBJECTS d6 = UserInvoiceDetail GRID 
    PROPERTIES(d6) SHOWIF showSPT(i) READONLY index, idBarcodeSku, nameSku, isTracking BACKGROUND backgroundEC(extraCode(sku(d6))), itemCustomCode, itemCustomCodeOther, dateStartSPT,
        deliveryTypePrev, deliveryNotePrev, deliveryNoteDate, deliveryNotePrevLineID, lineItemQuantitySPT, quantityDespatchedSPT, lineItemPriceSPT
    PROPERTIES (d6) SHOWIF showSPT(i) descriptionTracking ON CHANGE changeInTrackingLedger(d6)
    FILTERS userInvoice(d6) == i, isTracking(d6)

;

DESIGN userInvoice{
    specificationBox {
        NEW sptContainer {
            caption = 'Прослеживание';
            MOVE BOX(d6);
        }
    }
}

skipCheckBasisSale = DATA BOOLEAN () PREREAD;

CONSTRAINT (SET(isPosted(UserInvoiceDetail id)) OR SETCHANGED(sku(id)) OR CHANGED(batch(id)) OR DROPPED(trackingInvoiceDetail(id))) AND isPosted(id) AND isTracking(id)
    AND batch(id) AND date(id) >= dateStartSPT(id) AND NOT inTrackingLedger(id) AND NOT skipCheckBasisSale()
    MESSAGE 'Укажите основание СПТ для прослеживаемого товара, отсутствуют данные для СПТ' ;


CONSTRAINT (SET(isPosted(UserInvoiceDetail id)) OR SETCHANGED(sku(id)) OR CHANGED(batch(id))) AND isPosted(id) AND isTracking(id) AND date(id) >= dateStartSPT(id)
    AND NOT batch(id) AND NOT skipCheckBasisSale()
    MESSAGE 'Укажите партию для прослеживаемого товара' ;