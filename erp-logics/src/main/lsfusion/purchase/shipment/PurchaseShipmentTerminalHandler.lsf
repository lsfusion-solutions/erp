MODULE PurchaseShipmentTerminalHandler;

REQUIRE TerminalHandler, PurchaseInvoiceShipmentTerminal;

NAMESPACE Purchase;

skipFillInvoiceTerminal = ABSTRACT BOOLEAN (Purchase.UserInvoice);
overFillInvoiceTerminal ABSTRACT LIST (Purchase.UserInvoice, TerminalDocument);

fillInvoice 'Заполнить приходную накладную' (TerminalDocument t) {
    FOR number(Purchase.UserInvoice i) = parentDocument(t) AND NOT isPosted(i) AND NOT skipFillInvoiceTerminal(i) DO {
        lock(i);
        IF lockResult() THEN {
            TRY {
                LOCAL quantity = NUMERIC[16,5] (Sku, Purchase.UserInvoice);
                quantity(Sku sku, i) <- [GROUP SUM quantity(TerminalDocumentDetail tdd) IF terminalDocument(tdd) = t BY sku(tdd)](sku);

                FOR invoice(Purchase.UserInvoiceDetail o) == i DO {
                    shipmentQuantity(o) <- OVERRIDE (PARTITION UNGROUP quantity LIMIT STRICT quantity(o) IF invoice(o) == i ORDER index(o), o BY sku(o), invoice(o)), 0.0;
                }

                overFillInvoiceTerminal(i, t);
                
                used(t) <- TRUE;
                APPLY;
            } FINALLY {
                unlock(i);
            }
        } ELSE {
            throwException('Выполняется прием. Попробуйте еще раз позже.');
        }
    }
}

createInvoiceOrder(TerminalDocument t) {

    FOR number(Purchase.UserOrder order) = getWord(parentDocument(t), ',', 1) DO {
        lock(order);
        IF lockResult() THEN {
            TRY {
                APPLY;
                NEWSESSION FORMS userInvoice {
                    NEW i = UserInvoice {
                        fillHeader(i, order);
                        number(i) <- title(t);

                        FOR iterate(INTEGER j, 1, wordCount(parentDocument(t), ',')) AND number(Purchase.UserOrder o) = getWord(parentDocument(t), ',', j) DO {
                            include(o,i) <- TRUE;
                        }
                        overCreate (order, i);
                        afterCreateInvoice(i);

                        FOR terminalDocument(TerminalDocumentDetail tdd) == t ORDER number(tdd) NEW o = UserInvoiceDetail DO {
                            userInvoice(o) <- i;
                            sku(o) <- sku(tdd);
                            shipmentQuantity(o) <- quantity(tdd);
                            quantity(o) <- IF extraQuantity(tdd) != 0.0 THEN extraQuantity(tdd) ELSE quantity(tdd);
                            overAddDetailDialogTerminalUserInvoiceDetail(o, tdd);
                        }

                        used(t) <- TRUE;
                    }
                    APPLY;
                    IF canceled() THEN {
                        throwException(applyMessage());
                    }
                }
            } FINALLY {
                unlock(order);
            }
        } ELSE {
            throwException('Выполняется прием. Попробуйте еще раз позже.');
        }
    }
}

fillInvoice 'Заполнять накладную (заявка = накладная)' = DATA BOOLEAN (TerminalDocumentType);
createInvoiceOrder 'Создавать накладную (заявка = заказ)' = DATA BOOLEAN (TerminalDocumentType);

EXTEND FORM groupTerminalDocumentType
    PROPERTIES (tdt) fillInvoice, createInvoiceOrder;
EXTEND FORM groupTerminalDocumentTypes
    PROPERTIES (tdt) READONLY fillInvoice, createInvoiceOrder;

process(TerminalDocument document) + {
    IF fillInvoice(terminalDocumentType(document)) AND NOT used(document) AND quantityTerminalDocumentDetail(document) AND sumTerminalDocumentDetail(document) THEN fillInvoice(document);
    IF createInvoiceOrder(terminalDocumentType(document)) AND NOT used(document) AND quantityTerminalDocumentDetail(document) AND sumTerminalDocumentDetail(document) THEN createInvoiceOrder(document);
}