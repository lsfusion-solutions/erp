MODULE LotPrint;

REQUIRE Lot; 

NAMESPACE Lot;

count = DATA LOCAL INTEGER (Lot);
tailGS1(Lot l) = replace(replace(replace(tail(l), '' + '91', '[91]'), '' + '92', '[92]'), '' + '93', '[93]');
codeGS1 (Lot l) = '[01]' + substr(id(l), 3, 14) + '[21]' + substrFrom(id(l), 19) + tailGS1(l);

FORM printLot 'Печать марок'
    OBJECTS l = Lot
    PROPERTIES(l) count, id, nameSku, code, gtin, series, codeGS1
    ORDERS nameSku(l) 
    FILTERS count(l)
;

printLot () {
    IF GROUP SUM 1 IF count(Lot l) THEN
        PRINT printLot;
}