MODULE DisassemblyOperation;

REQUIRE Operation;

NAMESPACE Disassembly;

@defineOperation(' (разборка)');
@defineOperationRole();

DESIGN operation {
    tabContainer {
        NEW createContainer {
            caption = 'Производные документы';
        }
        NEW showContainer {
            caption = 'Отображение свойств';
        }
        NEW constraintContainer {
            caption = 'Ограничения';
        }
        NEW paramsContainer {
            caption = 'Параметры';
        }
    }
}

@defineOperationProperty(skipFillPriceHeader, 'Не изменять цену исходного товара по кнопке Рассчитать цены', paramsContainer);

@defineOperationProperty(onlyPositivePriceLedger, 'Проводить по регистрам цен только положительное количество', paramsContainer);
