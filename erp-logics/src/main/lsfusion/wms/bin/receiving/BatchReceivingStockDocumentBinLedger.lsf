MODULE BatchReceivingStockDocumentBinLedger;

REQUIRE BatchReceivingBinLedger, StockDocumentBinLedger,
        BatchReceivingInvoiceBinLedger //подключил для простоты вынесения на форму и как единственную реализацию назначения партий для строки приёмки
    ;

NAMESPACE Bin;

shipmentPrice '{document.price} (учетная)' = DATA NUMERIC[16,4] (ReceivingDetail) PATTERN '#,##0.00##';
shipmentSum '{document.sum.of} (учетная)'  = DATA NUMERIC[16,4] (ReceivingDetail)PATTERN '#,##0.00##';

shipmentSumReceivingDetail '{document.sum.of} (учетная)' (receiving) =
    GROUP SUM shipmentSum(ReceivingDetail idetail) BY receiving(idetail) CHARWIDTH 10 IN documentSum PATTERN '#,##0.00##';

WHEN LOCAL (CHANGED(GRDateTime(ReceivingDetail detail)) OR SETCHANGED(batch(detail))) AND
    batch(detail) AND NOT CHANGED(shipmentPrice(detail)) AND NOT skipUpdatePriceAccount() DO {
    shipmentPrice(detail) <- prevAccountPriceA(batch(detail), stock(inBin(detail)), GRDateTime(detail));
}

calcShipmentSum = ABSTRACT VALUE NUMERIC[18,4] (ReceivingDetail);
calcShipmentSum(ReceivingDetail detail) += NUMERIC[18,4](round2(quantity(detail) * shipmentPrice(detail))); //округление делаем до двух знаков, если надо, то переопределиться потом
shipmentSum (ReceivingDetail detail) <- calcShipmentSum(detail)
    WHEN DO (CHANGED(quantity(detail)) OR CHANGED (shipmentPrice(detail)));

EXTEND FORM receiving
    PROPERTIES(r) READONLY BACKGROUND RGB(255, 224, 255) shipmentSumReceivingDetail
    PROPERTIES(d) READONLY BACKGROUND RGB(255, 224, 255) AFTER nameBatch(d) shipmentPrice, shipmentSum
;

EXTEND FORM editReceiving
    PROPERTIES(r) READONLY BACKGROUND RGB(255, 224, 255) shipmentSumReceivingDetail
    PROPERTIES(d) READONLY BACKGROUND RGB(255, 224, 255) AFTER nameBatch(d) shipmentPrice, shipmentSum
;

DESIGN editReceiving {
    headerBox {
        MOVE GROUP(documentSum,r) {
            lines = 1;
        }
    }
}    

//делаем все перемещения по ячейкам позже первой даты/времени приёмки партии для заполнения учётных ценн и попадания в ТО верных сумм 
extraCompleteReceiving(Receiving receiving) + {
    NEWSESSION {
        FOR [GROUP SUM 1 BY batch(ReceivingDetail detail), receiving(detail)](Batch batch, receiving) AND 
            [GROUP SUM 1 BY batch(UserBinTransferDetail detail), userBinTransfer(detail)](batch, UserBinTransfer binTransfer) AND
        GRDateTime(batch)>dateTime(binTransfer) DO {
            date(binTransfer) <- toDate(GRDateTime(batch));
            time(binTransfer) <- toTime(GRDateTime(batch));
        }
        APPLY;
    }
}

needToRecalculateShipmentSum = ABSTRACT BOOLEAN (ReceivingDetail);
recalculateShipmentSum() + {
    NEWSESSION {
        shipmentPrice(ReceivingDetail detail) <- prevAccountPriceA(batch(detail), stock(inBin(detail)), GRDateTime(detail))
            WHERE needToRecalculateShipmentSum(detail) AND batch(detail) AND sum(GRDate(detail), countDaysToRecalculate())>=currentDate();
        APPLY;
    }
}

CLASS IncSDReceivingBinLedger 'Приемка (приход)' : IncStockDocumentBinLedger;

needToCreateIncSDReceivingBinLedger (Receiving t, BinGroup g) = GROUP SUM quantity(ReceivingDetail d) IF receiving(d) == t AND binGroup2(inBin(d)) == g;
incSDReceivingBinLedger = AGGR IncSDReceivingBinLedger WHERE needToCreateIncSDReceivingBinLedger(Receiving receiving, BinGroup binGroup) AND GRDateTime(receiving) MATERIALIZED INDEXED;

dateTime[StockDocumentBinLedger] (IncSDReceivingBinLedger ledger) += GRDateTime(receiving(ledger));
isPosted[StockDocumentBinLedger] (IncSDReceivingBinLedger ledger) += isPosted(receiving(ledger));
isClosed[StockDocumentBinLedger] (IncSDReceivingBinLedger ledger) += isClosed(receiving(ledger));
number[StockDocumentBinLedger] (IncSDReceivingBinLedger ledger) += number(receiving(ledger));
series[StockDocumentBinLedger] (IncSDReceivingBinLedger ledger) += series(receiving(ledger));
operation[StockDocumentBinLedger] (IncSDReceivingBinLedger ledger) += operationInvoice(receiving(ledger));
stock[StockDocumentBinLedger] (IncSDReceivingBinLedger ledger) += customerStock(receiving(ledger));
binGroup[StockDocumentBinLedger] (IncSDReceivingBinLedger ledger) += binGroup(ledger);
description[StockDocumentBinLedger] (IncSDReceivingBinLedger ledger) += description(receiving(ledger));
edit(IncSDReceivingBinLedger ledger) + {edit[UserReceiving](receiving(ledger));}

shipmentSum(IncSDReceivingBinLedger ledger) =
    NUMERIC[18,4](GROUP SUM shipmentSum(ReceivingDetail d) IF receiving(d) == receiving(ledger) AND binGroup2(inBin(d)) == binGroup(ledger));
sumItem[IncStockDocumentBinLedger] (IncSDReceivingBinLedger ledger) +=
    NUMERIC[18,4](GROUP SUM shipmentSum(ReceivingDetail d) IF isItem(sku(d)) AND receiving(d) == receiving(ledger) AND binGroup2(inBin(d)) == binGroup(ledger));
sumContainer[IncStockDocumentBinLedger] (IncSDReceivingBinLedger ledger) +=
    NUMERIC[18,4](GROUP SUM shipmentSum(ReceivingDetail d) IF isContainer(sku(d)) AND receiving(d) == receiving(ledger) AND binGroup2(inBin(d)) == binGroup(ledger));

legalEntity[StockDocumentBinLedger] (IncSDReceivingBinLedger ledger) += supplier(receiving(ledger));
legalEntityStock[StockDocumentBinLedger] (IncSDReceivingBinLedger ledger) += supplierStock(receiving(ledger));
