MODULE BinDepartment;

REQUIRE Bin, Warehouse, BinLedger;

NAMESPACE Bin;

CLASS Department 'Отдел';
TABLE department (Department);

id '{integration.id}' = DATA STRING[100] (Department) NONULL INDEXED CHARWIDTH 10;
name 'Наименование' = DATA ISTRING[100](Department) INDEXED CHARWIDTH 20;
order 'Порядок' = DATA ISTRING (Department) INDEXED CHARWIDTH 2;
stock = DATA Stock (Department) NONULL INDEXED;
nameStock 'Склад' (Department department) = name(department) CHARWIDTH 20;

department(id) = GROUP AGGR Department department BY id(department);

// Неактивный
inactive 'Неактивный' = DATA BOOLEAN (Department);
active 'Активный' (Department department) = department IS Department AND NOT inactive(department) MATERIALIZED INDEXED;

department = DATA Department (BinGroup);
nameDepartment 'Отдел' (BinGroup binGroup) = name(department(binGroup)) CHARWIDTH 20;

CONSTRAINT department(BinGroup binGroup) AND NOT stock(binGroup)==stock(department(binGroup))
    CHECKED BY department[BinGroup] MESSAGE 'Склад группы ячеек и отдела должен совпадать';

EXTEND FORM dataBinGroup
    PROPERTIES(g) nameDepartment
;    

DESIGN dataBinGroup {
    mainContainer {
        MOVE PROPERTY(nameDepartment(g));
    }
}

EXTEND FORM binGroups
    PROPERTIES(g) READONLY nameDepartment AFTER nameStock(g)
;

EXTEND FORM binStocks
    PROPERTIES(bg) READONLY nameDepartment AFTER nameStock(bg)
;

levelParentDepartment (Bin bin) = GROUP MIN level(binGroup(bin), BinGroup parent) IF department(parent) MATERIALIZED;
nearestParentDepartment (Bin bin) = binGroup(binGroup(bin), levelParentDepartment(bin));
department (Bin bin) = department(nearestParentDepartment(bin)) MATERIALIZED INDEXED;
nameDepartment 'Отдел' (Bin bin) = name(department(bin)) CHARWIDTH 20;

EXTEND FORM bin
    PROPERTIES(b) READONLY nameDepartment AFTER nameStock(b)
;

DESIGN bin {
    mainContainer {
        MOVE PROPERTY(nameDepartment(b));   
    }
}

EXTEND FORM bins
    PROPERTIES(b) READONLY nameDepartment AFTER nameStock(b)
;

EXTEND FORM dialogBinStock
    PROPERTIES(b) READONLY nameDepartment
;

EXTEND FORM binStocks
    PROPERTIES(b) READONLY nameDepartment AFTER nameStock(b)
;

FORM department 'Отдел'
    OBJECTS d=Department PANEL
    PROPERTIES(d) inactive, id, order, name, nameStock

    EDIT Department OBJECT d
;

FORM departments 'Отделы'
    OBJECTS d=Department
    PROPERTIES(d) READONLY id, order, name, nameStock
    PROPERTIES(d) NEWSESSION NEW, EDIT, DELETE
    ORDERS order(d), name(d)
    FILTERGROUP inactiveDepartment
        FILTER 'Активный' active(d) DEFAULT
    
    LIST Department OBJECT d
;

NAVIGATOR {
    binNavigator {
        NEW departments;
    }   
}

EXTEND FORM warehouse
    OBJECTS d=Department
    PROPERTIES(d) READONLY id, order, name, nameStock
    PROPERTIES(d) NEWSESSION NEW, EDIT, DELETE
    ORDERS order(d), name(d)
    FILTERGROUP inactiveDepartment 
        FILTER 'Активный' active(d) DEFAULT
;

DESIGN warehouse {
    OBJECTS {
        MOVE BOX(d);
    }
}