MODULE BatchBinTransferStockDocumentBinLedger;

REQUIRE BatchBinTransferBinLedger, StockDocumentBinLedger, DepartmentBinTransferBinLedger, BatchReceivingBinLedger;

NAMESPACE Bin;

shipmentPrice '{document.price} (учетная)' = ABSTRACT NUMERIC[16,4] (BinTransferDetail) MATERIALIZED PATTERN '#,##0.00##';
shipmentPrice '{document.price} (учетная)' = DATA NUMERIC[16,4] (UserBinTransferDetail);
shipmentPrice(UserBinTransferDetail userBinTransferDetail) += shipmentPrice(userBinTransferDetail);

shipmentSum '{document.sum.of} (учетная)' = ABSTRACT NUMERIC[16,4] (BinTransferDetail) MATERIALIZED PATTERN '#,##0.00##';
shipmentSum '{document.sum.of} (учетная)' = DATA NUMERIC[16,4] (UserBinTransferDetail);
shipmentSum(UserBinTransferDetail userBinTransferDetail) += shipmentSum(userBinTransferDetail);

sum(BinTransferDetail ledger) += shipmentSum(ledger);

shipmentSumBinTransferDetail '{document.sum.of} (учетная)' (binTransfer) = 
    GROUP SUM shipmentSum(BinTransferDetail idetail) BY binTransfer(idetail) CHARWIDTH 10 IN documentSum PATTERN '#,##0.00##';
shipmentSumUserBinTransferDetail '{document.sum.of} (учетная)' (userBinTransfer) = 
    GROUP SUM shipmentSum(UserBinTransferDetail idetail) BY userBinTransfer(idetail) CHARWIDTH 10 IN documentSum PATTERN '#,##0.00##';

@defineStockDocumentBinLedgerOperationProperty(Bin,'Проводить по ТО подразделений');

WHEN LOCAL (CHANGED(stock(UserBinTransferDetail detail)) OR CHANGED(dateTime(detail)) OR SETCHANGED(batch(detail))) AND 
    batch(detail) AND createStockDocumentBinLedger(operation(detail)) AND NOT CHANGED(shipmentPrice(detail)) AND NOT skipUpdatePriceAccount() DO {
    shipmentPrice(detail) <- prevAccountPriceA(batch(detail), stock(detail), dateTime(detail));
}

calcShipmentSum = ABSTRACT VALUE NUMERIC[18,4] (UserBinTransferDetail);
calcShipmentSum(UserBinTransferDetail detail) += NUMERIC[18,4](round2(quantity(detail) * shipmentPrice(detail))); //округление делаем до двух знаков, если надо, то переопределиться потом
shipmentSum (UserBinTransferDetail detail) <- calcShipmentSum(detail)
    WHEN DO (CHANGED(quantity(detail)) OR CHANGED (shipmentPrice(detail))) AND createStockDocumentBinLedger(operation(detail));

EXTEND FORM userBinTransfer
    PROPERTIES(o) READONLY BACKGROUND RGB(255, 224, 255) shipmentSumUserBinTransferDetail
    PROPERTIES(d) BACKGROUND RGB(255, 224, 255) AFTER quantity(d) SHOWIF createStockDocumentBinLedger(operation(d))
        shipmentPrice, shipmentSum
;

EXTEND FORM binTransfers
    PROPERTIES(o) READONLY BACKGROUND RGB(255, 224, 255) AFTER quantityBinTransferDetail(o) shipmentSumBinTransferDetail  
    PROPERTIES(d) READONLY BACKGROUND RGB(255, 224, 255) AFTER quantity(d) SHOWIF createStockDocumentBinLedger(operation(d))
        shipmentPrice, shipmentSum
;

recalculateShipmentSum() + {
    NEWSESSION {
        //удаляем учётные суммы, что не соответствуют настройкам операции
        shipmentSum (UserBinTransferDetail detail) <- NULL WHERE detail IS UserBinTransferDetail AND
            date(detail) >= (MAX documentsClosedDate(stock(detail)), sum(currentDate(), -countDaysToRecalculate())) AND
            NOT createStockDocumentBinLedger(operation(detail));
        APPLY;
    }
}

recalculateShipmentSum() + {
    NEWSESSION {
        //восстанавливаем хронологию, что перемещение в отдел не может быть раньше завершения первой приёмки по партии
        LOCAL maxGRDateTime = DATETIME (UserBinTransfer);
        maxGRDateTime(UserBinTransfer o) <- [GROUP MAX GRDateTime(batch(UserBinTransferDetail d)) BY userBinTransfer(d)](o)
            WHERE date(o) >= (MAX documentsClosedDate(stock(o)), sum(currentDate(), -countDaysToRecalculate())) AND 
                createStockDocumentBinLedger(operation(o));
        FOR  maxGRDateTime(UserBinTransfer o) > dateTime(o) INLINE DO {
            date(o) <- toDate(maxGRDateTime(o));
            time(o) <- toTime(maxGRDateTime(o));
        }
        APPLY;
    }
}

needToRecalculateShipmentSum = ABSTRACT BOOLEAN (UserBinTransferDetail);
recalculateShipmentSum() + {
    NEWSESSION {
        shipmentPrice(UserBinTransferDetail detail) <- prevAccountPriceA(batch(detail), stock(detail), dateTime(detail))
            WHERE needToRecalculateShipmentSum(detail) AND batch(detail) AND
                date(detail) >= MAX documentsClosedDate(stock(detail)), sum(currentDate(), -countDaysToRecalculate());
        APPLY;
    }
}

@defineStockDocumentBinLedgerOperationAggregation (inc, binTransfer, 'Перемещение по ячейкам (приход)', inDepartment);
    @implementStockDocumentBinLedger(inc, binTransfer, stock);


shipmentSum(IncSDBinTransferBinLedger ledger) =
    NUMERIC[18,4](GROUP SUM shipmentSum(BinTransferDetail d) IF binTransfer(d) == binTransfer(ledger) AND inDepartment(d) == department(ledger));
sumItem[IncStockDocumentBinLedger] (IncSDBinTransferBinLedger ledger) +=
    NUMERIC[18,4](GROUP SUM shipmentSum(BinTransferDetail d) IF isItem(sku(d)) AND binTransfer(d) == binTransfer(ledger) AND inDepartment(d) == department(ledger));
sumContainer[IncStockDocumentBinLedger] (IncSDBinTransferBinLedger ledger) +=
    NUMERIC[18,4](GROUP SUM shipmentSum(BinTransferDetail d) IF isContainer(sku(d)) AND binTransfer(d) == binTransfer(ledger) AND inDepartment(d) == department(ledger));

@defineStockDocumentBinLedgerOperationAggregation (out, binTransfer, 'Перемещение по ячейкам (расход)', outDepartment);
    @implementStockDocumentBinLedger(out, binTransfer, stock);

shipmentSum(OutSDBinTransferBinLedger ledger) =
    NUMERIC[18,4](GROUP SUM shipmentSum(BinTransferDetail d) IF binTransfer(d) == binTransfer(ledger) AND outDepartment(d) == department(ledger));
sumItem[OutStockDocumentBinLedger] (OutSDBinTransferBinLedger ledger) +=
    NUMERIC[18,4](GROUP SUM shipmentSum(BinTransferDetail d) IF isItem(sku(d)) AND binTransfer(d) == binTransfer(ledger) AND outDepartment(d) == department(ledger));
sumContainer[OutStockDocumentBinLedger] (OutSDBinTransferBinLedger ledger) +=
    NUMERIC[18,4](GROUP SUM shipmentSum(BinTransferDetail d) IF isContainer(sku(d)) AND binTransfer(d) == binTransfer(ledger) AND outDepartment(d) == department(ledger));