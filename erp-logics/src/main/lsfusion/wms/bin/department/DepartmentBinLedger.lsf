MODULE DepartmentBinLedger;

REQUIRE DepartmentBin, BinLedger, BatchBinLedger, EmployeeBinDepartment;

NAMESPACE Bin;

outDepartment = ABSTRACT Department (BinLedger) MATERIALIZED INDEXED;
nameOutDepartment 'Отдел (из)' (BinLedger ledger)= name(outDepartment(ledger)) CHARWIDTH 20;

inDepartment = ABSTRACT Department (BinLedger) MATERIALIZED INDEXED;
nameInDepartment 'Отдел (в)' (BinLedger ledger)= name(inDepartment(ledger)) CHARWIDTH 20;

EXTEND FORM binLedger
    PROPERTIES(b) READONLY nameInDepartment AFTER canonicalIdInBin(b), nameOutDepartment AFTER canonicalIdOutBin(b)
;

sum 'Сумма' (ledger) = ABSTRACT NUMERIC[18,4] (BinLedger) MATERIALIZED;

quantityIn(Department d, BinLedger ledger) = quantity(ledger) IF inDepartment(ledger)==d;
quantityOut(Department d, BinLedger ledger) = quantity(ledger) IF outDepartment(ledger)==d;
balanceQuantity 'Кол-во' (Department d, BinLedger ledger) = quantityIn(d, ledger) (-) quantityOut(d, ledger);

////товары
countInLedger 'Кол-во приходов' =
    GROUP SUM 1 IF active(BinLedger ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY sku(ledger), inDepartment(ledger) MATERIALIZED;

countOutLedger 'Кол-во расходов' =
    GROUP SUM 1 IF active(BinLedger ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY sku(ledger), outDepartment(ledger) MATERIALIZED;

countLedger 'Кол-во движений' (Sku sku, Department department) =
    countInLedger(sku, department) (+) countOutLedger(sku, department) MATERIALIZED;

countLedger 'Кол-во движений' = GROUP SUM countLedger(Sku sku, Department department) BY department;

inTotal 'Приход в отдел' =
    GROUP SUM quantity(BinLedger ledger) IF active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY sku(ledger), inDepartment(ledger) MATERIALIZED;
outTotal 'Расход из отдела' =
    GROUP SUM quantity(BinLedger ledger) IF active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY sku(ledger), outDepartment(ledger) MATERIALIZED;

inTotalA 'Приход в отдел' =
    GROUP SUM quantity(BinLedger ledger) IF date(ledger) > DATE date AND active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger)  BY sku(ledger), inDepartment(ledger), date;

outTotalA 'Расход из отдела' =
    GROUP SUM quantity(BinLedger ledger) IF date(ledger) > DATE date AND active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger)  BY sku(ledger), outDepartment(ledger), date;

inTotalB 'Приход в отдел' =
    GROUP SUM quantity(BinLedger ledger) IF date(ledger) >= DATE date AND active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger)  BY sku(ledger), inDepartment(ledger), date;

outTotalB 'Расход из отдела' =
    GROUP SUM quantity(BinLedger ledger) IF date(ledger) >= DATE date AND active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger)  BY sku(ledger), outDepartment(ledger), date;

inTotalA 'Приход в отдел' =
    GROUP SUM quantity(BinLedger ledger) IF dateTime(ledger) > DATETIME dateTime AND active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger)  BY sku(ledger), inDepartment(ledger), dateTime;

outTotalA 'Расход из отдела' =
    GROUP SUM quantity(BinLedger ledger) IF dateTime(ledger) > DATETIME dateTime AND active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger)  BY sku(ledger), outDepartment(ledger), dateTime;

inTotalB 'Приход в отдел' =
    GROUP SUM quantity(BinLedger ledger) IF dateTime(ledger) >= DATETIME dateTime AND active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger)  BY sku(ledger), inDepartment(ledger), dateTime;

outTotalB 'Расход из отдела' =
    GROUP SUM quantity(BinLedger ledger) IF dateTime(ledger) >= DATETIME dateTime AND active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger)  BY sku(ledger), outDepartment(ledger), dateTime;

currentBalance 'Текущий остаток в отделе' (Sku sku, Department department) =
    inTotal(sku, department) (-) outTotal(sku, department) MATERIALIZED;
prevCurrentBalance 'Текущий остаток в отделе' (Sku sku, Department department)=
    PREV(currentBalance(sku, department));
prevCurrentBalance 'Текущий остаток в отделе' = GROUP SUM prevCurrentBalance(Sku sku, Department department) BY department;

balanceB 'Остаток в отделе (до)' (Sku sku, Department department, DATETIME dateTime) = currentBalance(sku, department) (-)
    inTotalB(sku, department, dateTime) (+) outTotalB(sku, department, dateTime);
prevBalanceB 'Остаток (до)' (Sku sku, Department department, DATETIME dateTime) = PREV(balanceB(sku, department, dateTime) IF dateTime IS DATETIME);

balanceA 'Остаток в отделе (после)' (Sku sku, Department department, DATETIME dateTime) = currentBalance(sku, department) (-)
    inTotalA(sku, department, dateTime) (+) outTotalA(sku, department, dateTime);
prevBalanceA 'Остаток в отделе (после)' (Sku sku, Department department, DATETIME dateTime) = PREV(balanceA(sku, department, dateTime) IF dateTime IS DATETIME);
balanceA 'Остаток в отделе на конец дня' (Sku sku, Department department, DATE date) = 
    currentBalance(sku, department) (-) inTotalA(sku, department, date) (+) outTotalA(sku, department, date);

//кол-во
quantityIn 'Приход в отдел' =
    GROUP SUM quantity(BinLedger ledger) IF active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY sku(ledger), inDepartment(ledger), date(ledger);
quantityOut 'Расход из отдела' =
    GROUP SUM quantity(BinLedger ledger) IF active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY sku(ledger), outDepartment(ledger), date(ledger);

quantityIn 'Кол-во товара пришедшего за период' (Sku sku, Department department, DATE dFrom, DATE dTo)  =
    GROUP SUM quantityIn(sku, department, DATE dateIn) IF dateIn>=dFrom AND dateIn<=dTo;
quantityOut 'Кол-во товара ушедшего за период' (Sku sku, Department department, DATE dFrom, DATE dTo)  =
    GROUP SUM quantityOut(sku, department, DATE dateIn) IF dateIn>=dFrom AND dateIn<=dTo;

//сумма
sumIn 'Приход в отдел' =
    GROUP SUM sum(BinLedger ledger) IF active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY sku(ledger), inDepartment(ledger), date(ledger);
sumOut 'Расход из отдела' =
    GROUP SUM sum(BinLedger ledger) IF active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY sku(ledger), outDepartment(ledger), date(ledger);

sumIn 'Сумма товара пришедшего за период' (Sku sku, Department department, DATE dFrom, DATE dTo)  =
    GROUP SUM sumIn(sku, department, DATE dateIn) IF dateIn>=dFrom AND dateIn<=dTo;
sumOut 'Сумма товара ушедшего за период' (Sku sku, Department department, DATE dFrom, DATE dTo)  =
    GROUP SUM sumOut(sku, department, DATE dateIn) IF dateIn>=dFrom AND dateIn<=dTo;

inSumTotal 'Приход в отдел' =
    GROUP SUM sum(BinLedger ledger) IF active(ledger) BY sku(ledger), inDepartment(ledger) MATERIALIZED;

outSumTotal 'Расход из отдела' =
    GROUP SUM sum(BinLedger ledger) IF active(ledger) BY sku(ledger), outDepartment(ledger) MATERIALIZED;

inSumTotalA 'Приход в отдел' =
    GROUP SUM sum(BinLedger ledger) IF date(ledger) > DATE date AND active(ledger) BY sku(ledger), inDepartment(ledger), date;

outSumTotalA 'Расход из отдела' =
    GROUP SUM sum(BinLedger ledger) IF date(ledger) > DATE date AND active(ledger) BY sku(ledger), outDepartment(ledger), date;

inSumTotalB 'Приход в отдел' =
    GROUP SUM sum(BinLedger ledger) IF date(ledger) >= DATE date AND active(ledger) BY sku(ledger), inDepartment(ledger), date;

outSumTotalB 'Расход из отдела' =
    GROUP SUM sum(BinLedger ledger) IF date(ledger) >= DATE date AND active(ledger) BY sku(ledger), outDepartment(ledger), date;

inSumTotalA 'Приход в отдел' =
    GROUP SUM sum(BinLedger ledger) IF dateTime(ledger) > DATETIME dateTime AND active(ledger) BY sku(ledger), inDepartment(ledger), dateTime;

outSumTotalA 'Расход из отдела' =
    GROUP SUM sum(BinLedger ledger) IF dateTime(ledger) > DATETIME dateTime AND active(ledger) BY sku(ledger), outDepartment(ledger), dateTime;

inSumTotalB 'Приход в отдел' =
    GROUP SUM sum(BinLedger ledger) IF dateTime(ledger) >= DATETIME dateTime AND active(ledger) BY sku(ledger), inDepartment(ledger), dateTime;

outSumTotalB 'Расход из отдела' =
    GROUP SUM sum(BinLedger ledger) IF dateTime(ledger) >= DATETIME dateTime AND active(ledger) BY sku(ledger), outDepartment(ledger), dateTime;

currentSum 'Сумма текущего остатка в отделе' (Sku sku, Department department)=
    inSumTotal(sku, department) (-) outSumTotal(sku, department) MATERIALIZED;
prevCurrentSum 'Сумма текущего остатка в отделе' (Sku sku, Department department) = PREV(currentSum(sku, department));

sumB 'Остаток в отделе (до)' (Sku sku, Department dep, DATETIME dateTime) = currentSum(sku, dep) (-)
    inSumTotalB(sku, dep, dateTime) (+) outSumTotalB(sku, dep, dateTime);
prevSumB 'Остаток (до)' (Sku sku, Department dep, DATETIME dateTime) = PREV(sumB(sku, dep, dateTime) IF dateTime IS DATETIME);

sumA 'Остаток в отделе (после)' (Sku sku, Department dep, DATETIME dateTime) = currentSum(sku, dep) (-)
    inSumTotalA(sku, dep, dateTime) (+) outSumTotalA(sku, dep, dateTime);
prevSumA 'Остаток в отделе (после)' (Sku sku, Department dep, DATETIME dateTime) = PREV(sumA(sku, dep, dateTime) IF dateTime IS DATETIME);
sumA 'Остаток в отделе на конец дня' (Sku sku, Department dep, DATE date) = currentSum(sku, dep) (-)
    inSumTotalA(sku, dep, date) (+) outSumTotalA(sku, dep, date);

////партии
//количества
quantityIn 'Приход в отдел' =
    GROUP SUM quantity(BinLedger ledger) IF active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY batch(ledger), inDepartment(ledger), date(ledger);
quantityOut 'Расход из отдела' =
    GROUP SUM quantity(BinLedger ledger) IF active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY batch(ledger), outDepartment(ledger), date(ledger);

quantityIn 'Кол-во товара пришедшего за период' (Batch batch, Department department, DATE dFrom, DATE dTo)  =
    GROUP SUM quantityIn(batch, department, DATE dateIn) IF dateIn>=dFrom AND dateIn<=dTo;
quantityOut 'Кол-во товара ушедшего за период' (Batch batch, Department department, DATE dFrom, DATE dTo)  =
    GROUP SUM quantityOut(batch, department, DATE dateIn) IF dateIn>=dFrom AND dateIn<=dTo;

countInLedger 'Кол-во приходов' =
    GROUP SUM 1 IF active(BinLedger ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY batch(ledger), inDepartment(ledger) MATERIALIZED;

countInLedger 'Кол-во приходов' =
    GROUP SUM 1 IF active(BinLedger ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY batch(ledger), inDepartment(ledger), date(ledger);

countInLedgerA 'Кол-во приходов до' (Batch bt, Department b, DATE d) =
    [GROUP SUM 1 IF active(BinLedger ledger) AND date(ledger) < DATE d1 AND NOT outDepartment(ledger) = inDepartment(ledger) BY batch(ledger), inDepartment(ledger), d1](bt, b, sum(d,1));

countOutLedger 'Кол-во расходов' =
    GROUP SUM 1 IF active(BinLedger ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY batch(ledger), outDepartment(ledger) MATERIALIZED;

countLedger 'Кол-во движений' (Batch batch, Department department) =
    countInLedger(batch, department) (+) countOutLedger(batch, department) MATERIALIZED;

countBatchLedger 'Кол-во движений' = GROUP SUM countLedger(Batch batch, Department dep) BY dep;

inTotal 'Приход в отдел' =
    GROUP SUM quantity(BinLedger ledger) IF active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY batch(ledger), inDepartment(ledger) MATERIALIZED;

outTotal 'Расход из отдела' =
    GROUP SUM quantity(BinLedger ledger) IF active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY batch(ledger), outDepartment(ledger) MATERIALIZED;

inTotalA 'Приход в отдел' =
    GROUP SUM quantity(BinLedger ledger) IF date(ledger) > DATE date AND active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY batch(ledger), inDepartment(ledger), date;

outTotalA 'Расход из отдела' =
    GROUP SUM quantity(BinLedger ledger) IF date(ledger) > DATE date AND active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY batch(ledger), outDepartment(ledger), date;

inTotalB 'Приход в отдел' =
    GROUP SUM quantity(BinLedger ledger) IF date(ledger) >= DATE date AND active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY batch(ledger), inDepartment(ledger), date;

outTotalB 'Расход из отдела' =
    GROUP SUM quantity(BinLedger ledger) IF date(ledger) >= DATE date AND active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY batch(ledger), outDepartment(ledger), date;

inTotalA 'Приход в отдел' =
    GROUP SUM quantity(BinLedger ledger) IF dateTime(ledger) > DATETIME dateTime AND active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY batch(ledger), inDepartment(ledger), dateTime;

outTotalA 'Расход из отдела' =
    GROUP SUM quantity(BinLedger ledger) IF dateTime(ledger) > DATETIME dateTime AND active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY batch(ledger), outDepartment(ledger), dateTime;

inTotalB 'Приход в отдел' =
    GROUP SUM quantity(BinLedger ledger) IF dateTime(ledger) >= DATETIME dateTime AND active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY batch(ledger), inDepartment(ledger), dateTime;

outTotalB 'Расход из отдела' =
    GROUP SUM quantity(BinLedger ledger) IF dateTime(ledger) >= DATETIME dateTime AND active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY batch(ledger), outDepartment(ledger), dateTime;

currentBalance 'Текущий остаток в отделе' (Batch batch, Department department)=
    inTotal(batch, department) (-) outTotal(batch, department) MATERIALIZED;
prevCurrentBalance 'Текущий остаток в отделе' (Batch batch, Department department)= 
    PREV(currentBalance(batch, department));
balanceB 'Остаток в отделе (до)' (Batch batch, Department dep, DATETIME dateTime) = currentBalance(batch, dep) (-)
    inTotalB(batch, dep, dateTime) (+) outTotalB(batch, dep, dateTime);
prevBalanceB 'Остаток (до)' (Batch batch, Department dep, DATETIME dateTime) = PREV(balanceB(batch, dep, dateTime) IF dateTime IS DATETIME);

balanceA 'Остаток в отделе (после)' (Batch batch, Department dep, DATETIME dateTime) = currentBalance(batch, dep) (-)
    inTotalA(batch, dep, dateTime) (+) outTotalA(batch, dep, dateTime);
prevBalanceA 'Остаток в отделе (после)' (Batch batch, Department dep, DATETIME dateTime) = PREV(balanceA(batch, dep, dateTime) IF dateTime IS DATETIME);
balanceA 'Остаток в отделе на конец дня' (Batch batch, Department dep, DATE date) = currentBalance(batch, dep) (-)
    inTotalA(batch, dep, date) (+) outTotalA(batch, dep, date);

//сумма
sumIn 'Приход в отдел' =
    GROUP SUM sum(BinLedger ledger) IF active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY batch(ledger), inDepartment(ledger), date(ledger);
sumOut 'Расход из отдела' =
    GROUP SUM sum(BinLedger ledger) IF active(ledger) AND NOT outDepartment(ledger) = inDepartment(ledger) BY batch(ledger), outDepartment(ledger), date(ledger);

sumIn 'Сумма товара пришедшего за период' (Batch batch, Department department, DATE dFrom, DATE dTo)  =
    GROUP SUM sumIn(batch, department, DATE dateIn) IF dateIn>=dFrom AND dateIn<=dTo;
sumOut 'Сумма товара ушедшего за период' (Batch batch, Department department, DATE dFrom, DATE dTo)  =
    GROUP SUM sumOut(batch, department, DATE dateIn) IF dateIn>=dFrom AND dateIn<=dTo;

inSumTotal 'Приход в отдел' =
    GROUP SUM sum(BinLedger ledger) IF active(ledger) BY batch(ledger), inDepartment(ledger) MATERIALIZED;

outSumTotal 'Расход из отдела' =
    GROUP SUM sum(BinLedger ledger) IF active(ledger) BY batch(ledger), outDepartment(ledger) MATERIALIZED;

inSumTotalA 'Приход в отдел' =
    GROUP SUM sum(BinLedger ledger) IF date(ledger) > DATE date AND active(ledger) BY batch(ledger), inDepartment(ledger), date;

outSumTotalA 'Расход из отдела' =
    GROUP SUM sum(BinLedger ledger) IF date(ledger) > DATE date AND active(ledger) BY batch(ledger), outDepartment(ledger), date;

inSumTotalB 'Приход в отдел' =
    GROUP SUM sum(BinLedger ledger) IF date(ledger) >= DATE date AND active(ledger) BY batch(ledger), inDepartment(ledger), date;

outSumTotalB 'Расход из отдела' =
    GROUP SUM sum(BinLedger ledger) IF date(ledger) >= DATE date AND active(ledger) BY batch(ledger), outDepartment(ledger), date;

inSumTotalA 'Приход в отдел' =
    GROUP SUM sum(BinLedger ledger) IF dateTime(ledger) > DATETIME dateTime AND active(ledger) BY batch(ledger), inDepartment(ledger), dateTime;

outSumTotalA 'Расход из отдела' =
    GROUP SUM sum(BinLedger ledger) IF dateTime(ledger) > DATETIME dateTime AND active(ledger) BY batch(ledger), outDepartment(ledger), dateTime;

inSumTotalB 'Приход в отдел' =
    GROUP SUM sum(BinLedger ledger) IF dateTime(ledger) >= DATETIME dateTime AND active(ledger) BY batch(ledger), inDepartment(ledger), dateTime;

outSumTotalB 'Расход из отдела' =
    GROUP SUM sum(BinLedger ledger) IF dateTime(ledger) >= DATETIME dateTime AND active(ledger) BY batch(ledger), outDepartment(ledger), dateTime;

currentSum 'Сумма текущего остатка в отделе' (Batch batch, Department department)=
    inSumTotal(batch, department) (-) outSumTotal(batch, department) MATERIALIZED;
prevCurrentSum 'Сумма текущего остатка в отделе' (Batch batch, Department department) = PREV(currentSum(batch, department));

sumB 'Остаток в отделе (до)' (Batch batch, Department dep, DATETIME dateTime) = currentSum(batch, dep) (-)
    inSumTotalB(batch, dep, dateTime) (+) outSumTotalB(batch, dep, dateTime);
prevSumB 'Остаток (до)' (Batch batch, Department dep, DATETIME dateTime) = PREV(sumB(batch, dep, dateTime) IF dateTime IS DATETIME);

sumA 'Остаток в отделе (после)' (Batch batch, Department dep, DATETIME dateTime) = currentSum(batch, dep) (-)
    inSumTotalA(batch, dep, dateTime) (+) outSumTotalA(batch, dep, dateTime);
prevSumA 'Остаток в отделе (после)' (Batch batch, Department dep, DATETIME dateTime) = PREV(sumA(batch, dep, dateTime) IF dateTime IS DATETIME);
sumA 'Остаток в отделе на конец дня' (Batch batch, Department dep, DATE date) = currentSum(batch, dep) (-)
    inSumTotalA(batch, dep, date) (+) outSumTotalA(batch, dep, date);

dateTimeLastMoved 'Время последнего движения' (Sku sku, Department department) =
    GROUP LAST dateTime(BinLedger ledger)
    ORDER dateTime(ledger), ledger
    WHERE active(ledger) AND (inDepartment(ledger)==department OR outDepartment(ledger)==department)
    BY sku(ledger);

moved (Sku item, Department department, DATE date, LONG period) =
    dateTimeLastMoved(item, department) >= toDateTime(subtract(date, period));
moved (Sku item, Department department, DATETIME dateTime, LONG period) =
    dateTimeLastMoved(item, department) >= toDateTime(subtract(toDate(dateTime), period));

currentBalance (Sku item, Department department, LONG period) =
    moved (item, department, currentDate(), period) OR currentBalance(item, stock(department));
balance (Sku item, Department department, DATETIME dateTime, LONG period) =
    moved (item, department, dateTime, period) OR balanceB(item, stock(department), dateTime);

dateTimeLastMoved 'Время последнего прихода' (Batch b, Department department) =
    GROUP LAST dateTime(BinLedger ledger)
    ORDER dateTime(ledger), ledger
    WHERE active(ledger)
    BY batch(ledger), inDepartment(ledger);

dateTimeLastMovedInOut 'Время последнего движения' (Batch b, Department department) =
    GROUP LAST dateTime(BinLedger ledger)
    ORDER dateTime(ledger), ledger
    WHERE active(ledger) AND (inDepartment(ledger)==department OR outDepartment(ledger)==department)
    BY batch(ledger);

moved (Batch b, Department department, DATE date, LONG period) =
    dateTimeLastMovedInOut(b, department) >= toDateTime(subtract(date, period));
moved (Batch b, Department department, DATETIME dateTime, LONG period) =
    dateTimeLastMovedInOut(b, department) >= toDateTime(subtract(toDate(dateTime), period));

currentBalance (Batch b, Department department, LONG period) =
    moved (b, department, currentDate(), period) OR currentBalance(b, stock(department));
balance (Batch b, Department department, DATETIME dateTime, LONG period) =
    moved (b, department, dateTime, period) OR balanceB(b, stock(department), dateTime);

EXTEND FORM currentBalanceSkuStock
    PROPERTIES SHOWIF countAccessCompanyDepartments(currentUser(), ss) AND singleStore()
        READONLYIF countAccessCompanyDepartments(currentUser(), ss) = 1 nameFilterDepartment() ON CHANGE changeFilterDepartment(ss)
    FILTERS currentBalance(s, filterDepartment())
        OR NOT filterDepartment() OR NOT countAccessCompanyDepartments(currentUser(), ss) OR multipleStores()
    OBJECTS department = Department PANEL
    PROPERTIES(s, department) READONLY DRAW sts SHOWIF filterDepartment() AFTER currentBalance(s, st) currentBalance, currentSum 
    FILTERS department = filterDepartment()

    OBJECTS bin = Bin
    PROPERTIES(bin) READONLY order, canonicalId, name, id SHOWIF showIDs(), status
    PROPERTIES(s, bin) READONLY currentBalance, currentReserved, availableQuantity
    FILTERS stock(bin) = st, currentBalance(s, bin), filterDepartment()==department(bin)
        OR NOT filterDepartment() OR NOT countAccessCompanyDepartments(currentUser(), ss) OR multipleStores()
    ORDERS order(bin), canonicalId(bin), name(bin)
    
    OBJECTS bl = BinLedger
    PROPERTIES(bl) READONLY dateTime, description, skip, quantity, sum, canonicalIdInBin, nameInDepartment, 
        canonicalIdOutBin, nameOutDepartment
    PROPERTIES(bl) EDIT SHOWIF allowedEdit(bl) NEWSESSION, show SHOWIF allowedShow(bl)
    ORDERS dateTime(bl) DESC
    FILTERS isPosted(bl), sku(bl)==s,
        stock(bl) = st, inDepartment(bl)==filterDepartment() OR outDepartment(bl)==filterDepartment()
    OR NOT filterDepartment() OR NOT countAccessCompanyDepartments(currentUser(), ss) OR multipleStores()
    
    EVENTS ON CHANGE ss {
        IF countAccessCompanyDepartments(currentUser(), ss) = 1 AND singleStore() THEN {
            filterDepartment() <- OVERRIDE department(currentUser()), defaultCompanyDepartment(currentUser(), ss);
        } ELSE {
            filterDepartment() <- NULL;
        }
    }
;

DESIGN currentBalanceSkuStock {
    filter {
        MOVE PROPERTY(nameFilterDepartment()) AFTER PROPERTY(name(ss)) {tag='';}
    }
    ledgerBox {
        MOVE BOX(bin){
            PROPERTY(canonicalId(bin)) {defaultCompare = '=*';}
        }
        MOVE BOX(bl){
            PROPERTY(canonicalIdInBin(bl)) {defaultCompare = '=*';}
            PROPERTY(canonicalIdOutBin(bl)) {defaultCompare = '=*';}
        }
    }
}

EXTEND FORM balanceSkuStock
    PROPERTIES SHOWIF countAccessCompanyDepartments(currentUser(), ss) AND singleStore()
        READONLYIF countAccessCompanyDepartments(currentUser(), ss) = 1 nameFilterDepartment() ON CHANGE changeFilterDepartment(ss)
    FILTERS balanceB(s, filterDepartment(), t)
        OR NOT filterDepartment() OR NOT countAccessCompanyDepartments(currentUser(), ss) OR multipleStores()
    OBJECTS department = Department PANEL
    PROPERTIES(s, department, t) READONLY DRAW sts SHOWIF filterDepartment() AFTER balanceB(s, st,t) balanceB, sumB 
    FILTERS department = filterDepartment()

    OBJECTS bin = Bin
    PROPERTIES(bin) READONLY order, canonicalId, name, id SHOWIF showIDs(), status
    PROPERTIES READONLY balanceB(s, bin, t)
    FILTERS stock(bin) = st, balanceB(s, bin, t), department(bin)==filterDepartment()
        OR NOT filterDepartment() OR NOT countAccessCompanyDepartments(currentUser(), ss) OR multipleStores()
    ORDERS order(bin), canonicalId(bin), name(bin)

    OBJECTS bl = BinLedger
    PROPERTIES(bl) READONLY dateTime, description, skip, quantity, sum, canonicalIdInBin, nameInDepartment, 
        canonicalIdOutBin, nameOutDepartment
    PROPERTIES(bl) EDIT SHOWIF allowedEdit(bl) NEWSESSION, show SHOWIF allowedShow(bl)
    ORDERS dateTime(bl) DESC
    FILTERS isPosted(bl), sku(bl)==s,
        stock(bl) = st, inDepartment(bl)==filterDepartment() OR outDepartment(bl)==filterDepartment()
        OR NOT filterDepartment() OR NOT countAccessCompanyDepartments(currentUser(), ss) OR multipleStores()


    EVENTS ON CHANGE ss {
        IF countAccessCompanyDepartments(currentUser(), ss) = 1 AND singleStore() THEN {
            filterDepartment() <- defaultCompanyDepartment(currentUser(), ss);
        } ELSE {
            filterDepartment() <- NULL;
        }
    }
;

DESIGN balanceSkuStock {
    filter {
        MOVE PROPERTY(nameFilterDepartment()) AFTER PROPERTY(name(ss)) {tag='';}
    }
    ledgerBox {
        MOVE BOX(bin);
        MOVE BOX(bl);
    }
}

EXTEND FORM currentBalanceBatchStock
    PROPERTIES SHOWIF countAccessCompanyDepartments(currentUser(), ss) AND singleStore()
        READONLYIF countAccessCompanyDepartments(currentUser(), ss) = 1 nameFilterDepartment() ON CHANGE changeFilterDepartment(ss)
    FILTERS currentBalance(bt, filterDepartment())
        OR NOT filterDepartment() OR NOT countAccessCompanyDepartments(currentUser(), ss) OR multipleStores()
    OBJECTS department = Department PANEL
    PROPERTIES(bt, department) READONLY DRAW stb SHOWIF filterDepartment() AFTER currentBalance(bt, st) currentBalance, currentSum 
    FILTERS department = filterDepartment()

    OBJECTS bin = Bin
    PROPERTIES(bin) READONLY order, canonicalId, name, id SHOWIF showIDs(), statusBatch
    PROPERTIES(bt, bin) READONLY currentBalance
    FILTERS stock(bin) = st, currentBalance(bt, bin), department(bin)==filterDepartment()
        OR NOT filterDepartment() OR NOT countAccessCompanyDepartments(currentUser(), ss) OR multipleStores()
    ORDERS order(bin), canonicalId(bin), name(bin)

    OBJECTS bl = BinLedger
    PROPERTIES(bl) READONLY dateTime, description, skip, quantity, sum, canonicalIdInBin, nameInDepartment, 
        canonicalIdOutBin, nameOutDepartment
    PROPERTIES(bl) EDIT SHOWIF allowedEdit(bl) NEWSESSION, show SHOWIF allowedShow(bl)
    ORDERS dateTime(bl) DESC
    FILTERS isPosted(bl), batch(bl)==bt,
        stock(bl) = st, inDepartment(bl)==filterDepartment() OR outDepartment(bl)==filterDepartment()
        OR NOT filterDepartment() OR NOT countAccessCompanyDepartments(currentUser(), ss) OR multipleStores()

    EVENTS ON CHANGE ss {
        IF countAccessCompanyDepartments(currentUser(), ss) = 1 AND singleStore() THEN {
            filterDepartment() <- defaultCompanyDepartment(currentUser(), ss);
        } ELSE {
            filterDepartment() <- NULL;
        }
    }
;

DESIGN currentBalanceBatchStock {
    filter {
        MOVE PROPERTY(nameFilterDepartment()) AFTER PROPERTY(name(ss)) {tag='';}
    }
    ledgerBox {
        MOVE BOX(bin){
            PROPERTY(canonicalId(bin)) {defaultCompare = '=*';}
        }
        MOVE BOX(bl){
            PROPERTY(canonicalIdInBin(bl)) {defaultCompare = '=*';}
            PROPERTY(canonicalIdOutBin(bl)) {defaultCompare = '=*';}
        }
    }
}

EXTEND FORM balanceBatchStock
    PROPERTIES SHOWIF countAccessCompanyDepartments(currentUser(), ss) AND singleStore()
        READONLYIF countAccessCompanyDepartments(currentUser(), ss) = 1 nameFilterDepartment() ON CHANGE changeFilterDepartment(ss)
    FILTERS balanceB(bt, filterDepartment(), t)
        OR NOT filterDepartment() OR NOT countAccessCompanyDepartments(currentUser(), ss) OR multipleStores()
    OBJECTS department = Department PANEL
    PROPERTIES(bt, department, t) READONLY DRAW stb SHOWIF filterDepartment() AFTER balanceB(bt, st,t) balanceB, sumB 
    FILTERS department = filterDepartment()

    OBJECTS bin = Bin
    PROPERTIES(bin) READONLY order, canonicalId, name, id SHOWIF showIDs(), statusBatch
    PROPERTIES READONLY balanceB(bt, bin, t)
    FILTERS stock(bin) = st, balanceB(bt, bin, t), department(bin)==filterDepartment()
        OR NOT filterDepartment() OR NOT countAccessCompanyDepartments(currentUser(), ss) OR multipleStores()
    ORDERS order(bin), canonicalId(bin), name(bin)

    OBJECTS bl = BinLedger
    PROPERTIES(bl) READONLY dateTime, description, skip, quantity, sum, canonicalIdInBin, nameInDepartment, 
        canonicalIdOutBin, nameOutDepartment
    PROPERTIES(bl) EDIT SHOWIF allowedEdit(bl) NEWSESSION, show SHOWIF allowedShow(bl)
    ORDERS dateTime(bl) DESC
    FILTERS isPosted(bl), batch(bl)==bt,
        stock(bl) = st, inDepartment(bl)==filterDepartment() OR outDepartment(bl)==filterDepartment()
        OR NOT filterDepartment() OR NOT countAccessCompanyDepartments(currentUser(), ss) OR multipleStores()

    EVENTS ON CHANGE ss {
        IF countAccessCompanyDepartments(currentUser(), ss) = 1 AND singleStore() THEN {
            filterDepartment() <- defaultCompanyDepartment(currentUser(), ss);
        } ELSE {
            filterDepartment() <- NULL;
        }
    }
;

DESIGN balanceBatchStock {
    filter {
        MOVE PROPERTY(nameFilterDepartment()) AFTER PROPERTY(name(ss)) {tag='';}
    }
    ledgerBox {
        MOVE BOX(bin);
        MOVE BOX(bl);
    }
}

EXTEND FORM binLedger
    PROPERTIES(b) READONLY sum AFTER quantity(b)
;

META defineInterfaceDepartment (object, prefix, caption)
    prefix###department = ABSTRACT Department (###object) MATERIALIZED;
    prefix###department = DATA Department (###user###object);
    prefix###department (User###object object) += prefix###department(object);

    name###prefix###department 'Отдел'##caption (###object object) = name(prefix###department(object)) IN documentHeader CHARWIDTH 20;
    name###prefix###department 'Отдел'##caption (User###object user###object) = name(prefix###department(user###object)) IN documentHeader CHARWIDTH 20;

END

META defineDetailDepartment (object, prefix, caption)
    prefix###department(###object###detail object###Detail) = prefix###department(object(object###Detail));
    prefix###department(User###object###detail user###object###detail) = prefix###department(user###object(user###object###detail));

    name###prefix###department 'Отдел'##caption (###object###detail object###detail) = name(prefix###department(object###detail)) IN documentPrm CHARWIDTH 20;
    name###prefix###department 'Отдел'##caption (User###object###detail user###object###detail) = name(prefix###department(user###object###detail)) IN documentPrm CHARWIDTH 20;
    
END

META defineConstraintDetailDepartment(object, departmentProp, prefix, caption)
    //проверяем только в момент изменения в документе
    CONSTRAINT (CHANGED(prefix###bin(###object###detail object###Detail)) OR CHANGED(departmentProp(object###Detail))) AND
        departmentProp(object###Detail) AND prefix###bin(object###Detail) AND NOT departmentProp(object###Detail)==department(prefix###bin(object###Detail))
        MESSAGE 'Отдел ячейки'##caption + ' строки документа должен соответствовать отделу'##caption+ ' шапки документа';

END    

META defineDocumentDepartments (object)
    @defineInterfaceDepartment (object, in, ' (в)');
    @defineInterfaceDepartment (object, out, ' (из)');
END

META defineDocumentWithdetailDepartments (object)
    @defineInterfaceDepartment (object, in, ' (в)');
    @defineDetailDepartment (object, in, ' (в)');

    @defineInterfaceDepartment (object, out, ' (из)');
    @defineDetailDepartment (object, out, ' (из)');
END

META implementDepartmentLedger(class, object, departmentProp)
    departmentProp[BinLedger] (###class ledger) += departmentProp(object(ledger));
END

META defineInvoiceShipmentDepartment (object, prefix, caption)
    @defineInterfaceDepartment(object, prefix, caption);
    prefix##Department[ShipmentDetail] (InvoiceShipmentDetail detail) += prefix##Department(invoiceDetail(detail));
    
    EXTEND FORM userInvoice
        PROPERTIES(d) READONLY SHOWIF useBins(i) BACKGROUND backgroundShipped(i) AFTER name###prefix##Bin(d) name###prefix##Department       
    ;    
    EXTEND FORM invoices
        PROPERTIES(d) READONLY SHOWIF useBins(i) BACKGROUND backgroundShipped(i) AFTER name###prefix##Bin(d) name###prefix##Department
    ;
END

META setDepartmentDetail (object, prefix, caption)
   WHEN LOCAL CHANGED(prefix###bin(User###object###detail user###object###Detail)) DO {
       prefix###department(user###object###Detail) <- department(prefix###bin(user###object###Detail));   
   }

   CONSTRAINT (CHANGED(prefix###bin(###object###detail object###Detail)) OR CHANGED(prefix###department(object###Detail))) AND
       prefix###department(object###Detail) AND prefix###bin(object###Detail) AND NOT prefix###department(object###Detail)==department(prefix###bin(object###Detail))
       MESSAGE 'Отдел ячейки'##caption + ' строки документа должен соответствовать отделу'##caption;
END    