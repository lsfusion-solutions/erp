MODULE DepartmentRevaluationBinLedger;

REQUIRE DepartmentBinLedger, Revaluation;

NAMESPACE Revaluation;

@defineInterfaceDepartment(revaluation, , );

@defineDetailDepartment(revaluation, , '');

CONSTRAINT stock(UserRevaluation userRevaluation) AND department(userRevaluation) AND NOT
    stock(userRevaluation) = stock(department(userRevaluation))
    CHECKED BY department[UserRevaluation]
    MESSAGE 'Склад и отдел переоценки не имеют связи';

needDepartment 'Отдел обязателен' = DATA BOOLEAN (Operation);

EXTEND FORM operation
    PROPERTIES(o) needDepartment
;

DESIGN operation {
    constraintContainer {
        caption = 'Ограничения';
        MOVE PROPERTY(needDepartment(o));
    }
}

CONSTRAINT (CHANGED(operation(Revaluation r)) OR CHANGED(department(r))) AND NOT department(r) AND needDepartment(operation(r))
    MESSAGE 'Отдел обязателен для заданной операции переоценки';

EXTEND FORM userRevaluation
    PROPERTIES nameDepartment(p) 
;

DESIGN userRevaluation {
    third {
        MOVE PROPERTY(nameDepartment(p)) AFTER PROPERTY(nameStock(p)) {charWidth = 20;}
    }
}

EXTEND FORM revaluations
    PROPERTIES READONLY nameDepartment(p) AFTER nameStock(p)
;

//---------------------------- Проведение результатов по BinLedger----------------------------//

CLASS OutRevaluationBinLedger 'Уценка' : BinLedger; 

needToOutBinLedger(RevaluationDetail detail) = diffSum(detail)<0 AND isPosted(detail) AND department(detail);

outRevaluationBinLedger = AGGR OutRevaluationBinLedger WHERE needToOutBinLedger(RevaluationDetail revaluationDetail) MATERIALIZED INDEXED;

dateTime[BinLedger] (OutRevaluationBinLedger ledger) += dateTime(revaluationDetail(ledger));
isPosted[BinLedger] (OutRevaluationBinLedger ledger) += isPosted(revaluationDetail(ledger));
isClosed[BinLedger] (OutRevaluationBinLedger ledger) += isClosed(revaluationDetail(ledger));
stock[BinLedger] (OutRevaluationBinLedger ledger) += stock(revaluationDetail(ledger));
outDepartment[BinLedger] (OutRevaluationBinLedger ledger) += department(revaluationDetail(ledger));
description[BinLedger] (OutRevaluationBinLedger ledger) += description(revaluationDetail(ledger));
sku[BinLedger] (OutRevaluationBinLedger ledger) += sku(revaluationDetail(ledger));
batch[BinLedger] (OutRevaluationBinLedger ledger) += batch(revaluationDetail(ledger));
sum[BinLedger] (OutRevaluationBinLedger ledger) += abs(diffSum(revaluationDetail(ledger)));
edit[BinLedger](OutRevaluationBinLedger ledger) + {edit(revaluationDetail(ledger));}
show[BinLedger](OutRevaluationBinLedger ledger) + {show(revaluationDetail(ledger));}

CLASS InRevaluationBinLedger 'Дооценка' : BinLedger;

needToInBinLedger(RevaluationDetail detail) = diffSum(detail)>0 AND isPosted(detail) AND department(detail);

inRevaluationBinLedger = AGGR InRevaluationBinLedger WHERE needToInBinLedger(RevaluationDetail revaluationDetail) MATERIALIZED INDEXED;

dateTime[BinLedger] (InRevaluationBinLedger ledger) += dateTime(revaluationDetail(ledger));
isPosted[BinLedger] (InRevaluationBinLedger ledger) += isPosted(revaluationDetail(ledger));
isClosed[BinLedger] (InRevaluationBinLedger ledger) += isClosed(revaluationDetail(ledger));
stock[BinLedger] (InRevaluationBinLedger ledger) += stock(revaluationDetail(ledger));
outDepartment[BinLedger] (InRevaluationBinLedger ledger) += department(revaluationDetail(ledger));
description[BinLedger] (InRevaluationBinLedger ledger) += description(revaluationDetail(ledger));
sku[BinLedger] (InRevaluationBinLedger ledger) += sku(revaluationDetail(ledger));
batch[BinLedger] (InRevaluationBinLedger ledger) += batch(revaluationDetail(ledger));
sum[BinLedger] (InRevaluationBinLedger ledger) += abs(diffSum(revaluationDetail(ledger)));
edit[BinLedger](InRevaluationBinLedger ledger) + {edit(revaluationDetail(ledger));}
show[BinLedger](InRevaluationBinLedger ledger) + {show(revaluationDetail(ledger));}