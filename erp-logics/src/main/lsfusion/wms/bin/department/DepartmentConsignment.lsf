MODULE DepartmentConsignment;

REQUIRE Consignment, DepartmentBin;

NAMESPACE Consignment;

outDepartment = ABSTRACT Department (Consignment);
outDepartment = ABSTRACT Department (ConsignmentDetail);
nameOutDepartment 'Отдел (из)' (Consignment c)  = name(outDepartment(c)) CHARWIDTH 20;
addressOutDepartment(Consignment c) = address(outDepartment(c)) CHARWIDTH 20;
nameOutDepartment 'Отдел (из)' (ConsignmentDetail d)  = name(outDepartment(d)) CHARWIDTH 20;
addressOutDepartment(ConsignmentDetail d) = address(outDepartment(d)) CHARWIDTH 20;

inDepartment = ABSTRACT Department (Consignment);  
inDepartment = ABSTRACT Department (ConsignmentDetail);
nameInDepartment 'Отдел (в)' (Consignment c)  = name(inDepartment(c)) CHARWIDTH 20;
addressInDepartment (Consignment c)  = address(inDepartment(c)) CHARWIDTH 20;
nameInDepartment 'Отдел (в)' (ConsignmentDetail d)  = name(inDepartment(d)) CHARWIDTH 20;
addressInDepartment (ConsignmentDetail d)  = address(inDepartment(d)) CHARWIDTH 20;

