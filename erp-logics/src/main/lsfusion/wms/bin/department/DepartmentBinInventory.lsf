MODULE DepartmentBinInventory;

REQUIRE DepartmentBin, BinInventoryBinLedger, Inventory, BinInventoryBinSkuLedger, StockDocumentBinLedger, 
        DepartmentBinLedger, BinInventoryBatchBinLedger;

NAMESPACE BinInventory;

needDepartment 'Отдел обязателен' = DATA BOOLEAN (Operation);

EXTEND FORM operation
    PROPERTIES(o) needDepartment
;

DESIGN operation {
    constraintContainer {
        caption = 'Ограничения';
        MOVE PROPERTY(needDepartment(o));
    }
}

department = DATA Department (BinInventory);
nameDepartment 'Отдел' (BinInventory binInventory) = name(department(binInventory)) CHARWIDTH 15;

CONSTRAINT stock(BinInventory binInventory) AND department(binInventory) AND NOT
    stock(binInventory) = stock(department(binInventory))
    CHECKED BY department[BinInventory]
    MESSAGE 'Cклад и отдел для инвентаризации не имеют связи';

CONSTRAINT (CHANGED(operation(BinInventory binInventory)) OR CHANGED(department(binInventory))) AND NOT 
    department(binInventory) AND needDepartment(operation(binInventory))
    MESSAGE 'Отдел обязателен для заданной операции инвентаризации';

changeDepartment(BinInventory o) {
    DIALOG dialogDepartments OBJECTS d INPUT NULL FILTERS stock(d) = stock(o) DO {
        department(o) <- d;
        IF NOT stock(o) THEN stock(o) <- stock(d);
    }
}

EXTEND FORM binInventory
    PROPERTIES nameDepartment(i) ON CHANGE changeDepartment(i)
    
    FILTERS parentDepartment(ilbg)==department(i) OR ilbg IS StockBinGroup
    FILTERS parentDepartment(olbg)==department(i) OR olbg IS StockBinGroup
;

DESIGN binInventory {
    topRow2 {
        MOVE PROPERTY(nameDepartment(i)) AFTER PROPERTY(nameStock(i));
    }
}

EXTEND FORM binInventories 
    PROPERTIES(i) READONLY nameDepartment AFTER nameStock(i)
;

department(ListBinInventory li) = department(binInventory(li));
nameDepartment 'Отдел' (ListBinInventory li) = name(department(li)) CHARWIDTH 30;

department(InListBinInventoryDetail d) = department(binInventory(listBinInventory(d)));
nameDepartment 'Отдел' = name(department(InListBinInventoryDetail d)) CHARWIDTH 30;

department(OutListBinInventoryDetail d) = department(binInventory(listBinInventory(d)));
nameDepartment 'Отдел' = name(department(OutListBinInventoryDetail d)) CHARWIDTH 30;

binDepartment 'Ячейки должны принадлежать отделу' = DATA BOOLEAN (Operation);

EXTEND FORM operation
    PROPERTIES(o) binDepartment
;

DESIGN operation {
    constraintContainer {
        MOVE PROPERTY(binDepartment(o));
    }
}

overExtraOutBinFilter(Bin b, BinInventory i) += department(i)==department(b);
needExtraOutBinFilter(Bin b, BinInventory i) += department(i) AND binDepartment(operation(i)) AND b IS Bin;

overExtraOutBinFilter(Sku sku, BinInventory i) += TRUE IF currentBalance(sku, department(i));
needExtraOutBinFilter(Sku sku, BinInventory i) += department(i) AND binDepartment(operation(i)) AND sku IS Sku;

overExtraOutBinFilter(Batch batch, BinInventory i) += TRUE IF currentBalance(batch, department(i));
needExtraOutBinFilter(Batch batch, BinInventory i) += department(i) AND binDepartment(operation(i)) AND batch IS Batch;

CONSTRAINT (CHANGED(operation(InListBinInventoryDetail d)) OR CHANGED(department(d))) AND 
    binDepartment(operation(d)) AND bin(d) AND NOT department(bin(d))==department(d) 
    MESSAGE 'Отдел строки описи должен совпадать с отделом инвентаризации';

CONSTRAINT (CHANGED(operation(OutListBinInventoryDetail d)) OR CHANGED(department(d))) AND
    binDepartment(operation(d)) AND bin(d) AND NOT department(bin(d))==department(d)
    MESSAGE 'Отдел строки описи должен совпадать с отделом инвентаризации';

inventoryCommittee = DATA InventoryCommittee (Department);
nameInventoryCommittee 'Комиссия инвентаризации отдела' (Department department) = name(inventoryCommittee(department)) IN committee;
is 'По умолчанию' (InventoryCommittee committee, Department department) = inventoryCommittee(department) == committee;
inInventoryCommittee (Department department, Employee employee) = in(inventoryCommittee(department), employee);
nameEmployeInventoryCommittee 'Члены комиссии' (Department department) = namePositionEmployee(inventoryCommittee(department));
shortNameEmployeeInventoryCommittee 'Члены комиссии' (Department department) = shortNamePositionEmployee(inventoryCommittee(department));
nameChairmanInventoryCommittee 'Председатель комиссии' (Department department) = nameChairman(inventoryCommittee(department));
shortNameChairmanInventoryCommittee 'Председатель комиссии' (Department department) = shortNameChairman(inventoryCommittee(department));
namePositionChairmanInventoryCommittee 'Должность' (Department department) = namePositionChairman(inventoryCommittee(department));
CONSTRAINT inventoryCommittee(Department department) AND NOT in(inventoryCommittee(department), stock(department))
    CHECKED BY inventoryCommittee[Department] MESSAGE 'Для отдела выбрана комиссия, которая для него не действует';

EXTEND FORM department
    PROPERTIES(d) nameInventoryCommittee
;

EXTEND FORM departments
    PROPERTIES(d) READONLY nameInventoryCommittee
;

committee (BinInventory binInventory) <- inventoryCommittee(department(binInventory))
    WHEN CHANGED(department(binInventory));

//---------------------------- Проведение по StockDocumentBinLedger----------------------------//

CLASS OutBinInventorySDBinLedger 'Инвентаризация (расход)' : OutStockDocumentBinLedger; ////BinInventoryStockDocumentBinLedger
CLASS IncBinInventorySDBinLedger 'Инвентаризация (приход)' : IncStockDocumentBinLedger;
CLASS OutRoundingBinInventorySDBinLedger 'Инвентаризация (расход, округления)' : OutStockDocumentBinLedger;
CLASS IncRoundingBinInventorySDBinLedger 'Инвентаризация (приход, округления)' : IncStockDocumentBinLedger;

needToStockDocumentBinLedger(BinInventory binInventory) =
    createSkuLedger(binInventory) AND isPosted(binInventory);

needToOutBinInventorySDBinLedger(BinInventory binInventory) =
    needToStockDocumentBinLedger(binInventory) AND
    (mainSumItemShortage(binInventory) > 0 OR mainSumContainerShortage(binInventory) > 0);

needToIncBinInventorySDBinLedger(BinInventory binInventory) =
    needToStockDocumentBinLedger(binInventory) AND
    (mainSumItemShortage(binInventory) < 0 OR mainSumContainerShortage(binInventory) < 0);

needToOutRoundingBinInventorySDBinLedger(BinInventory binInventory) =
    needToStockDocumentBinLedger(binInventory) AND splitRoundingBinInventoryLedger(binInventory) AND
    (sumItemRoundingShortage(binInventory) > 0 OR sumContainerRoundingShortage(binInventory) > 0);

needToIncRoundingBinInventorySDBinLedger(BinInventory binInventory) =
    needToStockDocumentBinLedger(binInventory) AND splitRoundingBinInventoryLedger(binInventory) AND
    (sumItemRoundingShortage(binInventory) < 0 OR sumContainerRoundingShortage(binInventory) < 0);

outBinInventorySDBinLedger = AGGR OutBinInventorySDBinLedger WHERE needToOutBinInventorySDBinLedger(BinInventory binInventory) MATERIALIZED INDEXED;
incBinInventorySDBinLedger = AGGR IncBinInventorySDBinLedger WHERE needToIncBinInventorySDBinLedger(BinInventory binInventory) MATERIALIZED INDEXED;
outRoundingBinInventorySDBinLedger = AGGR OutRoundingBinInventorySDBinLedger WHERE needToOutRoundingBinInventorySDBinLedger(BinInventory binInventory) MATERIALIZED INDEXED;
incRoundingBinInventorySDBinLedger = AGGR IncRoundingBinInventorySDBinLedger WHERE needToIncRoundingBinInventorySDBinLedger(BinInventory binInventory) MATERIALIZED INDEXED;

META implBinInventorySDBinLedger(ledgerClass)
    series[StockDocumentBinLedger] (ledgerClass ledger) += series(binInventory(ledger));
    number[StockDocumentBinLedger] (ledgerClass ledger) += number(binInventory(ledger));
    dateTime[StockDocumentBinLedger] (ledgerClass ledger) += dateTime(binInventory(ledger));
    isPosted[StockDocumentBinLedger] (ledgerClass ledger) += isPosted(binInventory(ledger));
    isClosed[StockDocumentBinLedger] (ledgerClass ledger) += isClosed(binInventory(ledger));
    stock[StockDocumentBinLedger] (ledgerClass ledger) += stock(binInventory(ledger));
    description[StockDocumentBinLedger] (ledgerClass ledger) += STRING[200](description(binInventory(ledger)));
    operation[StockDocumentBinLedger] (ledgerClass ledger) += operation(binInventory(ledger));
    department[StockDocumentBinLedger] (ledgerClass ledger) += department(binInventory(ledger));
    skip[StockDocumentBinLedger] (ledgerClass ledger) += ledger IS ledgerClass AND NOT department(ledger);
END

@implBinInventorySDBinLedger(OutBinInventorySDBinLedger);
@implBinInventorySDBinLedger(IncBinInventorySDBinLedger);
@implBinInventorySDBinLedger(OutRoundingBinInventorySDBinLedger);
@implBinInventorySDBinLedger(IncRoundingBinInventorySDBinLedger);

sumItem[OutStockDocumentBinLedger]      (OutBinInventorySDBinLedger ledger) += mainSumItemShortage(binInventory(ledger)) IF mainSumItemShortage(binInventory(ledger)) > 0;
sumContainer[OutStockDocumentBinLedger] (OutBinInventorySDBinLedger ledger) += mainSumContainerShortage(binInventory(ledger)) IF mainSumContainerShortage(binInventory(ledger)) > 0;

sumItem[IncStockDocumentBinLedger]      (IncBinInventorySDBinLedger ledger) += -mainSumItemShortage(binInventory(ledger)) IF mainSumItemShortage(binInventory(ledger)) < 0;
sumContainer[IncStockDocumentBinLedger] (IncBinInventorySDBinLedger ledger) += -mainSumContainerShortage(binInventory(ledger)) IF mainSumContainerShortage(binInventory(ledger)) < 0;

sumItem[OutStockDocumentBinLedger]      (OutRoundingBinInventorySDBinLedger ledger) += sumItemRoundingShortage(binInventory(ledger)) IF sumItemRoundingShortage(binInventory(ledger)) > 0;
sumContainer[OutStockDocumentBinLedger] (OutRoundingBinInventorySDBinLedger ledger) += sumContainerRoundingShortage(binInventory(ledger)) IF sumContainerRoundingShortage(binInventory(ledger)) > 0;

sumItem[IncStockDocumentBinLedger]      (IncRoundingBinInventorySDBinLedger ledger) += -sumItemRoundingShortage(binInventory(ledger)) IF sumItemRoundingShortage(binInventory(ledger)) < 0;
sumContainer[IncStockDocumentBinLedger] (IncRoundingBinInventorySDBinLedger ledger) += -sumContainerRoundingShortage(binInventory(ledger)) IF sumContainerRoundingShortage(binInventory(ledger)) < 0;

isResponsiblePerson 'Материально ответственное лицо' = DATA BOOLEAN (Department, Employee);
orderResponsiblePerson 'Порядок отображения в печатной форме' = DATA INTEGER (Department, Employee);

WHEN DROPPED(isResponsiblePerson(Department d, Employee e)) DO {
    orderResponsiblePerson(d, e) <- NULL;
}

CONSTRAINT isResponsiblePerson(Department d, Employee e) AND NOT accessCompany(e, d)
    MESSAGE 'У материально-ответственного лица должен быть доступ к отделу';

namePositionResponsiblies 'МОЛ(ы)' (Department stock) = (GROUP
    CONCAT positionName(Employee employee) IF isResponsiblePerson(stock, employee), ', '
    ORDER employee)
    CHARWIDTH 50;

shortNamePositionResponsiblies 'МОЛ(ы)' (Department stock) = (GROUP
    CONCAT positionShortName(Employee employee) IF isResponsiblePerson(stock, employee), ', '
    ORDER employee)
    CHARWIDTH 50;

nameResponsiblies 'МОЛ(ы)' (Department stock) = (GROUP
    CONCAT name[Contact](Employee employee) IF isResponsiblePerson(stock, employee), ', '
    ORDER employee)
    CHARWIDTH 50;

shortNameResponsiblies 'МОЛ(ы)' (Department stock) = (GROUP
    CONCAT shortName(Employee employee) IF isResponsiblePerson(stock, employee), ', '
    ORDER employee)
    CHARWIDTH 50;

nameResponsibliesDepartment 'Материально-ответственные лица' (ListBinInventory li) = nameResponsiblies(department(li)) IN inventoryCommittee CHARWIDTH 30;

EXTEND FORM department
    OBJECTS e = Employee GRID
    PROPERTIES(e) READONLY firstName, lastName
    PROPERTIES(d,e) isResponsiblePerson, orderResponsiblePerson
    ORDERS lastName(e)
    FILTERGROUP active
        FILTER 'Активные' active(e) DEFAULT
    FILTERGROUP isResponsiblePerson
        FILTER 'Материально-ответственные лица' isResponsiblePerson(d, e)
    FILTERGROUP accessCompany 
        FILTER 'Доступ разрешен к отделу' accessCompany(e,d)
;

DESIGN department {
    tabContainer {
        fill = 1;
        MOVE BOX(e) {
            caption = 'Материально-ответственные лица';
        };
    }
}

EXTEND FORM employee
    PROPERTIES isResponsiblePerson(department, e)
;

inspector = DATA Employee (BinInventory);
namePositionInspector 'Должность' (BinInventory i) = namePosition(inspector(i))  CHARWIDTH 50;
shortNamePositionInspector 'Проверил' (BinInventory i) = positionShortName(inspector(i))  CHARWIDTH 50;
nameInspector 'Проверил' (BinInventory i) = name(inspector(i))  CHARWIDTH 50;
shortNameInspector 'Проверил' (BinInventory i) = shortName(inspector(i))  CHARWIDTH 50;

isResponsiblePerson 'Материально ответственное лицо' = DATA BOOLEAN (BinInventory, Employee);
orderResponsiblePerson 'Порядок отображения в печатной форме' = DATA INTEGER (BinInventory, Employee);

WHEN LOCAL CHANGED(department(BinInventory binInventory)) DO {
    isResponsiblePerson (binInventory, Employee e) <- isResponsiblePerson(department(binInventory), e) AND active(e);
    orderResponsiblePerson(binInventory, Employee e) <- orderResponsiblePerson(department(binInventory), e) IF isResponsiblePerson(department(binInventory), e);
}

namePositionResponsiblies 'МОЛ(ы)' (BinInventory binInventory) = (GROUP
    CONCAT positionName(Employee employee) IF isResponsiblePerson(binInventory, employee), ', '
    ORDER employee)
    CHARWIDTH 50;

shortNamePositionResponsiblies 'МОЛ(ы)' (BinInventory binInventory) = (GROUP
    CONCAT positionShortName(Employee employee) IF isResponsiblePerson(binInventory, employee), ', '
    ORDER employee)
    CHARWIDTH 50;

nameResponsiblies 'МОЛ(ы)' (BinInventory binInventory) = (GROUP
    CONCAT name[Contact](Employee employee) IF isResponsiblePerson(binInventory, employee), ', '
    ORDER employee)
    CHARWIDTH 50;

shortNameResponsiblies 'МОЛ(ы)' (BinInventory binInventory) = (GROUP
    CONCAT shortName(Employee employee) IF isResponsiblePerson(binInventory, employee), ', '
    ORDER employee)
    CHARWIDTH 50;

firstShortNameResponsiblies 'МОЛ(ы)' (BinInventory binInventory) = (GROUP
    CONCAT firstShortName(Employee employee) IF isResponsiblePerson(binInventory, employee), ', '
    ORDER employee)
    CHARWIDTH 50;

CONSTRAINT SET(isResponsiblePerson(BinInventory i, Employee e)) AND NOT PREV(accessCompany(e,department(i)))
    MESSAGE 'У материально-ответственного лица должен быть доступ к отделу инвентаризации';

FORM dialogBinInventoryResponsiblePerson 'Материально-ответственные лица'
    OBJECTS i = BinInventory PANEL
    PROPERTIES READONLY nameDepartment(i)
    OBJECTS e =Employee
    PROPERTIES(i, e) isResponsiblePerson, orderResponsiblePerson
    PROPERTIES READONLY name(e), namePosition(e), accessCompany 'Доступ разрешен (компания)' =accessCompany(e, department(i))
    FILTERGROUP active FILTER 'Активные' active(e) 'F6'  DEFAULT
    FILTERGROUP accessCompany 
        FILTER 'Доступ разрешен' accessCompany(e,department(i)) DEFAULT
        FILTER 'Материально-ответственные лица склада' isResponsiblePerson(department(i), e)
    FILTERGROUP isSelected 
        FILTER 'Выбранные' isResponsiblePerson(i,e)
    
;    

changeResponsiblePerson 'Изменить материально-ответственных' (BinInventory i1) {
    NEWSESSION {
        DIALOG dialogBinInventoryResponsiblePerson OBJECTS i = i1 DO {
            IF (GROUP MAX isResponsiblePerson(i1, Employee e) IF NOT PREV(isResponsiblePerson(i1, e)))
                OR (GROUP MAX PREV(isResponsiblePerson(i1, Employee e)) IF NOT isResponsiblePerson(i1, e)) THEN APPLY;
        }
    }
} TOOLBAR;

EXTEND FORM binInventory
    PROPERTIES nameInspector(i)
    OBJECTS eResponsible = Employee
    PROPERTIES(eResponsible) READONLY name, namePosition
    PROPERTIES READONLY orderResponsiblePerson(i, eResponsible)
    PROPERTIES changeResponsiblePerson(i) DRAW eResponsible
    ORDERS orderResponsiblePerson(i, eResponsible)
    FILTERS isResponsiblePerson(i, eResponsible)
;    

DESIGN binInventory {
    tabbedContainer {
        NEW responsibliesContainer LAST {
            caption = 'Материально-ответственные лица и проверяющие';
            NEW responsibliesContainerHead {
                horizontal = TRUE;
                MOVE PROPERTY(nameInspector(i));
            }
            MOVE BOX (eResponsible);
        }
    }
}

isResponsiblePerson 'Материально ответственное лицо' (ListBinInventory l, Employee e) = isResponsiblePerson(binInventory(l), e);
orderResponsiblePerson 'Материально ответственное лицо' (ListBinInventory l, Employee e) = orderResponsiblePerson(binInventory(l), e);
namePositionResponsiblies 'Материально-ответственные лица' (ListBinInventory li) = namePositionResponsiblies(binInventory(li)) IN inventoryCommittee CHARWIDTH 30;
shortNamePositionResponsiblies 'Материально-ответственные лица' (ListBinInventory li) = shortNamePositionResponsiblies(binInventory(li)) IN inventoryCommittee CHARWIDTH 30;
nameResponsiblies 'Материально-ответственные лица' (ListBinInventory li) = nameResponsiblies(binInventory(li)) IN inventoryCommittee CHARWIDTH 30;
shortNameResponsiblies 'Материально-ответственные лица' (ListBinInventory li) = shortNameResponsiblies(binInventory(li)) IN inventoryCommittee CHARWIDTH 30;
firstShortNameResponsiblies 'Материально-ответственные лица' (ListBinInventory li) = firstShortNameResponsiblies(binInventory(li)) IN inventoryCommittee CHARWIDTH 30;

price 'Цена' = DATA NUMERIC[18,4] (InListBinInventoryDetail) CHARWIDTH 7;
price 'Цена' = DATA NUMERIC[18,4] (OutListBinInventoryDetail) CHARWIDTH 7;

sum '{document.sum.of}' = DATA NUMERIC[18,4] (InListBinInventoryDetail) CHARWIDTH 7;
sumInListBinInventoryDetail '{document.sum.of}' (ListBinInventory l) = GROUP SUM sum(InListBinInventoryDetail d) BY listBinInventory(d) CHARWIDTH 7;

sum '{document.sum.of}' = DATA NUMERIC[18,4] (OutListBinInventoryDetail) CHARWIDTH 7;
sumOutListBinInventoryDetail '{document.sum.of}' (ListBinInventory l) = GROUP SUM sum(OutListBinInventoryDetail d) BY listBinInventory(d) CHARWIDTH 7;

diffRoundSum 'Разница округления' (InListBinInventoryDetail ilid) = price(ilid)*quantity(ilid) (-) sum(ilid);
diffRoundSum 'Разница округления' (OutListBinInventoryDetail ilid) = price(ilid)*quantity(ilid) (-) sum(ilid);

overCreateInListBinInventoryDetail (InListBinInventoryDetail ilid, OutListBinInventoryDetail olid) + {
    price(ilid) <- price(olid);
    sum(ilid) <- sum(olid);
}

overFillOutListBinInventoryDetail(OutListBinInventoryDetail olid, Batch batch, Bin bin) + {
    price(olid) <- prevAccountPriceA(batch, stock(bin), dateTime(olid));
    sum(olid) <- NUMERIC[18,4](Utils.round(quantity(olid) * price(olid), priceRound(binInventory(olid))));
}

overChangeQuantity(InListBinInventoryDetail l) + {
    sum(l) <- NUMERIC[18,4](Utils.round(quantity(l) * price(l), priceRound(binInventory(l))));
}

inDepartment[BinLedger] (InListBinInventoryDetail ledger) += department(ledger);
outDepartment[BinLedger] (OutListBinInventoryDetail ledger) += department(ledger);

sum[BinLedger] (InListBinInventoryDetail ledger) += sum(ledger);
sum[BinLedger] (OutListBinInventoryDetail ledger) += sum(ledger);

EXTEND FORM binInventory
    PROPERTIES(ilid) READONLY price, sum, diffRoundSum
    PROPERTIES(olid) READONLY price, sum, diffRoundSum
;

WHEN SET(isPosted(BinInventory i)) DO {
    ASK 'Выставить дату закрытия документов равную дате инвентаризации' DO {
        documentsClosedDate(department(i)) <- date(i);
    } 
}

WHEN CHANGED(department(BinInventory o)) AND o IS BinInventory AND NOT SET(o IS BinInventory) AND NOT disableDocumentLog()  DO {
    NEW d = BinInventoryLog {
        documentId(d) <- LONG(o);
        typeDocument(d) <- objectClassName(o);
        numberDocument(d) <- number(o);
        seriesDocument(d) <- series(o);
        dateDocument(d) <- date(o);
        typeChange(d) <- TypeChange.departmentChange;
        note(d) <- STRING[255](CONCAT '','Предыдущее значение : ', name(PREV(department(o))));
        hostnameComputer(d) <- hostnameCurrentComputer();
        userLogin(d) <- login(currentUser());
        nameContact(d) <- STRING[100](name(currentUser()));
        dateTimeSession(d) <- currentDateTime();
        stock(d) <- stock(o);
    }
}

WHEN SET(InListBinInventoryDetail d IS InListBinInventoryDetail) AND NOT disableDocumentLog() DO
    NEW l = InListBinInventoryDetailLog {
        documentId(l) <- LONG (binInventory(d));
        index(l) <- index(d);
        numberDocument(l) <- number(binInventory(d));
        seriesDocument(l) <- series(binInventory(d));
        dateDocument(l) <- date(binInventory(d));
        typeDocument(l) <- objectClassName(binInventory(d));
        listBinInventory(l) <- listBinInventory(d);
        sku(l) <- sku(d);
        batch(l) <- CONCAT ', ', 'Код: ' + id(batch(d)), ' Наименование: ' + name(batch(d));
        prevQuantity(l) <- quantity(d);
        quantity(l) <- quantity(d);
        price(l) <- price(d);
        nameUser(l) <- ISTRING[100](name(currentUser()));
        dateTime(l) <- currentDateTime();
        noteL(l) <- 'Добавление';
    }

WHEN DROPPED(InListBinInventoryDetail d IS InListBinInventoryDetail) AND NOT disableDocumentLog() DO
    NEW l = InListBinInventoryDetailLog{
        documentId(l) <- LONG(PREV(binInventory(d)));
        index(l) <- PREV(index(d));
        numberDocument(l) <- number(PREV(binInventory(d)));
        seriesDocument(l) <- series(PREV(binInventory(d)));
        dateDocument(l) <- date(PREV(binInventory(d)));
        typeDocument(l) <- objectClassName(PREV(binInventory(d)));
        listBinInventory(l) <- PREV(listBinInventory(d));
        sku(l) <- PREV(sku(d));
        batch(l) <- CONCAT ', ', 'Код: ' + id(PREV(batch(d))), ' Наименование: ' + name(PREV(batch(d)));
        prevQuantity(l) <- PREV(quantity(d));
        quantity(l) <- PREV(quantity(d));
        price(l) <- PREV(price(d));
        nameUser(l) <- ISTRING[100](name(currentUser()));
        dateTime(l) <- currentDateTime();
        noteL(l) <- 'Удаление';
    }

WHEN (CHANGED(quantity(InListBinInventoryDetail d))) AND NOT DROPPED(d IS InListBinInventoryDetail) AND NOT SET(d IS InListBinInventoryDetail) AND NOT disableDocumentLog() DO
    NEW l = InListBinInventoryDetailLog{
        documentId(l) <- LONG (binInventory(d));
        index(l) <- index(d);
        numberDocument(l) <- number(binInventory(d));
        seriesDocument(l) <- series(binInventory(d));
        dateDocument(l) <- date(binInventory(d));
        typeDocument(l) <- objectClassName(binInventory(d));
        listBinInventory(l) <- listBinInventory(d);
        sku(l) <- sku(d);
        batch(l) <- CONCAT ', ', 'Код: ' + id(batch(d)), ' Наименование: ' + name(batch(d));
        prevQuantity(l) <- PREV(quantity(d));
        quantity(l) <- quantity(d);
        price(l) <- price(d);
        nameUser(l) <- ISTRING[100](name(currentUser()));
        dateTime(l) <- currentDateTime();
        noteL(l) <- 'Изменение кол-ва. ' + (CONCAT '','Предыдущее значение : ', PREV(quantity(d)));
    }

WHEN (CHANGED(batch(InListBinInventoryDetail d))) AND NOT DROPPED(d IS InListBinInventoryDetail) AND NOT SET(d IS InListBinInventoryDetail) AND NOT disableDocumentLog() DO
    NEW l = InListBinInventoryDetailLog{
        documentId(l) <- LONG (binInventory(d));
        index(l) <- index(d);
        numberDocument(l) <- number(binInventory(d));
        seriesDocument(l) <- series(binInventory(d));
        dateDocument(l) <- date(binInventory(d));
        typeDocument(l) <- objectClassName(binInventory(d));
        listBinInventory(l) <- listBinInventory(d);
        sku(l) <- sku(d);
        batch(l) <- CONCAT ', ', 'Код: ' + id(batch(d)), ' Наименование: ' + name(batch(d));
        prevQuantity(l) <- PREV(quantity(d));
        quantity(l) <- quantity(d);
        price(l) <- price(d);
        nameUser(l) <- ISTRING[100](name(currentUser()));
        dateTime(l) <- currentDateTime();
        noteL(l) <- 'Изменение партии. ' + (CONCAT '','Предыдущее значение : ', name(PREV(batch(d))));
    }