MODULE DepartmentBinInventory;

REQUIRE DepartmentBin, BinInventoryBinLedger, Inventory, BinInventoryBinSkuLedger, StockDocumentBinLedger;

NAMESPACE BinInventory;

needDepartment 'Отдел обязателен' = DATA BOOLEAN (Operation);

EXTEND FORM operation
    PROPERTIES(o) needDepartment
;

DESIGN operation {
    constraintContainer {
        caption = 'Ограничения';
        MOVE PROPERTY(needDepartment(o));
    }
}

department = DATA Department (BinInventory);
nameDepartment 'Отдел' (BinInventory binInventory) = name(department(binInventory)) CHARWIDTH 15;

CONSTRAINT stock(BinInventory binInventory) AND department(binInventory) AND NOT
    stock(binInventory) = stock(department(binInventory))
    CHECKED BY department[BinInventory]
    MESSAGE 'Cклад и отдел для инвентаризации не имеют связи';

CONSTRAINT (CHANGED(operation(BinInventory binInventory)) OR CHANGED(department(binInventory))) AND NOT 
    department(binInventory) AND needDepartment(operation(binInventory))
    MESSAGE 'Отдел обязателен для заданной операции инвентаризации';

changeDepartment(BinInventory o) {
    DIALOG dialogDepartments OBJECTS d INPUT NULL FILTERS stock(d) = stock(o) DO {
        department(o) <- d;
        IF NOT stock(o) THEN stock(o) <- stock(d);
    }
}

EXTEND FORM binInventory
    PROPERTIES nameDepartment(i) ON CHANGE changeDepartment(i)
;

DESIGN binInventory {
    topRow2 {
        MOVE PROPERTY(nameDepartment(i)) AFTER PROPERTY(nameStock(i));
    }
}

EXTEND FORM binInventories 
    PROPERTIES(i) READONLY nameDepartment AFTER nameStock(i)
;

binDepartment 'Ячейки должны принадлежать отделу' = DATA BOOLEAN (Operation);

EXTEND FORM operation
    PROPERTIES(o) binDepartment
;

DESIGN operation {
    constraintContainer {
        MOVE PROPERTY(binDepartment(o));
    }
}

overExtraOutBinFilter(Bin b, BinInventory i) += department(i)==department(b);
needExtraOutBinFilter(Bin b, BinInventory i) += department(i) AND binDepartment(operation(i)) AND b IS Bin;

inventoryCommittee = DATA InventoryCommittee (Department);
nameInventoryCommittee 'Комиссия инвентаризации отдела' (Department department) = name(inventoryCommittee(department)) IN committee;
is 'По умолчанию' (InventoryCommittee committee, Department department) = inventoryCommittee(department) == committee;
inInventoryCommittee (Department department, Employee employee) = in(inventoryCommittee(department), employee);
nameEmployeInventoryCommittee 'Члены комиссии' (Department department) = namePositionEmployee(inventoryCommittee(department));
shortNameEmployeeInventoryCommittee 'Члены комиссии' (Department department) = shortNamePositionEmployee(inventoryCommittee(department));
nameChairmanInventoryCommittee 'Председатель комиссии' (Department department) = nameChairman(inventoryCommittee(department));
shortNameChairmanInventoryCommittee 'Председатель комиссии' (Department department) = shortNameChairman(inventoryCommittee(department));
namePositionChairmanInventoryCommittee 'Должность' (Department department) = namePositionChairman(inventoryCommittee(department));
CONSTRAINT inventoryCommittee(Department department) AND NOT in(inventoryCommittee(department), stock(department))
    CHECKED BY inventoryCommittee[Department] MESSAGE 'Для отдела выбрана комиссия, которая для него не действует';

EXTEND FORM department
    PROPERTIES(d) nameInventoryCommittee
;

EXTEND FORM departments
    PROPERTIES(d) READONLY nameInventoryCommittee
;

committee (BinInventory binInventory) <- inventoryCommittee(department(binInventory))
    WHEN CHANGED(department(binInventory));

//---------------------------- Проведение по StockDocumentBinLedger----------------------------//

CLASS BinInventorySDBinLedger 'Инвентаризация' : OutStockDocumentBinLedger; ////BinInventoryStockDocumentBinLedger

needToStockDocumentBinLedger(BinInventory binInventory) =
    createSkuLedger(binInventory) AND isPosted(binInventory);

binInventorySDBinLedger = AGGR BinInventorySDBinLedger WHERE needToStockDocumentBinLedger(BinInventory binInventory) MATERIALIZED INDEXED;

series[OutStockDocumentBinLedger] (BinInventorySDBinLedger ledger) += series(binInventory(ledger));
number[OutStockDocumentBinLedger] (BinInventorySDBinLedger ledger) += number(binInventory(ledger));
dateTime[OutStockDocumentBinLedger] (BinInventorySDBinLedger ledger) += dateTime(binInventory(ledger));
isPosted[OutStockDocumentBinLedger] (BinInventorySDBinLedger ledger) += isPosted(binInventory(ledger));
isClosed[OutStockDocumentBinLedger] (BinInventorySDBinLedger ledger) += isClosed(binInventory(ledger));
stock[OutStockDocumentBinLedger] (BinInventorySDBinLedger ledger) += stock(binInventory(ledger));
description[OutStockDocumentBinLedger] (BinInventorySDBinLedger ledger) += STRING[200](description(binInventory(ledger)));
sumItem[OutStockDocumentBinLedger](BinInventorySDBinLedger ledger) += -sumItemShortage(binInventory(ledger));
sumContainer[OutStockDocumentBinLedger] (BinInventorySDBinLedger ledger) += -sumContainerShortage(binInventory(ledger));
operation[StockDocumentBinLedger](BinInventorySDBinLedger ledger) += operation(binInventory(ledger));
department[StockDocumentBinLedger] (BinInventorySDBinLedger ledger) += department(binInventory(ledger));
skip[StockDocumentBinLedger] (BinInventorySDBinLedger ledger) += ledger IS BinInventorySDBinLedger AND NOT department(ledger);