MODULE DepartmentSaleLedger;

REQUIRE SaleLedger, DepartmentBin;

NAMESPACE SaleLedger;

department = ABSTRACT Department (SaleLedger) MATERIALIZED INDEXED;
nameDepartment 'Отдел' (SaleLedger ledger) = name(department(ledger)) CHARWIDTH 20;

EXTEND FORM saleLedger
    PROPERTIES READONLY nameDepartment(s) AFTER nameStock(s)
;
