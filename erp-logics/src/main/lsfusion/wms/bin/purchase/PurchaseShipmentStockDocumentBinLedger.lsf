MODULE PurchaseShipmentStockDocumentBinLedger;

REQUIRE PurchaseShipmentBinLedger, StockDocumentBinLedger;

NAMESPACE Purchase;

@defineStockDocumentBinLedgerOperationProperty(Purchase, 'Проводить приход по ТО подразделений');

@defineStockDocumentBinLedgerOp (inc, shipment, 'Поставка закупка (приход)', customerStock, binGroup2, inBin);
legalEntity[StockDocumentBinLedger] (IncSDShipmentBinLedger ledger) += supplier(shipment(ledger));
legalEntityStock[StockDocumentBinLedger] (IncSDShipmentBinLedger ledger) += supplierStock(shipment(ledger));

skip(IncSDShipmentBinLedger l) += (isCommission(invoice(shipment(l))) IF excludeCommission()) OR overSkipStockDocumentLedger(shipment(l));
