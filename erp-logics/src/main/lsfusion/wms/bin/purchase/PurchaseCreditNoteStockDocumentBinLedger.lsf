MODULE PurchaseCreditNoteStockDocumentBinLedger;

REQUIRE PurchaseCreditNoteBinLedger, PurchaseShipmentStockDocumentBinLedger, StockDocumentBinLedger, 
        DepartmentPurchaseCreditNoteBinLedger;

NAMESPACE Purchase;

@defineStockDocumentBinLedger (out, creditNote, 'Акт расхождения (расход)', customerStock, outDepartment);

legalEntity[StockDocumentBinLedger] (OutSDCreditNoteBinLedger ledger) += supplier(creditNote(ledger));
legalEntityStock[StockDocumentBinLedger] (OutSDCreditNoteBinLedger ledger) += supplierStock(creditNote(ledger));
