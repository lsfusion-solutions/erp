MODULE EmployeeBinDepartment;

REQUIRE EmployeeBin, BinSkuLedger, ReservedBinLedger, DepartmentBin;

NAMESPACE Bin;

limitAccessCompanyDepartments 'Ограничить доступ к отделам склада' = DATA BOOLEAN (Employee);

dataAccessCompany 'Доступ разрешен (компания)' = DATA BOOLEAN (Employee, Department);
accessCompany 'Доступ разрешен (компания)' (Employee e, Department department) =
    OVERRIDE dataAccessCompany(e, department),
        department IS Department AND e IS Employee AND NOT limitAccessCompanyDepartments(e) MATERIALIZED;

WHEN DROPPED(accessCompany(Employee e, stock(Department department))) DO {
    dataAccessCompany(e, department) <- NULL;    
}

WHEN SET(department(BinGroup binGroup)) DO {
    dataAccessCompany(Employee e, Department department) <- TRUE WHERE accessCompany(e, binGroup) AND department(binGroup)==department; 
}

EXTEND FORM employee
    OBJECTS department=Department
    PROPERTIES(e) limitAccessCompanyDepartments READONLYIF NOT limitAccess(e)
    PROPERTIES(department) READONLY id, order, name, nameStock
    PROPERTIES accessCompany(e, department) READONLYIF NOT accessCompany(e, stock(department))
    ORDERS order(department), name(department)
;

DESIGN employee {
    pane {
        NEW departmentContainer{
            caption = 'Отделы';
            MOVE PROPERTY(limitAccessCompanyDepartments(e));
            MOVE BOX(department);    
        }
    }
}    

filterDepartment  = DATA LOCAL NESTED Department ();
nameFilterDepartment 'Отдел' = name(filterDepartment()) CHARWIDTH 15;

changeFilterDepartment(Stock st) {
    DIALOG dialogDepartments OBJECTS d INPUT NULL FILTERS stock(d) = st DO  {
        filterDepartment() <- d;
    }
}

countAccessCompanyDepartments 'Кол-во доступных отделов (компания)' (Employee employee) =
    GROUP SUM 1 IF accessCompany(employee, Department department);
countAccessCompanyDepartments 'Кол-во доступных отделов (компания)' (Employee employee, Stock st) =
    GROUP SUM 1 IF accessCompany(employee, Department department) AND stock(department) = st;
defaultCompanyDepartment (Employee employee) =
    GROUP MIN Department department IF accessCompany(employee, department);
defaultCompanyDepartment (Employee employee, Stock st) =
    GROUP MIN Department department IF accessCompany(employee, department) AND stock(department) = st;

companyDepartments 'Отделы (компания)' (Employee employee) = ISTRING[2000](GROUP
    CONCAT name(Department department) IF accessCompany(employee, department), ', '
    ORDER name(department), department) CHARWIDTH 20;
companyDepartments 'Отделы (компания)' (Employee employee, Stock st) = ISTRING[2000](GROUP
    CONCAT name(Department department) IF accessCompany(employee, department) AND stock(department) = st, ', '
    ORDER name(department), department) CHARWIDTH 20;

dataBinZoneOld = DATA BinGroup (Employee) @@deprecated;
dataDepartment = DATA Department (Employee);
department (Employee e) = OVERRIDE dataDepartment(e), defaultCompanyDepartment(e) IF countAccessCompanyDepartments(e) == 1 MATERIALIZED;
idDepartment 'Основной отдел' (Employee e) = id(department(e));
nameDepartment 'Основной отдел' (Employee e) = name(department(e));

WHEN SETCHANGED(Department department = department(Employee e)) AND NOT accessCompany(e, department) DO {
    dataAccessCompany(e, department) <- TRUE;
}

CONSTRAINT Department department == dataDepartment(Employee e) AND NOT accessCompany(e, department) 
    CHECKED BY dataDepartment[Employee] MESSAGE 'Не разрешен доступ к отделу выбранного в качестве основного';

EXTEND FORM employees 
    PROPERTIES(e) READONLY nameDepartment
;

EXTEND FORM employee
    PROPERTIES nameDepartment(e) ON CHANGE {DIALOG dialogDepartments OBJECTS d=department(e) INPUT NULL DO {dataDepartment(e) <- d;}}
;

DESIGN employee {
    pane {
        departmentContainer {
            MOVE PROPERTY(nameDepartment(e)) BEFORE BOX(department);
        }
    }    
}

@extendFormFilterStockAccess(bg, dialogBinStock);
@extendFormFilterStockAccess(b, dialogBinStock);