MODULE WriteOffStockDocumentBinLedger;

REQUIRE WriteOffBinLedger, StockDocumentBinLedger, DepartmentWriteOffBinLedger;

NAMESPACE WriteOff;

@defineStockDocumentBinLedger (out, writeOff, 'Списание (расход)', stock, department);

skip[StockDocumentBinLedger](OutSDWriteOffBinLedger ledger) += skipStockDocumentLedger(writeOff(ledger));
