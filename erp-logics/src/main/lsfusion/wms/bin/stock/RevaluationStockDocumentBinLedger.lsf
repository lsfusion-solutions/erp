MODULE RevaluationStockDocumentBinLedger;

REQUIRE Revaluation, BinLedger, StockDocumentBinLedger, DepartmentRevaluationBinLedger;

NAMESPACE Revaluation;

EXTEND CLASS Revaluation : OutStockDocumentBinLedger;
// Проведение по товарному отчету
series[StockDocumentBinLedger] (Revaluation ledger) += series(ledger);
number[StockDocumentBinLedger] (Revaluation ledger) += number(ledger);
dateTime[StockDocumentBinLedger] (Revaluation ledger) += dateTime(ledger);
isPosted[StockDocumentBinLedger] (Revaluation ledger) += isPosted(ledger);
isClosed[StockDocumentBinLedger] (Revaluation ledger) += isClosed(ledger);
stock[StockDocumentBinLedger] (Revaluation ledger) += stock(ledger);
description[StockDocumentBinLedger] (Revaluation ledger) += STRING[200](description(ledger));

sumItem[OutStockDocumentBinLedger](Revaluation ledger) += -diffSumRevaluationDetail(ledger);
sumContainer[OutStockDocumentBinLedger] (Revaluation ledger) += 0.0 IF ledger IS Revaluation;

operation[StockDocumentBinLedger](Revaluation ledger) += operation(ledger);

department[StockDocumentBinLedger] (Revaluation ledger) += department(ledger);

skip[StockDocumentBinLedger] (Revaluation ledger) += ledger IS Revaluation AND NOT department(ledger);
