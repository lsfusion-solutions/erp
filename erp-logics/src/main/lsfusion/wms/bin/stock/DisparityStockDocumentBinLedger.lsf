MODULE DisparityStockDocumentBinLedger;

REQUIRE DisparityBinLedger, BinLedger, StockDocumentBinLedger;

NAMESPACE Disparity;

@defineStockDocumentBinLedgerAggregation (out, disparity, 'Изменение сортности (расход)', binGroup2, bin);
@implementStockDocumentBinLedger(out, disparity, stock);

skip[StockDocumentBinLedger](OutSDDisparityBinLedger ledger) += disparity(ledger) IS Disparity AND notConduct(disparity(ledger));

diffSumItemDisparityDetail 'Сумма, товар' (Disparity disparity, BinGroup g) =
    GROUP
        SUM diffSum(DisparityDetail idetail) IF isItem(sku(idetail)) BY disparity(idetail), binGroup2(bin(idetail)) IN documentSum;
diffSumContainerDisparityDetail 'Сумма, тара' (Disparity disparity, BinGroup g) =
    GROUP 
        SUM diffSum(DisparityDetail idetail) IF isContainer(sku(idetail)) BY disparity(idetail), binGroup2(bin(idetail)) IN documentSum;
diffSumChargeDisparityDetail 'Сумма услуг' (Disparity disparity, BinGroup g) =
    GROUP
        SUM diffSum(DisparityDetail idetail) IF isCharge(sku(idetail)) BY disparity(idetail), binGroup2(bin(idetail)) IN documentSum;
diffSumNotChargeDisparityDetail 'Сумма кроме услуг' (Disparity disparity, BinGroup g) =
    GROUP
        SUM diffSum(DisparityDetail idetail) IF isNotCharge(sku(idetail)) BY disparity(idetail), binGroup2(bin(idetail)) IN documentSum;
diffSumNotItemDisparityDetail 'Сумма кроме товара' (Disparity disparity, BinGroup g) =
    GROUP
        SUM diffSum(DisparityDetail idetail) IF isNotItem(sku(idetail)) BY disparity(idetail), binGroup2(bin(idetail)) IN documentSum;
diffSumNotContainerDisparityDetail 'Сумма кроме тары' (Disparity disparity, BinGroup g) =
    GROUP
        SUM diffSum(DisparityDetail idetail) IF isNotContainer(sku(idetail)) BY disparity(idetail), binGroup2(bin(idetail)) IN documentSum;

diffSumItemUserDisparityDetail 'Сумма, товар' (UserDisparity userDisparity, BinGroup g) =
    GROUP
        SUM diffSum(UserDisparityDetail idetail) IF isItem(sku(idetail)) BY userDisparity(idetail), binGroup2(bin(idetail)) IN documentSum;
diffSumContainerUserDisparityDetail 'Сумма, тара' (UserDisparity userDisparity, BinGroup g) =
    GROUP 
        SUM diffSum(UserDisparityDetail idetail) IF isContainer(sku(idetail)) BY userDisparity(idetail), binGroup2(bin(idetail)) IN documentSum;
diffSumChargeUserDisparityDetail 'Сумма услуг' (UserDisparity userDisparity, BinGroup g) =
    GROUP
        SUM diffSum(UserDisparityDetail idetail) IF isCharge(sku(idetail)) BY userDisparity(idetail), binGroup2(bin(idetail)) IN documentSum;
diffSumNotChargeUserDisparityDetail 'Сумма кроме услуг' (UserDisparity userDisparity, BinGroup g) =
    GROUP
        SUM diffSum(UserDisparityDetail idetail) IF isNotCharge(sku(idetail)) BY userDisparity(idetail), binGroup2(bin(idetail)) IN documentSum;
diffSumNotItemUserDisparityDetail 'Сумма кроме товара' (UserDisparity userDisparity, BinGroup g) =
    GROUP
        SUM diffSum(UserDisparityDetail idetail) IF isNotItem(sku(idetail)) BY userDisparity(idetail), binGroup2(bin(idetail)) IN documentSum;
diffSumNotContainerUserDisparityDetail 'Сумма кроме тары' (UserDisparity userDisparity, BinGroup g) =
    GROUP
        SUM diffSum(UserDisparityDetail idetail) IF isNotContainer(sku(idetail)) BY userDisparity(idetail), binGroup2(bin(idetail)) IN documentSum;

sumItem (OutSDDisparityBinLedger ledger) += diffSumItemDisparityDetail(disparity(ledger), binGroup(ledger));
sumContainer (OutSDDisparityBinLedger ledger) += diffSumContainerDisparityDetail(disparity(ledger), binGroup(ledger));