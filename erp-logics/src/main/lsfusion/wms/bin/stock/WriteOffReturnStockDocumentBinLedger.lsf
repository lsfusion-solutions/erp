MODULE WriteOffReturnStockDocumentBinLedger;

REQUIRE WriteOffStockDocumentBinLedger, StockDocumentBinLedger, WriteOffReturnBinLedger, DepartmentWriteOffReturnBinLedger;

NAMESPACE WriteOffReturn;

@defineStockDocumentBinLedger (inc, writeOff, 'Списание-возврат (приход)', stock, department);

isReturn[StockDocumentBinLedger] (IncSDWriteOffBinLedger ledger) += writeOff(ledger) IS WriteOffReturn.WriteOff;
