MODULE WriteOffReturnStockDocumentBinLedger;

REQUIRE WriteOffStockDocumentBinLedger, StockDocumentBinLedger, WriteOffReturnBinLedger;

NAMESPACE WriteOffReturn;

@defineStockDocumentBinLedger (inc, writeOff, 'Списание-возврат (приход)', stock, binGroup2, inBin);

isReturn[StockDocumentBinLedger] (IncSDWriteOffBinLedger ledger) += writeOff(ledger) IS WriteOffReturn.WriteOff;
