MODULE BinInventoryBatchBinSkuLedger;

REQUIRE BinInventoryBinSkuLedger, BinInventoryBatchBinLedger;

NAMESPACE BinInventory;

EXTEND CLASS TypeSkuLedger {
    byBatches 'По партиям'
}

TABLE batchListBinInventory (Batch, ListBinInventory);

price 'Цена' = DATA NUMERIC[16,4] (Batch, ListBinInventory) CHARWIDTH 7 PATTERN '#,##0.00##';

calcOutSum = ABSTRACT VALUE NUMERIC[18,4] (Batch, ListBinInventory);
calcOutSum(Batch batch, ListBinInventory li) += NUMERIC[18,4](Utils.round(outQuantity(batch, li) * price(batch, li), priceRound(binInventory(li))));
outSum 'Сумма по описям (расход)' = DATA NUMERIC[18,4] (Batch, ListBinInventory) CHARWIDTH 9 PATTERN '#,##0.00##';

calcOutSum = ABSTRACT VALUE NUMERIC[18,4] (Batch, Bin, ListBinInventory);
calcOutSum(Batch batch, Bin b, ListBinInventory li) += NUMERIC[18,4](Utils.round(outQuantity(batch, b, li) * price(batch, li), priceRound(binInventory(li))));
outSum 'Сумма по описям (расход)' = DATA NUMERIC[18,4] (Batch, Bin, ListBinInventory) CHARWIDTH 9 PATTERN '#,##0.00##';

calcInSum = ABSTRACT VALUE NUMERIC[18,4] (Batch, ListBinInventory);
calcInSum(Batch batch, ListBinInventory li) += NUMERIC[18,4](Utils.round(inQuantity(batch, li) * price(batch, li), priceRound(binInventory(li))));
inSum 'Сумма по описям (приход)' = DATA NUMERIC[18,4] (Batch, ListBinInventory) CHARWIDTH 9 PATTERN '#,##0.00##';

calcInSum = ABSTRACT VALUE NUMERIC[18,4] (Batch, Bin, ListBinInventory);
calcInSum(Batch batch, Bin b, ListBinInventory li) += NUMERIC[18,4](Utils.round(inQuantity(batch, b, li) * price(batch, li), priceRound(binInventory(li))));
inSum 'Сумма по описям (приход)' = DATA NUMERIC[18,4] (Batch, Bin, ListBinInventory) CHARWIDTH 9 PATTERN '#,##0.00##';

sumShortage 'Сумма недостачи / излишка' (Batch batch, ListBinInventory li)= outSum(batch, li) (-) inSum(batch, li) CHARWIDTH 9 PATTERN '#,##0.00##';
sumShortage 'Сумма недостачи / излишка' (Batch batch, Bin b, ListBinInventory li)= outSum(batch, b, li) (-) inSum(batch, b, li) CHARWIDTH 9 PATTERN '#,##0.00##';

overFillBatchSum ABSTRACT (ListBinInventory);
fillBatchSum 'Заполнить суммы описи' (ListBinInventory li) {
    IF typeSkuLedger(binInventory(li)) == TypeSkuLedger.byBatches THEN {
        price(Batch batch, li) <- prevAccountPriceB(batch, stock(li), dateTime(li)) WHERE in(batch, li);
        outSum(Batch batch, li) <- calcOutSum(batch, li) WHERE in(batch, li);
        inSum(Batch batch, li) <- calcInSum(batch, li) WHERE in(batch, li);
    }
    overFillBatchSum(li);
}

countBatch 'Кол-во строк' (BinInventory i) =
    GROUP SUM 1 IF in(Batch cbt, i) MATERIALIZED IN documentSum;

TABLE batchBinInventory (Batch, BinInventory);

price 'Цена' = DATA NUMERIC[16,4] (Batch, BinInventory) CHARWIDTH 7 PATTERN '#,##0.00##';
sum 'Сумма по описям' = DATA NUMERIC[18,4] (Batch, BinInventory) CHARWIDTH 9 PATTERN '#,##0.00##';

calcSum = ABSTRACT VALUE NUMERIC[18,4] (Batch, BinInventory);
calcSum(Batch batch, BinInventory i) += NUMERIC[18,4](Utils.round(inQuantity(batch, i) * price(batch, i), priceRound(i)));

overQuantityBalance = ABSTRACT NUMERIC[16,5] (Batch, BinInventory);
quantityBalance 'Кол-во по остаткам' = DATA NUMERIC[16,5] (Batch, BinInventory);
overSumBalance = ABSTRACT NUMERIC[18,4] (Batch, BinInventory);
sumBalance 'Сумма по остаткам' = DATA NUMERIC[18,4] (Batch, BinInventory) CHARWIDTH 9 PATTERN '#,##0.00##';

quantityShortage 'Кол-во недостачи / излишка' (Batch batch, BinInventory binInventory) =
    quantityBalance(batch, binInventory) (-) inQuantity(batch, binInventory) MATERIALIZED;
sumShortage 'Сумма недостачи / излишка' (Batch batch, BinInventory binInventory) =
    sumBalance(batch, binInventory) (-) sum(batch, binInventory) MATERIALIZED PATTERN '#,##0.00##';

quantityBatch 'Кол-во по описям' = GROUP SUM inQuantity(Batch batch, BinInventory i) BY i CHARWIDTH 12 PATTERN '#,##0.00##';
quantityBatchBalance 'Кол-во по остаткам'  = GROUP SUM quantityBalance(Batch batch, BinInventory i) BY i CHARWIDTH 12 PATTERN '#,##0.00##';
quantityBatchShortage 'Кол-во недостачи / излишка' = GROUP SUM quantityShortage(Batch batch, BinInventory i) BY i CHARWIDTH 12 PATTERN '#,##0.00##';

sumBatch 'Сумма по описям' = GROUP SUM sum(Batch batch, BinInventory i) BY i CHARWIDTH 12 PATTERN '#,##0.00##';
sumBatchBalance 'Сумма по остаткам'  = GROUP SUM sumBalance(Batch batch, BinInventory i) BY i CHARWIDTH 12 PATTERN '#,##0.00##';
sumBatchShortage 'Сумма недостачи / излишка' = GROUP SUM sumShortage(Batch batch, BinInventory i) BY i CHARWIDTH 12 PATTERN '#,##0.00##';

sumItemBatchShortage 'Сумма недостачи / излишка, товар' (BinInventory binInventory) =
    GROUP SUM sumShortage(Batch batch, binInventory) IF in(batch, binInventory) IF isItem(batch) MATERIALIZED;
sumContainerBatchShortage 'Сумма недостачи / излишка, тара' (BinInventory binInventory) =
    GROUP SUM sumShortage(Batch batch, binInventory) IF in(batch, binInventory) IF isContainer(batch) MATERIALIZED;

sumItemQtyBatchShortage 'Сумма расхождений по кол-ву, товар' (BinInventory binInventory) =
    GROUP SUM sumShortage(Batch batch, binInventory) IF in(batch, binInventory) AND isItem(batch) AND quantityShortage(batch, binInventory) MATERIALIZED;
sumItemRoundingBatchShortage 'Сумма округлений, товар' (BinInventory binInventory) =
    GROUP SUM sumShortage(Batch batch, binInventory) IF in(batch, binInventory) AND isItem(batch) AND NOT quantityShortage(batch, binInventory) AND sumShortage(batch, binInventory) MATERIALIZED;
sumContainerQtyBatchShortage 'Сумма расхождений по кол-ву, тара' (BinInventory binInventory) =
    GROUP SUM sumShortage(Batch batch, binInventory) IF in(batch, binInventory) AND isContainer(batch) AND quantityShortage(batch, binInventory) MATERIALIZED;
sumContainerRoundingBatchShortage 'Сумма округлений, тара' (BinInventory binInventory) =
    GROUP SUM sumShortage(Batch batch, binInventory) IF in(batch, binInventory) AND isContainer(batch) AND NOT quantityShortage(batch, binInventory) AND sumShortage(batch, binInventory) MATERIALIZED;

sumItemShortage(BinInventory i) += WHEN typeSkuLedger(i)==TypeSkuLedger.byBatches THEN sumItemBatchShortage(i);
sumContainerShortage(BinInventory i) += WHEN typeSkuLedger(i)==TypeSkuLedger.byBatches THEN sumContainerBatchShortage(i);

sumItemQtyShortage(BinInventory i) += WHEN typeSkuLedger(i)==TypeSkuLedger.byBatches THEN sumItemQtyBatchShortage(i);
sumItemRoundingShortage(BinInventory i) += WHEN typeSkuLedger(i)==TypeSkuLedger.byBatches THEN sumItemRoundingBatchShortage(i);
sumContainerQtyShortage(BinInventory i) += WHEN typeSkuLedger(i)==TypeSkuLedger.byBatches THEN sumContainerQtyBatchShortage(i);
sumContainerRoundingShortage(BinInventory i) += WHEN typeSkuLedger(i)==TypeSkuLedger.byBatches THEN sumContainerRoundingBatchShortage(i);

overFillSum 'Заполнить сумму по описям для ячеек-партий' (BinInventory i) {
    outSum(Batch batch, Bin b, ListBinInventory li) <- calcOutSum(batch, b, li) WHERE in(batch, b, li) AND binInventory(li)==i;
    inSum(Batch batch, Bin b, ListBinInventory li) <- calcInSum(batch, b, li) WHERE in(batch, b, li) AND binInventory(li)==i;
}
overFillSumNewSession 'Заполнить сумму по описям для ячеек-партий' (BinInventory i) {
    NEWSESSION {
        overFillSum(i);
        APPLY;
    }
}

overFillCollationSheet (BinInventory i) + {
    IF typeSkuLedger(i)==TypeSkuLedger.byBatches THEN {
        price(Batch batch, i)  <- prevAccountPriceB(batch, stock(i), dateTime(i)) WHERE in(batch, i);
        sum(Batch batch, i) <- calcSum(batch, i) WHERE in(batch, i);
        quantityBalance(Batch batch, i) <- (OVERRIDE overQuantityBalance(batch, i), balanceB(batch, stock(i), dateTime(i))) WHERE in(batch, i);
        sumBalance(Batch batch, i) <- (OVERRIDE overSumBalance(batch, i), sumB(batch, stock(i), dateTime(i))) WHERE in(batch, i);

        price(Batch batch, ListBinInventory li)  <- prevAccountPriceB(batch, stock(li), dateTime(li)) WHERE in(batch, li) AND binInventory(li)==i;
        outSum(Batch batch, ListBinInventory li) <- calcOutSum(batch, li) WHERE in(batch, li) AND binInventory(li)==i;
        inSum(Batch batch, ListBinInventory li) <- calcInSum(batch, li) WHERE in(batch, li) AND binInventory(li)==i;

        overFillSum(i);
    }
}

diffBinInventoryBatch 'C расхождением' = DATA LOCAL NESTED BOOLEAN ();

EXTEND FORM binInventory
    PROPERTIES diffBinInventoryBatch()
    PROPERTIES(lbt, li) SHOWIF typeSkuLedger(i)==TypeSkuLedger.byBatches READONLY price, outSum, inSum, sumShortage
    PROPERTIES(lbt1, li) SHOWIF typeSkuLedger(i)==TypeSkuLedger.byBatches READONLY price
    PROPERTIES(lbt1, bin1, li)  SHOWIF typeSkuLedger(i)==TypeSkuLedger.byBatches READONLY outSum, inSum, sumShortage
    PROPERTIES(li) fillBatchSum DRAW lbt PANEL TOOLBAR SHOWIF typeSkuLedger(i)==TypeSkuLedger.byBatches

    PROPERTIES(i) READONLY countBatch, quantityBatch, quantityBatchBalance, quantityBatchShortage, sumBatch, sumBatchBalance, sumBatchShortage

    OBJECTS cbt = Batch
    PROPERTIES(cbt) READONLY nameSku, nameSkuType, idBarcodeSku, name
    ORDERS nameSku(cbt)
    PROPERTIES(cbt, i) READONLY inQuantity, quantityBalance, quantityShortage, price, sum, sumBalance, sumShortage
    FILTERS isParent(csg, cbt),
        in(cbt, i),
        quantityShortage(cbt, i) OR sumShortage(cbt, i) OR NOT diffBinInventoryBatch()
    FILTERGROUP balanceBatch
        FILTER 'В описях' inQuantity(cbt, i)
        FILTER 'С остатком' quantityBalance(cbt, i) OR (sumBalance(cbt, i) AND NOT quantityBalance(cbt, i))
;

DESIGN binInventory {
    topCollationSheet {
        NEW sumBatchCollationSheet {
            horizontal = TRUE;
            showIf = typeSkuLedger(i)==TypeSkuLedger.byBatches;
            caption = 'Итоговые суммы';
            MOVE PROPERTY(countBatch(i));
            MOVE PROPERTY(quantityBatch(i));
            MOVE PROPERTY(quantityBatchBalance(i));
            MOVE PROPERTY(quantityBatchShortage(i));
            MOVE PROPERTY(sumBatch(i));
            MOVE PROPERTY(sumBatchBalance(i));
            MOVE PROPERTY(sumBatchShortage(i));
        }
    }
    bottomCollationSheet {
        MOVE BOX(cbt) {
            showIf = typeSkuLedger(i)==TypeSkuLedger.byBatches;
            fill = 2;
            PROPERTY(inQuantity(cbt, i)) {caption = 'Кол-во по описям';}
            TOOLBAR(cbt) {
                MOVE PROPERTY(diffBinInventoryBatch());
            }
        }
    }
}

//---------------------------- Проведение по SkuLedger-------------------------------------//

CLASS ABSTRACT InventoryBatchDetail 'Изменение остатка инвентаризацией' : DataSkuLedger;
TABLE inventoryBatchDetail (InventoryBatchDetail);

CLASS OutInventoryBatchDetail 'Недостача инвентаризации' : InventoryBatchDetail;
CLASS InInventoryBatchDetail 'Излишки инвентаризации' : InventoryBatchDetail;

needToOutLedger (Batch batch, BinInventory binInventory) =
    (quantityShortage(batch, binInventory) > 0 OR (sumShortage(batch, binInventory) > 0 AND NOT quantityShortage(batch, binInventory)))
        AND in(batch, binInventory)
        AND typeSkuLedger(binInventory) == TypeSkuLedger.byBatches
        AND isPosted(binInventory);

needToInLedger (Batch batch, BinInventory binInventory) =
    (quantityShortage(batch, binInventory) < 0 OR (sumShortage(batch, binInventory) < 0 AND NOT quantityShortage(batch, binInventory)))
        AND in(batch, binInventory)
        AND typeSkuLedger(binInventory) == TypeSkuLedger.byBatches
        AND isPosted(binInventory);

outInventoryBatchDetail = AGGR OutInventoryBatchDetail WHERE needToOutLedger(Batch batch, BinInventory binInventory) MATERIALIZED INDEXED;
inInventoryBatchDetail = AGGR InInventoryBatchDetail WHERE needToInLedger(Batch batch, BinInventory binInventory) MATERIALIZED INDEXED;

binInventory(InventoryBatchDetail inventoryBatchDetail) =
    MULTI binInventory[OutInventoryBatchDetail](inventoryBatchDetail), binInventory[InInventoryBatchDetail](inventoryBatchDetail) MATERIALIZED INDEXED;

@defineDocumentDetailTime(binInventory, InventoryBatchDetail);
@defineDocumentDetailPosted(binInventory, InventoryBatchDetail);

@defineDocumentDetailClosed(binInventory, InventoryBatchDetail);

@defineDocumentDetailStock(binInventory, InventoryBatchDetail, stock, stock, 'Склад');
stock(InInventoryBatchDetail detail) = stock[InventoryBatchDetail](detail) IF detail IS InInventoryBatchDetail;
stock(OutInventoryBatchDetail detail) = stock[InventoryBatchDetail](detail) IF detail IS OutInventoryBatchDetail;

quantity (OutInventoryBatchDetail inventoryBatchDetail) = quantityShortage(batch(inventoryBatchDetail), binInventory(inventoryBatchDetail));
quantity (InInventoryBatchDetail inventoryBatchDetail) = -quantityShortage(batch(inventoryBatchDetail), binInventory(inventoryBatchDetail));

sum (OutInventoryBatchDetail inventoryBatchDetail) = sumShortage(batch(inventoryBatchDetail), binInventory(inventoryBatchDetail));
sum (InInventoryBatchDetail inventoryBatchDetail) = -sumShortage(batch(inventoryBatchDetail), binInventory(inventoryBatchDetail));

batch(InventoryBatchDetail inventoryBatchDetail) = 
    MULTI batch[OutInventoryBatchDetail](inventoryBatchDetail), batch[InInventoryBatchDetail](inventoryBatchDetail) MATERIALIZED;
nameBatch 'Партия' (InventoryBatchDetail inventoryBatchDetail) = name(batch(inventoryBatchDetail)) CHARWIDTH 15;

sku (InventoryBatchDetail inventoryBatchDetail) = sku(batch(inventoryBatchDetail));
nameSku 'Товар' (InventoryBatchDetail inventoryBatchDetail) = nameSku(batch(inventoryBatchDetail)) CHARWIDTH 15;
idBarcode 'Штрихкод' (InventoryBatchDetail inventoryBatchDetail) = idBarcode(sku(inventoryBatchDetail));

quantity 'Кол-во недостачи / излишка' (InventoryBatchDetail inventoryBatchDetail) = quantityShortage(batch(inventoryBatchDetail), binInventory(inventoryBatchDetail)) MATERIALIZED;
sum 'Сумма недостачи / излишка' (InventoryBatchDetail inventoryBatchDetail) = sumShortage(batch(inventoryBatchDetail), binInventory(inventoryBatchDetail)) MATERIALIZED;

description 'Название документа' (OutInventoryBatchDetail inventoryBatchDetail) =
    'Недостача по инвентаризации ' + number(binInventory(inventoryBatchDetail)) + ' от ' + date(binInventory(inventoryBatchDetail));

description 'Название документа' (InInventoryBatchDetail inventoryBatchDetail) =
    'Излишек по инвентаризации ' + number(binInventory(inventoryBatchDetail)) + ' от ' + date(binInventory(inventoryBatchDetail));

description 'Название документа' (InventoryBatchDetail inventoryBatchDetail) =
    MULTI description[InInventoryBatchDetail](inventoryBatchDetail), description[OutInventoryBatchDetail](inventoryBatchDetail);

dateTime[DataSkuLedger] (InventoryBatchDetail ledger) += dateTime(ledger);
isPosted[DataSkuLedger] (InventoryBatchDetail ledger) += isPosted(ledger);
isClosed[DataSkuLedger] (InventoryBatchDetail ledger) += isClosed(ledger);
sku[DataSkuLedger] (InventoryBatchDetail ledger) += sku(ledger);
stock[DataSkuLedger] (InventoryBatchDetail ledger) += stock(ledger);
description[DataSkuLedger] (InventoryBatchDetail ledger) += ISTRING[200](description(ledger));

changed(InventoryBatchDetail ledger) += CHANGED(batch(ledger));
batch(InventoryBatchDetail ledger) += batch(ledger);

isRoundingBatchDetail(InventoryBatchDetail d) = NOT quantityShortage(batch(d), binInventory(d));
isRoundingBatchLedger(InventoryBatchDetail d) = isRoundingBatchDetail(d) AND splitRoundingBinInventoryLedger(binInventory(d));

EXTEND CLASS OutInventoryBatchDetail : OutFIFOSkuLedger;
quantity (OutInventoryBatchDetail ledger) += quantity(ledger);
sum (OutInventoryBatchDetail ledger) += sum(ledger);
stockDocumentLedger(OutInventoryBatchDetail ledger) += OVERRIDE outRoundingBinInventorySDLedger(binInventory(ledger)) IF isRoundingBatchLedger(ledger),
                                                             incRoundingBinInventorySDLedger(binInventory(ledger)) IF isRoundingBatchLedger(ledger),
                                                             outBinInventorySDLedger(binInventory(ledger)) IF NOT isRoundingBatchLedger(ledger),
                                                             incBinInventorySDLedger(binInventory(ledger)) IF NOT isRoundingBatchLedger(ledger);


EXTEND CLASS InInventoryBatchDetail : InLIFOSkuLedger;
quantity (InInventoryBatchDetail ledger) += quantity(ledger);
sum (InInventoryBatchDetail ledger) += sum(ledger);
stockDocumentLedger(InInventoryBatchDetail ledger) += OVERRIDE incRoundingBinInventorySDLedger(binInventory(ledger)) IF isRoundingBatchLedger(ledger),
                                                            outRoundingBinInventorySDLedger(binInventory(ledger)) IF isRoundingBatchLedger(ledger),
                                                            incBinInventorySDLedger(binInventory(ledger)) IF NOT isRoundingBatchLedger(ledger),
                                                            outBinInventorySDLedger(binInventory(ledger)) IF NOT isRoundingBatchLedger(ledger)
;

edit(InInventoryBatchDetail d) + { DIALOG binInventory OBJECTS i = binInventory(d), cbt = batch(d) DOCKED; }
edit(OutInventoryBatchDetail d) + { DIALOG binInventory OBJECTS i = binInventory(d), cbt = batch(d) DOCKED; }

show 'Просмотреть' (InInventoryBatchDetail d)  {
    NEWSESSION {
        SHOW binInventory OBJECTS i = binInventory(d), cbt = batch(d) DOCKED READONLY;
    }
}
show(InInventoryBatchDetail d) + {  show(d); }

show 'Просмотреть' (OutInventoryBatchDetail d)  {
    NEWSESSION {
        SHOW binInventory OBJECTS i = binInventory(d), cbt = batch(d) DOCKED READONLY;
    }
}
show(OutInventoryBatchDetail d) + {  show(d); }