MODULE BinInventoryBatchBinLedger;

REQUIRE BinInventoryBinLedger, BatchBinLedger;

NAMESPACE BinInventory;

in 'Отм.' = DATA LOCAL BOOLEAN (Batch);
FORM selectedBatches 'Выбор партий'
    OBJECTS st=Stock PANEL

    TREE skuTree sg = SkuGroup PARENT parent(sg)
    PROPERTIES READONLY order(sg), skuGroupName = name(sg)
    ORDERS order(sg), skuGroupName
    FILTERGROUP inactive
        FILTER 'Активные' active(sg) DEFAULT

    OBJECTS bt = Batch
    PROPERTIES(bt) in
    PROPERTIES(bt) READONLY id SHOWIF showIDs()
    PROPERTIES(bt) READONLY nameSku, name, idBarcodeSku, shortNameUOM
    ORDERS name(bt)
    FILTERGROUP groupFilters
        FILTER 'С группами' isParent(sg, bt) OR overFilterGroup(sku(bt)) DEFAULT
        FILTER 'Без групп' NOT skuGroup(sku(bt))
    FILTERGROUP filterBalance
        FILTER 'Партии с остатком' currentBalance(bt, st) DEFAULT
        FILTER 'Партии с движением по складу' countLedger(bt, st)
        FILTER 'Партии пришедшие за последний 1 день' date(bt) >= subtract(currentDate(), 1)
        FILTER 'Партии пришедшие за последние 7 дней' date(bt) >= subtract(currentDate(), 7)
        FILTER 'Партии пришедшие за последние 30 дней' date(bt) >= subtract(currentDate(), 30)
;

DESIGN selectedBatches {
    BOX {
        size = (1024, 768);

        NEW topContainer {
            horizontal = TRUE;
            fill = 1;

            MOVE BOX(TREE skuTree) {
                caption = 'Группы SKU';
                width = 200;
            }

            MOVE BOX(bt) {
                fill = 2;
            }
        }
        MOVE TOOLBARBOX;
    }
}


EXTEND CLASS InventoryScope {
    byBatches 'По партиям',
    byDiffBatches 'По расхождениям остатков партий'
}

order(InventoryScope is) += WHEN is == InventoryScope.byBatches THEN 25;
order(InventoryScope is) += WHEN is == InventoryScope.byDiffBatches THEN 35;

customFillByDiffBatches ABSTRACT (BinInventory);

in = DATA LOCAL BOOLEAN (Batch, Bin);

overSelectedBins(InventoryScope is, BinInventory i) + {
    CASE WHEN is == InventoryScope.byBatches THEN {
        SHOW selectedBatches FILTERS st==stock(i) NOMANAGESESSION;
        in(Batch bt, Bin bin) <- TRUE WHERE currentBalance(bt, bin) AND in(bt);
        needCreateListBinInventory() <- GROUP MAX in(Batch bt, Bin bin);
    } WHEN is == InventoryScope.byDiffBatches THEN {
        IF useCustomFillByDiff() THEN {
            customFillByDiffBatches(i);
            needCreateListBinInventory() <- GROUP MAX in(Batch bt, Bin bin);
        } ELSE {
            in(Batch bt, Bin bin) <- TRUE WHERE (discrepancies(bt) OR currentDiffBalanceBin(bt, stock(i))) AND currentBalance(bt, bin);
            needCreateListBinInventory() <- GROUP MAX in(Batch bt, Bin bin);
        }    
    }    
}

@defineDocumentDetailBatchCustom(outListBinInventoryDetail, batch);
idBatch 'Код партии' (OutListBinInventoryDetail detail) = id(batch(detail));

EXTEND FORM binInventory
    PROPERTIES READONLY nameBatch(olid) AFTER nameSkuTypeSku(olid)
;

batch[BinLedger] (OutListBinInventoryDetail ledger) += batch(ledger);

replace(Sku s, Batch b) + {sku(OutListBinInventoryDetail detail) <- s WHERE batch(detail) == b;}

@defineDocumentDetailBatchCustom(inListBinInventoryDetail, batch);
idBatch 'Код партии' (InListBinInventoryDetail detail) = id(batch(detail));

changeBatch(InListBinInventoryDetail detail) {
    NEWSESSION {
        DIALOG batches OBJECTS bt=batch(detail) INPUT FILTERS skuLedger(bt, stock(detail))==sku(detail) DO {
            batch(detail) <- bt;
            APPLY;   
        }
    }
}

EXTEND FORM binInventory
    PROPERTIES AFTER nameSkuTypeSku(ilid) nameBatch(ilid) ON CHANGE changeBatch(ilid) READONLYIF NOT status(li)==ListBinInventoryStatus.inProgress
;

batchLocal = DATA LOCAL NESTED Batch (ListBinInventory);
nameBatchLocal 'Партия' (ListBinInventory o)= name(batchLocal(o)) CHARWIDTH 20;

CONSTRAINT batchLocal(ListBinInventory li) IS Batch AND NOT skuLedger(batchLocal(li), stock(li))==skuLocal(li)
    CHECKED BY batchLocal[ListBinInventory]
    MESSAGE 'Партия должны быть с движение по складу инвентаризации';

overAddInListBinInventoryDetail(ListBinInventory o, InListBinInventoryDetail detail) + {
    batch(detail) <- batchLocal(o);
    batchLocal(o) <- NULL;
}

EXTEND FORM addInListBinInventoryDetail
    PROPERTIES nameBatchLocal(o)
;

DESIGN addInListBinInventoryDetail {
    propHorizontalContainer {
        MOVE PROPERTY(nameBatchLocal(o)) AFTER PROPERTY(nameSkuLocal(o)) {
            font = 'bold 24';
            panelCaptionVertical = TRUE;
            charWidth = 35;
        }
    }
}

batch[BinLedger] (InListBinInventoryDetail ledger) += batch(ledger);

replace(Sku s, Batch b) + {sku(InListBinInventoryDetail detail) <- s WHERE batch(detail) == b;}

overCreateInListBinInventoryDetail (InListBinInventoryDetail ilid, OutListBinInventoryDetail olid) + {
    batch(ilid) <- batch(olid);
}

useCustomFillListBinInventory() += TRUE;
customFillListBinInventory(ListBinInventory li) + {
    IF NOT (GROUP MAX in(Batch bt)) THEN {
        in(Batch bt, Bin bin) <- TRUE WHERE in(sku(bt), bin) AND currentBalance(bt, bin);
    }
    FOR in(Batch batch, Bin bin) INLINE NEW olid = OutListBinInventoryDetail DO {
        listBinInventory(olid) <- li;
        include(bin, li) <- TRUE;
        sku(olid) <- sku(batch);
        batch(olid) <- batch;
        bin(olid) <- bin;
        quantity(olid) <- currentBalance(batch, bin);
    }
}

outQuantity 'Кол-во (расход)' =
    GROUP SUM quantity(OutListBinInventoryDetail detail) BY batch(detail), listBinInventory(detail) MATERIALIZED INDEXED;

outQuantity 'Кол-во (расход)' =
    GROUP SUM outQuantity(Batch batch, ListBinInventory li) BY batch, binInventory(li);

inQuantity 'Кол-во (приход)' =
    GROUP SUM quantity(InListBinInventoryDetail detail) BY batch(detail), listBinInventory(detail) MATERIALIZED INDEXED;

inQuantity 'Кол-во (приход)' =
    GROUP SUM inQuantity(Batch batch, ListBinInventory li) BY batch, binInventory(li);

diffQuantity 'Расхождение' (Batch batch, ListBinInventory li) = outQuantity(batch, li) (-) inQuantity(batch, li);
diffQuantity 'Расхождение' (Batch batch, BinInventory i) = outQuantity(batch, i) (-) inQuantity(batch, i);

in 'Вкл.' = inQuantity(Batch batch, ListBinInventory li) OR outQuantity(batch, li) MATERIALIZED INDEXED;
in 'Вкл.' = GROUP MAX in(Batch batch, ListBinInventory li) BY batch, binInventory(li);

EXTEND FORM binInventory
    TREE lbskuTree lbsg = SkuGroup PARENT parent(lbsg)
    PROPERTIES READONLY order(lbsg), name(lbsg)
    ORDERS order(lbsg), name(lbsg)
    FILTERGROUP lbinactiveSkuGroup
        FILTER 'Активные' active(lbsg) DEFAULT

    OBJECTS lbt = Batch
    PROPERTIES(lbt) READONLY nameSku, idBarcodeSku, name
    ORDERS nameSku(lbt)
    PROPERTIES(lbt, li) READONLY outQuantity, inQuantity, diffQuantity
    FILTERS isParent(lbsg, lbt)
    FILTERGROUP lbDiff
        FILTER 'С расхождением' diffQuantity(lbt, li) DEFAULT
        FILTER 'В описи' in(lbt, li)

    TREE bskuTree bsg = SkuGroup PARENT parent(bsg)
    PROPERTIES READONLY order(bsg), name(bsg)
    ORDERS order(bsg), name(bsg)
    FILTERGROUP binactiveSkuGroup
        FILTER 'Активные' active(bsg) DEFAULT

    OBJECTS bt = Batch
    PROPERTIES(bt) READONLY nameSku, idBarcodeSku, name
    ORDERS nameSku(bt)
    PROPERTIES(bt, i) READONLY outQuantity, inQuantity, diffQuantity
    FILTERS isParent(bsg, bt)
    FILTERGROUP bDiff
        FILTER 'С расхождением' diffQuantity(bt, i) DEFAULT
        FILTER 'В инвентаризации' in(bt, i)    
;

DESIGN binInventory {
    tabbedContainer {
        listBinInventoryDetailContainer {
            NEW listBinInventoryBatches {
                caption = 'Партии "'+ name(li)+ '"';
                horizontal = TRUE;
                fill = 1;
                MOVE BOX(TREE lbskuTree);
                MOVE BOX(lbt) {fill = 2;}
            }
        }
        NEW batchesContainer {
            caption = 'Партии инвентаризации';
            horizontal = TRUE;
            fill = 1;
            MOVE BOX(TREE bskuTree);
            MOVE BOX(bt) {fill = 2;}
        }
    }
}