MODULE BinSkuLedger;

REQUIRE SkuLedger, BinLedger;

NAMESPACE Bin;

currentDiffBalanceBin 'Расхождение по остаткам в ячейках' (Sku sku, Stock st)=
    currentBalanceSku(sku, st) (-) currentBalance(sku, st);
prevCurrentDiffBalanceBin 'Расхождение по остаткам в ячейках' (Sku sku, Stock st)=
    prevCurrentBalanceSku(sku, st) (-) prevCurrentBalance(sku, st);
diffBalanceBinB 'Расхождение в ячейках (до)' (Sku sku, Stock st, DATETIME dateTime)=
    balanceBSku(sku, st,dateTime) (-) balanceB(sku, st,dateTime);
prevDiffBalanceBinB 'Расхождение в ячейках (до)' (Sku sku, Stock st, DATETIME dateTime)=
    prevBalanceBSku(sku, st,dateTime) (-) prevBalanceB(sku, st,dateTime);
diffBalanceBinA 'Расхождение в ячейках (после)' (Sku sku, Stock st, DATETIME dateTime)=
    balanceASku(sku, st,dateTime) (-) balanceA(sku, st,dateTime);
prevDiffBalanceBinA 'Расхождение в ячейках (после)' (Sku sku, Stock st, DATETIME dateTime)=
    prevBalanceASku(sku, st,dateTime) (-) prevBalanceA(sku, st,dateTime);

FORM currentBalanceBinSkuStock 'Сравнение остатков товаров по ячейкам и складу'

    OBJECTS ss = Stock PANEL
    PROPERTIES(ss) name SELECTOR SHOWIF singleStore()
    FILTERS isCompany(ss),
        useBins(ss)

    TREE skuTree sk = SkuGroup PARENT parent(sk)
    PROPERTIES READONLY order(sk), skuTreeName = name(sk)
    ORDERS order(sk), skuTreeName
    FILTERGROUP inactive FILTER 'Активные' active(sk) 'F6' DEFAULT

    OBJECTS sts=(st=Stock, s=Sku)
    PROPERTIES READONLY BACKGROUND backgroundBalance(s, st) 
        name(s) ON CONTEXTMENU showBalanceMovementSku(s, st) ON CONTEXTMENU showBalancePriceSku(s, st) ON CONTEXTMENU showBalanceReserveSku(s,st), 
        id(s) SHOWIF showIDs(), nameCountry(s), nameUOM(s)  //  idBarcodeSku
    FILTERS isParent(sk, s),
            st == ss

    FILTERGROUP inactiveStock
        FILTER 'Активный' active(s) 'ctrl F10' DEFAULT
        FILTER 'Неактивный' inactive(s) 'shift F10'

    PROPERTIES(s, st) READONLY currentBalance, currentBalanceSku, currentDiffBalanceBin, currentSum
    PROPERTIES(s)     READONLY idSkuGroup, canonicalNameSkuGroup

    FILTERGROUP container
        FILTER 'Товар' isItem(s)
        FILTER 'Тара' isContainer(s)

    FILTERGROUP filters
        FILTER 'Товары с остатком' currentBalance(s, st) OR currentSum(s, st) OR currentBalanceSku(s, st) 'F10' 
        FILTER 'Товары с расхождением между по остаткам на складе и в ячейках ' (currentBalance(s, st) OR currentBalanceSku(s, st)) AND NOT currentBalance(s, st) = currentBalanceSku(s, st) 'F11' DEFAULT
        FILTER 'Товары с остатком по складу' currentBalance(s, st) 
        FILTER 'Товары с остатком по ячейкам' currentBalanceSku(s, st) 

        FILTER 'Товары с движением не позднее 1 дня' currentBalance(s, st, 1) 'F9'
        FILTER 'Товары с движением не позднее 7 дней' currentBalance(s, st, 7) 'F8'
        FILTER 'Товары с движением не позднее 30 дней' currentBalance(s, st, 30) 'F7'
    
    OBJECTS b = Bin 
    PROPERTIES(b) READONLY order, canonicalId, name
    PROPERTIES  currentBalance(s, b)
    FILTERS stock(b) = ss, currentBalance(s, b)
    ORDERS order(b), canonicalId(b), name(b)

    OBJECTS bl = BinLedger
    PROPERTIES(bl) READONLY dateTime, description, skip, quantity, canonicalIdInBin, nameInBin, canonicalIdOutBin, nameOutBin
    PROPERTIES(bl) EDIT SHOWIF allowedEdit(bl) NEWSESSION, show SHOWIF allowedShow(bl)
    ORDERS dateTime(bl) DESC
    FILTERS isPosted(bl), sku(bl)==s

;

@extendFormFilterStockAccess(ss, currentBalanceBinSkuStock);

DESIGN currentBalanceBinSkuStock {
    BOX {
        size = (1024, 768);
        NEW filter {
            alignment = STRETCH;
            horizontal = TRUE;
            MOVE PROPERTY (name(ss));
        }
        NEW topContainer {
            fill = 1;
            horizontal = TRUE;

            NEW firstCaseTwo {
                fill = 1;
                MOVE BOX(TREE skuTree) { caption = 'Группы'; }
            }

            NEW secondCase {
                fill = 3;
                NEW skuBox {
                    fill = 2;
                    MOVE BOX(sts) {
                        fill = 2;
                    }
                }
                NEW ledgerBox {
                    fill = 1;
                    tabbed = TRUE;
                    MOVE BOX(b){
                        PROPERTY(canonicalId(b)) {defaultCompare = '=*';}
                    }
                    MOVE BOX(bl){
                        PROPERTY(canonicalIdInBin(bl)) {defaultCompare = '=*';}
                        PROPERTY(canonicalIdOutBin(bl)) {defaultCompare = '=*';}
                        PROPERTY(nameInBin(bl)) {defaultCompare = '=*';}
                        PROPERTY(nameOutBin(bl)) {defaultCompare = '=*';}
                    }
                }
            }
        }
        MOVE TOOLBARBOX;
    }
}

NAVIGATOR {
    WMSDocument {
        NEW currentBalanceBinSkuStock;
    }
}

dateTimeLastMoved 'Время последнего прихода' (sku, bin) =
    GROUP LAST dateTime(BinLedger ledger)
    ORDER dateTime(ledger), ledger
    WHERE active(ledger)
    BY sku(ledger), inBin(ledger);